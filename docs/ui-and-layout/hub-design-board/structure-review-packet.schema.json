{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/ui-and-layout/hub-design-board/structure-review-packet.schema.json",
  "title": "Zircon Hub structure-first design-board review packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "schema",
    "source",
    "canvas",
    "review_priority",
    "manual_signoff",
    "reference_target",
    "reference_alignment_checks",
    "reference_alignment_matrix",
    "structure_geometry_baseline",
    "structure_responsive_baseline",
    "structure_review_route_baseline",
    "structure_overlay_baseline",
    "structure_reference_route_baseline",
    "structure_signoff_checklist",
    "structure_decision_log",
    "artifacts",
    "review_sequence",
    "manual_review_items",
    "support_documents",
    "validation_commands",
    "acceptance_boundary"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "schema": {
      "const": "docs/ui-and-layout/hub-design-board/structure-review-packet.schema.json"
    },
    "source": {
      "const": "docs/ui-and-layout/hub-design-board/index.html"
    },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "const": 1568
        },
        "height": {
          "const": 1003
        }
      }
    },
    "review_priority": {
      "const": "overall-interaction-structure-layout"
    },
    "manual_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "required_primary_artifact"
      ],
      "properties": {
        "status": {
          "const": "pending"
        },
        "required_primary_artifact": {
          "const": "docs/ui-and-layout/hub-design-structure-layout.png"
        }
      }
    },
    "reference_target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "role",
        "canvas"
      ],
      "properties": {
        "path": {
          "const": "docs/ui-and-layout/hub.png"
        },
        "role": {
          "const": "target-ui-reference"
        },
        "canvas": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "width",
            "height"
          ],
          "properties": {
            "width": {
              "const": 1568
            },
            "height": {
              "const": 1003
            }
          }
        }
      }
    },
    "reference_alignment_checks": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "target_region",
          "primary_artifact",
          "review_focus",
          "acceptance_rule"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "target_region": {
            "type": "string"
          },
          "primary_artifact": {
            "type": "string",
            "pattern": "^hub-design-.*\\.png$"
          },
          "review_focus": {
            "type": "string"
          },
          "acceptance_rule": {
            "type": "string"
          }
        }
      }
    },
    "reference_alignment_matrix": {
      "const": "docs/ui-and-layout/hub-design-board/REFERENCE_ALIGNMENT_MATRIX.md"
    },
    "structure_geometry_baseline": {
      "const": "docs/ui-and-layout/hub-design-board/structure-geometry-baseline.json"
    },
    "structure_responsive_baseline": {
      "const": "docs/ui-and-layout/hub-design-board/structure-responsive-baseline.json"
    },
    "structure_review_route_baseline": {
      "const": "docs/ui-and-layout/hub-design-board/structure-review-route-baseline.json"
    },
    "structure_overlay_baseline": {
      "const": "docs/ui-and-layout/hub-design-board/structure-overlay-baseline.json"
    },
    "structure_reference_route_baseline": {
      "const": "docs/ui-and-layout/hub-design-board/structure-reference-route-baseline.json"
    },
    "structure_signoff_checklist": {
      "const": "docs/ui-and-layout/hub-design-board/STRUCTURE_SIGNOFF_CHECKLIST.md"
    },
    "structure_decision_log": {
      "const": "docs/ui-and-layout/hub-design-board/STRUCTURE_DECISION_LOG.md"
    },
    "artifacts": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "path",
          "category",
          "review_role"
        ],
        "properties": {
          "id": {
            "enum": [
              "structure",
              "flow",
              "details"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^docs/ui-and-layout/hub-design-.*\\.png$"
          },
          "category": {
            "enum": [
              "primary-structure",
              "secondary-functional-detail"
            ]
          },
          "review_role": {
            "type": "string"
          }
        }
      }
    },
    "review_sequence": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step",
          "artifact_id",
          "focus",
          "decision_scope"
        ],
        "properties": {
          "step": {
            "type": "number",
            "enum": [
              1,
              2,
              3
            ]
          },
          "artifact_id": {
            "enum": [
              "structure",
              "flow",
              "details"
            ]
          },
          "focus": {
            "enum": [
              "overall-interaction-structure-layout",
              "route-and-responsive-structure",
              "functional-content-local-detail"
            ]
          },
          "decision_scope": {
            "type": "string"
          }
        }
      }
    },
    "manual_review_items": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "item",
          "primary_artifact",
          "secondary_artifact"
        ],
        "properties": {
          "item": {
            "enum": [
              "Shell frame",
              "Navigation",
              "Workspace",
              "Overlay layer",
              "State layer",
              "Responsive structure",
              "Bottom strip",
              "Functional detail"
            ]
          },
          "primary_artifact": {
            "type": "string",
            "pattern": "^hub-design-.*\\.png$"
          },
          "secondary_artifact": {
            "type": "string",
            "pattern": "^hub-design-.*\\.png$"
          }
        }
      }
    },
    "support_documents": {
      "type": "array",
      "minItems": 20,
      "maxItems": 20,
      "items": {
        "type": "string"
      }
    },
    "validation_commands": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "string"
      }
    },
    "acceptance_boundary": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "enum": [
          "design-board-and-web-reference-only",
          "manual-signoff-required",
          "runtime-behavior-out-of-scope"
        ]
      }
    }
  }
}
