[asset]
kind = "component"
id = "res://ui/editor/material_components/material_mui_x_data_grid.zui"
version = 2
display_name = "Material MUI X Data Grid Prototype"

[imports]
widgets = []
styles = []

[components.MaterialMuiXDataGridPrototype]
root = "root"
default_classes = ["material-lab-prototype", "material-surface"]

[nodes.title]
component = "Label"
control_id = "mui-x-data-grid_Title"
classes = ["material-lab-title"]
props = { text = "MUI X Data Grid", text_tone = "primary", font_size = 13.0, font_weight = 700 }
layout = { width = { stretch = "Stretch" }, height = { min = 22.0, preferred = 22.0, max = 22.0, stretch = "Fixed" } }

[nodes.meta]
component = "HorizontalBox"
control_id = "mui_x_data_grid_Meta"
classes = ["material-lab-meta-strip", "material-lab-meta"]
layout = { width = { stretch = "Stretch" }, height = { min = 18.0, preferred = 18.0, max = 18.0, stretch = "Fixed" }, container = { kind = "HorizontalBox", gap = 4.0 } }
children = [
  { node = "meta_group" },
  { node = "meta_response" },
  { node = "meta_variant" },
  { node = "meta_layout" },
]

[nodes.meta_group]
component = "Label"
control_id = "mui_x_data_grid_MetaGroup"
classes = ["material-lab-meta-chip", "material-lab-meta-group"]
props = { text = "MUI X", text_tone = "secondary", font_size = 8.0, surface_variant = "elevated", corner_radius = 999.0, border_width = 1.0 }
layout = { width = { min = 53, preferred = 53, max = 53, stretch = "Fixed" }, height = { min = 16.0, preferred = 16.0, max = 16.0, stretch = "Fixed" } }

[nodes.meta_response]
component = "Label"
control_id = "mui_x_data_grid_MetaResponse"
classes = ["material-lab-meta-chip", "material-lab-meta-response"]
props = { text = "click / press", text_tone = "success", font_size = 8.0, surface_variant = "elevated", response_mechanism = "click / press", density = "compact", corner_radius = 999.0, border_width = 1.0 }
layout = { width = { min = 97, preferred = 97, max = 97, stretch = "Fixed" }, height = { min = 16.0, preferred = 16.0, max = 16.0, stretch = "Fixed" } }
[nodes.meta_variant]
component = "Label"
control_id = "mui_x_data_grid_MetaVariant"
classes = ["material-lab-meta-chip", "material-lab-meta-variant"]
props = { text = "sorted / selected", text_tone = "primary", font_size = 8.0, surface_variant = "elevated", variant = "sorted / selected", density = "compact", corner_radius = 999.0, border_width = 1.0 }
layout = { width = { min = 117, preferred = 117, max = 117, stretch = "Fixed" }, height = { min = 16.0, preferred = 16.0, max = 16.0, stretch = "Fixed" } }

[nodes.meta_layout]
component = "Label"
control_id = "mui_x_data_grid_MetaLayout"
classes = ["material-lab-meta-chip", "material-lab-meta-layout"]
props = { text = "data viewport", text_tone = "warning", font_size = 8.0, surface_variant = "elevated", layout_mode = "data viewport", density = "compact", corner_radius = 999.0, border_width = 1.0 }
layout = { width = { min = 97, preferred = 97, max = 97, stretch = "Fixed" }, height = { min = 16.0, preferred = 16.0, max = 16.0, stretch = "Fixed" } }
[nodes.sample]
component = "DataGrid"
control_id = "mui-x-data-grid_Sample"
classes = ["material-control", "material-lab-sample", "MuiDataGrid-root"]
props = { rows = ["Alpha", "Beta"], columns = ["Name", "State"], density = "compact", loading = true, checkboxSelection = true, disableColumnMenu = false, disableRowSelectionOnClick = false, autoHeight = true, showToolbar = true, hideFooterPagination = true, hideFooterSelectedRowCount = true, showCellVerticalBorder = true, showColumnVerticalBorder = true, rowSpacingType = "border", scrollbarSize = 12, label = "Material grid", page = 1, pageSize = 25, rowCount = 100, rowHeight = 32.0, overscanCount = 4, disableVirtualization = true, viewport_start = 5, viewport_count = 20, requested_start = 4, requested_count = 24, scrollTop = 128.0, rowSelectionModel = ["Alpha"], sortingMode = "client", filterMode = "client", sortModel = ["Name:asc"], filterModel = { items = ["State=Ready"] }, paginationModel = { page = 1, pageSize = 25 }, quickFilterValues = ["Alpha"], editMode = "row", cellModesModel = { Alpha = "edit" }, rowModesModel = { Beta = "view" }, columnVisibilityModel = { State = false }, pinnedColumns = { left = ["Name"], right = ["State"] }, slotProps = { header = { className = "material-mui-x-header" }, columnHeader = { className = "material-mui-x-column-header" }, row = { className = "material-mui-x-row" }, cell = { className = "material-mui-x-cell" } }, text = "MUI X Data Grid", surface_variant = "elevated", button_variant = "contained", text_tone = "primary", validation_level = "normal", hovered = true, pressed = false, focused = true, selected = true, checked = true, disabled = false, open = true, popup_open = true, corner_radius = 10.0, border_width = 1.0, input_interactive = true, input_clickable = true, input_hoverable = true, input_focusable = true }
layout = { width = { stretch = "Stretch" }, height = { min = 34.0, preferred = 34.0, max = 34.0, stretch = "Fixed" } }
events = [
  { id = "MaterialLab/MuiXDataGrid/Click", event = "Click", route = "MaterialLab.MuiXDataGrid.Click" },
]

[nodes.state_strip]
component = "HorizontalBox"
control_id = "mui_x_data_grid_StateStrip"
classes = ["material-lab-state-strip"]
layout = { width = { stretch = "Stretch" }, height = { min = 20.0, preferred = 20.0, max = 20.0, stretch = "Fixed" }, container = { kind = "HorizontalBox", gap = 4.0 } }
children = [
  { node = "state_default" },
  { node = "state_hover" },
  { node = "state_pressed" },
  { node = "state_focus" },
  { node = "state_disabled" },
  { node = "state_selected" },
  { node = "state_open" },
  { node = "state_error" },
]
