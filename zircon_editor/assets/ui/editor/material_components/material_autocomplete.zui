component = "HorizontalBox"
control_id = "autocomplete_InputRoot"
classes = ["material-control", "material-autocomplete-input-root"]
props = { text = "Search", surface_variant = "elevated", text_tone = "primary", validation_level = "normal", hovered = true, pressed = false, focused = true, selected = false, checked = false, disabled = false, open = true, popup_open = true, corner_radius = 10.0, border_width = 1.0, input_interactive = false, input_clickable = false, input_hoverable = false, input_focusable = false }
layout = { width = { min = 56.0, preferred = 66.0, max = 76.0, stretch = "Fixed" }, height = { min = 32.0, preferred = 32.0, max = 32.0, stretch = "Fixed" } }

