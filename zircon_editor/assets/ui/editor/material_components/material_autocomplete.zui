[asset]
kind = "component"
id = "res://ui/editor/material_components/material_autocomplete.zui"
version = 2
display_name = "Material Autocomplete Prototype"

[imports]
widgets = []
styles = []

[components.MaterialAutocompletePrototype]
root = "root"
default_classes = ["material-lab-prototype", "material-surface"]

[nodes.title]
component = "Label"
control_id = "autocomplete_Title"
classes = ["material-lab-title"]
props = { text = "Autocomplete", text_tone = "primary", font_size = 13.0, font_weight = 700 }
layout = { width = { stretch = "Stretch" }, height = { min = 22.0, preferred = 22.0, max = 22.0, stretch = "Fixed" } }

[nodes.meta]
component = "HorizontalBox"
control_id = "autocomplete_Meta"
classes = ["material-lab-meta-strip", "material-lab-meta"]
layout = { width = { stretch = "Stretch" }, height = { min = 18.0, preferred = 18.0, max = 18.0, stretch = "Fixed" }, container = { kind = "HorizontalBox", gap = 4.0 } }
children = [
  { node = "meta_group" },
  { node = "meta_response" },
  { node = "meta_variant" },
  { node = "meta_layout" },
]

[nodes.meta_group]
component = "Label"
control_id = "autocomplete_MetaGroup"
classes = ["material-lab-meta-chip", "material-lab-meta-group"]
props = { text = "Inputs", text_tone = "secondary", font_size = 8.0, surface_variant = "elevated", corner_radius = 999.0, border_width = 1.0 }
layout = { width = { min = 58, preferred = 58, max = 58, stretch = "Fixed" }, height = { min = 16.0, preferred = 16.0, max = 16.0, stretch = "Fixed" } }

[nodes.meta_response]
component = "Label"
control_id = "autocomplete_MetaResponse"
classes = ["material-lab-meta-chip", "material-lab-meta-response"]
props = { text = "change / commit", text_tone = "success", font_size = 8.0, surface_variant = "elevated", response_mechanism = "change / commit", density = "compact", corner_radius = 999.0, border_width = 1.0 }
layout = { width = { min = 107, preferred = 107, max = 107, stretch = "Fixed" }, height = { min = 16.0, preferred = 16.0, max = 16.0, stretch = "Fixed" } }
[nodes.meta_variant]
component = "Label"
control_id = "autocomplete_MetaVariant"
classes = ["material-lab-meta-chip", "material-lab-meta-variant"]
props = { text = "outlined / menu", text_tone = "primary", font_size = 8.0, surface_variant = "elevated", variant = "outlined / menu", density = "compact", corner_radius = 999.0, border_width = 1.0 }
layout = { width = { min = 108, preferred = 108, max = 108, stretch = "Fixed" }, height = { min = 16.0, preferred = 16.0, max = 16.0, stretch = "Fixed" } }

[nodes.meta_layout]
component = "Label"
control_id = "autocomplete_MetaLayout"
classes = ["material-lab-meta-chip", "material-lab-meta-layout"]
props = { text = "inline controls", text_tone = "warning", font_size = 8.0, surface_variant = "elevated", layout_mode = "inline controls", density = "compact", corner_radius = 999.0, border_width = 1.0 }
layout = { width = { min = 107, preferred = 107, max = 107, stretch = "Fixed" }, height = { min = 16.0, preferred = 16.0, max = 16.0, stretch = "Fixed" } }
[nodes.sample]
component = "Autocomplete"
control_id = "autocomplete_Sample"
classes = ["material-control", "material-lab-sample", "MuiAutocomplete-root"]
props = { query = "at", inputValue = "at", value = "atlas", value_text = "Atlas", selected_options = ["atlas"], selectedOptions = ["atlas"], options = ["atlas", "asset", "disabled"], filtered_options = ["atlas", "asset"], filteredOptions = ["atlas", "asset"], disabled_options = ["disabled"], disabledOptions = ["disabled"], focused_options = ["atlas"], focusedOptions = ["atlas"], hovered_options = ["atlas"], hoveredOptions = ["atlas"], pressed_options = [], pressedOptions = [], matched_options = ["atlas", "asset"], matchedOptions = ["atlas", "asset"], size = "small", multiple = true, free_solo = false, freeSolo = false, surface_variant = "elevated", button_variant = "contained", text_tone = "primary", validation_level = "normal", hovered = true, pressed = false, focused = true, selected = true, checked = true, disabled = false, open = true, popup_open = true, popupOpen = true, fullWidth = true, disableClearable = false, disablePortal = true, inputFocused = true, loading = false, readOnly = false, forcePopupIcon = "auto", className = "material-autocomplete-sample", slotProps = { inputRoot = { className = "material-autocomplete-input-root" }, input = { className = "material-autocomplete-input" }, tag = { className = "material-autocomplete-tag" }, popupIndicator = { className = "material-autocomplete-popup-indicator" }, popper = { className = "material-autocomplete-popper" }, paper = { className = "material-autocomplete-paper" }, listbox = { className = "material-autocomplete-listbox" }, option = { className = "material-autocomplete-option" } }, corner_radius = 10.0, border_width = 1.0, input_interactive = true, input_clickable = true, input_hoverable = true, input_focusable = true }
layout = { width = { stretch = "Stretch" }, height = { min = 34.0, preferred = 34.0, max = 34.0, stretch = "Fixed" }, container = { kind = "HorizontalBox", gap = 4.0 } }
children = [
  { node = "autocomplete_input_root", slot = { name = "inputRoot" } },
  { node = "autocomplete_input", slot = { name = "input" } },
  { node = "autocomplete_tag", slot = { name = "tag" } },
  { node = "autocomplete_popup_indicator", slot = { name = "popupIndicator" } },
  { node = "autocomplete_popper", slot = { name = "popper" } },
  { node = "autocomplete_paper", slot = { name = "paper" } },
  { node = "autocomplete_listbox", slot = { name = "listbox" } },
  { node = "autocomplete_option", slot = { name = "option" } },
]
events = [
  { id = "MaterialLab/Autocomplete/Change", event = "Change", route = "MaterialLab.Autocomplete.Change" },
]

