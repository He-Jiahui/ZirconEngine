import { LineEdit } from "std-widgets.slint";
import { Palette, ShellButton, ShellIcon } from "chrome.slint";
import { TemplatePaneNodeData } from "template_node_data.slint";

export struct RecentProjectData {
    display_name: string,
    path: string,
    last_opened_label: string,
    status_label: string,
    invalid: bool,
}

export struct NewProjectFormData {
    project_name: string,
    location: string,
    project_path_preview: string,
    template_label: string,
    validation_message: string,
    can_create: bool,
    can_open_existing: bool,
    browse_supported: bool,
}

export struct WelcomePaneData {
    nodes: [TemplatePaneNodeData],
    title: string,
    subtitle: string,
    status_message: string,
    form: NewProjectFormData,
}

component FieldCard inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> placeholder;
    callback edited(value: string);

    palette := Palette {}
    border-radius: 8px;
    border-width: 1px;
    border-color: palette.border_soft;
    background: palette.panel_bg_soft;

    Text {
        x: 12px;
        y: 10px;
        text: root.label;
        color: palette.text_dim;
        font-size: 10px;
        font-weight: 700;
    }

    LineEdit {
        x: 12px;
        y: 28px;
        width: parent.width - 24px;
        height: 28px;
        text: root.value;
        placeholder-text: root.placeholder;
        font-size: 12px;
        edited(value) => { root.edited(value); }
    }
}

export component WelcomePane inherits Rectangle {
    in property <WelcomePaneData> welcome;
    in property <[RecentProjectData]> recent_projects;
    in property <int> hovered_recent_project_index: -1;
    in property <int> hovered_recent_action: -1;
    in property <float> recent_projects_scroll_px: 0.0;
    callback control_changed(control_id: string, value: string);
    callback control_clicked(control_id: string);
    callback recent_projects_pointer_clicked(x: float, y: float, width: float, height: float);
    callback recent_projects_pointer_moved(x: float, y: float, width: float, height: float);
    callback recent_projects_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: palette.panel_bg;
    clip: true;

    for outer_panel_node in root.welcome.nodes: Rectangle {
        visible: outer_panel_node.control_id == "WelcomeOuterPanel";
        x: outer_panel_node.frame.x * 1px;
        y: outer_panel_node.frame.y * 1px;
        width: outer_panel_node.frame.width * 1px;
        height: outer_panel_node.frame.height * 1px;
        border-radius: 16px;
        border-width: 1px;
        border-color: palette.border;
        background: #1c1f23;
        clip: true;

        for recent_panel_node in root.welcome.nodes: Rectangle {
            visible: recent_panel_node.control_id == "WelcomeRecentPanel";
            x: (recent_panel_node.frame.x - outer_panel_node.frame.x) * 1px;
            y: (recent_panel_node.frame.y - outer_panel_node.frame.y) * 1px;
            width: recent_panel_node.frame.width * 1px;
            height: recent_panel_node.frame.height * 1px;
            border-top-left-radius: 16px;
            border-bottom-left-radius: 16px;
            background: #181b1f;
            border-width: 0px;
            clip: true;

            for recent_header_panel_node in root.welcome.nodes: Rectangle {
                visible: recent_header_panel_node.control_id == "WelcomeRecentHeaderPanel";
                x: (recent_header_panel_node.frame.x - recent_panel_node.frame.x) * 1px;
                y: (recent_header_panel_node.frame.y - recent_panel_node.frame.y) * 1px;
                width: recent_header_panel_node.frame.width * 1px;
                height: recent_header_panel_node.frame.height * 1px;
                background: transparent;
                clip: true;

                Text {
                    x: 0px;
                    y: 0px;
                    text: "Recent Projects";
                    color: palette.text;
                    font-size: 20px;
                    font-weight: 700;
                }

                Text {
                    x: 0px;
                    y: 30px;
                    width: parent.width;
                    text: "Resume a valid directory project or clean up broken entries.";
                    color: palette.text_dim;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            for recent_list_panel_node in root.welcome.nodes: Rectangle {
                visible: recent_list_panel_node.control_id == "WelcomeRecentListPanel";
                x: (recent_list_panel_node.frame.x - recent_panel_node.frame.x) * 1px;
                y: (recent_list_panel_node.frame.y - recent_panel_node.frame.y) * 1px;
                width: recent_list_panel_node.frame.width * 1px;
                height: recent_list_panel_node.frame.height * 1px;
                clip: true;

                recent_rows := VerticalLayout {
                    x: 0px;
                    y: 0px - root.recent_projects_scroll_px * 1px;
                    width: max(parent.width - 8px, 0px);
                    spacing: 10px;

                    for recent[index] in root.recent_projects: Rectangle {
                        height: 112px;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: recent.invalid ? #6d4a4a : palette.border_soft;
                        background:
                            recent.invalid
                                ? (root.hovered_recent_project_index == index ? #3a292c : #312224)
                                : (root.hovered_recent_project_index == index ? palette.chrome_bg_soft : palette.panel_bg_soft);

                        ShellIcon {
                            x: 14px;
                            y: 14px;
                            width: 18px;
                            height: 18px;
                            icon_key: "project";
                            icon_color: recent.invalid ? #f0b3b3 : palette.text_muted;
                        }

                        Text {
                            x: 42px;
                            y: 12px;
                            width: parent.width - 56px;
                            text: recent.display_name;
                            color: palette.text;
                            font-size: 13px;
                            font-weight: 700;
                            overflow: elide;
                        }

                        Text {
                            x: 14px;
                            y: 40px;
                            width: parent.width - 28px;
                            text: recent.path;
                            color: palette.text_dim;
                            font-size: 10px;
                            overflow: elide;
                        }

                        Text {
                            x: 14px;
                            y: 62px;
                            text: recent.last_opened_label;
                            color: palette.text_dim;
                            font-size: 10px;
                        }

                        if recent.status_label != "": Rectangle {
                            x: parent.width - status_text.preferred-width - 26px;
                            y: 58px;
                            width: status_text.preferred-width + 14px;
                            height: 18px;
                            border-radius: 9px;
                            border-width: 1px;
                            border-color: recent.invalid ? #8b5f5f : palette.border_soft;
                            background: recent.invalid ? #4a2f33 : palette.chrome_bg_soft;

                            status_text := Text {
                                x: 7px;
                                y: 3px;
                                text: recent.status_label;
                                color: recent.invalid ? #ffd1d1 : palette.text_dim;
                                font-size: 9px;
                                font-weight: 700;
                            }
                        }

                        ShellButton {
                            x: 14px;
                            y: 80px;
                            width: 88px;
                            label: "Open";
                            enabled: true;
                            interactive: false;
                            hovered: root.hovered_recent_project_index == index && root.hovered_recent_action == 0;
                        }

                        ShellButton {
                            x: 110px;
                            y: 80px;
                            width: 88px;
                            label: "Remove";
                            enabled: true;
                            interactive: false;
                            hovered: root.hovered_recent_project_index == index && root.hovered_recent_action == 1;
                        }
                    }

                    if root.recent_projects.length == 0: Rectangle {
                        height: 116px;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: palette.border_soft;
                        background: palette.panel_bg_soft;

                        Text {
                            x: 18px;
                            y: 18px;
                            text: "No recent projects";
                            color: palette.text;
                            font-size: 13px;
                            font-weight: 700;
                        }

                        Text {
                            x: 18px;
                            y: 44px;
                            width: parent.width - 36px;
                            text: "Create a renderable empty project on the right, or type an existing project root to open it.";
                            color: palette.text_dim;
                            font-size: 11px;
                            wrap: word-wrap;
                        }
                    }
                }

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    moved => {
                        root.recent_projects_pointer_moved(
                            parent.x / 1px + self.mouse-x / 1px,
                            parent.y / 1px + self.mouse-y / 1px,
                            root.width / 1px,
                            root.height / 1px,
                        );
                    }
                    clicked => {
                        root.recent_projects_pointer_clicked(
                            parent.x / 1px + self.mouse-x / 1px,
                            parent.y / 1px + self.mouse-y / 1px,
                            root.width / 1px,
                            root.height / 1px,
                        );
                    }
                    scroll-event(event) => {
                        root.recent_projects_pointer_scrolled(
                            parent.x / 1px + self.mouse-x / 1px,
                            parent.y / 1px + self.mouse-y / 1px,
                            event.delta_y / 1px,
                            root.width / 1px,
                            root.height / 1px,
                        );
                        accept
                    }
                }
            }
        }

        for main_panel_node in root.welcome.nodes: Rectangle {
            visible: main_panel_node.control_id == "WelcomeMainPanel";
            x: (main_panel_node.frame.x - outer_panel_node.frame.x) * 1px;
            y: (main_panel_node.frame.y - outer_panel_node.frame.y) * 1px;
            width: main_panel_node.frame.width * 1px;
            height: main_panel_node.frame.height * 1px;
            background: transparent;
            clip: true;

            for hero_panel_node in root.welcome.nodes: Rectangle {
                visible: hero_panel_node.control_id == "WelcomeHeroPanel";
                x: (hero_panel_node.frame.x - main_panel_node.frame.x) * 1px;
                y: (hero_panel_node.frame.y - main_panel_node.frame.y) * 1px;
                width: hero_panel_node.frame.width * 1px;
                height: hero_panel_node.frame.height * 1px;
                border-radius: 14px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: #1f242a;
                clip: true;

                Text {
                    x: 20px;
                    y: 16px;
                    text: root.welcome.title;
                    color: palette.text;
                    font-size: 26px;
                    font-weight: 800;
                }

                Text {
                    x: 20px;
                    y: 46px;
                    width: parent.width - 40px;
                    text: root.welcome.subtitle;
                    color: palette.text_dim;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            for status_panel_node in root.welcome.nodes: Rectangle {
                visible: status_panel_node.control_id == "WelcomeStatusPanel";
                x: (status_panel_node.frame.x - main_panel_node.frame.x) * 1px;
                y: (status_panel_node.frame.y - main_panel_node.frame.y) * 1px;
                width: status_panel_node.frame.width * 1px;
                height: status_panel_node.frame.height * 1px;
                border-radius: 10px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;
                clip: true;

                Text {
                    x: 14px;
                    y: max((parent.height - 12px) / 2, 0px);
                    width: parent.width - 28px;
                    text: root.welcome.status_message;
                    color: palette.text_muted;
                    font-size: 11px;
                    overflow: elide;
                }
            }

            for new_project_header_panel_node in root.welcome.nodes: Rectangle {
                visible: new_project_header_panel_node.control_id == "WelcomeNewProjectHeaderPanel";
                x: (new_project_header_panel_node.frame.x - main_panel_node.frame.x) * 1px;
                y: (new_project_header_panel_node.frame.y - main_panel_node.frame.y) * 1px;
                width: new_project_header_panel_node.frame.width * 1px;
                height: new_project_header_panel_node.frame.height * 1px;
                background: transparent;
                clip: true;

                Text {
                    x: 0px;
                    y: 0px;
                    text: "New Project";
                    color: palette.text;
                    font-size: 18px;
                    font-weight: 700;
                }

                Text {
                    x: 0px;
                    y: 28px;
                    width: parent.width;
                    text: "JetBrains-style scaffold flow: name first, root directory second, preview the final path before creation.";
                    color: palette.text_dim;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            for project_name_field_node in root.welcome.nodes: FieldCard {
                visible: project_name_field_node.control_id == "WelcomeProjectNameField";
                x: (project_name_field_node.frame.x - main_panel_node.frame.x) * 1px;
                y: (project_name_field_node.frame.y - main_panel_node.frame.y) * 1px;
                width: project_name_field_node.frame.width * 1px;
                height: project_name_field_node.frame.height * 1px;
                label: "Project Name";
                value: root.welcome.form.project_name;
                placeholder: "MyGame";
                edited(value) => { root.control_changed("ProjectNameEdited", value); }
            }

            for location_field_node in root.welcome.nodes: FieldCard {
                visible: location_field_node.control_id == "WelcomeLocationField";
                x: (location_field_node.frame.x - main_panel_node.frame.x) * 1px;
                y: (location_field_node.frame.y - main_panel_node.frame.y) * 1px;
                width: location_field_node.frame.width * 1px;
                height: location_field_node.frame.height * 1px;
                label: "Location";
                value: root.welcome.form.location;
                placeholder: "E:/Projects";
                edited(value) => { root.control_changed("LocationEdited", value); }
            }

            for preview_panel_node in root.welcome.nodes: Rectangle {
                visible: preview_panel_node.control_id == "WelcomePreviewPanel";
                x: (preview_panel_node.frame.x - main_panel_node.frame.x) * 1px;
                y: (preview_panel_node.frame.y - main_panel_node.frame.y) * 1px;
                width: preview_panel_node.frame.width * 1px;
                height: preview_panel_node.frame.height * 1px;
                border-radius: 10px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.panel_bg_soft;
                clip: true;

                Text {
                    x: 14px;
                    y: 12px;
                    text: "Project Path Preview";
                    color: palette.text_dim;
                    font-size: 10px;
                    font-weight: 700;
                }

                Text {
                    x: 14px;
                    y: 30px;
                    width: parent.width - 28px;
                    text: root.welcome.form.project_path_preview;
                    color: palette.text;
                    font-size: 12px;
                    overflow: elide;
                }

                Text {
                    x: 14px;
                    y: 52px;
                    width: parent.width - 28px;
                    text: "Template: " + root.welcome.form.template_label;
                    color: palette.text_dim;
                    font-size: 10px;
                    overflow: elide;
                }
            }

            for validation_panel_node in root.welcome.nodes: Rectangle {
                visible:
                    root.welcome.form.validation_message != "" &&
                    validation_panel_node.control_id == "WelcomeValidationPanel";
                x: (validation_panel_node.frame.x - main_panel_node.frame.x) * 1px;
                y: (validation_panel_node.frame.y - main_panel_node.frame.y) * 1px;
                width: validation_panel_node.frame.width * 1px;
                height: validation_panel_node.frame.height * 1px;
                border-radius: 10px;
                border-width: 1px;
                border-color: #7a4a4f;
                background: #341f22;
                clip: true;

                Text {
                    x: 14px;
                    y: 10px;
                    width: parent.width - 28px;
                    text: root.welcome.form.validation_message;
                    color: #ffd4d8;
                    font-size: 11px;
                    wrap: word-wrap;
                }
            }

            for actions_row_node in root.welcome.nodes: Rectangle {
                visible: actions_row_node.control_id == "WelcomeActionsRow";
                x: (actions_row_node.frame.x - main_panel_node.frame.x) * 1px;
                y: (actions_row_node.frame.y - main_panel_node.frame.y) * 1px;
                width: actions_row_node.frame.width * 1px;
                height: actions_row_node.frame.height * 1px;
                background: transparent;
                clip: true;

                HorizontalLayout {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: parent.height;
                    spacing: 10px;

                    ShellButton {
                        width: 138px;
                        label: "Create Project";
                        active: root.welcome.form.can_create;
                        enabled: root.welcome.form.can_create;
                        clicked => { root.control_clicked("CreateProject"); }
                    }

                    ShellButton {
                        width: 156px;
                        label: "Open Existing Project";
                        enabled: root.welcome.form.can_open_existing;
                        clicked => { root.control_clicked("OpenExistingProject"); }
                    }
                }
            }
        }
    }
}
