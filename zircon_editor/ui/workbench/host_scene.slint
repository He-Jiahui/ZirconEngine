import { Palette } from "chrome.slint";
import { HostWindowLayoutData, HostMenuChromeData, HostPageChromeData, HostStatusBarData, HostResizeLayerData, HostTabDragOverlayData, HostSideDockSurfaceData, HostDocumentDockSurfaceData, HostBottomDockSurfaceData, HostFloatingWindowLayerData, HostWorkbenchSurfaceMetricsData, HostWorkbenchSurfaceOrchestrationData, HostMenuChrome, HostPageChrome, HostDocumentDockSurface, HostSideDockSurface, HostBottomDockSurface, HostStatusBar, HostResizeLayer, HostFloatingWindowLayer, HostTabDragOverlay } from "host_components.slint";

export struct HostWorkbenchWindowSceneData {
    layout: HostWindowLayoutData,
    metrics: HostWorkbenchSurfaceMetricsData,
    orchestration: HostWorkbenchSurfaceOrchestrationData,
    menu_chrome: HostMenuChromeData,
    page_chrome: HostPageChromeData,
    status_bar: HostStatusBarData,
    resize_layer: HostResizeLayerData,
    drag_overlay: HostTabDragOverlayData,
    left_dock: HostSideDockSurfaceData,
    document_dock: HostDocumentDockSurfaceData,
    right_dock: HostSideDockSurfaceData,
    bottom_dock: HostBottomDockSurfaceData,
    floating_layer: HostFloatingWindowLayerData,
}

export component HostWorkbenchWindowScene inherits Rectangle {
    in property <HostWorkbenchWindowSceneData> scene_data;
    palette := Palette {}
    background: palette.shell_bg;

    host_menu := HostMenuChrome {
        width: parent.width;
        height: parent.height;
        menu_data: root.scene_data.menu_chrome;
    }

    Rectangle {
        x: root.scene_data.metrics.outer_margin_px * 1px;
        y: root.scene_data.metrics.outer_margin_px * 1px;
        width: parent.width - root.scene_data.metrics.outer_margin_px * 2px;
        height: parent.height - root.scene_data.metrics.outer_margin_px * 2px;
        background: palette.chrome_bg;
        border-width: 0px;
        border-color: palette.border;
        border-radius: 0px;
        clip: true;

        HostPageChrome {
            width: parent.width;
            height: parent.height;
            page_data: root.scene_data.page_chrome;
        }

        Rectangle {
            x: 0px;
            y: root.scene_data.layout.center_band_frame.y * 1px - 1px;
            width: parent.width;
            height: 1px;
            background: palette.border;
        }

        main_content_zone := Rectangle {
            x: root.scene_data.layout.center_band_frame.x * 1px;
            y: root.scene_data.layout.center_band_frame.y * 1px;
            width: root.scene_data.layout.center_band_frame.width * 1px;
            height: root.scene_data.layout.center_band_frame.height * 1px;
            background: palette.panel_bg;
        }

        if root.scene_data.orchestration.left_stack_width_px > 0.0: HostSideDockSurface {
            surface_data: root.scene_data.left_dock;
        }

        HostDocumentDockSurface {
            surface_data: root.scene_data.document_dock;
        }

        if root.scene_data.orchestration.right_stack_width_px > 0.0: HostSideDockSurface {
            surface_data: root.scene_data.right_dock;
        }

        if root.scene_data.orchestration.bottom_panel_height_px > 0.0: HostBottomDockSurface {
            surface_data: root.scene_data.bottom_dock;
        }

        HostStatusBar {
            width: parent.width;
            height: parent.height;
            status_data: root.scene_data.status_bar;
        }
    }

    HostResizeLayer {
        width: parent.width;
        height: parent.height;
        resize_data: root.scene_data.resize_layer;
    }

    HostFloatingWindowLayer {
        width: parent.width;
        height: parent.height;
        layer_data: root.scene_data.floating_layer;
    }

    HostTabDragOverlay {
        width: parent.width;
        height: parent.height;
        overlay_data: root.scene_data.drag_overlay;
    }
}
