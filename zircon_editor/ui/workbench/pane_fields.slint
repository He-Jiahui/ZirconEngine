import { LineEdit } from "std-widgets.slint";
import { Palette } from "chrome.slint";

export component CompactField inherits Rectangle {
    in property <string> text;
    in property <string> placeholder;
    in property <bool> enabled: true;
    callback edited(value: string);

    palette := Palette {}
    height: 22px;
    border-radius: 3px;
    border-width: 1px;
    border-color: palette.border;
    background: enabled ? palette.panel_bg_soft : palette.panel_bg;
    opacity: enabled ? 1.0 : 0.55;

    LineEdit {
        x: 6px;
        y: 1px;
        width: parent.width - 12px;
        height: parent.height - 2px;
        text: root.text;
        placeholder-text: root.placeholder;
        enabled: root.enabled;
        font-size: 11px;
        edited(value) => { root.edited(value); }
    }
}

export component AxisField inherits Rectangle {
    in property <string> axis;
    in property <color> axis_color;
    in property <string> value;
    callback edited(value: string);

    palette := Palette {}
    height: 22px;
    border-radius: 3px;
    border-width: 1px;
    border-color: palette.border;
    background: palette.panel_bg_soft;

    Text {
        x: 7px;
        y: 5px;
        text: root.axis;
        color: root.axis_color;
        font-size: 10px;
        font-weight: 700;
    }

    LineEdit {
        x: 18px;
        y: 1px;
        width: parent.width - 24px;
        height: parent.height - 2px;
        text: root.value;
        placeholder-text: root.axis;
        font-size: 11px;
        edited(value) => { root.edited(value); }
    }
}
