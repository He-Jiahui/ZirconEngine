import { Palette, TabChip } from "chrome.slint";
import { HostDocumentDockSurfaceData } from "host_components.slint";
import { UiHostContext } from "host_context.slint";
import { PaneSurface } from "pane_surface.slint";

export component HostDocumentDockSurface inherits Rectangle {
    in property <HostDocumentDockSurfaceData> surface_data;
    palette := Palette {}
    x: root.surface_data.region_frame.x * 1px;
    y: root.surface_data.region_frame.y * 1px;
    width: root.surface_data.region_frame.width * 1px;
    height: root.surface_data.region_frame.height * 1px;
    background: palette.panel_bg;
    clip: true;

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: root.surface_data.header_height_px * 1px;
            background: palette.tab_bg;

            HorizontalLayout {
                x: 8px;
                y: 1px;
                spacing: 2px;
                for tab[index] in root.surface_data.tabs: TabChip {
                    label: tab.title;
                    icon_key: tab.icon_key;
                    active: tab.active;
                    closeable: tab.closeable;
                    drag_origin_x: (root.surface_data.tab_origin_x_px * 1px + self.x) / 1px;
                    drag_origin_y: (root.surface_data.tab_origin_y_px * 1px + self.y) / 1px;
                    pointer_clicked(x, y) => {
                        UiHostContext.document_tab_pointer_clicked(
                            root.surface_data.surface_key,
                            index,
                            8.0 + self.x / 1px,
                            self.width / 1px,
                            8.0 + self.x / 1px + x,
                            1.0 + self.y / 1px + y,
                        );
                    }
                    close_pointer_clicked(x, y) => {
                        UiHostContext.document_tab_close_pointer_clicked(
                            root.surface_data.surface_key,
                            index,
                            8.0 + self.x / 1px,
                            self.width / 1px,
                            8.0 + self.x / 1px + self.width / 1px - 24.0 + x,
                            1.0 + self.y / 1px + 7.0 + y,
                        );
                    }
                    drag_started(x, y) => {
                        UiHostContext.drag_state = {
                            active_drag_target_group: UiHostContext.drag_state.active_drag_target_group,
                            drag_active: true,
                            drag_tab_id: tab.id,
                            drag_tab_title: tab.title,
                            drag_tab_icon_key: tab.icon_key,
                            drag_source_group: root.surface_data.surface_key,
                            drag_pointer_x: x,
                            drag_pointer_y: y,
                        };
                        UiHostContext.host_drag_pointer_event(
                            1,
                            UiHostContext.drag_state.drag_pointer_x,
                            UiHostContext.drag_state.drag_pointer_y,
                        );
                    }
                    drag_moved(x, y) => {
                        if (UiHostContext.drag_state.drag_tab_id == tab.id) {
                            UiHostContext.drag_state = {
                                active_drag_target_group: UiHostContext.drag_state.active_drag_target_group,
                                drag_active: UiHostContext.drag_state.drag_active,
                                drag_tab_id: UiHostContext.drag_state.drag_tab_id,
                                drag_tab_title: UiHostContext.drag_state.drag_tab_title,
                                drag_tab_icon_key: UiHostContext.drag_state.drag_tab_icon_key,
                                drag_source_group: UiHostContext.drag_state.drag_source_group,
                                drag_pointer_x: x,
                                drag_pointer_y: y,
                            };
                            UiHostContext.host_drag_pointer_event(
                                1,
                                UiHostContext.drag_state.drag_pointer_x,
                                UiHostContext.drag_state.drag_pointer_y,
                            );
                        }
                    }
                }
            }

            Text {
                x: parent.width - 144px;
                y: 9px;
                width: 132px;
                horizontal-alignment: right;
                text: root.surface_data.pane.subtitle;
                color: palette.text_dim;
                font-size: 10px;
                overflow: elide;
            }
        }

        Rectangle { height: 1px; background: palette.border_soft; }

        PaneSurface {
            width: parent.width;
            height: parent.height - root.surface_data.header_height_px * 1px - 1px;
            pane: root.surface_data.pane;
            show_header: false;
            compact_empty: false;
        }
    }
}
