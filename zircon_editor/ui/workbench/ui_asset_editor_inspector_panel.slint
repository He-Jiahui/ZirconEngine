import { Palette, ShellButton } from "chrome.slint";
import { CompactField } from "pane_fields.slint";
import { UiAssetEditorPaneDraftData, UiAssetInspectorPanelData } from "ui_asset_editor_data.slint";
import { UiAssetSelectableSection } from "ui_asset_editor_components.slint";

export component UiAssetEditorInspectorPanel inherits Rectangle {
    in property <UiAssetInspectorPanelData> inspector_panel;
    in property <UiAssetEditorPaneDraftData> draft_data;
    callback detail_event(detail_id: string, action_id: string, item_index: int, primary: string, secondary: string);
    callback draft_value_changed(draft_id: string, value: string);
    callback clear_draft(draft_id: string);
    callback collection_event(collection_id: string, event_kind: string, item_index: int);
    palette := Palette {}
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    clip: true;

                    Text {
                        x: 10px;
                        y: 6px;
                        text: "Inspector";
                        color: #d98bb5;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Rectangle {
                        x: 0px;
                        y: 26px;
                        width: parent.width;
                        height: parent.height - 26px;
                        clip: true;

                        VerticalLayout {
                            x: 10px;
                            y: 8px;
                            width: parent.width - 20px;
                            spacing: 4px;

                            Text {
                                text: "Widget";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: 52px;
                                    text: "Node";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                Text {
                                    x: 56px;
                                    y: 3px;
                                    width: parent.width - 56px;
                                    text: root.inspector_panel.widget.selected_node_id != "" ? root.inspector_panel.widget.selected_node_id : "No selection";
                                    color: palette.text_muted;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: 52px;
                                    text: "Type";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                Text {
                                    x: 56px;
                                    y: 3px;
                                    width: parent.width - 56px;
                                    text:
                                        root.inspector_panel.widget.widget_label != "" ?
                                        root.inspector_panel.widget.widget_kind + " • " + root.inspector_panel.widget.widget_label :
                                        "";
                                    color: palette.text_muted;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: 52px;
                                    text: "Parent";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                Text {
                                    x: 56px;
                                    y: 3px;
                                    width: parent.width - 56px;
                                    text:
                                        root.inspector_panel.widget.parent_node_id != "" ?
                                        (root.inspector_panel.widget.mount != "" ? root.inspector_panel.widget.parent_node_id + " • " + root.inspector_panel.widget.mount : root.inspector_panel.widget.parent_node_id) :
                                        "";
                                    color: palette.text_muted;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Control Id";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.widget.control_id;
                                    placeholder: "control-id";
                                    enabled: root.inspector_panel.widget.can_edit_control_id;
                edited(value) => { root.detail_event("widget", "widget.control_id.set", -1, value, ""); }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Text";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.widget.text_prop;
                                    placeholder: "props.text";
                                    enabled: root.inspector_panel.widget.can_edit_text_prop;
                edited(value) => { root.detail_event("widget", "widget.text.set", -1, value, ""); }
                                }
                            }

                            Text {
                                text: "Promote Draft";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Asset";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.widget.promote_asset_id;
                                    placeholder: "res://ui/widgets/widget.ui.toml";
                                    enabled: root.inspector_panel.widget.can_edit_promote_draft;
                edited(value) => { root.detail_event("widget_promote", "promote.asset_id.set", -1, value, ""); }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Comp";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.widget.promote_component_name;
                                    placeholder: "ComponentName";
                                    enabled: root.inspector_panel.widget.can_edit_promote_draft;
                edited(value) => { root.detail_event("widget_promote", "promote.component_name.set", -1, value, ""); }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Doc";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.widget.promote_document_id;
                                    placeholder: "ui.widgets.widget";
                                    enabled: root.inspector_panel.widget.can_edit_promote_draft;
                edited(value) => { root.detail_event("widget_promote", "promote.document_id.set", -1, value, ""); }
                                }
                            }

                            Text {
                                text: "Slot";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Mount";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.widget.mount;
                                    placeholder: "slot mount";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                edited(value) => { root.detail_event("slot", "slot.mount.set", -1, value, ""); }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Padding";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.slot.padding;
                                    placeholder: "slot.padding";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                edited(value) => { root.detail_event("slot", "slot.padding.set", -1, value, ""); }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Width";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.slot.width_preferred;
                                    placeholder: "slot.layout.width.preferred";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                edited(value) => { root.detail_event("slot", "slot.layout.width.preferred.set", -1, value, ""); }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Height";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.slot.height_preferred;
                                    placeholder: "slot.layout.height.preferred";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                edited(value) => { root.detail_event("slot", "slot.layout.height.preferred.set", -1, value, ""); }
                                }
                            }

                            if root.inspector_panel.slot.kind == "HorizontalBox" || root.inspector_panel.slot.kind == "VerticalBox": Text {
                                text: "Linear Slot";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.inspector_panel.slot.kind == "HorizontalBox" || root.inspector_panel.slot.kind == "VerticalBox": Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Main Wgt"; color: palette.text_dim; font-size: 10px; }
                                CompactField {
                                    x: 62px; y: 0px; width: parent.width - 62px;
                                    text: root.inspector_panel.slot.linear_main_weight;
                                    placeholder: root.inspector_panel.slot.kind == "HorizontalBox" ? "layout.width.weight" : "layout.height.weight";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                                    edited(value) => {
                                        if (root.inspector_panel.slot.kind == "HorizontalBox") {
                    root.detail_event("slot", "slot.linear.width_weight.set", -1, value, "");
                                        } else {
                    root.detail_event("slot", "slot.linear.height_weight.set", -1, value, "");
                                        }
                                    }
                                }
                            }

                            if root.inspector_panel.slot.kind == "HorizontalBox" || root.inspector_panel.slot.kind == "VerticalBox": Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Main Str"; color: palette.text_dim; font-size: 10px; }
                                CompactField {
                                    x: 62px; y: 0px; width: parent.width - 62px;
                                    text: root.inspector_panel.slot.linear_main_stretch;
                                    placeholder: root.inspector_panel.slot.kind == "HorizontalBox" ? "layout.width.stretch" : "layout.height.stretch";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                                    edited(value) => {
                                        if (root.inspector_panel.slot.kind == "HorizontalBox") {
                    root.detail_event("slot", "slot.linear.width_stretch.set", -1, value, "");
                                        } else {
                    root.detail_event("slot", "slot.linear.height_stretch.set", -1, value, "");
                                        }
                                    }
                                }
                            }

                            if root.inspector_panel.slot.kind == "HorizontalBox" || root.inspector_panel.slot.kind == "VerticalBox": Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Cross Wgt"; color: palette.text_dim; font-size: 10px; }
                                CompactField {
                                    x: 62px; y: 0px; width: parent.width - 62px;
                                    text: root.inspector_panel.slot.linear_cross_weight;
                                    placeholder: root.inspector_panel.slot.kind == "HorizontalBox" ? "layout.height.weight" : "layout.width.weight";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                                    edited(value) => {
                                        if (root.inspector_panel.slot.kind == "HorizontalBox") {
                    root.detail_event("slot", "slot.linear.height_weight.set", -1, value, "");
                                        } else {
                    root.detail_event("slot", "slot.linear.width_weight.set", -1, value, "");
                                        }
                                    }
                                }
                            }

                            if root.inspector_panel.slot.kind == "HorizontalBox" || root.inspector_panel.slot.kind == "VerticalBox": Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Cross Str"; color: palette.text_dim; font-size: 10px; }
                                CompactField {
                                    x: 62px; y: 0px; width: parent.width - 62px;
                                    text: root.inspector_panel.slot.linear_cross_stretch;
                                    placeholder: root.inspector_panel.slot.kind == "HorizontalBox" ? "layout.height.stretch" : "layout.width.stretch";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                                    edited(value) => {
                                        if (root.inspector_panel.slot.kind == "HorizontalBox") {
                    root.detail_event("slot", "slot.linear.height_stretch.set", -1, value, "");
                                        } else {
                    root.detail_event("slot", "slot.linear.width_stretch.set", -1, value, "");
                                        }
                                    }
                                }
                            }

                            if root.inspector_panel.slot.kind == "Overlay": Text {
                                text: "Overlay Slot";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.inspector_panel.slot.kind == "Overlay": Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Anchor X"; color: palette.text_dim; font-size: 10px; }
                                CompactField {
                                    x: 62px; y: 0px; width: parent.width - 62px;
                                    text: root.inspector_panel.slot.overlay_anchor_x;
                                    placeholder: "layout.anchor.x";
                                    enabled: root.inspector_panel.widget.parent_node_id != "";
                edited(value) => { root.detail_event("slot", "slot.overlay.anchor_x.set", -1, value, ""); }
                                }
                            }

                            if root.inspector_panel.slot.kind == "Overlay": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Anchor Y"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.overlay_anchor_y; placeholder: "layout.anchor.y"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.overlay.anchor_y.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Overlay": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Pivot X"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.overlay_pivot_x; placeholder: "layout.pivot.x"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.overlay.pivot_x.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Overlay": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Pivot Y"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.overlay_pivot_y; placeholder: "layout.pivot.y"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.overlay.pivot_y.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Overlay": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Pos X"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.overlay_position_x; placeholder: "layout.position.x"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.overlay.position_x.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Overlay": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Pos Y"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.overlay_position_y; placeholder: "layout.position.y"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.overlay.position_y.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Overlay": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Z"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.overlay_z_index; placeholder: "layout.z_index"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.overlay.z_index.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Grid": Text {
                                text: "Grid Slot";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.inspector_panel.slot.kind == "Grid": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Row"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.grid_row; placeholder: "row"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.grid.row.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Grid": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Column"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.grid_column; placeholder: "column"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.grid.column.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Grid": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Row Span"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.grid_row_span; placeholder: "row_span"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.grid.row_span.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Grid": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Col Span"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.grid_column_span; placeholder: "column_span"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.grid.column_span.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Flow": Text {
                                text: "Flow Slot";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.inspector_panel.slot.kind == "Flow": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Break"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.flow_break_before; placeholder: "break_before"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.flow.break_before.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.kind == "Flow": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Align"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.slot.flow_alignment; placeholder: "alignment"; enabled: root.inspector_panel.widget.parent_node_id != ""; edited(value) => { root.detail_event("slot", "slot.flow.alignment.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.slot.semantic.title != "": Text {
                                text: root.inspector_panel.slot.semantic.title;
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.inspector_panel.slot.semantic.title != "": UiAssetSelectableSection {
                                width: parent.width;
                                height: 92px;
                                title: root.inspector_panel.slot.semantic.title;
                                items: root.inspector_panel.slot.semantic.collection.items;
                                selected_index: root.inspector_panel.slot.semantic.collection.selected_index;
                                accent: #6ec0d5;
                                item_selected(item_index) => { root.collection_event("slot_semantic", "selected", item_index); }
                            }

                            if root.inspector_panel.slot.semantic.title != "": Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: parent.width;
                                    text:
                                        root.inspector_panel.slot.semantic.path != "" ?
                                        root.inspector_panel.slot.semantic.path :
                                        "Select slot semantic";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            if root.inspector_panel.slot.semantic.title != "": CompactField {
                                width: parent.width;
                                text: root.inspector_panel.slot.semantic.value;
                                placeholder: root.inspector_panel.slot.semantic.path;
                                enabled: root.inspector_panel.slot.semantic.collection.selected_index >= 0;
                edited(value) => { root.detail_event("slot", "slot.semantic.value.set", -1, value, ""); }
                            }

                            if root.inspector_panel.slot.semantic.title != "": HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 52px;
                                    label: "Clear";
                                    enabled: root.inspector_panel.slot.semantic.collection.selected_index >= 0;
                clicked => { root.detail_event("slot", "slot.semantic.delete", -1, "", ""); }
                                }
                            }

                            Text {
                                text: "Layout";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Width";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.layout.width_preferred;
                                    placeholder: "layout.width.preferred";
                                    enabled: root.inspector_panel.widget.selected_node_id != "";
                edited(value) => { root.detail_event("layout", "layout.width.preferred.set", -1, value, ""); }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Height";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.layout.height_preferred;
                                    placeholder: "layout.height.preferred";
                                    enabled: root.inspector_panel.widget.selected_node_id != "";
                edited(value) => { root.detail_event("layout", "layout.height.preferred.set", -1, value, ""); }
                                }
                            }

                            if root.inspector_panel.layout.kind == "HorizontalBox" || root.inspector_panel.layout.kind == "VerticalBox": Text {
                                text: "Linear Layout";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.inspector_panel.layout.kind == "HorizontalBox" || root.inspector_panel.layout.kind == "VerticalBox": Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Gap";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_panel.layout.box_gap;
                                    placeholder: "container.gap";
                                    enabled: root.inspector_panel.widget.selected_node_id != "";
                edited(value) => { root.detail_event("layout", "layout.box.gap.set", -1, value, ""); }
                                }
                            }

                            if root.inspector_panel.layout.kind == "ScrollableBox": Text {
                                text: "Scrollable Layout";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.inspector_panel.layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Axis"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.layout.scroll_axis; placeholder: "container.axis"; enabled: root.inspector_panel.widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.axis.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Gap"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.layout.scroll_gap; placeholder: "container.gap"; enabled: root.inspector_panel.widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.gap.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Bar"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.layout.scrollbar_visibility; placeholder: "container.scrollbar_visibility"; enabled: root.inspector_panel.widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.scrollbar_visibility.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Extent"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.layout.virtualization_item_extent; placeholder: "container.virtualization.item_extent"; enabled: root.inspector_panel.widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.virtualization.item_extent.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Over"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.layout.virtualization_overscan; placeholder: "container.virtualization.overscan"; enabled: root.inspector_panel.widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.virtualization.overscan.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Clip"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_panel.layout.clip; placeholder: "clip"; enabled: root.inspector_panel.widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.clip.set", -1, value, ""); } }
                            }

                            if root.inspector_panel.layout.semantic.title != "": Text {
                                text: root.inspector_panel.layout.semantic.title;
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.inspector_panel.layout.semantic.title != "": UiAssetSelectableSection {
                                width: parent.width;
                                height: 92px;
                                title: root.inspector_panel.layout.semantic.title;
                                items: root.inspector_panel.layout.semantic.collection.items;
                                selected_index: root.inspector_panel.layout.semantic.collection.selected_index;
                                accent: #d7a86b;
                                item_selected(item_index) => { root.collection_event("layout_semantic", "selected", item_index); }
                            }

                            if root.inspector_panel.layout.semantic.title != "": Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: parent.width;
                                    text:
                                        root.inspector_panel.layout.semantic.path != "" ?
                                        root.inspector_panel.layout.semantic.path :
                                        "Select layout semantic";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            if root.inspector_panel.layout.semantic.title != "": CompactField {
                                width: parent.width;
                                text: root.inspector_panel.layout.semantic.value;
                                placeholder: root.inspector_panel.layout.semantic.path;
                                enabled: root.inspector_panel.layout.semantic.collection.selected_index >= 0;
                edited(value) => { root.detail_event("layout", "layout.semantic.value.set", -1, value, ""); }
                            }

                            if root.inspector_panel.layout.semantic.title != "": HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 52px;
                                    label: "Clear";
                                    enabled: root.inspector_panel.layout.semantic.collection.selected_index >= 0;
                clicked => { root.detail_event("layout", "layout.semantic.delete", -1, "", ""); }
                                }
                            }

                            Text {
                                text: "Bindings";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 104px;
                                title: "Bindings";
                                items: root.inspector_panel.binding.collection.items;
                                selected_index: root.inspector_panel.binding.collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => { root.collection_event("binding", "selected", item_index); }
                            }

                            CompactField {
                                width: parent.width;
                                text: root.inspector_panel.binding.binding_id;
                                placeholder: "binding id";
                                enabled: root.inspector_panel.binding.can_edit;
                edited(value) => { root.detail_event("binding", "binding.id.set", -1, value, ""); }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 86px;
                                title: "Event";
                                items: root.inspector_panel.binding.event_collection.items;
                                selected_index: root.inspector_panel.binding.event_collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => { root.collection_event("binding_event", "selected", item_index); }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 68px;
                                title: "Action Kind";
                                items: root.inspector_panel.binding.action_kind_collection.items;
                                selected_index: root.inspector_panel.binding.action_kind_collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => { root.collection_event("binding_action_kind", "selected", item_index); }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: parent.width;
                                    text: root.inspector_panel.binding.action_kind_collection.selected_index == 2 ? "Binding Target" : "Route";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text: root.inspector_panel.binding.binding_route;
                                placeholder:
                                    root.inspector_panel.binding.action_kind_collection.selected_index == 2 ?
                                    "EditorActions.SaveProject" :
                                    "MenuAction.SaveProject";
                                enabled: root.inspector_panel.binding.can_edit;
                edited(value) => { root.detail_event("binding", "binding.route.set", -1, value, ""); }
                            }

                            if root.inspector_panel.binding.action_kind_collection.selected_index != 2: Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: parent.width;
                                    text: "Route Target";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            if root.inspector_panel.binding.action_kind_collection.selected_index != 2: CompactField {
                                width: parent.width;
                                text: root.inspector_panel.binding.binding_route_target;
                                placeholder: "MenuAction.SaveProject";
                                enabled: root.inspector_panel.binding.can_edit;
                edited(value) => { root.detail_event("binding", "binding.route_target.set", -1, value, ""); }
                            }

                            if root.inspector_panel.binding.action_kind_collection.selected_index == 2: Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: parent.width;
                                    text: "Action Target";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            if root.inspector_panel.binding.action_kind_collection.selected_index == 2: CompactField {
                                width: parent.width;
                                text: root.inspector_panel.binding.binding_action_target;
                                placeholder: "EditorActions.SaveProject";
                                enabled: root.inspector_panel.binding.can_edit;
                edited(value) => { root.detail_event("binding", "binding.action_target.set", -1, value, ""); }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 72px;
                                title: "Route Suggestions";
                                items: root.inspector_panel.binding.route_suggestion_collection.items;
                                selected_index: root.inspector_panel.binding.route_suggestion_collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => {
                                    root.detail_event("binding_route_suggestion", "binding.route.suggestion.apply", item_index, "", "");
                                }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 72px;
                                title: "Action Suggestions";
                                items: root.inspector_panel.binding.action_suggestion_collection.items;
                                selected_index: root.inspector_panel.binding.action_suggestion_collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => {
                                    root.detail_event("binding_action_suggestion", "binding.action.suggestion.apply", item_index, "", "");
                                }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 86px;
                                title: "Binding Schema";
                                items: root.inspector_panel.binding.schema_items;
                                selected_index: -1;
                                accent: #7cc6b9;
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 104px;
                                title: "Payload";
                                items: root.inspector_panel.binding.payload_collection.items;
                                selected_index: root.inspector_panel.binding.payload_collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => {
                                    root.collection_event("binding_payload", "selected", item_index);
                                    root.draft_value_changed("binding.payload.key", root.inspector_panel.binding.payload_key);
                                    root.draft_value_changed("binding.payload.value", root.inspector_panel.binding.payload_value);
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.draft_data.binding.payload_key != "" ?
                                    root.draft_data.binding.payload_key :
                                    root.inspector_panel.binding.payload_key;
                                placeholder: "payload key";
                                enabled: root.inspector_panel.binding.can_edit;
                                edited(value) => { root.draft_value_changed("binding.payload.key", value); }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.draft_data.binding.payload_value != "" ?
                                    root.draft_data.binding.payload_value :
                                    root.inspector_panel.binding.payload_value;
                                placeholder: "payload value";
                                enabled: root.inspector_panel.binding.can_edit;
                                edited(value) => { root.draft_value_changed("binding.payload.value", value); }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 64px;
                                    label: "Add Click";
                                    enabled: root.inspector_panel.widget.selected_node_id != "";
                                    active: root.inspector_panel.widget.selected_node_id != "";
                clicked => { root.detail_event("binding", "binding.add", -1, "", ""); }
                                }

                                ShellButton {
                                    width: 52px;
                                    label: "Delete";
                                    enabled: root.inspector_panel.binding.can_delete;
                clicked => { root.detail_event("binding", "binding.delete", -1, "", ""); }
                                }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 86px;
                                title: "Payload Suggestions";
                                items: root.inspector_panel.binding.payload_suggestion_collection.items;
                                selected_index: root.inspector_panel.binding.payload_suggestion_collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => {
                                    root.detail_event("binding_payload_suggestion", "binding.payload.suggestion.apply", item_index, "", "");
                                    root.clear_draft("binding.payload.key");
                                    root.clear_draft("binding.payload.value");
                                }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 48px;
                                    label: "Upsert";
                                    enabled:
                                        root.inspector_panel.binding.can_edit &&
                                        ((root.draft_data.binding.payload_key != "" ? root.draft_data.binding.payload_key : root.inspector_panel.binding.payload_key) != "");
                                    active:
                                        root.inspector_panel.binding.can_edit &&
                                        ((root.draft_data.binding.payload_key != "" ? root.draft_data.binding.payload_key : root.inspector_panel.binding.payload_key) != "");
                                    clicked => {
                                        root.detail_event("binding_payload", "binding.payload.upsert", root.inspector_panel.binding.payload_collection.selected_index, root.draft_data.binding.payload_key != "" ? root.draft_data.binding.payload_key : root.inspector_panel.binding.payload_key, root.draft_data.binding.payload_value != "" ? root.draft_data.binding.payload_value : root.inspector_panel.binding.payload_value);
                                        root.clear_draft("binding.payload.key");
                                        root.clear_draft("binding.payload.value");
                                    }
                                }

                                ShellButton {
                                    width: 56px;
                                    label: "Delete";
                                    enabled: root.inspector_panel.binding.payload_collection.selected_index >= 0;
                                    clicked => {
                                        root.detail_event("binding_payload", "binding.payload.delete", root.inspector_panel.binding.payload_collection.selected_index, "", "");
                                        root.clear_draft("binding.payload.key");
                                        root.clear_draft("binding.payload.value");
                                    }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 1px;
                                background: palette.border_soft;
                            }

                            if root.inspector_panel.widget.items.length == 0: Text {
                                text: "No inspector summary entries";
                                color: palette.text_dim;
                                font-size: 10px;
                            }

                            for item in root.inspector_panel.widget.items: Text {
                                text: item;
                                color: palette.text_muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }
}
