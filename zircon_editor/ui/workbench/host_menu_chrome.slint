import { MenuBarButton, MenuItemRow, Palette } from "chrome.slint";
import { UiHostContext } from "host_context.slint";
import { FrameRect, HostMenuChromeData } from "host_components.slint";

export component HostMenuChrome inherits Rectangle {
    in property <HostMenuChromeData> menu_data: {
        outer_margin_px: 0.0,
        top_bar_height_px: 25.0,
        save_project_enabled: false,
        undo_enabled: false,
        redo_enabled: false,
        delete_enabled: false,
        preset_names: [],
        active_preset_name: "",
        resolved_preset_name: "rider",
    };
    out property <FrameRect> file_menu_button_frame: {
        x: top_bar.x / 1px + menu_button_row.x / 1px + file_menu_button.x / 1px,
        y: top_bar.y / 1px + menu_button_row.y / 1px,
        width: file_menu_button.width / 1px,
        height: file_menu_button.height / 1px,
    };
    out property <FrameRect> edit_menu_button_frame: {
        x: top_bar.x / 1px + menu_button_row.x / 1px + edit_menu_button.x / 1px,
        y: top_bar.y / 1px + menu_button_row.y / 1px,
        width: edit_menu_button.width / 1px,
        height: edit_menu_button.height / 1px,
    };
    out property <FrameRect> selection_menu_button_frame: {
        x: top_bar.x / 1px + menu_button_row.x / 1px + selection_menu_button.x / 1px,
        y: top_bar.y / 1px + menu_button_row.y / 1px,
        width: selection_menu_button.width / 1px,
        height: selection_menu_button.height / 1px,
    };
    out property <FrameRect> view_menu_button_frame: {
        x: top_bar.x / 1px + menu_button_row.x / 1px + view_menu_button.x / 1px,
        y: top_bar.y / 1px + menu_button_row.y / 1px,
        width: view_menu_button.width / 1px,
        height: view_menu_button.height / 1px,
    };
    out property <FrameRect> window_menu_button_frame: {
        x: top_bar.x / 1px + menu_button_row.x / 1px + window_menu_button.x / 1px,
        y: top_bar.y / 1px + menu_button_row.y / 1px,
        width: window_menu_button.width / 1px,
        height: window_menu_button.height / 1px,
    };
    out property <FrameRect> help_menu_button_frame: {
        x: top_bar.x / 1px + menu_button_row.x / 1px + help_menu_button.x / 1px,
        y: top_bar.y / 1px + menu_button_row.y / 1px,
        width: help_menu_button.width / 1px,
        height: help_menu_button.height / 1px,
    };
    palette := Palette {}
    background: transparent;

    top_bar := Rectangle {
        x: root.menu_data.outer_margin_px * 1px;
        y: root.menu_data.outer_margin_px * 1px;
        width: parent.width - root.menu_data.outer_margin_px * 2px;
        height: root.menu_data.top_bar_height_px * 1px;
        background: palette.chrome_bg;

        menu_button_row := HorizontalLayout {
            x: 8px;
            y: 1px;
            spacing: 2px;

            file_menu_button := MenuBarButton { label: "File"; active: UiHostContext.menu_state.open_menu_index == 0; hovered: UiHostContext.menu_state.hovered_menu_index == 0; interactive: false; }
            edit_menu_button := MenuBarButton { label: "Edit"; active: UiHostContext.menu_state.open_menu_index == 1; hovered: UiHostContext.menu_state.hovered_menu_index == 1; interactive: false; }
            selection_menu_button := MenuBarButton { label: "Selection"; active: UiHostContext.menu_state.open_menu_index == 2; hovered: UiHostContext.menu_state.hovered_menu_index == 2; interactive: false; }
            view_menu_button := MenuBarButton { label: "View"; active: UiHostContext.menu_state.open_menu_index == 3; hovered: UiHostContext.menu_state.hovered_menu_index == 3; interactive: false; }
            window_menu_button := MenuBarButton { label: "Window"; active: UiHostContext.menu_state.open_menu_index == 4; hovered: UiHostContext.menu_state.hovered_menu_index == 4; interactive: false; }
            help_menu_button := MenuBarButton { label: "Help"; active: UiHostContext.menu_state.open_menu_index == 5; hovered: UiHostContext.menu_state.hovered_menu_index == 5; interactive: false; }
        }

        if UiHostContext.menu_state.open_menu_index == -1: TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            clicked => {
                UiHostContext.menu_pointer_clicked(
                    top_bar.x / 1px + self.mouse-x / 1px,
                    top_bar.y / 1px + self.mouse-y / 1px,
                );
            }
        }
    }

    Rectangle {
        x: root.menu_data.outer_margin_px * 1px;
        y: (root.menu_data.outer_margin_px + root.menu_data.top_bar_height_px) * 1px;
        width: parent.width - root.menu_data.outer_margin_px * 2px;
        height: 1px;
        background: palette.border;
    }

    if UiHostContext.menu_state.open_menu_index == 0: Rectangle {
        x: root.file_menu_button_frame.x * 1px;
        y: (root.file_menu_button_frame.y + root.file_menu_button_frame.height + 3) * 1px;
        width: 208px;
        height: 146px;
        border-radius: 8px;
        background: palette.panel_bg;
        border-width: 1px;
        border-color: palette.border;
        VerticalLayout {
            x: 6px;
            y: 6px;
            width: parent.width - 12px;
            spacing: 2px;
            MenuItemRow { label: "Open Project"; shortcut: "Ctrl+O"; hovered: UiHostContext.menu_state.hovered_menu_item_index == 0; interactive: false; }
            MenuItemRow { label: "Save Project"; shortcut: "Ctrl+S"; enabled: root.menu_data.save_project_enabled; hovered: UiHostContext.menu_state.hovered_menu_item_index == 1; interactive: false; }
            MenuItemRow { label: "Save Layout"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 2; interactive: false; }
            MenuItemRow { label: "Reset Layout"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 3; interactive: false; }
            MenuItemRow { label: "Recent Projects"; shortcut: ""; enabled: false; hovered: UiHostContext.menu_state.hovered_menu_item_index == 4; interactive: false; }
        }
    }

    if UiHostContext.menu_state.open_menu_index == 1: Rectangle {
        x: root.edit_menu_button_frame.x * 1px;
        y: (root.edit_menu_button_frame.y + root.edit_menu_button_frame.height + 3) * 1px;
        width: 186px;
        height: 66px;
        border-radius: 8px;
        background: palette.panel_bg;
        border-width: 1px;
        border-color: palette.border;
        VerticalLayout {
            x: 6px;
            y: 6px;
            width: parent.width - 12px;
            spacing: 2px;
            MenuItemRow { label: "Undo"; shortcut: "Ctrl+Z"; enabled: root.menu_data.undo_enabled; hovered: UiHostContext.menu_state.hovered_menu_item_index == 0; interactive: false; }
            MenuItemRow { label: "Redo"; shortcut: "Ctrl+Shift+Z"; enabled: root.menu_data.redo_enabled; hovered: UiHostContext.menu_state.hovered_menu_item_index == 1; interactive: false; }
        }
    }

    if UiHostContext.menu_state.open_menu_index == 2: Rectangle {
        x: root.selection_menu_button_frame.x * 1px;
        y: (root.selection_menu_button_frame.y + root.selection_menu_button_frame.height + 3) * 1px;
        width: 218px;
        height: 118px;
        border-radius: 8px;
        background: palette.panel_bg;
        border-width: 1px;
        border-color: palette.border;
        VerticalLayout {
            x: 6px;
            y: 6px;
            width: parent.width - 12px;
            spacing: 2px;
            MenuItemRow { label: "Create Cube"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 0; interactive: false; }
            MenuItemRow { label: "Create Camera"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 1; interactive: false; }
            MenuItemRow { label: "Create Directional Light"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 2; interactive: false; }
            MenuItemRow { label: "Delete Selection"; shortcut: "Delete"; enabled: root.menu_data.delete_enabled; hovered: UiHostContext.menu_state.hovered_menu_item_index == 3; interactive: false; }
        }
    }

    if UiHostContext.menu_state.open_menu_index == 3: Rectangle {
        x: root.view_menu_button_frame.x * 1px;
        y: (root.view_menu_button_frame.y + root.view_menu_button_frame.height + 3) * 1px;
        width: 198px;
        height: 234px;
        border-radius: 8px;
        background: palette.panel_bg;
        border-width: 1px;
        border-color: palette.border;
        VerticalLayout {
            x: 6px;
            y: 6px;
            width: parent.width - 12px;
            spacing: 2px;
            MenuItemRow { label: "Project"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 0; interactive: false; }
            MenuItemRow { label: "Hierarchy"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 1; interactive: false; }
            MenuItemRow { label: "Inspector"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 2; interactive: false; }
            MenuItemRow { label: "Scene"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 3; interactive: false; }
            MenuItemRow { label: "Game"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 4; interactive: false; }
            MenuItemRow { label: "Assets"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 5; interactive: false; }
            MenuItemRow { label: "Console"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 6; interactive: false; }
            MenuItemRow { label: "Prefab Editor"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 7; interactive: false; }
        }
    }

    if UiHostContext.menu_state.open_menu_index == 4: Rectangle {
        x: root.window_menu_button_frame.x * 1px;
        y: (root.window_menu_button_frame.y + root.window_menu_button_frame.height + 3) * 1px;
        width: 224px;
        height: UiHostContext.menu_state.window_menu_popup_height_px * 1px;
        border-radius: 8px;
        background: palette.panel_bg;
        border-width: 1px;
        border-color: palette.border;
        clip: true;
        VerticalLayout {
            x: 6px;
            y: 6px - UiHostContext.menu_state.window_menu_scroll_px * 1px;
            width: parent.width - 12px;
            spacing: 2px;
            MenuItemRow { label: "Save Preset Asset"; shortcut: root.menu_data.resolved_preset_name; hovered: UiHostContext.menu_state.hovered_menu_item_index == 0; interactive: false; }
            MenuItemRow { label: "Reset Layout"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 1; interactive: false; }
            for preset[index] in root.menu_data.preset_names: MenuItemRow {
                label: preset;
                shortcut: preset == root.menu_data.active_preset_name ? "active" : "";
                hovered: UiHostContext.menu_state.hovered_menu_item_index == index + 2;
                interactive: false;
            }
        }
    }

    if UiHostContext.menu_state.open_menu_index == 5: Rectangle {
        x: root.help_menu_button_frame.x * 1px;
        y: (root.help_menu_button_frame.y + root.help_menu_button_frame.height + 3) * 1px;
        width: 194px;
        height: 38px;
        border-radius: 8px;
        background: palette.panel_bg;
        border-width: 1px;
        border-color: palette.border;
        VerticalLayout {
            x: 6px;
            y: 6px;
            width: parent.width - 12px;
            spacing: 2px;
            MenuItemRow { label: "Workbench Guide"; shortcut: ""; hovered: UiHostContext.menu_state.hovered_menu_item_index == 0; interactive: false; }
        }
    }

    if UiHostContext.menu_state.open_menu_index != -1: TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        moved => {
            UiHostContext.menu_pointer_moved(self.mouse-x / 1px, self.mouse-y / 1px);
        }
        clicked => {
            UiHostContext.menu_pointer_clicked(self.mouse-x / 1px, self.mouse-y / 1px);
        }
        scroll-event(event) => {
            UiHostContext.menu_pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                event.delta_y / 1px,
            );
            accept
        }
    }
}
