import { EmptyStateCard, Palette, ShellIcon, ToolbarButton, ToolbarIconButton } from "chrome.slint";
import { AssetBrowserPane, AssetFolderData, AssetItemData, AssetReferenceData, AssetSelectionData, AssetsActivityPane, ProjectOverviewData, ProjectOverviewPane } from "assets.slint";
import { ConsolePane, FallbackPane, HierarchyPane, InspectorPane, SceneNodeData, ToolWindowEmptyState, UiAssetEditorPane, UiAssetEditorPaneData } from "panes.slint";
import { RecentProjectData, WelcomePane, WelcomePaneData } from "welcome.slint";

export struct SceneViewportChromeData {
    tool: string,
    transform_space: string,
    projection_mode: string,
    view_orientation: string,
    display_mode: string,
    grid_mode: string,
    gizmos_enabled: bool,
    preview_lighting: bool,
    preview_skybox: bool,
    translate_snap: float,
    rotate_snap_deg: float,
    scale_snap: float,
    translate_snap_label: string,
    rotate_snap_label: string,
    scale_snap_label: string,
}

export struct PaneData {
    id: string,
    slot: string,
    kind: string,
    title: string,
    icon_key: string,
    subtitle: string,
    info: string,
    show_empty: bool,
    empty_title: string,
    empty_body: string,
    primary_action_label: string,
    primary_action_id: string,
    secondary_action_label: string,
    secondary_action_id: string,
    secondary_hint: string,
    show_toolbar: bool,
    viewport: SceneViewportChromeData,
    ui_asset: UiAssetEditorPaneData,
}

component SceneViewportToolbar inherits Rectangle {
    in property <SceneViewportChromeData> viewport;
    callback pointer_clicked(control_id: string, control_x: float, control_y: float, control_width: float, control_height: float, point_x: float, point_y: float);

    palette := Palette {}
    height: 28px;
    background: #2b2d30;
    border-width: 1px;
    border-color: palette.border_soft;
    clip: true;

    right_group := Rectangle {
        x: parent.width - self.width - 8px;
        y: 4px;
        width: 314px;
        height: 20px;

        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 4px;

            ToolbarButton {
                label: "Persp";
                active: root.viewport.projection_mode == "Perspective";
                min-width: 44px;
                pointer_clicked(x, y) => { root.pointer_clicked("projection.perspective", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Ortho";
                active: root.viewport.projection_mode == "Orthographic";
                min-width: 44px;
                pointer_clicked(x, y) => { root.pointer_clicked("projection.orthographic", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "+X";
                active: root.viewport.view_orientation == "PosX";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.pos_x", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "-X";
                active: root.viewport.view_orientation == "NegX";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.neg_x", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "+Y";
                active: root.viewport.view_orientation == "PosY";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.pos_y", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "-Y";
                active: root.viewport.view_orientation == "NegY";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.neg_y", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "+Z";
                active: root.viewport.view_orientation == "PosZ";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.pos_z", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "-Z";
                active: root.viewport.view_orientation == "NegZ";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.neg_z", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
        }
    }

    left_group := Rectangle {
        x: 8px;
        y: 4px;
        width: max(0px, parent.width - right_group.width - 24px);
        height: 20px;
        clip: true;

        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 4px;

            ToolbarButton {
                label: "Drag";
                active: root.viewport.tool == "Drag";
                min-width: 38px;
                pointer_clicked(x, y) => { root.pointer_clicked("tool.drag", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Move";
                active: root.viewport.tool == "Move";
                min-width: 38px;
                pointer_clicked(x, y) => { root.pointer_clicked("tool.move", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Rotate";
                active: root.viewport.tool == "Rotate";
                min-width: 44px;
                pointer_clicked(x, y) => { root.pointer_clicked("tool.rotate", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Scale";
                active: root.viewport.tool == "Scale";
                min-width: 40px;
                pointer_clicked(x, y) => { root.pointer_clicked("tool.scale", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: 3px;
                background: palette.border;
            }

            ToolbarButton {
                label: "Local";
                active: root.viewport.transform_space == "Local";
                min-width: 40px;
                pointer_clicked(x, y) => { root.pointer_clicked("space.local", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Global";
                active: root.viewport.transform_space == "Global";
                min-width: 42px;
                pointer_clicked(x, y) => { root.pointer_clicked("space.global", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: 3px;
                background: palette.border;
            }

            ToolbarButton {
                label:
                    root.viewport.display_mode == "Shaded" ? "Shade" :
                    root.viewport.display_mode == "WireOverlay" ? "Wire+" :
                    "Wire";
                active: root.viewport.display_mode != "Shaded";
                min-width: 48px;
                pointer_clicked(x, y) => { root.pointer_clicked("display.cycle", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label:
                    root.viewport.grid_mode == "Hidden" ? "Grid Off" :
                    root.viewport.grid_mode == "VisibleNoSnap" ? "Grid" :
                    "Snap";
                active: root.viewport.grid_mode != "Hidden";
                min-width: 52px;
                pointer_clicked(x, y) => { root.pointer_clicked("grid.cycle", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: root.viewport.translate_snap_label;
                active: root.viewport.grid_mode == "VisibleAndSnap";
                min-width: 42px;
                pointer_clicked(x, y) => { root.pointer_clicked("snap.translate", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: root.viewport.rotate_snap_label;
                active: root.viewport.grid_mode == "VisibleAndSnap";
                min-width: 42px;
                pointer_clicked(x, y) => { root.pointer_clicked("snap.rotate", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: root.viewport.scale_snap_label;
                active: root.viewport.grid_mode == "VisibleAndSnap";
                min-width: 42px;
                pointer_clicked(x, y) => { root.pointer_clicked("snap.scale", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: 3px;
                background: palette.border;
            }

            ToolbarButton {
                label: "Light";
                active: root.viewport.preview_lighting;
                min-width: 38px;
                pointer_clicked(x, y) => { root.pointer_clicked("toggle.lighting", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Sky";
                active: root.viewport.preview_skybox;
                min-width: 34px;
                pointer_clicked(x, y) => { root.pointer_clicked("toggle.skybox", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Gz";
                active: root.viewport.gizmos_enabled;
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("toggle.gizmos", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarIconButton {
                icon_key: "tool-fit";
                active: false;
                pointer_clicked(x, y) => { root.pointer_clicked("frame.selection", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
        }
    }
}

export global PaneSurfaceHostContext {
    in property <WelcomePaneData> welcome_pane;
    in property <[RecentProjectData]> recent_projects;
    in property <int> hovered_welcome_recent_index: -1;
    in property <int> hovered_welcome_recent_action: -1;
    in property <float> welcome_recent_scroll_px: 0.0;
    in property <[SceneNodeData]> hierarchy_nodes;
    in property <int> hovered_hierarchy_index: -1;
    in property <float> hierarchy_scroll_px: 0.0;
    in property <ProjectOverviewData> project_overview;
    in property <[AssetFolderData]> activity_asset_tree_folders;
    in property <[AssetFolderData]> activity_asset_content_folders;
    in property <[AssetItemData]> activity_asset_content_items;
    in property <AssetSelectionData> activity_asset_selection;
    in property <[AssetReferenceData]> activity_asset_references;
    in property <[AssetReferenceData]> activity_asset_used_by;
    in property <string> activity_asset_search_query;
    in property <string> activity_asset_kind_filter;
    in property <string> activity_asset_view_mode;
    in property <string> activity_asset_utility_tab;
    in property <int> activity_asset_tree_hovered_index: -1;
    in property <float> activity_asset_tree_scroll_px: 0.0;
    in property <int> activity_asset_content_hovered_index: -1;
    in property <float> activity_asset_content_scroll_px: 0.0;
    in property <int> activity_asset_references_hovered_index: -1;
    in property <float> activity_asset_references_scroll_px: 0.0;
    in property <int> activity_asset_used_by_hovered_index: -1;
    in property <float> activity_asset_used_by_scroll_px: 0.0;
    in property <[AssetFolderData]> browser_asset_tree_folders;
    in property <[AssetFolderData]> browser_asset_content_folders;
    in property <[AssetItemData]> browser_asset_content_items;
    in property <AssetSelectionData> browser_asset_selection;
    in property <[AssetReferenceData]> browser_asset_references;
    in property <[AssetReferenceData]> browser_asset_used_by;
    in property <string> browser_asset_search_query;
    in property <string> browser_asset_kind_filter;
    in property <string> browser_asset_view_mode;
    in property <string> browser_asset_utility_tab;
    in property <int> browser_asset_tree_hovered_index: -1;
    in property <float> browser_asset_tree_scroll_px: 0.0;
    in property <int> browser_asset_content_hovered_index: -1;
    in property <float> browser_asset_content_scroll_px: 0.0;
    in property <int> browser_asset_references_hovered_index: -1;
    in property <float> browser_asset_references_scroll_px: 0.0;
    in property <int> browser_asset_used_by_hovered_index: -1;
    in property <float> browser_asset_used_by_scroll_px: 0.0;
    in property <float> browser_asset_details_scroll_px: 0.0;
    in property <image> viewport_image;
    in property <string> inspector_name;
    in property <string> inspector_parent;
    in property <string> inspector_x;
    in property <string> inspector_y;
    in property <string> inspector_z;
    in property <float> inspector_scroll_px: 0.0;
    in property <string> status_text;
    in property <float> console_scroll_px: 0.0;
    in property <bool> delete_enabled;
    in-out property <string> mesh_import_path;
    callback surface_control_clicked(control_id: string, action_id: string);
    callback hierarchy_pointer_clicked(x: float, y: float, width: float, height: float);
    callback hierarchy_pointer_moved(x: float, y: float, width: float, height: float);
    callback hierarchy_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback console_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback inspector_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback inspector_control_changed(control_id: string, value: string);
    callback inspector_control_clicked(control_id: string);
    callback mesh_import_path_edited(value: string);
    callback asset_control_changed(source: string, control_id: string, value: string);
    callback asset_control_clicked(source: string, control_id: string);
    callback asset_tree_pointer_clicked(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_tree_pointer_moved(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_tree_pointer_scrolled(surface_mode: string, x: float, y: float, delta: float, width: float, height: float);
    callback asset_content_pointer_clicked(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_content_pointer_moved(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_content_pointer_scrolled(surface_mode: string, x: float, y: float, delta: float, width: float, height: float);
    callback asset_reference_pointer_clicked(surface_mode: string, list_kind: string, x: float, y: float, width: float, height: float);
    callback asset_reference_pointer_moved(surface_mode: string, list_kind: string, x: float, y: float, width: float, height: float);
    callback asset_reference_pointer_scrolled(surface_mode: string, list_kind: string, x: float, y: float, delta: float, width: float, height: float);
    callback browser_asset_details_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback welcome_control_changed(control_id: string, value: string);
    callback welcome_control_clicked(control_id: string);
    callback welcome_recent_pointer_clicked(x: float, y: float, width: float, height: float);
    callback welcome_recent_pointer_moved(x: float, y: float, width: float, height: float);
    callback welcome_recent_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback viewport_pointer_event(kind: int, button: int, x: float, y: float, delta: float);
    callback viewport_toolbar_pointer_clicked(surface_key: string, control_id: string, control_x: float, control_y: float, control_width: float, control_height: float, point_x: float, point_y: float);
    callback ui_asset_action(instance_id: string, action_id: string);
    callback ui_asset_style_class_action(instance_id: string, action_id: string, class_name: string);
    callback ui_asset_detail_event(instance_id: string, detail_id: string, action_id: string, item_index: int, primary: string, secondary: string);
    callback ui_asset_collection_event(instance_id: string, collection_id: string, event_kind: string, item_index: int);
    callback ui_asset_source_edited(instance_id: string, value: string);
    callback ui_asset_source_cursor_changed(instance_id: string, byte_offset: int);
    callback ui_asset_palette_drag_hover(instance_id: string, surface_x: float, surface_y: float);
    callback ui_asset_palette_drag_drop(instance_id: string);
    callback ui_asset_palette_drag_cancel(instance_id: string);
    callback ui_asset_palette_target_confirm(instance_id: string);
    callback ui_asset_palette_target_cancel(instance_id: string);
}

export component PaneSurface inherits Rectangle {
    in property <PaneData> pane;
    in property <string> project_path;
    in property <WelcomePaneData> welcome_pane <=> PaneSurfaceHostContext.welcome_pane;
    in property <[RecentProjectData]> recent_projects <=> PaneSurfaceHostContext.recent_projects;
    in property <int> hovered_welcome_recent_index <=> PaneSurfaceHostContext.hovered_welcome_recent_index;
    in property <int> hovered_welcome_recent_action <=> PaneSurfaceHostContext.hovered_welcome_recent_action;
    in property <float> welcome_recent_scroll_px <=> PaneSurfaceHostContext.welcome_recent_scroll_px;
    in property <[SceneNodeData]> hierarchy_nodes <=> PaneSurfaceHostContext.hierarchy_nodes;
    in property <int> hovered_hierarchy_index <=> PaneSurfaceHostContext.hovered_hierarchy_index;
    in property <float> hierarchy_scroll_px <=> PaneSurfaceHostContext.hierarchy_scroll_px;
    in property <ProjectOverviewData> project_overview <=> PaneSurfaceHostContext.project_overview;
    in property <[AssetFolderData]> activity_asset_tree_folders <=> PaneSurfaceHostContext.activity_asset_tree_folders;
    in property <[AssetFolderData]> activity_asset_content_folders <=> PaneSurfaceHostContext.activity_asset_content_folders;
    in property <[AssetItemData]> activity_asset_content_items <=> PaneSurfaceHostContext.activity_asset_content_items;
    in property <AssetSelectionData> activity_asset_selection <=> PaneSurfaceHostContext.activity_asset_selection;
    in property <[AssetReferenceData]> activity_asset_references <=> PaneSurfaceHostContext.activity_asset_references;
    in property <[AssetReferenceData]> activity_asset_used_by <=> PaneSurfaceHostContext.activity_asset_used_by;
    in property <string> activity_asset_search_query <=> PaneSurfaceHostContext.activity_asset_search_query;
    in property <string> activity_asset_kind_filter <=> PaneSurfaceHostContext.activity_asset_kind_filter;
    in property <string> activity_asset_view_mode <=> PaneSurfaceHostContext.activity_asset_view_mode;
    in property <string> activity_asset_utility_tab <=> PaneSurfaceHostContext.activity_asset_utility_tab;
    in property <int> activity_asset_tree_hovered_index <=> PaneSurfaceHostContext.activity_asset_tree_hovered_index;
    in property <float> activity_asset_tree_scroll_px <=> PaneSurfaceHostContext.activity_asset_tree_scroll_px;
    in property <int> activity_asset_content_hovered_index <=> PaneSurfaceHostContext.activity_asset_content_hovered_index;
    in property <float> activity_asset_content_scroll_px <=> PaneSurfaceHostContext.activity_asset_content_scroll_px;
    in property <int> activity_asset_references_hovered_index <=> PaneSurfaceHostContext.activity_asset_references_hovered_index;
    in property <float> activity_asset_references_scroll_px <=> PaneSurfaceHostContext.activity_asset_references_scroll_px;
    in property <int> activity_asset_used_by_hovered_index <=> PaneSurfaceHostContext.activity_asset_used_by_hovered_index;
    in property <float> activity_asset_used_by_scroll_px <=> PaneSurfaceHostContext.activity_asset_used_by_scroll_px;
    in property <[AssetFolderData]> browser_asset_tree_folders <=> PaneSurfaceHostContext.browser_asset_tree_folders;
    in property <[AssetFolderData]> browser_asset_content_folders <=> PaneSurfaceHostContext.browser_asset_content_folders;
    in property <[AssetItemData]> browser_asset_content_items <=> PaneSurfaceHostContext.browser_asset_content_items;
    in property <AssetSelectionData> browser_asset_selection <=> PaneSurfaceHostContext.browser_asset_selection;
    in property <[AssetReferenceData]> browser_asset_references <=> PaneSurfaceHostContext.browser_asset_references;
    in property <[AssetReferenceData]> browser_asset_used_by <=> PaneSurfaceHostContext.browser_asset_used_by;
    in property <string> browser_asset_search_query <=> PaneSurfaceHostContext.browser_asset_search_query;
    in property <string> browser_asset_kind_filter <=> PaneSurfaceHostContext.browser_asset_kind_filter;
    in property <string> browser_asset_view_mode <=> PaneSurfaceHostContext.browser_asset_view_mode;
    in property <string> browser_asset_utility_tab <=> PaneSurfaceHostContext.browser_asset_utility_tab;
    in property <int> browser_asset_tree_hovered_index <=> PaneSurfaceHostContext.browser_asset_tree_hovered_index;
    in property <float> browser_asset_tree_scroll_px <=> PaneSurfaceHostContext.browser_asset_tree_scroll_px;
    in property <int> browser_asset_content_hovered_index <=> PaneSurfaceHostContext.browser_asset_content_hovered_index;
    in property <float> browser_asset_content_scroll_px <=> PaneSurfaceHostContext.browser_asset_content_scroll_px;
    in property <int> browser_asset_references_hovered_index <=> PaneSurfaceHostContext.browser_asset_references_hovered_index;
    in property <float> browser_asset_references_scroll_px <=> PaneSurfaceHostContext.browser_asset_references_scroll_px;
    in property <int> browser_asset_used_by_hovered_index <=> PaneSurfaceHostContext.browser_asset_used_by_hovered_index;
    in property <float> browser_asset_used_by_scroll_px <=> PaneSurfaceHostContext.browser_asset_used_by_scroll_px;
    in property <float> browser_asset_details_scroll_px <=> PaneSurfaceHostContext.browser_asset_details_scroll_px;
    in property <image> viewport_image <=> PaneSurfaceHostContext.viewport_image;
    in property <string> inspector_name <=> PaneSurfaceHostContext.inspector_name;
    in property <string> inspector_parent <=> PaneSurfaceHostContext.inspector_parent;
    in property <string> inspector_x <=> PaneSurfaceHostContext.inspector_x;
    in property <string> inspector_y <=> PaneSurfaceHostContext.inspector_y;
    in property <string> inspector_z <=> PaneSurfaceHostContext.inspector_z;
    in property <float> inspector_scroll_px <=> PaneSurfaceHostContext.inspector_scroll_px;
    in property <string> status_text <=> PaneSurfaceHostContext.status_text;
    in property <float> console_scroll_px <=> PaneSurfaceHostContext.console_scroll_px;
    in property <bool> delete_enabled <=> PaneSurfaceHostContext.delete_enabled;
    in-out property <string> mesh_import_path <=> PaneSurfaceHostContext.mesh_import_path;
    callback asset_control_changed(source: string, control_id: string, value: string);
    callback asset_control_clicked(source: string, control_id: string);
    callback welcome_control_changed(control_id: string, value: string);
    callback welcome_control_clicked(control_id: string);
    callback viewport_toolbar_pointer_clicked(surface_key: string, control_id: string, control_x: float, control_y: float, control_width: float, control_height: float, point_x: float, point_y: float);
    in property <bool> show_header: true;
    in property <bool> compact_empty: true;
    out property <float> viewport_width: root.pane.kind == "Scene" || root.pane.kind == "Game" ? self.width / 1px : 0.0;
    out property <float> viewport_height:
        root.pane.kind == "Scene" || root.pane.kind == "Game" ?
        (self.height - root.chrome_height - root.viewport_toolbar_height) / 1px :
        0.0;

    palette := Palette {}
    background: transparent;
    clip: true;
    property <length> chrome_height: root.show_header ? 34px : 0px;
    property <length> viewport_toolbar_height: root.pane.kind == "Scene" ? 28px : 0px;
    property <string> empty_eyebrow:
        root.pane.kind == "Scene" || root.pane.kind == "Game" ? "Welcome" :
        root.pane.kind == "Project" || root.pane.kind == "Assets" ? "Workspace" :
        root.pane.kind == "Console" ? "Task Output" :
        "";

    if root.show_header: Rectangle {
        width: parent.width;
        height: 34px;
        background: palette.panel_bg_soft;
        border-color: palette.border_soft;
        border-width: 1px;

        ShellIcon {
            width: 14px;
            height: 14px;
            x: 10px;
            y: 10px;
            icon_key: root.pane.icon_key;
            icon_color: palette.text_muted;
        }

        Text {
            x: 30px;
            y: 7px;
            text: root.pane.title;
            color: palette.text;
            font-size: 12px;
            font-weight: 600;
        }

        Text {
            x: parent.width - self.preferred-width - 12px;
            y: 8px;
            text: root.pane.subtitle;
            color: palette.text_dim;
            font-size: 11px;
        }
    }

    if root.pane.kind == "Welcome": WelcomePane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        welcome: root.welcome_pane;
        recent_projects: root.recent_projects;
        hovered_recent_project_index: root.hovered_welcome_recent_index;
        hovered_recent_action: root.hovered_welcome_recent_action;
        recent_projects_scroll_px: root.welcome_recent_scroll_px;
        control_changed(control_id, value) => { root.welcome_control_changed(control_id, value); }
        control_clicked(control_id) => { root.welcome_control_clicked(control_id); }
        recent_projects_pointer_clicked(x, y, width, height) => { PaneSurfaceHostContext.welcome_recent_pointer_clicked(x, y, width, height); }
        recent_projects_pointer_moved(x, y, width, height) => { PaneSurfaceHostContext.welcome_recent_pointer_moved(x, y, width, height); }
        recent_projects_pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.welcome_recent_pointer_scrolled(x, y, delta, width, height); }
    }

    if root.pane.kind == "Scene" || root.pane.kind == "Game": Rectangle {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        background: #1c1f24;
        clip: true;

        if root.pane.kind == "Scene": SceneViewportToolbar {
            width: parent.width;
            viewport: root.pane.viewport;
            pointer_clicked(control_id, control_x, control_y, control_width, control_height, point_x, point_y) => { root.viewport_toolbar_pointer_clicked(root.pane.id, control_id, control_x, control_y, control_width, control_height, point_x, point_y); }
        }

        viewport_canvas := Rectangle {
            y: root.viewport_toolbar_height;
            width: parent.width;
            height: parent.height - root.viewport_toolbar_height;
            background: #171a20;
            clip: true;

            if !root.pane.show_empty: Rectangle {
                x: 0px;
                y: parent.height / 2;
                width: parent.width;
                height: 1px;
                background: #ffffff09;
            }

            if !root.pane.show_empty: Rectangle {
                x: parent.width / 2;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: #ffffff09;
            }

            if !root.pane.show_empty: Image {
                width: parent.width;
                height: parent.height;
                source: root.viewport_image;
                image-fit: contain;
            }

            if !root.pane.show_empty: Rectangle {
                x: 10px;
                y: 10px;
                width: 94px;
                height: 18px;
                border-radius: 3px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: #1d2027dd;
                Text {
                    text: root.pane.subtitle;
                    x: 8px;
                    y: 2px;
                    color: palette.text;
                    font-size: 10px;
                }
            }

            if root.pane.show_empty: EmptyStateCard {
                width: parent.width;
                height: parent.height;
                compact: false;
                eyebrow: root.empty_eyebrow;
                title: root.pane.empty_title;
                body: root.pane.empty_body;
                primary_action_label: root.pane.primary_action_label;
                primary_action_id: root.pane.primary_action_id;
                secondary_action_label: root.pane.secondary_action_label;
                secondary_action_id: root.pane.secondary_action_id;
                secondary_hint: root.pane.secondary_hint;
                trigger_action(action_id) => { PaneSurfaceHostContext.surface_control_clicked("TriggerAction", action_id); }
            }

            viewport_touch := TouchArea {
                enabled: !root.pane.show_empty;
                width: parent.width;
                height: parent.height;
                mouse-cursor: crosshair;
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        PaneSurfaceHostContext.viewport_pointer_event(0, 1, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                        PaneSurfaceHostContext.viewport_pointer_event(2, 1, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                        PaneSurfaceHostContext.viewport_pointer_event(0, 2, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.up) {
                        PaneSurfaceHostContext.viewport_pointer_event(2, 2, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.middle && event.kind == PointerEventKind.down) {
                        PaneSurfaceHostContext.viewport_pointer_event(0, 3, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.middle && event.kind == PointerEventKind.up) {
                        PaneSurfaceHostContext.viewport_pointer_event(2, 3, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    }
                }
                moved => {
                    PaneSurfaceHostContext.viewport_pointer_event(1, 0, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                }
                scroll-event(event) => {
                    PaneSurfaceHostContext.viewport_pointer_event(3, 0, self.mouse-x / 1px, self.mouse-y / 1px, event.delta_y / 1px);
                    accept
                }
            }
        }
    }

    if !(root.pane.kind == "Scene" || root.pane.kind == "Game") && root.pane.show_empty && root.pane.kind != "Console" && root.compact_empty: ToolWindowEmptyState {
        width: parent.width;
        height: parent.height - root.chrome_height;
        y: root.chrome_height;
        eyebrow: root.empty_eyebrow;
        title: root.pane.empty_title;
        body: root.pane.empty_body;
        primary_action_label: root.pane.primary_action_label;
        primary_action_id: root.pane.primary_action_id;
        secondary_hint: root.pane.secondary_hint;
        trigger_action(action_id) => { PaneSurfaceHostContext.surface_control_clicked("TriggerAction", action_id); }
    }

    if !(root.pane.kind == "Scene" || root.pane.kind == "Game") && root.pane.show_empty && root.pane.kind != "Console" && !root.compact_empty: EmptyStateCard {
        width: parent.width;
        height: parent.height - root.chrome_height;
        y: root.chrome_height;
        compact: false;
        eyebrow: root.empty_eyebrow;
        title: root.pane.empty_title;
        body: root.pane.empty_body;
        primary_action_label: root.pane.primary_action_label;
        primary_action_id: root.pane.primary_action_id;
        secondary_action_label: root.pane.secondary_action_label;
        secondary_action_id: root.pane.secondary_action_id;
        secondary_hint: root.pane.secondary_hint;
        trigger_action(action_id) => { PaneSurfaceHostContext.surface_control_clicked("TriggerAction", action_id); }
    }

    if !root.pane.show_empty && root.pane.kind == "Project": ProjectOverviewPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        project: root.project_overview;
        surface_control_clicked(control_id, action_id) => { PaneSurfaceHostContext.surface_control_clicked(control_id, action_id); }
        asset_control_clicked(control_id) => { root.asset_control_clicked("project", control_id); }
    }

    if !root.pane.show_empty && root.pane.kind == "Assets": AssetsActivityPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        folder_tree: root.activity_asset_tree_folders;
        content_folders: root.activity_asset_content_folders;
        content_items: root.activity_asset_content_items;
        selection: root.activity_asset_selection;
        references: root.activity_asset_references;
        used_by: root.activity_asset_used_by;
        search_query: root.activity_asset_search_query;
        kind_filter: root.activity_asset_kind_filter;
        view_mode: root.activity_asset_view_mode;
        utility_tab: root.activity_asset_utility_tab;
        tree_hovered_index: root.activity_asset_tree_hovered_index;
        tree_scroll_px: root.activity_asset_tree_scroll_px;
        content_hovered_index: root.activity_asset_content_hovered_index;
        content_scroll_px: root.activity_asset_content_scroll_px;
        references_hovered_index: root.activity_asset_references_hovered_index;
        references_scroll_px: root.activity_asset_references_scroll_px;
        used_by_hovered_index: root.activity_asset_used_by_hovered_index;
        used_by_scroll_px: root.activity_asset_used_by_scroll_px;
        control_changed(control_id, value) => { root.asset_control_changed("activity", control_id, value); }
        control_clicked(control_id) => { root.asset_control_clicked("activity", control_id); }
        tree_pointer_clicked(x, y, width, height) => { PaneSurfaceHostContext.asset_tree_pointer_clicked("activity", x, y, width, height); }
        tree_pointer_moved(x, y, width, height) => { PaneSurfaceHostContext.asset_tree_pointer_moved("activity", x, y, width, height); }
        tree_pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.asset_tree_pointer_scrolled("activity", x, y, delta, width, height); }
        content_pointer_clicked(x, y, width, height) => { PaneSurfaceHostContext.asset_content_pointer_clicked("activity", x, y, width, height); }
        content_pointer_moved(x, y, width, height) => { PaneSurfaceHostContext.asset_content_pointer_moved("activity", x, y, width, height); }
        content_pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.asset_content_pointer_scrolled("activity", x, y, delta, width, height); }
        reference_pointer_clicked(list_kind, x, y, width, height) => { PaneSurfaceHostContext.asset_reference_pointer_clicked("activity", list_kind, x, y, width, height); }
        reference_pointer_moved(list_kind, x, y, width, height) => { PaneSurfaceHostContext.asset_reference_pointer_moved("activity", list_kind, x, y, width, height); }
        reference_pointer_scrolled(list_kind, x, y, delta, width, height) => { PaneSurfaceHostContext.asset_reference_pointer_scrolled("activity", list_kind, x, y, delta, width, height); }
    }

    if !root.pane.show_empty && root.pane.kind == "AssetBrowser": AssetBrowserPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        project: root.project_overview;
        folder_tree: root.browser_asset_tree_folders;
        content_folders: root.browser_asset_content_folders;
        content_items: root.browser_asset_content_items;
        selection: root.browser_asset_selection;
        references: root.browser_asset_references;
        used_by: root.browser_asset_used_by;
        search_query: root.browser_asset_search_query;
        kind_filter: root.browser_asset_kind_filter;
        view_mode: root.browser_asset_view_mode;
        utility_tab: root.browser_asset_utility_tab;
        tree_hovered_index: root.browser_asset_tree_hovered_index;
        tree_scroll_px: root.browser_asset_tree_scroll_px;
        content_hovered_index: root.browser_asset_content_hovered_index;
        content_scroll_px: root.browser_asset_content_scroll_px;
        references_hovered_index: root.browser_asset_references_hovered_index;
        references_scroll_px: root.browser_asset_references_scroll_px;
        used_by_hovered_index: root.browser_asset_used_by_hovered_index;
        used_by_scroll_px: root.browser_asset_used_by_scroll_px;
        details_scroll_px: root.browser_asset_details_scroll_px;
        mesh_import_path: root.mesh_import_path;
        control_changed(control_id, value) => { root.asset_control_changed("browser", control_id, value); }
        control_clicked(control_id) => { root.asset_control_clicked("browser", control_id); }
        tree_pointer_clicked(x, y, width, height) => { PaneSurfaceHostContext.asset_tree_pointer_clicked("browser", x, y, width, height); }
        tree_pointer_moved(x, y, width, height) => { PaneSurfaceHostContext.asset_tree_pointer_moved("browser", x, y, width, height); }
        tree_pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.asset_tree_pointer_scrolled("browser", x, y, delta, width, height); }
        content_pointer_clicked(x, y, width, height) => { PaneSurfaceHostContext.asset_content_pointer_clicked("browser", x, y, width, height); }
        content_pointer_moved(x, y, width, height) => { PaneSurfaceHostContext.asset_content_pointer_moved("browser", x, y, width, height); }
        content_pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.asset_content_pointer_scrolled("browser", x, y, delta, width, height); }
        reference_pointer_clicked(list_kind, x, y, width, height) => { PaneSurfaceHostContext.asset_reference_pointer_clicked("browser", list_kind, x, y, width, height); }
        reference_pointer_moved(list_kind, x, y, width, height) => { PaneSurfaceHostContext.asset_reference_pointer_moved("browser", list_kind, x, y, width, height); }
        reference_pointer_scrolled(list_kind, x, y, delta, width, height) => { PaneSurfaceHostContext.asset_reference_pointer_scrolled("browser", list_kind, x, y, delta, width, height); }
        details_pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.browser_asset_details_pointer_scrolled(x, y, delta, width, height); }
        mesh_import_path_edited(value) => { PaneSurfaceHostContext.mesh_import_path_edited(value); }
    }

    if !root.pane.show_empty && root.pane.kind == "Hierarchy": HierarchyPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        hierarchy_nodes: root.hierarchy_nodes;
        hovered_index: root.hovered_hierarchy_index;
        scroll_px: root.hierarchy_scroll_px;
        pointer_clicked(x, y, width, height) => { PaneSurfaceHostContext.hierarchy_pointer_clicked(x, y, width, height); }
        pointer_moved(x, y, width, height) => { PaneSurfaceHostContext.hierarchy_pointer_moved(x, y, width, height); }
        pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.hierarchy_pointer_scrolled(x, y, delta, width, height); }
    }

    if !root.pane.show_empty && root.pane.kind == "Inspector": InspectorPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        info: root.pane.info;
        inspector_name: root.inspector_name;
        inspector_parent: root.inspector_parent;
        inspector_x: root.inspector_x;
        inspector_y: root.inspector_y;
        inspector_z: root.inspector_z;
        scroll_px: root.inspector_scroll_px;
        delete_enabled: root.delete_enabled;
        pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.inspector_pointer_scrolled(x, y, delta, width, height); }
        control_changed(control_id, value) => { PaneSurfaceHostContext.inspector_control_changed(control_id, value); }
        control_clicked(control_id) => { PaneSurfaceHostContext.inspector_control_clicked(control_id); }
    }

    if root.pane.kind == "Console": ConsolePane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        show_empty: root.pane.show_empty;
        empty_title: root.pane.empty_title;
        empty_body: root.pane.empty_body;
        status_text: root.status_text;
        scroll_px: root.console_scroll_px;
        pointer_scrolled(x, y, delta, width, height) => { PaneSurfaceHostContext.console_pointer_scrolled(x, y, delta, width, height); }
    }

    if !root.pane.show_empty && root.pane.kind == "UiAssetEditor": UiAssetEditorPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        pane: root.pane.ui_asset;
        action(action_id) => { PaneSurfaceHostContext.ui_asset_action(root.pane.id, action_id); }
        style_class_action(action_id, class_name) => { PaneSurfaceHostContext.ui_asset_style_class_action(root.pane.id, action_id, class_name); }
        detail_event(detail_id, action_id, item_index, primary, secondary) => { PaneSurfaceHostContext.ui_asset_detail_event(root.pane.id, detail_id, action_id, item_index, primary, secondary); }
        source_edited(value) => { PaneSurfaceHostContext.ui_asset_source_edited(root.pane.id, value); }
        source_cursor_changed(byte_offset) => { PaneSurfaceHostContext.ui_asset_source_cursor_changed(root.pane.id, byte_offset); }
        collection_event(collection_id, event_kind, item_index) => { PaneSurfaceHostContext.ui_asset_collection_event(root.pane.id, collection_id, event_kind, item_index); }
        palette_drag_hovered(surface_x, surface_y) => { PaneSurfaceHostContext.ui_asset_palette_drag_hover(root.pane.id, surface_x, surface_y); }
        palette_drag_dropped() => { PaneSurfaceHostContext.ui_asset_palette_drag_drop(root.pane.id); }
        palette_drag_cancelled() => { PaneSurfaceHostContext.ui_asset_palette_drag_cancel(root.pane.id); }
        palette_target_confirm() => { PaneSurfaceHostContext.ui_asset_palette_target_confirm(root.pane.id); }
        palette_target_cancel() => { PaneSurfaceHostContext.ui_asset_palette_target_cancel(root.pane.id); }
    }

    if !root.pane.show_empty && !(root.pane.kind == "Project" || root.pane.kind == "Assets" || root.pane.kind == "Hierarchy" || root.pane.kind == "Inspector" || root.pane.kind == "Scene" || root.pane.kind == "Game" || root.pane.kind == "Console" || root.pane.kind == "AssetBrowser" || root.pane.kind == "UiAssetEditor"): FallbackPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        compact: root.compact_empty;
        title: root.pane.title;
        body: root.pane.info;
        hint: root.pane.subtitle;
    }
}

