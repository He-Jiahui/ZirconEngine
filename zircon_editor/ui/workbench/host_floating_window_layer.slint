import { Palette, TabChip } from "chrome.slint";
import { HostFloatingWindowLayerData } from "host_components.slint";
import { UiHostContext } from "host_context.slint";
import { PaneSurface } from "pane_surface.slint";

export component HostFloatingWindowLayer inherits Rectangle {
    in property <HostFloatingWindowLayerData> layer_data;
    palette := Palette {}
    background: transparent;

    for window[index] in root.layer_data.floating_windows: floating_window_card := Rectangle {
        property <bool> attach_drop_active: UiHostContext.drag_state.active_drag_target_group == window.target_group;
        property <bool> left_edge_drop_active: UiHostContext.drag_state.active_drag_target_group == window.left_edge_target_group;
        property <bool> right_edge_drop_active: UiHostContext.drag_state.active_drag_target_group == window.right_edge_target_group;
        property <bool> top_edge_drop_active: UiHostContext.drag_state.active_drag_target_group == window.top_edge_target_group;
        property <bool> bottom_edge_drop_active: UiHostContext.drag_state.active_drag_target_group == window.bottom_edge_target_group;
        property <bool> any_drop_active:
            attach_drop_active ||
            left_edge_drop_active ||
            right_edge_drop_active ||
            top_edge_drop_active ||
            bottom_edge_drop_active;
        x: window.frame.x * 1px;
        y: window.frame.y * 1px;
        width: window.frame.width * 1px;
        height: window.frame.height * 1px;
        border-radius: 8px;
        border-width: 1px;
        border-color: any_drop_active ? palette.accent : palette.border_soft;
        background: any_drop_active ? #223448f0 : #20242be8;
        clip: true;

        Rectangle {
            width: parent.width;
            height: parent.height;
            border-radius: 8px;
            background: transparent;

            VerticalLayout {
                spacing: 0px;

                Rectangle {
                    height: root.layer_data.header_height_px * 1px;
                    background: palette.chrome_bg;

                    header_touch := TouchArea {
                        x: max(parent.width - 170px, floating_tabs_row.x + floating_tabs_row.width + 8px);
                        width: max(parent.width - self.x, 0px);
                        height: parent.height;
                        clicked => {
                            UiHostContext.floating_window_header_pointer_clicked(
                                floating_window_card.x / 1px + self.x / 1px + self.mouse-x / 1px,
                                floating_window_card.y / 1px + self.mouse-y / 1px,
                            );
                        }
                    }

                    floating_tabs_row := HorizontalLayout {
                        x: 8px;
                        y: 1px;
                        spacing: 2px;
                        for tab[index] in window.tabs: TabChip {
                            label: tab.title;
                            icon_key: tab.icon_key;
                            active: tab.active;
                            closeable: tab.closeable;
                            drag_origin_x: (floating_window_card.x + floating_tabs_row.x + self.x) / 1px;
                            drag_origin_y: (floating_window_card.y + floating_tabs_row.y + self.y) / 1px;
                            pointer_clicked(x, y) => {
                                UiHostContext.document_tab_pointer_clicked(
                                    window.window_id,
                                    index,
                                    8.0 + self.x / 1px,
                                    self.width / 1px,
                                    8.0 + self.x / 1px + x,
                                    1.0 + self.y / 1px + y,
                                );
                            }
                            close_pointer_clicked(x, y) => {
                                UiHostContext.document_tab_close_pointer_clicked(
                                    window.window_id,
                                    index,
                                    8.0 + self.x / 1px,
                                    self.width / 1px,
                                    8.0 + self.x / 1px + self.width / 1px - 24.0 + x,
                                    1.0 + self.y / 1px + 7.0 + y,
                                );
                            }
                            drag_started(x, y) => {
                                UiHostContext.drag_state = {
                                    active_drag_target_group: UiHostContext.drag_state.active_drag_target_group,
                                    drag_active: true,
                                    drag_tab_id: tab.id,
                                    drag_tab_title: tab.title,
                                    drag_tab_icon_key: tab.icon_key,
                                    drag_source_group: window.window_id,
                                    drag_pointer_x: x,
                                    drag_pointer_y: y,
                                };
                                UiHostContext.host_drag_pointer_event(
                                    1,
                                    UiHostContext.drag_state.drag_pointer_x,
                                    UiHostContext.drag_state.drag_pointer_y,
                                );
                            }
                            drag_moved(x, y) => {
                                if (UiHostContext.drag_state.drag_tab_id == tab.id) {
                                    UiHostContext.drag_state = {
                                        active_drag_target_group: UiHostContext.drag_state.active_drag_target_group,
                                        drag_active: UiHostContext.drag_state.drag_active,
                                        drag_tab_id: UiHostContext.drag_state.drag_tab_id,
                                        drag_tab_title: UiHostContext.drag_state.drag_tab_title,
                                        drag_tab_icon_key: UiHostContext.drag_state.drag_tab_icon_key,
                                        drag_source_group: UiHostContext.drag_state.drag_source_group,
                                        drag_pointer_x: x,
                                        drag_pointer_y: y,
                                    };
                                    UiHostContext.host_drag_pointer_event(
                                        1,
                                        UiHostContext.drag_state.drag_pointer_x,
                                        UiHostContext.drag_state.drag_pointer_y,
                                    );
                                }
                            }
                        }
                    }

                    Text {
                        x: parent.width - 170px;
                        y: 9px;
                        width: 158px;
                        horizontal-alignment: right;
                        text: window.title;
                        color: palette.text_dim;
                        font-size: 10px;
                        overflow: elide;
                    }
                }

                Rectangle { height: 1px; background: palette.border_soft; }

                PaneSurface {
                    width: parent.width;
                    height: parent.height - root.layer_data.header_height_px * 1px - 1px;
                    pane: window.active_pane;
                    show_header: false;
                    compact_empty: false;
                }
            }

            if left_edge_drop_active: Rectangle {
                x: 12px;
                y: 34px;
                width: min(max(72px, parent.width * 0.24), parent.width * 0.45);
                height: max(parent.height - 68px, 56px);
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.accent;
                background: #2c527955;
            }

            if right_edge_drop_active: Rectangle {
                x: parent.width - self.width - 12px;
                y: 34px;
                width: min(max(72px, parent.width * 0.24), parent.width * 0.45);
                height: max(parent.height - 68px, 56px);
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.accent;
                background: #2c527955;
            }

            if top_edge_drop_active: Rectangle {
                x: 12px;
                y: 34px;
                width: max(parent.width - 24px, 56px);
                height: min(max(54px, parent.height * 0.2), parent.height * 0.4);
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.accent;
                background: #2c527955;
            }

            if bottom_edge_drop_active: Rectangle {
                x: 12px;
                y: parent.height - self.height - 12px;
                width: max(parent.width - 24px, 56px);
                height: min(max(54px, parent.height * 0.2), parent.height * 0.4);
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.accent;
                background: #2c527955;
            }
        }
    }
}
