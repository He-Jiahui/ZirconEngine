import { Palette } from "chrome.slint";

export struct AnimationEditorPaneData {
    mode: string,
    asset_path: string,
    status: string,
    selection: string,
    current_frame: int,
    timeline_start_frame: int,
    timeline_end_frame: int,
    playback_label: string,
    track_items: [string],
    parameter_items: [string],
    node_items: [string],
    state_items: [string],
    transition_items: [string],
}

component AnimationListSection inherits Rectangle {
    in property <string> title;
    in property <[string]> items;

    height: title_text.height + (root.items.length > 0 ? root.items.length * 20px : 20px) + 8px;
    background: transparent;

    title_text := Text {
        x: 0px;
        y: 0px;
        text: root.title;
        color: palette.text;
        font-size: 11px;
    }

    item_column := Rectangle {
        x: 0px;
        y: title_text.height + 4px;
        width: parent.width;
        height: parent.height - self.y;
        background: transparent;

        VerticalLayout {
            x: 0px;
            y: 0px;
            width: parent.width;
            spacing: 2px;

            for item[index] in root.items: item_row := Rectangle {
                height: 18px;
                border-radius: 3px;
                background: palette.panel_bg_soft;

                Text {
                    x: 8px;
                    y: 2px;
                    width: parent.width - 16px;
                    height: parent.height - 4px;
                    text: item;
                    color: palette.text_muted;
                    font-size: 11px;
                    overflow: elide;
                }
            }

            if root.items.length == 0: Rectangle {
                height: 18px;
                Text {
                    width: parent.width;
                    height: parent.height;
                    text: "No Items";
                    color: palette.text_dim;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
    }

    palette := Palette {}
}

export component AnimationEditorPane inherits Rectangle {
    in property <AnimationEditorPaneData> pane;

    palette := Palette {}
    background: palette.panel_bg;
    clip: true;

    header := Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 64px;
        background: palette.panel_bg_soft;

        mode_text := Text {
            x: 12px;
            y: 10px;
            text: root.pane.mode;
            color: palette.accent;
            font-size: 11px;
        }

        path_text := Text {
            x: 12px;
            y: 26px;
            width: parent.width - 24px;
            text: root.pane.asset_path;
            color: palette.text;
            font-size: 12px;
            overflow: elide;
        }

        status_text := Text {
            x: 12px;
            y: 44px;
            width: parent.width - 24px;
            text:
                root.pane.status != "" ? root.pane.status :
                root.pane.selection != "" ? root.pane.selection :
                root.pane.playback_label;
            color: palette.text_muted;
            font-size: 11px;
            overflow: elide;
        }

        Rectangle {
            x: 0px;
            y: parent.height - 1px;
            width: parent.width;
            height: 1px;
            background: palette.border_soft;
        }
    }

    body := Rectangle {
        x: 0px;
        y: 64px;
        width: parent.width;
        height: parent.height - 64px;
        background: palette.panel_bg;
        clip: true;

        if root.pane.mode == "sequence": Rectangle {
            x: 12px;
            y: 12px;
            width: parent.width - 24px;
            height: parent.height - 24px;

            timeline_text := Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                text: "Frame " + root.pane.current_frame + " • Range " + root.pane.timeline_start_frame + ".." + root.pane.timeline_end_frame + " • " + root.pane.playback_label;
                color: palette.text;
                font-size: 11px;
                overflow: elide;
            }

            selection_text := Text {
                x: 0px;
                y: 18px;
                width: parent.width;
                text:
                    root.pane.selection != "" ? root.pane.selection :
                    root.pane.playback_label != "" ? root.pane.playback_label :
                    "No timeline selection";
                color: palette.text_muted;
                font-size: 11px;
                overflow: elide;
            }

            AnimationListSection {
                x: 0px;
                y: 44px;
                width: parent.width;
                title: "Tracks";
                items: root.pane.track_items;
            }
        }

        if root.pane.mode == "graph": Rectangle {
            x: 12px;
            y: 12px;
            width: parent.width - 24px;
            height: parent.height - 24px;

            AnimationListSection {
                x: 0px;
                y: 0px;
                width: parent.width;
                title: "Parameters";
                items: root.pane.parameter_items;
            }

            AnimationListSection {
                x: 0px;
                y: 140px;
                width: parent.width;
                title: "Nodes";
                items: root.pane.node_items;
            }
        }

        if root.pane.mode == "state_machine": Rectangle {
            x: 12px;
            y: 12px;
            width: parent.width - 24px;
            height: parent.height - 24px;

            entry_text := Text {
                x: 0px;
                y: 0px;
                width: parent.width;
                text: "Entry: " + root.pane.selection;
                color: palette.text;
                font-size: 11px;
                overflow: elide;
            }

            AnimationListSection {
                x: 0px;
                y: 24px;
                width: parent.width;
                title: "States";
                items: root.pane.state_items;
            }

            AnimationListSection {
                x: 0px;
                y: 148px;
                width: parent.width;
                title: "Transitions";
                items: root.pane.transition_items;
            }
        }
    }
}
