import { DockTabButton, Palette, RailButton } from "chrome.slint";
import { HostSideDockSurfaceData } from "host_components.slint";
import { WorkbenchHostContext } from "host_context.slint";
import { PaneSurface } from "pane_surface.slint";

export component HostSideDockSurface inherits Rectangle {
    in property <HostSideDockSurfaceData> surface_data;
    palette := Palette {}
    property <bool> show_panel: root.surface_data.panel_width_px > 0.0;
    x: root.surface_data.region_frame.x * 1px;
    y: root.surface_data.region_frame.y * 1px;
    width: root.surface_data.region_frame.width * 1px;
    height: root.surface_data.region_frame.height * 1px;
    background: transparent;
    clip: true;

    HorizontalLayout {
        spacing: 0px;

        if root.surface_data.rail_before_panel: Rectangle {
            width: root.surface_data.rail_width_px * 1px;
            background: palette.rail_bg;

            VerticalLayout {
                x: 3px;
                y: 6px;
                spacing: 2px;
                for tab in root.surface_data.tabs: RailButton {
                    icon_key: tab.icon_key;
                    active: tab.active;
                    pointer_pressed(x, y) => {
                        WorkbenchHostContext.activity_rail_pointer_clicked(
                            root.surface_data.surface_key,
                            self.x / 1px + x,
                            self.y / 1px + y,
                        );
                    }
                }
            }
        }

        if root.surface_data.rail_before_panel && root.show_panel: Rectangle {
            width: 1px;
            background: palette.border_soft;
        }

        if root.show_panel: Rectangle {
            width: root.surface_data.panel_width_px * 1px;
            background: palette.panel_bg;

            VerticalLayout {
                spacing: 0px;

                Rectangle {
                    height: root.surface_data.panel_header_height_px * 1px;
                    background: palette.chrome_bg;

                    HorizontalLayout {
                        x: 6px;
                        y: 2px;
                        spacing: 4px;
                        for tab[index] in root.surface_data.tabs: DockTabButton {
                            label: tab.title;
                            icon_key: tab.icon_key;
                            active: tab.active;
                            drag_enabled: true;
                            drag_origin_x: (root.surface_data.tab_origin_x_px * 1px + self.x) / 1px;
                            drag_origin_y: (root.surface_data.tab_origin_y_px * 1px + self.y) / 1px;
                            pointer_clicked(x, y) => {
                                WorkbenchHostContext.drawer_header_pointer_clicked(
                                    root.surface_data.surface_key,
                                    index,
                                    6.0 + self.x / 1px,
                                    self.width / 1px,
                                    6.0 + self.x / 1px + x,
                                    2.0 + self.y / 1px + y,
                                );
                            }
                            drag_started(x, y) => {
                                WorkbenchHostContext.drag_state = {
                                    active_drag_target_group: WorkbenchHostContext.drag_state.active_drag_target_group,
                                    drag_active: true,
                                    drag_tab_id: tab.id,
                                    drag_tab_title: tab.title,
                                    drag_tab_icon_key: tab.icon_key,
                                    drag_source_group: root.surface_data.surface_key,
                                    drag_pointer_x: x,
                                    drag_pointer_y: y,
                                };
                                WorkbenchHostContext.workbench_drag_pointer_event(
                                    1,
                                    WorkbenchHostContext.drag_state.drag_pointer_x,
                                    WorkbenchHostContext.drag_state.drag_pointer_y,
                                );
                            }
                            drag_moved(x, y) => {
                                if (WorkbenchHostContext.drag_state.drag_tab_id == tab.id) {
                                    WorkbenchHostContext.drag_state = {
                                        active_drag_target_group: WorkbenchHostContext.drag_state.active_drag_target_group,
                                        drag_active: WorkbenchHostContext.drag_state.drag_active,
                                        drag_tab_id: WorkbenchHostContext.drag_state.drag_tab_id,
                                        drag_tab_title: WorkbenchHostContext.drag_state.drag_tab_title,
                                        drag_tab_icon_key: WorkbenchHostContext.drag_state.drag_tab_icon_key,
                                        drag_source_group: WorkbenchHostContext.drag_state.drag_source_group,
                                        drag_pointer_x: x,
                                        drag_pointer_y: y,
                                    };
                                    WorkbenchHostContext.workbench_drag_pointer_event(
                                        1,
                                        WorkbenchHostContext.drag_state.drag_pointer_x,
                                        WorkbenchHostContext.drag_state.drag_pointer_y,
                                    );
                                }
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: palette.border_soft; }

                PaneSurface {
                    width: parent.width;
                    height: parent.height - root.surface_data.panel_header_height_px * 1px - 1px;
                    pane: root.surface_data.pane;
                    show_header: false;
                    compact_empty: true;
                }
            }
        }

        if !root.surface_data.rail_before_panel && root.show_panel: Rectangle {
            width: 1px;
            background: palette.border_soft;
        }

        if !root.surface_data.rail_before_panel: Rectangle {
            width: root.surface_data.rail_width_px * 1px;
            background: palette.rail_bg;

            VerticalLayout {
                x: 3px;
                y: 6px;
                spacing: 2px;
                for tab in root.surface_data.tabs: RailButton {
                    icon_key: tab.icon_key;
                    active: tab.active;
                    pointer_pressed(x, y) => {
                        WorkbenchHostContext.activity_rail_pointer_clicked(
                            root.surface_data.surface_key,
                            self.x / 1px + x,
                            self.y / 1px + y,
                        );
                    }
                }
            }
        }
    }
}
