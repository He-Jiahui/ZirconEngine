import { Palette, ShellButton } from "chrome.slint";
import { ModulePluginsPaneData } from "pane_data.slint";

export component ModulePluginsPane inherits Rectangle {
    in property <ModulePluginsPaneData> pane;
    callback plugin_action(action_id: string);

    palette := Palette {}
    background: palette.panel_bg;
    clip: true;

    VerticalLayout {
        x: 8px;
        y: 8px;
        width: parent.width - 16px;
        spacing: 6px;

        if root.pane.diagnostics != "": Rectangle {
            height: 44px;
            border-radius: 4px;
            border-width: 1px;
            border-color: #7a4a4f;
            background: #341f22;

            Text {
                x: 8px;
                y: 6px;
                width: parent.width - 16px;
                height: parent.height - 12px;
                text: root.pane.diagnostics;
                color: #ffd4d8;
                font-size: 10px;
                wrap: word-wrap;
                overflow: elide;
            }
        }

        for plugin in root.pane.plugins: Rectangle {
            height: 96px;
            border-radius: 6px;
            border-width: 1px;
            border-color: plugin.enabled ? palette.accent_soft : palette.border_soft;
            background: plugin.enabled ? #26313c : palette.chrome_bg_soft;

            Text {
                x: 10px;
                y: 8px;
                width: parent.width - 112px;
                height: 16px;
                text: plugin.display_name;
                color: palette.text;
                font-size: 12px;
                font-weight: 600;
                overflow: elide;
            }

            Text {
                x: 10px;
                y: 28px;
                width: parent.width - 20px;
                height: 14px;
                text: plugin.plugin_id + (plugin.required ? "  required" : "") + "  " + plugin.package_source + "  " + plugin.load_state;
                color: palette.text_dim;
                font-size: 10px;
                overflow: elide;
            }

            Text {
                x: 10px;
                y: 46px;
                width: parent.width - 20px;
                height: 14px;
                text: "runtime " + plugin.runtime_crate + "  editor " + plugin.editor_crate;
                color: palette.text_muted;
                font-size: 10px;
                overflow: elide;
            }

            Text {
                x: 10px;
                y: 64px;
                width: parent.width - 104px;
                height: 24px;
                text: plugin.diagnostics != "" ? plugin.diagnostics : plugin.capabilities;
                color: plugin.diagnostics != "" ? #ffd4d8 : palette.text_dim;
                font-size: 10px;
                wrap: word-wrap;
                overflow: elide;
            }

            ShellButton {
                x: parent.width - 88px;
                y: 10px;
                width: 76px;
                label: plugin.enabled ? "Disable" : "Enable";
                active: plugin.enabled;
                enabled: !plugin.required || !plugin.enabled;
                clicked => {
                    root.plugin_action((plugin.enabled ? "Plugin.Disable." : "Plugin.Enable.") + plugin.plugin_id);
                }
            }
        }
    }
}
