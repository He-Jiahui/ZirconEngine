import { Palette, TabChip } from "chrome.slint";
import { HostNativeFloatingWindowSurfaceData } from "host_components.slint";
import { WorkbenchHostContext } from "host_context.slint";
import { PaneSurface } from "pane_surface.slint";

export component HostNativeFloatingWindowSurface inherits Rectangle {
    in property <HostNativeFloatingWindowSurfaceData> surface_data;
    palette := Palette {}
    background: palette.shell_bg;

    for window[index] in root.surface_data.floating_windows: Rectangle {
        visible: window.window_id == root.surface_data.native_floating_window_id;
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #20242be8;
        clip: true;

        VerticalLayout {
            spacing: 0px;

            Rectangle {
                height: root.surface_data.header_height_px * 1px;
                background: palette.chrome_bg;

                native_header_touch := TouchArea {
                    x: max(parent.width - 170px, native_floating_tabs_row.x + native_floating_tabs_row.width + 8px);
                    width: max(parent.width - self.x, 0px);
                    height: parent.height;
                    clicked => {
                        WorkbenchHostContext.floating_window_header_pointer_clicked(
                            root.surface_data.native_window_bounds.x + self.x / 1px + self.mouse-x / 1px,
                            root.surface_data.native_window_bounds.y + self.mouse-y / 1px,
                        );
                    }
                }

                native_floating_tabs_row := HorizontalLayout {
                    x: 8px;
                    y: 1px;
                    spacing: 2px;
                    for tab[index] in window.tabs: TabChip {
                        label: tab.title;
                        icon_key: tab.icon_key;
                        active: tab.active;
                        closeable: tab.closeable;
                        drag_enabled: false;
                        pointer_clicked(x, y) => {
                            WorkbenchHostContext.document_tab_pointer_clicked(
                                window.window_id,
                                index,
                                8.0 + self.x / 1px,
                                self.width / 1px,
                                8.0 + self.x / 1px + x,
                                1.0 + self.y / 1px + y,
                            );
                        }
                        close_pointer_clicked(x, y) => {
                            WorkbenchHostContext.document_tab_close_pointer_clicked(
                                window.window_id,
                                index,
                                8.0 + self.x / 1px,
                                self.width / 1px,
                                8.0 + self.x / 1px + self.width / 1px - 24.0 + x,
                                1.0 + self.y / 1px + 7.0 + y,
                            );
                        }
                    }
                }

                Text {
                    x: parent.width - 170px;
                    y: 9px;
                    width: 158px;
                    horizontal-alignment: right;
                    text: window.title;
                    color: palette.text_dim;
                    font-size: 10px;
                    overflow: elide;
                }
            }

            Rectangle { height: 1px; background: palette.border_soft; }

            PaneSurface {
                width: parent.width;
                height: parent.height - root.surface_data.header_height_px * 1px - 1px;
                pane: window.active_pane;
                show_header: false;
                compact_empty: false;
            }
        }
    }
}
