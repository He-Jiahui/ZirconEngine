import { LineEdit } from "std-widgets.slint";
import { Palette, ShellButton } from "chrome.slint";
import { TemplatePaneNodeData } from "template_node_data.slint";

component TemplatePaneNode inherits Rectangle {
    in property <TemplatePaneNodeData> node;
    callback node_dispatched(control_id: string, dispatch_kind: string, action_id: string);
    callback node_dragged(control_id: string, dispatch_kind: string, action_id: string, delta: float);
    callback node_edited(control_id: string, dispatch_kind: string, action_id: string, value: string);
    callback node_option_selected(control_id: string, dispatch_kind: string, action_id: string, option_id: string);
    callback node_action_invoked(control_id: string, dispatch_kind: string, action_id: string);

    palette := Palette {}
    x: root.node.frame.x * 1px;
    y: root.node.frame.y * 1px;
    width: root.node.frame.width * 1px;
    height: root.node.frame.height * 1px;
    background: transparent;

    property <brush> panel_background:
        root.node.surface_variant == "panel" ? palette.panel_bg_soft :
        root.node.surface_variant == "inset" ? palette.chrome_bg_soft :
        transparent;
    property <brush> panel_border:
        root.node.surface_variant == "panel" || root.node.surface_variant == "inset" ?
        palette.border_soft :
        transparent;
    property <color> text_color:
        root.node.text_tone == "muted" ? palette.text_dim :
        root.node.text_tone == "subtle" ? palette.text_muted :
        palette.text;
    property <color> component_border:
        root.node.validation_level == "error" ? #d96b63 :
        root.node.validation_level == "warning" ? #d8a24d :
        root.node.drop_hovered ? #76d17d :
        root.node.popup_open ? palette.accent :
        palette.border;
    property <color> component_background:
        root.node.disabled ? palette.panel_bg :
        root.node.pressed ? palette.chrome_bg :
        root.node.dragging ? palette.accent_soft :
        root.node.selection_state == "focused" || root.node.focused ? palette.chrome_bg_soft :
        root.node.checked || root.node.expanded ? palette.chrome_bg_soft :
        palette.panel_bg_soft;
    property <bool> drag_pressed: false;
    property <bool> suppress_click: false;
    property <float> drag_last_x: 0.0;
    property <float> drag_last_y: 0.0;
    property <float> drag_threshold_px: 1.0;
    property <bool> editable_field:
        root.node.component_role == "input-field" ||
        root.node.component_role == "text-field" ||
        root.node.component_role == "number-field" ||
        root.node.component_role == "range-field";
    property <bool> reference_value_primitive:
        root.node.component_role == "asset-field" ||
        root.node.component_role == "instance-field" ||
        root.node.component_role == "object-field";
    property <bool> structure_value_primitive:
        root.node.component_role == "group" ||
        root.node.component_role == "foldout" ||
        root.node.component_role == "inspector-section" ||
        root.node.component_role == "property-row" ||
        root.node.component_role == "array-field" ||
        root.node.component_role == "map-field" ||
        root.node.component_role == "list-row" ||
        root.node.component_role == "tree-row";
    property <bool> material_value_primitive:
        root.node.component_role == "checkbox" ||
        root.node.component_role == "radio" ||
        root.node.component_role == "toggle-button" ||
        root.node.component_role == "progress-bar" ||
        root.node.component_role == "range-field" ||
        root.node.component_role == "color-field" ||
        root.node.component_role == "image" ||
        root.node.component_role == "icon" ||
        root.node.component_role == "svg-icon" ||
        root.node.component_role == "separator" ||
        root.node.component_role == "spinner" ||
        root.node.component_role == "badge" ||
        root.node.component_role == "help-row" ||
        root.node.component_role == "vector2-field" ||
        root.node.component_role == "vector3-field" ||
        root.node.component_role == "vector4-field" ||
        root.reference_value_primitive ||
        root.structure_value_primitive;

    if root.node.role == "Panel": Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: root.node.corner_radius * 1px;
        border-width: root.node.border_width * 1px;
        border-color: root.panel_border;
        background: root.panel_background;
    }

    if root.node.role == "Label" && root.node.component_role == "": Text {
        width: parent.width;
        height: parent.height;
        text: root.node.text;
        color: root.text_color;
        font-size: root.node.font_size * 1px;
        font-weight: root.node.font_weight;
        vertical-alignment: center;
        horizontal-alignment:
            root.node.text_align == "center" ? center :
            root.node.text_align == "right" ? right :
            left;
        overflow: root.node.overflow == "elide" ? elide : clip;
    }

    if root.node.role == "Button" && root.node.component_role == "": ShellButton {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        label: root.node.text;
        active: root.node.button_variant == "primary";
        clicked => {
            root.node_dispatched(
                root.node.control_id,
                root.node.dispatch_kind,
                root.node.action_id,
            );
        }
    }

    if root.node.component_role != "": Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: max(root.node.corner_radius, 4.0) * 1px;
        border-width: max(root.node.border_width, 1.0) * 1px;
        border-color: root.component_border;
        background: root.component_background;
        opacity: root.node.disabled ? 0.48 : 1.0;

        Text {
            x: 8px;
            y: 0px;
            width: parent.width * 0.46;
            height: parent.height;
            text: root.node.text != "" ? root.node.text : root.node.control_id;
            color: palette.text;
            font-size: max(root.node.font_size, 11.0) * 1px;
            font-weight: root.node.font_weight > 0 ? root.node.font_weight : 400;
            vertical-alignment: center;
            overflow: elide;
        }

        if root.node.component_role == "checkbox": Rectangle {
            x: parent.width * 0.50;
            y: (parent.height - 16px) / 2;
            width: 16px;
            height: 16px;
            border-radius: 3px;
            border-width: 1px;
            border-color: root.node.checked ? palette.accent : root.component_border;
            background: root.node.checked ? palette.accent_soft : palette.chrome_bg;

            Rectangle {
                visible: root.node.checked;
                x: 3px;
                y: 3px;
                width: 10px;
                height: 10px;
                border-radius: 2px;
                background: palette.accent;
            }
        }

        if root.node.component_role == "radio": Rectangle {
            x: parent.width * 0.50;
            y: (parent.height - 16px) / 2;
            width: 16px;
            height: 16px;
            border-radius: 8px;
            border-width: 1px;
            border-color: root.node.checked ? palette.accent : root.component_border;
            background: palette.chrome_bg;

            Rectangle {
                visible: root.node.checked;
                x: 4px;
                y: 4px;
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: palette.accent;
            }
        }

        if root.node.component_role == "toggle-button": Rectangle {
            x: parent.width * 0.50;
            y: (parent.height - 18px) / 2;
            width: 34px;
            height: 18px;
            border-radius: 9px;
            border-width: 1px;
            border-color: root.node.checked ? palette.accent : root.component_border;
            background: root.node.checked ? palette.accent_soft : palette.chrome_bg;

            Rectangle {
                x: root.node.checked ? 18px : 2px;
                y: 2px;
                width: 14px;
                height: 14px;
                border-radius: 7px;
                background: root.node.checked ? palette.accent : palette.text_dim;
            }
        }

        if root.node.component_role == "progress-bar": Rectangle {
            x: parent.width * 0.50;
            y: (parent.height - 8px) / 2;
            width: parent.width * 0.36;
            height: 8px;
            border-radius: 4px;
            background: palette.chrome_bg;
            border-width: 1px;
            border-color: palette.border_soft;
            clip: true;

            Rectangle {
                width: parent.width * root.node.value_percent;
                height: parent.height;
                border-radius: parent.border-radius;
                background: palette.accent;
            }
        }

        if root.node.component_role == "range-field": Rectangle {
            x: parent.width * 0.50;
            y: parent.height - 7px;
            width: parent.width * 0.20;
            height: 4px;
            border-radius: 2px;
            background: palette.chrome_bg;
            clip: true;

            Rectangle {
                width: parent.width * root.node.value_percent;
                height: parent.height;
                border-radius: parent.border-radius;
                background: palette.accent;
            }
        }

        if root.node.component_role == "color-field": Rectangle {
            x: parent.width * 0.50;
            y: 5px;
            width: 34px;
            height: max(parent.height - 10px, 14px);
            border-radius: 4px;
            border-width: 1px;
            border-color: root.component_border;
            background: root.node.value_color;
        }

        if root.node.component_role == "image": Rectangle {
            x: parent.width * 0.50;
            y: 4px;
            width: 38px;
            height: max(parent.height - 8px, 16px);
            border-radius: 4px;
            border-width: 1px;
            border-color: root.component_border;
            background: palette.chrome_bg;

            Text {
                width: parent.width;
                height: parent.height;
                text: "IMG";
                color: palette.text_dim;
                font-size: 9px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.node.component_role == "image": Text {
            x: parent.width * 0.50 + 46px;
            y: 0px;
            width: parent.width * 0.22;
            height: parent.height;
            text: root.node.media_source != "" ? root.node.media_source : root.node.value_text;
            color: palette.text_muted;
            font-size: 10px;
            vertical-alignment: center;
            overflow: elide;
        }

        if root.node.component_role == "icon" || root.node.component_role == "svg-icon": Rectangle {
            x: parent.width * 0.50;
            y: 4px;
            width: 24px;
            height: max(parent.height - 8px, 16px);
            border-radius: 4px;
            border-width: 1px;
            border-color: root.component_border;
            background: root.node.component_role == "svg-icon" ? palette.accent_soft : palette.chrome_bg;

            Text {
                width: parent.width;
                height: parent.height;
                text: root.node.component_role == "svg-icon" ? "SVG" : "IC";
                color: root.node.component_role == "svg-icon" ? palette.accent : palette.text_dim;
                font-size: 8px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.node.component_role == "icon" || root.node.component_role == "svg-icon": Text {
            x: parent.width * 0.50 + 32px;
            y: 0px;
            width: parent.width * 0.28;
            height: parent.height;
            text: root.node.icon_name != "" ? root.node.icon_name : root.node.media_source;
            color: palette.text_muted;
            font-size: 10px;
            vertical-alignment: center;
            overflow: elide;
        }

        if root.node.component_role == "separator": Rectangle {
            x: parent.width * 0.50;
            y: (parent.height - 1px) / 2;
            width: parent.width * 0.36;
            height: 1px;
            background: palette.border;
        }

        if root.node.component_role == "spinner": Rectangle {
            x: parent.width * 0.50;
            y: (parent.height - 16px) / 2;
            width: 16px;
            height: 16px;
            border-radius: 8px;
            border-width: 2px;
            border-color: palette.accent;
            background: transparent;

            Rectangle {
                x: 10px;
                y: 1px;
                width: 4px;
                height: 4px;
                border-radius: 2px;
                background: palette.chrome_bg_soft;
            }
        }

        if root.node.component_role == "badge": Rectangle {
            x: parent.width * 0.50;
            y: 4px;
            width: min(parent.width * 0.30, 98px);
            height: max(parent.height - 8px, 16px);
            border-radius: 8px;
            border-width: 1px;
            border-color: palette.accent;
            background: palette.accent_soft;

            Text {
                x: 8px;
                width: parent.width - 16px;
                height: parent.height;
                text: root.node.text != "" ? root.node.text : root.node.value_text;
                color: palette.accent;
                font-size: 10px;
                horizontal-alignment: center;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if root.node.component_role == "help-row": Rectangle {
            x: parent.width * 0.50;
            y: (parent.height - 14px) / 2;
            width: 14px;
            height: 14px;
            border-radius: 7px;
            background: root.node.validation_level == "warning" ? #d8a24d : palette.accent;

            Text {
                width: parent.width;
                height: parent.height;
                text: "!";
                color: palette.chrome_bg;
                font-size: 10px;
                font-weight: 700;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if root.node.component_role == "help-row": Text {
            x: parent.width * 0.50 + 22px;
            y: 0px;
            width: parent.width * 0.26;
            height: parent.height;
            text: root.node.validation_message != "" ? root.node.validation_message : root.node.value_text;
            color: root.node.validation_level == "warning" ? #ffe3b3 : palette.text_muted;
            font-size: 10px;
            vertical-alignment: center;
            overflow: elide;
        }

        if root.node.component_role == "vector2-field" || root.node.component_role == "vector3-field" || root.node.component_role == "vector4-field": Rectangle {
            x: parent.width * 0.50;
            y: 4px;
            width: parent.width * 0.34;
            height: max(parent.height - 8px, 18px);
            border-radius: 4px;
            background: transparent;

            for component[index] in root.node.vector_components: Rectangle {
                x: index * 28px;
                y: 0px;
                width: 24px;
                height: parent.height;
                border-radius: 4px;
                border-width: 1px;
                border-color: root.component_border;
                background: component == 0.0 ? palette.chrome_bg : palette.chrome_bg_soft;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: index == 0 ? "X" : index == 1 ? "Y" : index == 2 ? "Z" : "W";
                    color: component == 0.0 ? palette.text_dim : palette.accent;
                    font-size: 10px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 116px;
                y: 0px;
                width: max(parent.width - 116px, 24px);
                height: parent.height;
                text: root.node.value_text;
                color: palette.text_muted;
                font-size: 10px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if root.reference_value_primitive: Rectangle {
            x: parent.width * 0.50;
            y: 4px;
            width: parent.width * 0.22;
            height: max(parent.height - 8px, 20px);
            border-radius: 4px;
            border-width: 1px;
            border-color: root.node.validation_level == "error" ? #d96b63 :
                root.node.validation_level == "warning" ? #d8a24d :
                root.node.drop_hovered ? #76d17d :
                root.node.value_text == "" ? palette.border :
                palette.accent;
            background: root.node.value_text == "" ? palette.chrome_bg :
                root.node.drop_hovered ? #1f3524 :
                root.node.validation_level == "error" ? #3a2424 :
                palette.chrome_bg_soft;
            clip: true;

            Rectangle {
                x: 4px;
                y: 4px;
                width: 20px;
                height: max(parent.height - 8px, 12px);
                border-radius: 4px;
                background: root.node.component_role == "asset-field" ? palette.accent_soft :
                    root.node.component_role == "instance-field" ? palette.panel_bg :
                    palette.chrome_bg;
                border-width: 1px;
                border-color: root.component_border;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: root.node.component_role == "asset-field" ? "A" :
                        root.node.component_role == "instance-field" ? "S" :
                        "O";
                    color: root.node.component_role == "asset-field" ? palette.accent : palette.text_dim;
                    font-size: 10px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 30px;
                y: 1px;
                width: parent.width - 34px;
                height: max(parent.height / 2, 10px);
                text: root.node.value_text != "" ? root.node.value_text : "None";
                color: root.node.value_text == "" ? palette.text_dim : palette.text;
                font-size: 10px;
                vertical-alignment: center;
                overflow: elide;
            }

            Text {
                x: 30px;
                y: parent.height / 2 - 1px;
                width: parent.width - 34px;
                height: max(parent.height / 2, 10px);
                text: root.node.validation_message != "" ? root.node.validation_message : root.node.accepted_drag_payloads;
                color: root.node.validation_level == "error" ? #ffd3d0 :
                    root.node.validation_level == "warning" ? #ffe3b3 :
                    palette.text_dim;
                font-size: 8px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if root.structure_value_primitive: Rectangle {
            x: parent.width * 0.50;
            y: 4px;
            width: root.node.actions.length > 0 ? parent.width * 0.20 : parent.width * 0.36;
            height: max(parent.height - 8px, 20px);
            border-radius: 4px;
            border-width: 1px;
            border-color: root.node.selection_state == "focused" || root.node.focused ? palette.accent :
                root.node.expanded ? palette.accent :
                root.component_border;
            background: root.node.selection_state == "focused" || root.node.focused ? palette.chrome_bg_soft :
                root.node.expanded ? palette.chrome_bg_soft :
                palette.chrome_bg;
            clip: true;

            Rectangle {
                x: 4px;
                y: 4px;
                width: 20px;
                height: max(parent.height - 8px, 12px);
                border-radius: 4px;
                border-width: 1px;
                border-color: root.component_border;
                background: root.node.component_role == "array-field" || root.node.component_role == "map-field" ?
                    palette.panel_bg :
                    transparent;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: root.node.component_role == "array-field" ? "[]" :
                        root.node.component_role == "map-field" ? "{}" :
                        root.node.component_role == "property-row" || root.node.component_role == "list-row" ? "-" :
                        root.node.expanded ? "v" : ">";
                    color: root.node.expanded ? palette.accent : palette.text_dim;
                    font-size: 10px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                x: 30px;
                y: 1px;
                width: parent.width - 34px;
                height: max(parent.height / 2, 10px);
                text: root.node.component_role == "array-field" ? "Array" :
                    root.node.component_role == "map-field" ? "Map" :
                    root.node.component_role == "inspector-section" ? "Section" :
                    root.node.component_role == "tree-row" ? "Tree" :
                    root.node.component_role;
                color: palette.text;
                font-size: 10px;
                vertical-alignment: center;
                overflow: elide;
            }

            Text {
                x: 30px;
                y: parent.height / 2 - 1px;
                width: parent.width - 34px;
                height: max(parent.height / 2, 10px);
                text: root.node.value_text != "" ? root.node.value_text :
                    root.node.expanded ? "expanded" : "collapsed";
                color: palette.text_dim;
                font-size: 8px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if root.structure_value_primitive && root.node.collection_items.length > 0: Rectangle {
            x: parent.width * 0.50;
            y: parent.height - min(20px, parent.height);
            width: root.node.actions.length > 0 ? parent.width * 0.20 : parent.width * 0.36;
            height: min(18px, max(parent.height / 2, 12px));
            background: transparent;
            clip: true;

            for item[index] in root.node.collection_items: Text {
                visible: index < 2;
                x: 32px + index * 82px;
                y: 0px;
                width: 78px;
                height: parent.height;
                text: item;
                color: root.node.validation_level == "error" ? #ffd3d0 : palette.text_dim;
                font-size: 8px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        if !root.editable_field && !root.material_value_primitive: Text {
            x: parent.width * 0.50;
            y: 0px;
            width: parent.width * 0.36;
            height: parent.height;
            text: root.node.value_text != "" ? root.node.value_text : root.node.component_role;
            color: palette.text_muted;
            font-size: 11px;
            vertical-alignment: center;
            horizontal-alignment: right;
            overflow: elide;
        }

        if root.editable_field: LineEdit {
            x: root.node.component_role == "range-field" ? parent.width * 0.72 : parent.width * 0.50;
            y: 3px;
            width: root.node.component_role == "range-field" ? parent.width * 0.14 : parent.width * 0.36;
            height: max(parent.height - 6px, 18px);
            text: root.node.value_text;
            placeholder-text: root.node.component_role;
            enabled: !root.node.disabled;
            font-size: 11px;
            edited(value) => {
                if (root.node.dispatch_kind != "") {
                    root.node_edited(
                        root.node.control_id,
                        root.node.dispatch_kind,
                        root.node.edit_action_id,
                        value,
                    );
                }
            }
        }

        if !root.reference_value_primitive && !root.structure_value_primitive: Text {
            x: parent.width - 54px;
            y: 0px;
            width: 46px;
            height: parent.height;
            text: root.node.popup_open ? "open" :
                root.node.accepted_drag_payloads != "" ? root.node.accepted_drag_payloads :
                root.node.validation_message;
            color: root.node.validation_level == "error" ? #ffd3d0 :
                root.node.validation_level == "warning" ? #ffe3b3 :
                palette.text_dim;
            font-size: 10px;
            vertical-alignment: center;
            horizontal-alignment: right;
            overflow: elide;
        }

        touch := TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: root.node.drag_action_id != "" ?
                (root.drag_pressed || root.suppress_click ? MouseCursor.grabbing : MouseCursor.grab) :
                default;
            clicked => {
                if (!root.suppress_click && !root.node.disabled && root.node.dispatch_kind != "") {
                    root.node_dispatched(
                        root.node.control_id,
                        root.node.dispatch_kind,
                        root.node.action_id,
                    );
                }
                root.suppress_click = false;
            }
            pointer-event(event) => {
                if (root.node.disabled || root.node.drag_action_id == "" || event.button != PointerEventButton.left) {
                    return;
                }
                if (event.kind == PointerEventKind.down) {
                    root.drag_pressed = true;
                    root.suppress_click = false;
                    root.drag_last_x = self.mouse-x / 1px;
                    root.drag_last_y = self.mouse-y / 1px;
                    if (root.node.begin_drag_action_id != "") {
                        root.node_dispatched(
                            root.node.control_id,
                            root.node.dispatch_kind,
                            root.node.begin_drag_action_id,
                        );
                    }
                } else if (event.kind == PointerEventKind.up) {
                    root.drag_pressed = false;
                    if (root.node.end_drag_action_id != "") {
                        root.node_dispatched(
                            root.node.control_id,
                            root.node.dispatch_kind,
                            root.node.end_drag_action_id,
                        );
                    }
                }
            }
            moved => {
                if (root.node.disabled || root.node.drag_action_id == "" || !root.drag_pressed) {
                    return;
                }
                if (
                    (self.mouse-x / 1px - root.drag_last_x) * (self.mouse-x / 1px - root.drag_last_x)
                    + (self.mouse-y / 1px - root.drag_last_y) * (self.mouse-y / 1px - root.drag_last_y)
                    >= root.drag_threshold_px * root.drag_threshold_px
                ) {
                    root.suppress_click = true;
                    root.node_dragged(
                        root.node.control_id,
                        root.node.dispatch_kind,
                        root.node.drag_action_id,
                        (self.mouse-x / 1px - root.drag_last_x) - (self.mouse-y / 1px - root.drag_last_y),
                    );
                    root.drag_last_x = self.mouse-x / 1px;
                    root.drag_last_y = self.mouse-y / 1px;
                }
            }
        }

        if root.node.actions.length > 0: HorizontalLayout {
            x: root.reference_value_primitive ? parent.width * 0.74 :
                root.structure_value_primitive ? parent.width * 0.72 :
                parent.width * 0.50;
            y: 3px;
            width: root.reference_value_primitive ? parent.width * 0.22 :
                root.structure_value_primitive ? parent.width * 0.24 :
                parent.width * 0.36;
            height: max(parent.height - 6px, 18px);
            spacing: 4px;

            for action[index] in root.node.actions: ShellButton {
                width: max(34px, min(56px, (parent.width - 12px) / root.node.actions.length));
                height: parent.height;
                label: action.label;
                active: false;
                clicked => {
                    if (!root.node.disabled && root.node.dispatch_kind != "") {
                        root.node_action_invoked(
                            root.node.control_id,
                            root.node.dispatch_kind,
                            action.action_id,
                        );
                    }
                }
            }
        }

    }

}

component TemplatePanePopup inherits Rectangle {
    in property <TemplatePaneNodeData> node;
    callback node_option_selected(control_id: string, dispatch_kind: string, action_id: string, option_id: string);

    palette := Palette {}
    visible: root.node.popup_open && (root.node.options.length > 0 || root.node.menu_items.length > 0);
    x: (root.node.frame.x + root.node.frame.width * 0.50) * 1px;
    y: (root.node.frame.y + root.node.frame.height - 1.0) * 1px;
    width: root.node.frame.width * 0.48 * 1px;
    height: min(144px, max(28px, max(root.node.options.length, root.node.menu_items.length) * 22px + 4px));
    border-radius: 4px;
    border-width: 1px;
    border-color: palette.accent;
    background: palette.chrome_bg;
    clip: true;

    for option[index] in root.node.options: Rectangle {
        visible: root.node.menu_items.length == 0;
        x: 2px;
        y: 2px + index * 22px;
        width: parent.width - 4px;
        height: 20px;
        border-radius: 3px;
        background: option == root.node.value_text ? palette.chrome_bg_soft : transparent;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: option;
            color: option == root.node.value_text ? palette.text : palette.text_muted;
            font-size: 10px;
            vertical-alignment: center;
            overflow: elide;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                if (!root.node.disabled && root.node.dispatch_kind != "") {
                    root.node_option_selected(
                        root.node.control_id,
                        root.node.dispatch_kind,
                        root.node.action_id,
                        option,
                    );
                }
            }
        }
    }

    for menu_item[index] in root.node.menu_items: Rectangle {
        visible: root.node.menu_items.length > 0;
        x: 2px;
        y: 2px + index * 22px;
        width: parent.width - 4px;
        height: 20px;
        border-radius: 3px;
        background: menu_item == "---" ? palette.border_soft :
            menu_item == root.node.value_text ? palette.chrome_bg_soft :
            transparent;

        Text {
            x: 6px;
            y: 0px;
            width: parent.width - 12px;
            height: parent.height;
            text: menu_item;
            color: menu_item == "---" ? palette.border : palette.text_muted;
            font-size: 10px;
            vertical-alignment: center;
            overflow: elide;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                if (!root.node.disabled && root.node.dispatch_kind != "" && menu_item != "---") {
                    root.node_option_selected(
                        root.node.control_id,
                        root.node.dispatch_kind,
                        root.node.action_id,
                        menu_item,
                    );
                }
            }
        }
    }
}

export component TemplatePane inherits Rectangle {
    in property <[TemplatePaneNodeData]> nodes;
    callback node_dispatched(control_id: string, dispatch_kind: string, action_id: string);
    callback node_dragged(control_id: string, dispatch_kind: string, action_id: string, delta: float);
    callback node_edited(control_id: string, dispatch_kind: string, action_id: string, value: string);
    callback node_option_selected(control_id: string, dispatch_kind: string, action_id: string, option_id: string);
    callback node_action_invoked(control_id: string, dispatch_kind: string, action_id: string);

    background: transparent;
    clip: true;

    for node in root.nodes: TemplatePaneNode {
        node: node;
        node_dispatched(control_id, dispatch_kind, action_id) => {
            root.node_dispatched(control_id, dispatch_kind, action_id);
        }
        node_dragged(control_id, dispatch_kind, action_id, delta) => {
            root.node_dragged(control_id, dispatch_kind, action_id, delta);
        }
        node_edited(control_id, dispatch_kind, action_id, value) => {
            root.node_edited(control_id, dispatch_kind, action_id, value);
        }
        node_action_invoked(control_id, dispatch_kind, action_id) => {
            root.node_action_invoked(control_id, dispatch_kind, action_id);
        }
    }

    for node in root.nodes: TemplatePanePopup {
        node: node;
        node_option_selected(control_id, dispatch_kind, action_id, option_id) => {
            root.node_option_selected(control_id, dispatch_kind, action_id, option_id);
        }
    }
}
