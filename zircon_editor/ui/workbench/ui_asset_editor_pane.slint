import { Palette, ShellButton } from "chrome.slint";
import { UiAssetActionStateData, UiAssetCollectionPanelData, UiAssetEditorPaneData, UiAssetEditorPaneDraftData, UiAssetInspectorPanelData, UiAssetPaletteDragData, UiAssetPaletteDragSessionData, UiAssetPaneHeaderData, UiAssetPreviewPanelData, UiAssetSourcePanelData, UiAssetStylePanelData } from "ui_asset_editor_data.slint";
import { UiAssetSelectableSection } from "ui_asset_editor_components.slint";
import { UiAssetEditorCenterColumn } from "ui_asset_editor_center_column.slint";
import { UiAssetEditorInspectorPanel } from "ui_asset_editor_inspector_panel.slint";
import { UiAssetEditorStylesheetPanel } from "ui_asset_editor_stylesheet_panel.slint";

export component UiAssetEditorPane inherits Rectangle {
    in property <UiAssetEditorPaneData> pane;
    callback action(action_id: string);
    callback detail_event(detail_id: string, action_id: string, item_index: int, primary: string, secondary: string);
    callback draft_value_changed(draft_id: string, value: string);
    callback clear_draft(draft_id: string);
    callback begin_palette_drag_session(source_index: int, pointer_x: float, pointer_y: float);
    callback update_palette_drag_pointer(pointer_x: float, pointer_y: float);
    callback clear_palette_drag_session();
    callback collection_event(collection_id: string, event_kind: string, item_index: int);
    property <UiAssetPaneHeaderData> header: root.pane.header;
    property <UiAssetActionStateData> actions: root.pane.actions;
    property <UiAssetCollectionPanelData> collections: root.pane.collections;
    property <UiAssetSourcePanelData> source_panel: root.pane.source;
    property <UiAssetPreviewPanelData> preview_panel: root.pane.preview;
    property <UiAssetInspectorPanelData> inspector_panel: root.pane.inspector;
    property <UiAssetStylePanelData> style_panel: root.pane.style;
    property <UiAssetPaletteDragData> palette_drag_projection: root.pane.palette_drag;
    palette := Palette {}
    property <UiAssetEditorPaneDraftData> draft_state: {
        style: {
            class_name: "",
            rule_selector: "",
            rule_declaration_path: "",
            rule_declaration_value: "",
            token_name: "",
            token_value: "",
        },
        preview: {
            mock_value: "",
            mock_nested_key: "",
            mock_nested_value: "",
        },
        binding: {
            payload_key: "",
            payload_value: "",
        },
    };
    property <UiAssetEditorPaneDraftData> draft_data: root.draft_state;
    property <UiAssetPaletteDragSessionData> palette_drag_session_state: {
        active: false,
        source_index: -1,
        pointer_x: 0.0,
        pointer_y: 0.0,
        label: "",
    };
    property <UiAssetPaletteDragSessionData> palette_drag_session: root.palette_drag_session_state;
    draft_value_changed(draft_id, value) => {
        if (draft_id == "style.class") {
            root.draft_state = {
                style: {
                    class_name: value,
                    rule_selector: root.draft_state.style.rule_selector,
                    rule_declaration_path: root.draft_state.style.rule_declaration_path,
                    rule_declaration_value: root.draft_state.style.rule_declaration_value,
                    token_name: root.draft_state.style.token_name,
                    token_value: root.draft_state.style.token_value,
                },
                preview: root.draft_state.preview,
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "style.rule.selector") {
            root.draft_state = {
                style: {
                    class_name: root.draft_state.style.class_name,
                    rule_selector: value,
                    rule_declaration_path: root.draft_state.style.rule_declaration_path,
                    rule_declaration_value: root.draft_state.style.rule_declaration_value,
                    token_name: root.draft_state.style.token_name,
                    token_value: root.draft_state.style.token_value,
                },
                preview: root.draft_state.preview,
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "style.rule.declaration.path") {
            root.draft_state = {
                style: {
                    class_name: root.draft_state.style.class_name,
                    rule_selector: root.draft_state.style.rule_selector,
                    rule_declaration_path: value,
                    rule_declaration_value: root.draft_state.style.rule_declaration_value,
                    token_name: root.draft_state.style.token_name,
                    token_value: root.draft_state.style.token_value,
                },
                preview: root.draft_state.preview,
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "style.rule.declaration.value") {
            root.draft_state = {
                style: {
                    class_name: root.draft_state.style.class_name,
                    rule_selector: root.draft_state.style.rule_selector,
                    rule_declaration_path: root.draft_state.style.rule_declaration_path,
                    rule_declaration_value: value,
                    token_name: root.draft_state.style.token_name,
                    token_value: root.draft_state.style.token_value,
                },
                preview: root.draft_state.preview,
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "style.token.name") {
            root.draft_state = {
                style: {
                    class_name: root.draft_state.style.class_name,
                    rule_selector: root.draft_state.style.rule_selector,
                    rule_declaration_path: root.draft_state.style.rule_declaration_path,
                    rule_declaration_value: root.draft_state.style.rule_declaration_value,
                    token_name: value,
                    token_value: root.draft_state.style.token_value,
                },
                preview: root.draft_state.preview,
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "style.token.value") {
            root.draft_state = {
                style: {
                    class_name: root.draft_state.style.class_name,
                    rule_selector: root.draft_state.style.rule_selector,
                    rule_declaration_path: root.draft_state.style.rule_declaration_path,
                    rule_declaration_value: root.draft_state.style.rule_declaration_value,
                    token_name: root.draft_state.style.token_name,
                    token_value: value,
                },
                preview: root.draft_state.preview,
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "preview.mock.value") {
            root.draft_state = {
                style: root.draft_state.style,
                preview: {
                    mock_value: value,
                    mock_nested_key: root.draft_state.preview.mock_nested_key,
                    mock_nested_value: root.draft_state.preview.mock_nested_value,
                },
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "preview.mock.nested.key") {
            root.draft_state = {
                style: root.draft_state.style,
                preview: {
                    mock_value: root.draft_state.preview.mock_value,
                    mock_nested_key: value,
                    mock_nested_value: root.draft_state.preview.mock_nested_value,
                },
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "preview.mock.nested.value") {
            root.draft_state = {
                style: root.draft_state.style,
                preview: {
                    mock_value: root.draft_state.preview.mock_value,
                    mock_nested_key: root.draft_state.preview.mock_nested_key,
                    mock_nested_value: value,
                },
                binding: root.draft_state.binding,
            };
        } else if (draft_id == "binding.payload.key") {
            root.draft_state = {
                style: root.draft_state.style,
                preview: root.draft_state.preview,
                binding: {
                    payload_key: value,
                    payload_value: root.draft_state.binding.payload_value,
                },
            };
        } else if (draft_id == "binding.payload.value") {
            root.draft_state = {
                style: root.draft_state.style,
                preview: root.draft_state.preview,
                binding: {
                    payload_key: root.draft_state.binding.payload_key,
                    payload_value: value,
                },
            };
        }
    }
    clear_draft(draft_id) => {
        root.draft_value_changed(draft_id, "");
    }
    begin_palette_drag_session(source_index, pointer_x, pointer_y) => {
        root.palette_drag_session_state = {
            active: true,
            source_index: source_index,
            pointer_x: pointer_x,
            pointer_y: pointer_y,
            label:
                source_index >= 0 && source_index < root.collections.palette.items.length ?
                root.collections.palette.items[source_index] :
                "",
        };
    }
    update_palette_drag_pointer(pointer_x, pointer_y) => {
        root.palette_drag_session_state = {
            active: root.palette_drag_session_state.active,
            source_index: root.palette_drag_session_state.source_index,
            pointer_x: pointer_x,
            pointer_y: pointer_y,
            label: root.palette_drag_session_state.label,
        };
    }
    clear_palette_drag_session() => {
        root.palette_drag_session_state = {
            active: false,
            source_index: -1,
            pointer_x: 0.0,
            pointer_y: 0.0,
            label: "",
        };
    }
    drag_focus_host := FocusScope {
        x: 0px;
        y: 0px;
        width: 0px;
        height: 0px;
        enabled: root.palette_drag_session.active || root.palette_drag_projection.target_chooser_active;
        key-pressed(event) => {
            if (event.text == Key.LeftArrow || event.text == Key.UpArrow) {
                root.action("palette.target.previous");
                return accept;
            }
            if (
                event.text == Key.RightArrow
                || event.text == Key.DownArrow
                || event.text == Key.Tab
                ) {
                root.action("palette.target.next");
                return accept;
            }
            if (event.text == Key.Return || event.text == "\n") {
                if (root.palette_drag_projection.target_chooser_active) {
                    root.action("palette.target.confirm");
                    return accept;
                }
                if (root.palette_drag_projection.target_action != "") {
                    root.action("palette.drag.drop");
                }
                return accept;
            }
            if (event.text == Key.Escape) {
                if (root.palette_drag_projection.target_chooser_active) {
                    root.action("palette.target.cancel");
                } else {
                    root.action("palette.drag.cancel");
                    root.clear_palette_drag_session();
                }
                return accept;
            }
            reject
        }
    }
    background: transparent;
    clip: true;

    Rectangle {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
        height: 56px;
        border-radius: 4px;
        border-width: 1px;
        border-color: palette.border_soft;
        background: #ffffff06;

        Text {
            x: 10px;
            y: 6px;
            text: root.header.asset_id != "" ? root.header.asset_id : root.header.mode;
            color: palette.text;
            font-size: 10px;
            overflow: elide;
        }

        Text {
            x: 10px;
            y: 16px;
            width: parent.width - 20px;
            text:
                root.header.status != "" ?
                root.header.mode + " • " + root.header.selection + " • " + root.header.status :
                root.header.mode + " • " + root.header.selection;
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        HorizontalLayout {
            x: 10px;
            y: 28px;
            width: parent.width - 20px;
            spacing: 4px;

            ShellButton {
                width: 56px;
                label: "Design";
                active: root.header.mode == "Design";
                clicked => { root.action("mode.design"); }
            }
            ShellButton {
                width: 52px;
                label: "Split";
                active: root.header.mode == "Split";
                clicked => { root.action("mode.split"); }
            }
            ShellButton {
                width: 56px;
                label: "Source";
                active: root.header.mode == "Source";
                clicked => { root.action("mode.source"); }
            }
            ShellButton {
                width: 60px;
                label: "Preview";
                active: root.header.mode == "Preview";
                clicked => { root.action("mode.preview"); }
            }

            Rectangle { width: 1px; height: 20px; background: palette.border_soft; }

            ShellButton {
                width: 58px;
                label: "Docked";
                active: root.preview_panel.preset == "Editor Docked";
                clicked => { root.action("preview.preset.editor_docked"); }
            }
            ShellButton {
                width: 50px;
                label: "Float";
                active: root.preview_panel.preset == "Editor Floating";
                clicked => { root.action("preview.preset.editor_floating"); }
            }
            ShellButton {
                width: 44px;
                label: "HUD";
                active: root.preview_panel.preset == "Game HUD";
                clicked => { root.action("preview.preset.game_hud"); }
            }
            ShellButton {
                width: 58px;
                label: "Dialog";
                active: root.preview_panel.preset == "Dialog";
                clicked => { root.action("preview.preset.dialog"); }
            }

            Rectangle { width: 1px; height: 20px; background: palette.border_soft; }

            ShellButton {
                width: 46px;
                label: "Save";
                enabled: root.actions.can_save;
                active: root.actions.can_save;
                clicked => { root.action("save"); }
            }
            ShellButton {
                width: 48px;
                label: "Undo";
                enabled: root.actions.can_undo;
                clicked => { root.action("undo"); }
            }
            ShellButton {
                width: 48px;
                label: "Redo";
                enabled: root.actions.can_redo;
                clicked => { root.action("redo"); }
            }

            Text {
                text: root.preview_panel.available ? root.preview_panel.summary : "Preview unavailable";
                color: palette.text_dim;
                font-size: 9px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }

    HorizontalLayout {
        x: 10px;
        y: 74px;
        width: parent.width - 20px;
        height: parent.height - 84px;
        spacing: 8px;

        Rectangle {
            width: 240px;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                palette_section := UiAssetSelectableSection {
                    height: parent.height * 0.42;
                    title: "Palette";
                    items: root.collections.palette.items;
                    selected_index: root.collections.palette.selected_index;
                    accent: #9dc07c;
                    drag_enabled: true;
                    item_selected(item_index) => { root.collection_event("palette", "selected", item_index); }
                    item_drag_started(item_index, x, y) => {
                        root.collection_event("palette", "selected", item_index);
                        root.begin_palette_drag_session(
                            item_index,
                            palette_section.x / 1px + x,
                            palette_section.y / 1px + y,
                        );
                        drag_focus_host.focus();
                    }
                }

                UiAssetSelectableSection {
                    height: parent.height * 0.58 - 8px;
                    title: "Hierarchy";
                    items: root.collections.hierarchy.items;
                    selected_index: root.collections.hierarchy.selected_index;
                    accent: #7aa2e3;
                    item_selected(item_index) => { root.collection_event("hierarchy", "selected", item_index); }
                    item_activated(item_index) => { root.collection_event("hierarchy", "activated", item_index); }
                }
            }
        }

        center_column := UiAssetEditorCenterColumn {
            width: max(240px, parent.width - 536px);
            height: parent.height;
            actions: root.actions;
            collections: root.collections;
            source_panel: root.source_panel;
            preview_panel: root.preview_panel;
            palette_drag_projection: root.palette_drag_projection;
            draft_data: root.draft_data;
            palette_drag_session: root.palette_drag_session;
            action(action_id) => { root.action(action_id); }
            detail_event(detail_id, action_id, item_index, primary, secondary) => { root.detail_event(detail_id, action_id, item_index, primary, secondary); }
            draft_value_changed(draft_id, value) => { root.draft_value_changed(draft_id, value); }
            clear_draft(draft_id) => { root.clear_draft(draft_id); }
            collection_event(collection_id, event_kind, item_index) => { root.collection_event(collection_id, event_kind, item_index); }
        }

        Rectangle {
            width: 280px;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                UiAssetEditorInspectorPanel {
                    width: parent.width;
                    height: parent.height * 0.5;
                    inspector_panel: root.inspector_panel;
                    draft_data: root.draft_data;
                    detail_event(detail_id, action_id, item_index, primary, secondary) => { root.detail_event(detail_id, action_id, item_index, primary, secondary); }
                    draft_value_changed(draft_id, value) => { root.draft_value_changed(draft_id, value); }
                    clear_draft(draft_id) => { root.clear_draft(draft_id); }
                    collection_event(collection_id, event_kind, item_index) => { root.collection_event(collection_id, event_kind, item_index); }
                }

                UiAssetEditorStylesheetPanel {
                    width: parent.width;
                    height: parent.height * 0.5 - 8px;
                    style_panel: root.style_panel;
                    draft_data: root.draft_data;
                    action(action_id) => { root.action(action_id); }
                    detail_event(detail_id, action_id, item_index, primary, secondary) => { root.detail_event(detail_id, action_id, item_index, primary, secondary); }
                    draft_value_changed(draft_id, value) => { root.draft_value_changed(draft_id, value); }
                    clear_draft(draft_id) => { root.clear_draft(draft_id); }
                    collection_event(collection_id, event_kind, item_index) => { root.collection_event(collection_id, event_kind, item_index); }
                }
            }
        }
    }

    if root.palette_drag_session.active: TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: MouseCursor.grabbing;
        drag_focus := FocusScope {
            x: 0px;
            y: 0px;
            width: 0px;
            height: 0px;
            enabled: true;
            key-pressed(event) => {
                if (event.text == Key.LeftArrow || event.text == Key.UpArrow) {
                    root.action("palette.target.previous");
                    return accept;
                }
                if (
                    event.text == Key.RightArrow
                    || event.text == Key.DownArrow
                    || event.text == Key.Tab
                    ) {
                    root.action("palette.target.next");
                    return accept;
                }
                if (event.text == Key.Return || event.text == "\n") {
                    if (root.palette_drag_projection.target_chooser_active) {
                        root.action("palette.target.confirm");
                        return accept;
                    }
                    if (root.palette_drag_projection.target_action != "") {
                        root.action("palette.drag.drop");
                    }
                    return accept;
                }
                if (event.text == Key.Escape) {
                    if (root.palette_drag_projection.target_chooser_active) {
                        root.action("palette.target.cancel");
                    } else {
                        root.action("palette.drag.cancel");
                        root.clear_palette_drag_session();
                    }
                    return accept;
                }
                reject
            }
        }
        moved => {
            root.update_palette_drag_pointer(self.mouse-x / 1px, self.mouse-y / 1px);
            root.detail_event(
                "palette_drag",
                "palette.drag.hover",
                -1,
                "\{(root.palette_drag_session.pointer_x - (center_column.x / 1px + center_column.preview_canvas_x_px) - center_column.preview_surface_origin_x_px) / max(center_column.preview_surface_scale, 0.0001)}",
                "\{(root.palette_drag_session.pointer_y - (center_column.y / 1px + center_column.preview_canvas_y_px) - center_column.preview_surface_origin_y_px) / max(center_column.preview_surface_scale, 0.0001)}",
            );
        }
        pointer-event(event) => {
            if (event.button != PointerEventButton.left) {
                return;
            }
            if (event.kind == PointerEventKind.up) {
                root.update_palette_drag_pointer(self.mouse-x / 1px, self.mouse-y / 1px);
                root.detail_event(
                    "palette_drag",
                    "palette.drag.hover",
                    -1,
                    "\{(root.palette_drag_session.pointer_x - (center_column.x / 1px + center_column.preview_canvas_x_px) - center_column.preview_surface_origin_x_px) / max(center_column.preview_surface_scale, 0.0001)}",
                    "\{(root.palette_drag_session.pointer_y - (center_column.y / 1px + center_column.preview_canvas_y_px) - center_column.preview_surface_origin_y_px) / max(center_column.preview_surface_scale, 0.0001)}",
                );
                if (root.palette_drag_projection.target_action != "") {
                    root.action("palette.drag.drop");
                } else {
                    root.action("palette.drag.cancel");
                }
                root.clear_palette_drag_session();
            }
        }
    }

    if root.palette_drag_projection.candidate_items.length > 1 && (root.palette_drag_session.active || root.palette_drag_projection.target_chooser_active): Rectangle {
        x: min(
            max(center_column.x + center_column.preview_canvas_x_px * 1px + center_column.preview_canvas_width_px * 1px - self.width - 12px, 8px),
            max(root.width - self.width - 8px, 8px)
        );
        y: max(center_column.y + center_column.preview_canvas_y_px * 1px - 2px, 8px);
        width: 248px;
        height: min(224px, max(118px, 68px + root.palette_drag_projection.candidate_items.length * 22px));
        background: transparent;
        chooser_focus := FocusScope {
            x: 0px;
            y: 0px;
            width: 0px;
            height: 0px;
            enabled: root.palette_drag_projection.target_chooser_active && !root.palette_drag_session.active;
            key-pressed(event) => {
                if (event.text == Key.LeftArrow || event.text == Key.UpArrow) {
                    root.action("palette.target.previous");
                    return accept;
                }
                if (
                    event.text == Key.RightArrow
                    || event.text == Key.DownArrow
                    || event.text == Key.Tab
                    ) {
                    root.action("palette.target.next");
                    return accept;
                }
                if (event.text == Key.Return || event.text == "\n") {
                    root.action("palette.target.confirm");
                    return accept;
                }
                if (event.text == Key.Escape) {
                    root.action("palette.target.cancel");
                    return accept;
                }
                reject
            }
        }

        UiAssetSelectableSection {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height - 38px;
            title: "Target Cycle";
            items: root.palette_drag_projection.candidate_items;
            selected_index: root.palette_drag_projection.candidate_selected_index;
            accent: #53c98a;
            item_selected(item_index) => {
                root.collection_event("palette_target_candidate", "selected", item_index);
            }
            item_activated(item_index) => {
                root.collection_event("palette_target_candidate", "selected", item_index);
                root.action("palette.target.confirm");
            }
        }

        HorizontalLayout {
            x: 10px;
            y: parent.height - 34px;
            width: parent.width - 20px;
            spacing: 6px;

            ShellButton {
                width: 56px;
                label: "Apply";
                active: true;
                clicked => { root.action("palette.target.confirm"); }
            }

            ShellButton {
                width: 58px;
                label: "Cancel";
                clicked => { root.action("palette.target.cancel"); }
            }

            Text {
                width: parent.width - 120px;
                y: 4px;
                text:
                    root.palette_drag_projection.target_chooser_active ?
                    "Sticky target chooser  Tab/arrows cycle  Enter apply" :
                    "Tab / arrows cycle  Enter apply  Esc cancel";
                color: palette.text_dim;
                font-size: 9px;
                overflow: elide;
            }
        }
    }
}
