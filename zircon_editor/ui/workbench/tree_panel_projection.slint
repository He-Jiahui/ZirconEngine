import { Palette, ShellIcon } from "chrome.slint";
import { AssetFolderData } from "assets.slint";
import { TemplatePaneNodeData } from "template_node_data.slint";

export component ProjectedFolderTreePanel inherits Rectangle {
    in property <TemplatePaneNodeData> panel;
    in property <[TemplatePaneNodeData]> nodes;
    in property <string> header_control_id;
    in property <string> title_control_id;
    in property <string> subtitle_control_id;
    in property <string> divider_control_id;
    in property <string> body_control_id;
    in property <string> row_control_id;
    in property <string> row_icon_control_id;
    in property <string> row_name_control_id;
    in property <string> row_count_control_id;
    in property <[AssetFolderData]> folders;
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: transparent;

    for header_node in root.nodes: Rectangle {
        visible: header_node.control_id == root.header_control_id;
        x: (header_node.frame.x - root.panel.frame.x) * 1px;
        y: (header_node.frame.y - root.panel.frame.y) * 1px;
        width: header_node.frame.width * 1px;
        height: header_node.frame.height * 1px;
        background: palette.chrome_bg_soft;

        for title_node in root.nodes: Text {
            visible: title_node.control_id == root.title_control_id;
            x: (title_node.frame.x - header_node.frame.x) * 1px;
            y: (title_node.frame.y - header_node.frame.y) * 1px;
            width: title_node.frame.width * 1px;
            height: title_node.frame.height * 1px;
            text: title_node.text;
            color: palette.text;
            font-size: title_node.font_size * 1px;
            font-weight: title_node.font_weight;
            vertical-alignment: center;
            overflow: elide;
        }

        for subtitle_node in root.nodes: Text {
            visible: subtitle_node.control_id == root.subtitle_control_id;
            x: (subtitle_node.frame.x - header_node.frame.x) * 1px;
            y: (subtitle_node.frame.y - header_node.frame.y) * 1px;
            width: subtitle_node.frame.width * 1px;
            height: subtitle_node.frame.height * 1px;
            text: subtitle_node.text;
            color: palette.text_dim;
            font-size: subtitle_node.font_size * 1px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    for divider_node in root.nodes: Rectangle {
        visible: divider_node.control_id == root.divider_control_id;
        x: (divider_node.frame.x - root.panel.frame.x) * 1px;
        y: (divider_node.frame.y - root.panel.frame.y) * 1px;
        width: divider_node.frame.width * 1px;
        height: divider_node.frame.height * 1px;
        background: palette.border_soft;
    }

    for body_node in root.nodes: Rectangle {
        visible: body_node.control_id == root.body_control_id;
        x: (body_node.frame.x - root.panel.frame.x) * 1px;
        y: (body_node.frame.y - root.panel.frame.y) * 1px;
        width: body_node.frame.width * 1px;
        height: body_node.frame.height * 1px;
        background: transparent;
        clip: true;

        for row_panel_node in root.nodes: Rectangle {
            visible: row_panel_node.control_id == root.row_control_id;
            width: 0px;
            height: 0px;
            background: transparent;

            for folder[index] in root.folders: Rectangle {
                x: (row_panel_node.frame.x - body_node.frame.x) * 1px;
                y: ((row_panel_node.frame.y - body_node.frame.y) + index * 32.0 - root.scroll_px) * 1px;
                width: row_panel_node.frame.width * 1px;
                height: row_panel_node.frame.height * 1px;
                border-radius: row_panel_node.corner_radius * 1px;
                background:
                    folder.selected ? #365880
                    : root.hovered_index == index ? palette.chrome_bg_soft
                    : transparent;

                for row_icon_node in root.nodes: ShellIcon {
                    visible: row_icon_node.control_id == root.row_icon_control_id;
                    x: (row_icon_node.frame.x - row_panel_node.frame.x + folder.depth * 12.0) * 1px;
                    y: (row_icon_node.frame.y - row_panel_node.frame.y) * 1px;
                    width: row_icon_node.frame.width * 1px;
                    height: row_icon_node.frame.height * 1px;
                    icon_key: "project";
                    icon_color: folder.selected ? #eef4ff : palette.text_muted;
                }

                for row_name_node in root.nodes: Text {
                    visible: row_name_node.control_id == root.row_name_control_id;
                    x: (row_name_node.frame.x - row_panel_node.frame.x + folder.depth * 12.0) * 1px;
                    y: (row_name_node.frame.y - row_panel_node.frame.y) * 1px;
                    width: max(row_name_node.frame.width - folder.depth * 12.0, 0.0) * 1px;
                    height: row_name_node.frame.height * 1px;
                    text: folder.name;
                    color: folder.selected ? #eef4ff : palette.text;
                    font-size: row_name_node.font_size * 1px;
                    vertical-alignment: center;
                    overflow: elide;
                }

                for row_count_node in root.nodes: Text {
                    visible: row_count_node.control_id == root.row_count_control_id;
                    x: (row_count_node.frame.x - row_panel_node.frame.x) * 1px;
                    y: (row_count_node.frame.y - row_panel_node.frame.y) * 1px;
                    width: row_count_node.frame.width * 1px;
                    height: row_count_node.frame.height * 1px;
                    text: folder.count;
                    color: folder.selected ? #dce8ff : palette.text_dim;
                    font-size: row_count_node.font_size * 1px;
                    vertical-alignment: center;
                    horizontal-alignment: right;
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + (body_node.frame.y - root.panel.frame.y),
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + (body_node.frame.y - root.panel.frame.y),
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + (body_node.frame.y - root.panel.frame.y),
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}
