                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    scroll-event(event) => {
                        root.details_pointer_scrolled(
                            self.mouse-x / 1px + details_scroll_body_node.frame.x - details_panel_node.frame.x,
                            self.mouse-y / 1px + details_scroll_body_node.frame.y - details_panel_node.frame.y,
                            event.delta_y / 1px,
                            details_panel_node.frame.width,
                            details_panel_node.frame.height,
                        );
                        accept
                    }
                }
            }
