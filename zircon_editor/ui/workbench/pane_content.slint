    for utility_panel_node in root.pane.nodes: AssetSurfaceFrame {
        visible: utility_panel_node.control_id == "AssetBrowserUtilityPanel";
        x: utility_panel_node.frame.x * 1px;
        y: utility_panel_node.frame.y * 1px;
        width: utility_panel_node.frame.width * 1px;
        height: utility_panel_node.frame.height * 1px;

        for utility_tabs_row_node in root.pane.nodes: Rectangle {
            visible: utility_tabs_row_node.control_id == "AssetBrowserUtilityTabsRow";
            x: (utility_tabs_row_node.frame.x - utility_panel_node.frame.x) * 1px;
            y: (utility_tabs_row_node.frame.y - utility_panel_node.frame.y) * 1px;
            width: utility_tabs_row_node.frame.width * 1px;
            height: utility_tabs_row_node.frame.height * 1px;
            background: transparent;

            for utility_tab_button_node in root.pane.nodes: ToolbarButton {
                visible:
                    utility_tab_button_node.control_id == "AssetBrowserPreviewTabButton"
                    || utility_tab_button_node.control_id == "AssetBrowserReferencesTabButton"
                    || utility_tab_button_node.control_id == "AssetBrowserMetadataTabButton"
                    || utility_tab_button_node.control_id == "AssetBrowserPluginsTabButton";
                x: (utility_tab_button_node.frame.x - utility_tabs_row_node.frame.x) * 1px;
                y: (utility_tab_button_node.frame.y - utility_tabs_row_node.frame.y) * 1px;
                width: utility_tab_button_node.frame.width * 1px;
                height: utility_tab_button_node.frame.height * 1px;
                min-width: utility_tab_button_node.frame.width * 1px;
                label: utility_tab_button_node.text;
                active:
                    utility_tab_button_node.control_id == "AssetBrowserPreviewTabButton"
                    ? root.utility_tab == "preview"
                    : utility_tab_button_node.control_id == "AssetBrowserReferencesTabButton"
                    ? root.utility_tab == "references"
                    : utility_tab_button_node.control_id == "AssetBrowserMetadataTabButton"
                    ? root.utility_tab == "metadata"
                    : root.utility_tab == "plugins";
                clicked => {
                    root.control_changed(
                        "SetUtilityTab",
                        utility_tab_button_node.control_id == "AssetBrowserPreviewTabButton"
                        ? "preview"
                        : utility_tab_button_node.control_id == "AssetBrowserReferencesTabButton"
                        ? "references"
                        : utility_tab_button_node.control_id == "AssetBrowserMetadataTabButton"
                        ? "metadata"
                        : "plugins",
                    );
                }
