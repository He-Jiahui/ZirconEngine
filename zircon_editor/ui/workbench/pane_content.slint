import { EmptyStateCard, Palette, ShellButton, ShellIcon, ToolbarButton } from "chrome.slint";
import { AssetFolderData, AssetItemData, AssetListView, AssetReferenceData, AssetSelectionData, AssetSelectionDetailsImage, AssetSelectionPreviewImage, AssetSurfaceFrame, KindChip, SearchField } from "assets.slint";
import { AnimationEditorPaneData, AssetBrowserPaneData, AssetsActivityPaneData, ConsolePaneData, HierarchyPaneData, InspectorPaneData, PaneData, ProjectOverviewData, ProjectOverviewPaneData } from "pane_data.slint";
import { CompactField, AxisField } from "pane_fields.slint";
import { FallbackPane } from "fallback_pane.slint";
import { PaneSurfaceHostContext } from "pane_surface_host_context.slint";
import { ProjectedReferencePanel } from "reference_panel_projection.slint";
import { TemplatePane } from "template_pane.slint";
import { ToolWindowEmptyState } from "tool_window_empty_state.slint";
import { UiAssetEditorPane } from "ui_asset_editor_pane.slint";
import { WelcomePane } from "welcome.slint";
import { ModulePluginsPane } from "module_plugins_pane.slint";

component HierarchyPaneView inherits Rectangle {
    in property <HierarchyPaneData> pane;
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: transparent;
    clip: true;

    for list_panel_node in root.pane.nodes: Rectangle {
        visible: list_panel_node.control_id == "HierarchyListPanel" || list_panel_node.control_id == "HierarchyTreeSlotAnchor";
        x: list_panel_node.frame.x * 1px;
        y: list_panel_node.frame.y * 1px;
        width: list_panel_node.frame.width * 1px;
        height: list_panel_node.frame.height * 1px;
        background: transparent;
        clip: true;

        rows := VerticalLayout {
            x: 0px;
            y: 0px - root.scroll_px * 1px;
            width: parent.width;
            spacing: 1px;

            for node[index] in root.pane.hierarchy_nodes: Rectangle {
                height: 22px;
                border-radius: 3px;
                background: node.selected ? #365880 : root.hovered_index == index ? palette.chrome_bg_soft : transparent;

                Text {
                    x: 10px + node.depth * 14px;
                    y: 4px;
                    text: node.name;
                    color: node.selected ? #eef4ff : palette.text_muted;
                    font-size: 11px;
                }
            }
        }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        moved => {
            root.pointer_moved(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
        }
        clicked => {
            root.pointer_clicked(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
        }
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }
    }
}

component InspectorPaneView inherits Rectangle {
    in property <InspectorPaneData> pane;
    in property <float> scroll_px: 0.0;
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback control_changed(control_id: string, value: string);
    callback control_clicked(control_id: string);

    palette := Palette {}
    background: transparent;
    clip: true;

    scroll_capture := TouchArea {
        width: parent.width;
        height: parent.height;
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }

        for content_panel_node in root.pane.nodes: Rectangle {
            visible: content_panel_node.control_id == "InspectorContentPanel" || content_panel_node.control_id == "InspectorBodySection";
            x: content_panel_node.control_id == "InspectorBodySection" ? 0px : content_panel_node.frame.x * 1px;
            y: content_panel_node.control_id == "InspectorBodySection" ? 0px : content_panel_node.frame.y * 1px;
            width: content_panel_node.control_id == "InspectorBodySection" ? parent.width : content_panel_node.frame.width * 1px;
            height: content_panel_node.control_id == "InspectorBodySection" ? parent.height : content_panel_node.frame.height * 1px;
            background: transparent;
            clip: true;

            content := Rectangle {
                x: 0px;
                y: 0px - root.scroll_px * 1px;
                width: parent.width;
                height: max(parent.height, 140px);
                background: transparent;

                for header_panel_node in root.pane.nodes: Rectangle {
                    visible: header_panel_node.control_id == "InspectorHeaderPanel";
                    x: (header_panel_node.frame.x - content_panel_node.frame.x) * 1px;
                    y: (header_panel_node.frame.y - content_panel_node.frame.y) * 1px;
                    width: header_panel_node.frame.width * 1px;
                    height: header_panel_node.frame.height * 1px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    background: palette.panel_bg_soft;

                    Text {
                        x: 8px;
                        y: 3px;
                        text: "Transform";
                        color: palette.text;
                        font-size: 11px;
                        font-weight: 600;
                    }

                    Text {
                        x: parent.width - self.preferred-width - 8px;
                        y: 4px;
                        text: root.pane.info;
                        color: palette.text_dim;
                        font-size: 9px;
                        overflow: elide;
                    }
                }

                for name_row_node in root.pane.nodes: Rectangle {
                    visible: name_row_node.control_id == "InspectorNameRow";
                    x: (name_row_node.frame.x - content_panel_node.frame.x) * 1px;
                    y: (name_row_node.frame.y - content_panel_node.frame.y) * 1px;
                    width: name_row_node.frame.width * 1px;
                    height: name_row_node.frame.height * 1px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Name";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    CompactField {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        text: root.pane.inspector_name;
                        placeholder: "Name";
                        edited(value) => { root.control_changed("NameField", value); }
                    }
                }

                for parent_row_node in root.pane.nodes: Rectangle {
                    visible: parent_row_node.control_id == "InspectorParentRow";
                    x: (parent_row_node.frame.x - content_panel_node.frame.x) * 1px;
                    y: (parent_row_node.frame.y - content_panel_node.frame.y) * 1px;
                    width: parent_row_node.frame.width * 1px;
                    height: parent_row_node.frame.height * 1px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Parent";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    CompactField {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        text: root.pane.inspector_parent;
                        placeholder: "Parent Id";
                        edited(value) => { root.control_changed("ParentField", value); }
                    }
                }

                for position_row_node in root.pane.nodes: Rectangle {
                    visible: position_row_node.control_id == "InspectorPositionRow";
                    x: (position_row_node.frame.x - content_panel_node.frame.x) * 1px;
                    y: (position_row_node.frame.y - content_panel_node.frame.y) * 1px;
                    width: position_row_node.frame.width * 1px;
                    height: position_row_node.frame.height * 1px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Position";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    HorizontalLayout {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        spacing: 4px;

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "X";
                            axis_color: #c75450;
                            value: root.pane.inspector_x;
                            edited(value) => { root.control_changed("PositionXField", value); }
                        }

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "Y";
                            axis_color: #7fb062;
                            value: root.pane.inspector_y;
                            edited(value) => { root.control_changed("PositionYField", value); }
                        }

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "Z";
                            axis_color: #5a88d2;
                            value: root.pane.inspector_z;
                            edited(value) => { root.control_changed("PositionZField", value); }
                        }
                    }
                }

                for separator_row_node in root.pane.nodes: Rectangle {
                    visible: separator_row_node.control_id == "InspectorSeparatorRow";
                    x: (separator_row_node.frame.x - content_panel_node.frame.x) * 1px;
                    y: (separator_row_node.frame.y - content_panel_node.frame.y) * 1px;
                    width: separator_row_node.frame.width * 1px;
                    height: separator_row_node.frame.height * 1px;
                    background: palette.border_soft;
                }

                for actions_row_node in root.pane.nodes: Rectangle {
                    visible: actions_row_node.control_id == "InspectorActionsRow";
                    x: (actions_row_node.frame.x - content_panel_node.frame.x) * 1px;
                    y: (actions_row_node.frame.y - content_panel_node.frame.y) * 1px;
                    width: actions_row_node.frame.width * 1px;
                    height: actions_row_node.frame.height * 1px;
                    background: transparent;

                    ShellButton {
                        x: parent.width - 126px;
                        y: 0px;
                        width: 58px;
                        label: "Apply";
                        active: true;
                        clicked => { root.control_clicked("ApplyBatchButton"); }
                    }

                    ShellButton {
                        x: parent.width - 62px;
                        y: 0px;
                        width: 58px;
                        label: "Delete";
                        active: false;
                        enabled: root.pane.delete_enabled;
                        clicked => { root.control_clicked("DeleteSelected"); }
                    }
                }

                if content_panel_node.control_id == "InspectorBodySection": Rectangle {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: max(parent.height, 152px);
                    background: transparent;

                    header_panel := Rectangle {
                        x: 0px;
                        y: 0px;
                        width: parent.width;
                        height: 26px;
                        border-width: 1px;
                        border-color: palette.border_soft;
                        background: palette.panel_bg_soft;

                        Text {
                            x: 8px;
                            y: 3px;
                            text: "Transform";
                            color: palette.text;
                            font-size: 11px;
                            font-weight: 600;
                        }

                        Text {
                            x: max(8px, parent.width - self.preferred-width - 134px);
                            y: 4px;
                            text: root.pane.info;
                            color: palette.text_dim;
                            font-size: 9px;
                            overflow: elide;
                        }

                        for apply_action_node in root.pane.nodes: ShellButton {
                            visible: apply_action_node.control_id == "ApplyDraft";
                            x: parent.width - 126px;
                            y: 2px;
                            width: 58px;
                            label: apply_action_node.text != "" ? apply_action_node.text : "Apply";
                            active: true;
                            clicked => { root.control_clicked("ApplyBatchButton"); }
                        }

                        ShellButton {
                            x: parent.width - 62px;
                            y: 2px;
                            width: 58px;
                            label: "Delete";
                            active: false;
                            enabled: root.pane.delete_enabled;
                            clicked => { root.control_clicked("DeleteSelected"); }
                        }
                    }

                    Rectangle {
                        x: 0px;
                        y: 38px;
                        width: parent.width;
                        height: 24px;
                        background: transparent;

                        Text {
                            x: 0px;
                            y: 4px;
                            width: 58px;
                            text: "Name";
                            color: palette.text_dim;
                            font-size: 10px;
                        }

                        CompactField {
                            x: 62px;
                            y: 0px;
                            width: parent.width - 62px;
                            text: root.pane.inspector_name;
                            placeholder: "Name";
                            edited(value) => { root.control_changed("NameField", value); }
                        }
                    }

                    Rectangle {
                        x: 0px;
                        y: 68px;
                        width: parent.width;
                        height: 24px;
                        background: transparent;

                        Text {
                            x: 0px;
                            y: 4px;
                            width: 58px;
                            text: "Parent";
                            color: palette.text_dim;
                            font-size: 10px;
                        }

                        CompactField {
                            x: 62px;
                            y: 0px;
                            width: parent.width - 62px;
                            text: root.pane.inspector_parent;
                            placeholder: "Parent Id";
                            edited(value) => { root.control_changed("ParentField", value); }
                        }
                    }

                    Rectangle {
                        x: 0px;
                        y: 98px;
                        width: parent.width;
                        height: 24px;
                        background: transparent;

                        Text {
                            x: 0px;
                            y: 4px;
                            width: 58px;
                            text: "Position";
                            color: palette.text_dim;
                            font-size: 10px;
                        }

                        HorizontalLayout {
                            x: 62px;
                            y: 0px;
                            width: parent.width - 62px;
                            spacing: 4px;

                            AxisField {
                                width: (parent.width - 8px) / 3;
                                axis: "X";
                                axis_color: #c75450;
                                value: root.pane.inspector_x;
                                edited(value) => { root.control_changed("PositionXField", value); }
                            }

                            AxisField {
                                width: (parent.width - 8px) / 3;
                                axis: "Y";
                                axis_color: #7fb062;
                                value: root.pane.inspector_y;
                                edited(value) => { root.control_changed("PositionYField", value); }
                            }

                            AxisField {
                                width: (parent.width - 8px) / 3;
                                axis: "Z";
                                axis_color: #5a88d2;
                                value: root.pane.inspector_z;
                                edited(value) => { root.control_changed("PositionZField", value); }
                            }
                        }
                    }
                }
            }
        }
    }
}

component ConsolePaneView inherits Rectangle {
    in property <ConsolePaneData> pane;
    in property <bool> show_empty;
    in property <string> empty_body;
    in property <float> scroll_px: 0.0;
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    background: #17191c;
    clip: true;

    for text_panel_node in root.pane.nodes: Rectangle {
        visible: text_panel_node.control_id == "ConsoleBodySection";
        x: text_panel_node.frame.x * 1px;
        y: text_panel_node.frame.y * 1px;
        width: text_panel_node.frame.width * 1px;
        height: text_panel_node.frame.height * 1px;
        background: transparent;
        clip: true;

        lines := VerticalLayout {
            x: 0px;
            y: 0px - root.scroll_px * 1px;
            width: parent.width;
            spacing: 6px;

            if root.show_empty: Text {
                text: root.pane.status_text != "" ? "> " + root.pane.status_text : "> No output yet";
                color: #c3ccd8;
                font-size: 11px;
                font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                wrap: word-wrap;
            }

            if root.show_empty && root.empty_body != "": Text {
                text: root.empty_body;
                color: #8893a0;
                font-size: 10px;
                wrap: word-wrap;
            }

            if !root.show_empty: Text {
                text: root.pane.status_text;
                color: #c3ccd8;
                font-size: 11px;
                font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                wrap: word-wrap;
            }
        }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }
    }
}

component AnimationListSection inherits Rectangle {
    in property <string> title;
    in property <[string]> items;

    palette := Palette {}
    height: title_text.height + (root.items.length > 0 ? root.items.length * 20px : 20px) + 8px;
    background: transparent;

    title_text := Text {
        x: 0px;
        y: 0px;
        text: root.title;
        color: palette.text;
        font-size: 11px;
    }

    item_column := Rectangle {
        x: 0px;
        y: title_text.height + 4px;
        width: parent.width;
        height: parent.height - self.y;
        background: transparent;

        VerticalLayout {
            x: 0px;
            y: 0px;
            width: parent.width;
            spacing: 2px;

            for item[index] in root.items: Rectangle {
                height: 18px;
                border-radius: 3px;
                background: palette.panel_bg_soft;

                Text {
                    x: 8px;
                    y: 2px;
                    width: parent.width - 16px;
                    height: parent.height - 4px;
                    text: item;
                    color: palette.text_muted;
                    font-size: 11px;
                    overflow: elide;
                }
            }

            if root.items.length == 0: Rectangle {
                height: 18px;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: "No Items";
                    color: palette.text_dim;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }
    }
}

component AnimationEditorPaneView inherits Rectangle {
    in property <AnimationEditorPaneData> pane;

    palette := Palette {}
    background: palette.panel_bg;
    clip: true;

    for header_panel_node in root.pane.nodes: Rectangle {
        visible: header_panel_node.control_id == "AnimationEditorHeaderPanel" || header_panel_node.control_id == "ScrubTimeline" || header_panel_node.control_id == "AddNode";
        x: header_panel_node.frame.x * 1px;
        y: header_panel_node.frame.y * 1px;
        width: header_panel_node.frame.width * 1px;
        height: header_panel_node.frame.height * 1px;
        background: palette.panel_bg_soft;
        clip: true;

        for header_mode_row_node in root.pane.nodes: Text {
            visible: header_mode_row_node.control_id == "AnimationEditorHeaderModeRow";
            x: (header_mode_row_node.frame.x - header_panel_node.frame.x) * 1px;
            y: (header_mode_row_node.frame.y - header_panel_node.frame.y) * 1px;
            width: header_mode_row_node.frame.width * 1px;
            height: header_mode_row_node.frame.height * 1px;
            text: root.pane.mode;
            color: palette.accent;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }

        for header_path_row_node in root.pane.nodes: Text {
            visible: header_path_row_node.control_id == "AnimationEditorHeaderPathRow";
            x: (header_path_row_node.frame.x - header_panel_node.frame.x) * 1px;
            y: (header_path_row_node.frame.y - header_panel_node.frame.y) * 1px;
            width: header_path_row_node.frame.width * 1px;
            height: header_path_row_node.frame.height * 1px;
            text: root.pane.asset_path;
            color: palette.text;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }

        for header_status_row_node in root.pane.nodes: Text {
            visible: header_status_row_node.control_id == "AnimationEditorHeaderStatusRow";
            x: (header_status_row_node.frame.x - header_panel_node.frame.x) * 1px;
            y: (header_status_row_node.frame.y - header_panel_node.frame.y) * 1px;
            width: header_status_row_node.frame.width * 1px;
            height: header_status_row_node.frame.height * 1px;
            text:
                root.pane.status != "" ? root.pane.status :
                root.pane.selection != "" ? root.pane.selection :
                root.pane.playback_label;
            color: palette.text_muted;
            font-size: 11px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    for body_panel_node in root.pane.nodes: Rectangle {
        visible: body_panel_node.control_id == "AnimationEditorBodyPanel" || body_panel_node.control_id == "AnimationTimelineSlotAnchor" || body_panel_node.control_id == "AnimationGraphCanvasSlotAnchor";
        x: body_panel_node.frame.x * 1px;
        y: body_panel_node.frame.y * 1px;
        width: body_panel_node.frame.width * 1px;
        height: body_panel_node.frame.height * 1px;
        background: palette.panel_bg;
        clip: true;

        for sequence_content_panel_node in root.pane.nodes: Rectangle {
            visible:
                root.pane.mode == "sequence" &&
                (sequence_content_panel_node.control_id == "AnimationSequenceContentPanel" || sequence_content_panel_node.control_id == "AnimationTimelineSlotAnchor");
            x: (sequence_content_panel_node.frame.x - body_panel_node.frame.x) * 1px;
            y: (sequence_content_panel_node.frame.y - body_panel_node.frame.y) * 1px;
            width: sequence_content_panel_node.frame.width * 1px;
            height: sequence_content_panel_node.frame.height * 1px;
            background: transparent;
            clip: true;

            for sequence_timeline_row_node in root.pane.nodes: Text {
                visible: sequence_timeline_row_node.control_id == "AnimationSequenceTimelineRow";
                x: (sequence_timeline_row_node.frame.x - sequence_content_panel_node.frame.x) * 1px;
                y: (sequence_timeline_row_node.frame.y - sequence_content_panel_node.frame.y) * 1px;
                width: sequence_timeline_row_node.frame.width * 1px;
                height: sequence_timeline_row_node.frame.height * 1px;
                text: "Frame " + root.pane.current_frame + " • Range " + root.pane.timeline_start_frame + ".." + root.pane.timeline_end_frame + " • " + root.pane.playback_label;
                color: palette.text;
                font-size: 11px;
                vertical-alignment: center;
                overflow: elide;
            }

            for sequence_selection_row_node in root.pane.nodes: Text {
                visible: sequence_selection_row_node.control_id == "AnimationSequenceSelectionRow";
                x: (sequence_selection_row_node.frame.x - sequence_content_panel_node.frame.x) * 1px;
                y: (sequence_selection_row_node.frame.y - sequence_content_panel_node.frame.y) * 1px;
                width: sequence_selection_row_node.frame.width * 1px;
                height: sequence_selection_row_node.frame.height * 1px;
                text:
                    root.pane.selection != "" ? root.pane.selection :
                    root.pane.playback_label != "" ? root.pane.playback_label :
                    "No timeline selection";
                color: palette.text_muted;
                font-size: 11px;
                vertical-alignment: center;
                overflow: elide;
            }

            for sequence_tracks_panel_node in root.pane.nodes: AnimationListSection {
                visible: sequence_tracks_panel_node.control_id == "AnimationSequenceTracksPanel";
                x: (sequence_tracks_panel_node.frame.x - sequence_content_panel_node.frame.x) * 1px;
                y: (sequence_tracks_panel_node.frame.y - sequence_content_panel_node.frame.y) * 1px;
                width: sequence_tracks_panel_node.frame.width * 1px;
                title: "Tracks";
                items: root.pane.track_items;
            }
        }

        for graph_content_panel_node in root.pane.nodes: Rectangle {
            visible:
                root.pane.mode == "graph" &&
                (graph_content_panel_node.control_id == "AnimationGraphContentPanel" || graph_content_panel_node.control_id == "AnimationGraphCanvasSlotAnchor");
            x: (graph_content_panel_node.frame.x - body_panel_node.frame.x) * 1px;
            y: (graph_content_panel_node.frame.y - body_panel_node.frame.y) * 1px;
            width: graph_content_panel_node.frame.width * 1px;
            height: graph_content_panel_node.frame.height * 1px;
            background: transparent;
            clip: true;

            for graph_parameters_panel_node in root.pane.nodes: AnimationListSection {
                visible: graph_parameters_panel_node.control_id == "AnimationGraphParametersPanel";
                x: (graph_parameters_panel_node.frame.x - graph_content_panel_node.frame.x) * 1px;
                y: (graph_parameters_panel_node.frame.y - graph_content_panel_node.frame.y) * 1px;
                width: graph_parameters_panel_node.frame.width * 1px;
                title: "Parameters";
                items: root.pane.parameter_items;
            }

            for graph_nodes_panel_node in root.pane.nodes: AnimationListSection {
                visible: graph_nodes_panel_node.control_id == "AnimationGraphNodesPanel";
                x: (graph_nodes_panel_node.frame.x - graph_content_panel_node.frame.x) * 1px;
                y: (graph_nodes_panel_node.frame.y - graph_content_panel_node.frame.y) * 1px;
                width: graph_nodes_panel_node.frame.width * 1px;
                title: "Nodes";
                items: root.pane.node_items;
            }
        }

        for state_machine_content_panel_node in root.pane.nodes: Rectangle {
            visible:
                root.pane.mode == "state_machine" &&
                state_machine_content_panel_node.control_id == "AnimationStateMachineContentPanel";
            x: (state_machine_content_panel_node.frame.x - body_panel_node.frame.x) * 1px;
            y: (state_machine_content_panel_node.frame.y - body_panel_node.frame.y) * 1px;
            width: state_machine_content_panel_node.frame.width * 1px;
            height: state_machine_content_panel_node.frame.height * 1px;
            background: transparent;
            clip: true;

            for state_machine_entry_row_node in root.pane.nodes: Text {
                visible: state_machine_entry_row_node.control_id == "AnimationStateMachineEntryRow";
                x: (state_machine_entry_row_node.frame.x - state_machine_content_panel_node.frame.x) * 1px;
                y: (state_machine_entry_row_node.frame.y - state_machine_content_panel_node.frame.y) * 1px;
                width: state_machine_entry_row_node.frame.width * 1px;
                height: state_machine_entry_row_node.frame.height * 1px;
                text: "Entry: " + root.pane.selection;
                color: palette.text;
                font-size: 11px;
                vertical-alignment: center;
                overflow: elide;
            }

            for state_machine_states_panel_node in root.pane.nodes: AnimationListSection {
                visible: state_machine_states_panel_node.control_id == "AnimationStateMachineStatesPanel";
                x: (state_machine_states_panel_node.frame.x - state_machine_content_panel_node.frame.x) * 1px;
                y: (state_machine_states_panel_node.frame.y - state_machine_content_panel_node.frame.y) * 1px;
                width: state_machine_states_panel_node.frame.width * 1px;
                title: "States";
                items: root.pane.state_items;
            }

            for state_machine_transitions_panel_node in root.pane.nodes: AnimationListSection {
                visible: state_machine_transitions_panel_node.control_id == "AnimationStateMachineTransitionsPanel";
                x: (state_machine_transitions_panel_node.frame.x - state_machine_content_panel_node.frame.x) * 1px;
                y: (state_machine_transitions_panel_node.frame.y - state_machine_content_panel_node.frame.y) * 1px;
                width: state_machine_transitions_panel_node.frame.width * 1px;
                title: "Transitions";
                items: root.pane.transition_items;
            }
        }
    }
}

component AssetsActivityPaneView inherits Rectangle {
    in property <AssetsActivityPaneData> pane;
    in property <[AssetFolderData]> folder_tree;
    in property <[AssetFolderData]> content_folders;
    in property <[AssetItemData]> content_items;
    in property <AssetSelectionData> selection;
    in property <[AssetReferenceData]> references;
    in property <[AssetReferenceData]> used_by;
    in property <string> search_query;
    in property <string> kind_filter;
    in property <string> view_mode;
    in property <string> utility_tab;
    in property <int> tree_hovered_index: -1;
    in property <float> tree_scroll_px: 0.0;
    in property <int> content_hovered_index: -1;
    in property <float> content_scroll_px: 0.0;
    in property <int> references_hovered_index: -1;
    in property <float> references_scroll_px: 0.0;
    in property <int> used_by_hovered_index: -1;
    in property <float> used_by_scroll_px: 0.0;
    callback control_changed(control_id: string, value: string);
    callback control_clicked(control_id: string);
    callback tree_pointer_clicked(x: float, y: float, width: float, height: float);
    callback tree_pointer_moved(x: float, y: float, width: float, height: float);
    callback tree_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback content_pointer_clicked(x: float, y: float, width: float, height: float);
    callback content_pointer_moved(x: float, y: float, width: float, height: float);
    callback content_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback reference_pointer_clicked(list_kind: string, x: float, y: float, width: float, height: float);
    callback reference_pointer_moved(list_kind: string, x: float, y: float, width: float, height: float);
    callback reference_pointer_scrolled(list_kind: string, x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: transparent;
    clip: true;

    for toolbar_panel_node in root.pane.nodes: AssetSurfaceFrame {
        visible: toolbar_panel_node.control_id == "AssetsActivityToolbarPanel";
        x: toolbar_panel_node.frame.x * 1px;
        y: toolbar_panel_node.frame.y * 1px;
        width: toolbar_panel_node.frame.width * 1px;
        height: toolbar_panel_node.frame.height * 1px;
        background: palette.chrome_bg_soft;

        for toolbar_title_row_node in root.pane.nodes: Rectangle {
            visible: toolbar_title_row_node.control_id == "AssetsActivityToolbarTitleRow";
            x: (toolbar_title_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (toolbar_title_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: toolbar_title_row_node.frame.width * 1px;
            height: toolbar_title_row_node.frame.height * 1px;
            background: transparent;

            for toolbar_title_text_node in root.pane.nodes: Text {
                visible: toolbar_title_text_node.control_id == "AssetsActivityTitleText";
                x: (toolbar_title_text_node.frame.x - toolbar_title_row_node.frame.x) * 1px;
                y: (toolbar_title_text_node.frame.y - toolbar_title_row_node.frame.y) * 1px;
                width: toolbar_title_text_node.frame.width * 1px;
                height: toolbar_title_text_node.frame.height * 1px;
                text: toolbar_title_text_node.text;
                color: palette.text;
                font-size: toolbar_title_text_node.font_size * 1px;
                font-weight: toolbar_title_text_node.font_weight;
                vertical-alignment: center;
                overflow: elide;
            }

            for open_browser_button_node in root.pane.nodes: ShellButton {
                visible: open_browser_button_node.control_id == "OpenAssetBrowser";
                x: (open_browser_button_node.frame.x - toolbar_title_row_node.frame.x) * 1px;
                y: (open_browser_button_node.frame.y - toolbar_title_row_node.frame.y) * 1px;
                width: open_browser_button_node.frame.width * 1px;
                height: open_browser_button_node.frame.height * 1px;
                label: open_browser_button_node.text;
                active: false;
                clicked => { root.control_clicked("OpenAssetBrowser"); }
            }
        }

        for toolbar_subtitle_row_node in root.pane.nodes: Rectangle {
            visible: toolbar_subtitle_row_node.control_id == "AssetsActivityToolbarSubtitleRow";
            x: (toolbar_subtitle_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (toolbar_subtitle_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: toolbar_subtitle_row_node.frame.width * 1px;
            height: toolbar_subtitle_row_node.frame.height * 1px;
            background: transparent;

            for toolbar_subtitle_text_node in root.pane.nodes: Text {
                visible: toolbar_subtitle_text_node.control_id == "AssetsActivitySubtitleText";
                x: (toolbar_subtitle_text_node.frame.x - toolbar_subtitle_row_node.frame.x) * 1px;
                y: (toolbar_subtitle_text_node.frame.y - toolbar_subtitle_row_node.frame.y) * 1px;
                width: toolbar_subtitle_text_node.frame.width * 1px;
                height: toolbar_subtitle_text_node.frame.height * 1px;
                text: toolbar_subtitle_text_node.text;
                color: palette.text_dim;
                font-size: toolbar_subtitle_text_node.font_size * 1px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        for toolbar_search_row_node in root.pane.nodes: Rectangle {
            visible: toolbar_search_row_node.control_id == "AssetsActivityToolbarSearchRow";
            x: (toolbar_search_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (toolbar_search_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: toolbar_search_row_node.frame.width * 1px;
            height: toolbar_search_row_node.frame.height * 1px;
            background: transparent;

            for search_field_node in root.pane.nodes: SearchField {
                visible: search_field_node.control_id == "SearchEdited";
                x: (search_field_node.frame.x - toolbar_search_row_node.frame.x) * 1px;
                y: (search_field_node.frame.y - toolbar_search_row_node.frame.y) * 1px;
                width: search_field_node.frame.width * 1px;
                height: search_field_node.frame.height * 1px;
                text: root.search_query;
                placeholder: "Search assets";
                edited(value) => { root.control_changed("SearchEdited", value); }
            }

            for view_mode_button_node in root.pane.nodes: ToolbarButton {
                visible: view_mode_button_node.control_id == "AssetsActivityViewModeListButton";
                x: (view_mode_button_node.frame.x - toolbar_search_row_node.frame.x) * 1px;
                y: (view_mode_button_node.frame.y - toolbar_search_row_node.frame.y) * 1px;
                width: view_mode_button_node.frame.width * 1px;
                height: view_mode_button_node.frame.height * 1px;
                min-width: view_mode_button_node.frame.width * 1px;
                label: view_mode_button_node.text;
                active: root.view_mode == "list";
                clicked => { root.control_changed("SetViewMode", "list"); }
            }

            for view_mode_button_node in root.pane.nodes: ToolbarButton {
                visible: view_mode_button_node.control_id == "AssetsActivityViewModeThumbButton";
                x: (view_mode_button_node.frame.x - toolbar_search_row_node.frame.x) * 1px;
                y: (view_mode_button_node.frame.y - toolbar_search_row_node.frame.y) * 1px;
                width: view_mode_button_node.frame.width * 1px;
                height: view_mode_button_node.frame.height * 1px;
                min-width: view_mode_button_node.frame.width * 1px;
                label: view_mode_button_node.text;
                active: root.view_mode == "thumbnail";
                clicked => { root.control_changed("SetViewMode", "thumbnail"); }
            }
        }

        for kind_primary_row_node in root.pane.nodes: Rectangle {
            visible: kind_primary_row_node.control_id == "AssetsActivityToolbarKindPrimaryRow";
            x: (kind_primary_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (kind_primary_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: kind_primary_row_node.frame.width * 1px;
            height: kind_primary_row_node.frame.height * 1px;
            background: transparent;

            for kind_primary_chip_node in root.pane.nodes: KindChip {
                visible: kind_primary_chip_node.control_id == "AssetsActivityKindAllChip";
                x: (kind_primary_chip_node.frame.x - kind_primary_row_node.frame.x) * 1px;
                y: (kind_primary_chip_node.frame.y - kind_primary_row_node.frame.y) * 1px;
                width: kind_primary_chip_node.frame.width * 1px;
                height: kind_primary_chip_node.frame.height * 1px;
                label: kind_primary_chip_node.text;
                active: root.kind_filter == "" || root.kind_filter == "All";
                clicked => { root.control_changed("SetKindFilter", ""); }
            }

            for kind_primary_chip_node in root.pane.nodes: KindChip {
                visible: kind_primary_chip_node.control_id == "AssetsActivityKindTextureChip";
                x: (kind_primary_chip_node.frame.x - kind_primary_row_node.frame.x) * 1px;
                y: (kind_primary_chip_node.frame.y - kind_primary_row_node.frame.y) * 1px;
                width: kind_primary_chip_node.frame.width * 1px;
                height: kind_primary_chip_node.frame.height * 1px;
                label: kind_primary_chip_node.text;
                active: root.kind_filter == "Texture";
                clicked => { root.control_changed("SetKindFilter", "Texture"); }
            }

            for kind_primary_chip_node in root.pane.nodes: KindChip {
                visible: kind_primary_chip_node.control_id == "AssetsActivityKindMaterialChip";
                x: (kind_primary_chip_node.frame.x - kind_primary_row_node.frame.x) * 1px;
                y: (kind_primary_chip_node.frame.y - kind_primary_row_node.frame.y) * 1px;
                width: kind_primary_chip_node.frame.width * 1px;
                height: kind_primary_chip_node.frame.height * 1px;
                label: kind_primary_chip_node.text;
                active: root.kind_filter == "Material";
                clicked => { root.control_changed("SetKindFilter", "Material"); }
            }

            for kind_primary_chip_node in root.pane.nodes: KindChip {
                visible: kind_primary_chip_node.control_id == "AssetsActivityKindSceneChip";
                x: (kind_primary_chip_node.frame.x - kind_primary_row_node.frame.x) * 1px;
                y: (kind_primary_chip_node.frame.y - kind_primary_row_node.frame.y) * 1px;
                width: kind_primary_chip_node.frame.width * 1px;
                height: kind_primary_chip_node.frame.height * 1px;
                label: kind_primary_chip_node.text;
                active: root.kind_filter == "Scene";
                clicked => { root.control_changed("SetKindFilter", "Scene"); }
            }

            for kind_primary_chip_node in root.pane.nodes: KindChip {
                visible: kind_primary_chip_node.control_id == "AssetsActivityKindModelChip";
                x: (kind_primary_chip_node.frame.x - kind_primary_row_node.frame.x) * 1px;
                y: (kind_primary_chip_node.frame.y - kind_primary_row_node.frame.y) * 1px;
                width: kind_primary_chip_node.frame.width * 1px;
                height: kind_primary_chip_node.frame.height * 1px;
                label: kind_primary_chip_node.text;
                active: root.kind_filter == "Model";
                clicked => { root.control_changed("SetKindFilter", "Model"); }
            }

            for kind_primary_chip_node in root.pane.nodes: KindChip {
                visible: kind_primary_chip_node.control_id == "AssetsActivityKindShaderChip";
                x: (kind_primary_chip_node.frame.x - kind_primary_row_node.frame.x) * 1px;
                y: (kind_primary_chip_node.frame.y - kind_primary_row_node.frame.y) * 1px;
                width: kind_primary_chip_node.frame.width * 1px;
                height: kind_primary_chip_node.frame.height * 1px;
                label: kind_primary_chip_node.text;
                active: root.kind_filter == "Shader";
                clicked => { root.control_changed("SetKindFilter", "Shader"); }
            }
        }

        for kind_secondary_row_node in root.pane.nodes: Rectangle {
            visible: kind_secondary_row_node.control_id == "AssetsActivityToolbarKindSecondaryRow";
            x: (kind_secondary_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (kind_secondary_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: kind_secondary_row_node.frame.width * 1px;
            height: kind_secondary_row_node.frame.height * 1px;
            background: transparent;

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetsActivityKindPhysicsChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "PhysicsMaterial";
                clicked => { root.control_changed("SetKindFilter", "PhysicsMaterial"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetsActivityKindSkeletonChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationSkeleton";
                clicked => { root.control_changed("SetKindFilter", "AnimationSkeleton"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetsActivityKindClipChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationClip";
                clicked => { root.control_changed("SetKindFilter", "AnimationClip"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetsActivityKindSequenceChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationSequence";
                clicked => { root.control_changed("SetKindFilter", "AnimationSequence"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetsActivityKindGraphChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationGraph";
                clicked => { root.control_changed("SetKindFilter", "AnimationGraph"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetsActivityKindStateChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationStateMachine";
                clicked => { root.control_changed("SetKindFilter", "AnimationStateMachine"); }
            }
        }
    }

    for main_panel_node in root.pane.nodes: Rectangle {
        visible: main_panel_node.control_id == "AssetsActivityMainPanel";
        x: main_panel_node.frame.x * 1px;
        y: main_panel_node.frame.y * 1px;
        width: main_panel_node.frame.width * 1px;
        height: main_panel_node.frame.height * 1px;
        background: transparent;

        for tree_panel_node in root.pane.nodes: AssetSurfaceFrame {
            visible: tree_panel_node.control_id == "AssetsActivityTreePanel";
            x: (tree_panel_node.frame.x - main_panel_node.frame.x) * 1px;
            y: (tree_panel_node.frame.y - main_panel_node.frame.y) * 1px;
            width: tree_panel_node.frame.width * 1px;
            height: tree_panel_node.frame.height * 1px;

            for tree_header_panel_node in root.pane.nodes: Rectangle {
                visible: tree_header_panel_node.control_id == "AssetsActivityTreeHeaderPanel";
                x: (tree_header_panel_node.frame.x - tree_panel_node.frame.x) * 1px;
                y: (tree_header_panel_node.frame.y - tree_panel_node.frame.y) * 1px;
                width: tree_header_panel_node.frame.width * 1px;
                height: tree_header_panel_node.frame.height * 1px;
                background: palette.chrome_bg_soft;

                for tree_title_node in root.pane.nodes: Text {
                    visible: tree_title_node.control_id == "AssetsActivityTreeTitleText";
                    x: (tree_title_node.frame.x - tree_header_panel_node.frame.x) * 1px;
                    y: (tree_title_node.frame.y - tree_header_panel_node.frame.y) * 1px;
                    width: tree_title_node.frame.width * 1px;
                    height: tree_title_node.frame.height * 1px;
                    text: tree_title_node.text;
                    color: palette.text;
                    font-size: tree_title_node.font_size * 1px;
                    font-weight: tree_title_node.font_weight;
                }

                for tree_subtitle_node in root.pane.nodes: Text {
                    visible: tree_subtitle_node.control_id == "AssetsActivityTreeSubtitleText";
                    x: (tree_subtitle_node.frame.x - tree_header_panel_node.frame.x) * 1px;
                    y: (tree_subtitle_node.frame.y - tree_header_panel_node.frame.y) * 1px;
                    width: tree_subtitle_node.frame.width * 1px;
                    height: tree_subtitle_node.frame.height * 1px;
                    text: tree_subtitle_node.text;
                    color: palette.text_dim;
                    font-size: tree_subtitle_node.font_size * 1px;
                    overflow: elide;
                }
            }

            for tree_divider_node in root.pane.nodes: Rectangle {
                visible: tree_divider_node.control_id == "AssetsActivityTreeDivider";
                x: (tree_divider_node.frame.x - tree_panel_node.frame.x) * 1px;
                y: (tree_divider_node.frame.y - tree_panel_node.frame.y) * 1px;
                width: tree_divider_node.frame.width * 1px;
                height: tree_divider_node.frame.height * 1px;
                background: palette.border_soft;
            }

            for tree_scroll_body_node in root.pane.nodes: Rectangle {
                visible: tree_scroll_body_node.control_id == "AssetsActivityTreeScrollBody";
                x: (tree_scroll_body_node.frame.x - tree_panel_node.frame.x) * 1px;
                y: (tree_scroll_body_node.frame.y - tree_panel_node.frame.y) * 1px;
                width: tree_scroll_body_node.frame.width * 1px;
                height: tree_scroll_body_node.frame.height * 1px;
                background: transparent;
                clip: true;

                for tree_row_panel_node in root.pane.nodes: VerticalLayout {
                    visible: tree_row_panel_node.control_id == "AssetsActivityTreeRowPanel";
                    x: tree_row_panel_node.frame.x * 1px;
                    y: tree_row_panel_node.frame.y * 1px - root.tree_scroll_px * 1px;
                    width: tree_scroll_body_node.frame.width * 1px - 16px;
                    spacing: 4px;

                    for folder[index] in root.folder_tree: Rectangle {
                        height: tree_row_panel_node.frame.height * 1px;
                        border-radius: tree_row_panel_node.corner_radius * 1px;
                        background: folder.selected ? #365880 : root.tree_hovered_index == index ? palette.chrome_bg_soft : transparent;

                        for tree_row_icon_node in root.pane.nodes: ShellIcon {
                            visible: tree_row_icon_node.control_id == "AssetsActivityTreeRowIcon";
                            x: tree_row_icon_node.frame.x * 1px + folder.depth * 12px;
                            y: tree_row_icon_node.frame.y * 1px;
                            width: tree_row_icon_node.frame.width * 1px;
                            height: tree_row_icon_node.frame.height * 1px;
                            icon_key: "project";
                            icon_color: folder.selected ? #eef4ff : palette.text_muted;
                        }

                        for tree_row_name_node in root.pane.nodes: Text {
                            visible: tree_row_name_node.control_id == "AssetsActivityTreeRowNameText";
                            x: tree_row_name_node.frame.x * 1px + folder.depth * 12px;
                            y: tree_row_name_node.frame.y * 1px;
                            width: parent.width - (52px + folder.depth * 12px);
                            height: tree_row_name_node.frame.height * 1px;
                            text: folder.name;
                            color: folder.selected ? #eef4ff : palette.text;
                            font-size: tree_row_name_node.font_size * 1px;
                            overflow: elide;
                        }

                        for tree_row_count_node in root.pane.nodes: Text {
                            visible: tree_row_count_node.control_id == "AssetsActivityTreeRowCountText";
                            x: parent.width - 34px;
                            y: tree_row_count_node.frame.y * 1px;
                            width: tree_row_count_node.frame.width * 1px;
                            height: tree_row_count_node.frame.height * 1px;
                            horizontal-alignment: right;
                            text: folder.count;
                            color: folder.selected ? #dce8ff : palette.text_dim;
                            font-size: tree_row_count_node.font_size * 1px;
                        }
                    }
                }

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    moved => { root.tree_pointer_moved(self.mouse-x / 1px, self.mouse-y / 1px + tree_scroll_body_node.frame.y + 1.0, root.width / 1px, root.height / 1px); }
                    clicked => { root.tree_pointer_clicked(self.mouse-x / 1px, self.mouse-y / 1px + tree_scroll_body_node.frame.y + 1.0, root.width / 1px, root.height / 1px); }
                    scroll-event(event) => {
                        root.tree_pointer_scrolled(self.mouse-x / 1px, self.mouse-y / 1px + tree_scroll_body_node.frame.y + 1.0, event.delta_y / 1px, root.width / 1px, root.height / 1px);
                        accept
                    }
                }
            }
        }

        for content_panel_node in root.pane.nodes: AssetListView {
            visible: content_panel_node.control_id == "AssetsActivityContentPanel";
            x: (content_panel_node.frame.x - main_panel_node.frame.x) * 1px;
            y: (content_panel_node.frame.y - main_panel_node.frame.y) * 1px;
            width: content_panel_node.frame.width * 1px;
            height: content_panel_node.frame.height * 1px;
            title: "Content";
            subtitle: "Folder first • name sort";
            folders: root.content_folders;
            items: root.content_items;
            view_mode: root.view_mode;
            hovered_index: root.content_hovered_index;
            scroll_px: root.content_scroll_px;
            pointer_clicked(x, y, width, height) => { root.content_pointer_clicked(x, y, width, height); }
            pointer_moved(x, y, width, height) => { root.content_pointer_moved(x, y, width, height); }
            pointer_scrolled(x, y, delta, width, height) => { root.content_pointer_scrolled(x, y, delta, width, height); }
        }
    }

    for utility_panel_node in root.pane.nodes: AssetSurfaceFrame {
        visible: utility_panel_node.control_id == "AssetsActivityUtilityPanel";
        x: utility_panel_node.frame.x * 1px;
        y: utility_panel_node.frame.y * 1px;
        width: utility_panel_node.frame.width * 1px;
        height: utility_panel_node.frame.height * 1px;

        for utility_tabs_row_node in root.pane.nodes: Rectangle {
            visible: utility_tabs_row_node.control_id == "AssetsActivityUtilityTabsRow";
            x: (utility_tabs_row_node.frame.x - utility_panel_node.frame.x) * 1px;
            y: (utility_tabs_row_node.frame.y - utility_panel_node.frame.y) * 1px;
            width: utility_tabs_row_node.frame.width * 1px;
            height: utility_tabs_row_node.frame.height * 1px;
            background: transparent;

            for utility_tab_button_node in root.pane.nodes: ToolbarButton {
                visible: utility_tab_button_node.control_id == "AssetsActivityPreviewTabButton";
                x: (utility_tab_button_node.frame.x - utility_tabs_row_node.frame.x) * 1px;
                y: (utility_tab_button_node.frame.y - utility_tabs_row_node.frame.y) * 1px;
                width: utility_tab_button_node.frame.width * 1px;
                height: utility_tab_button_node.frame.height * 1px;
                min-width: utility_tab_button_node.frame.width * 1px;
                label: utility_tab_button_node.text;
                active: root.utility_tab == "preview";
                clicked => { root.control_changed("SetUtilityTab", "preview"); }
            }

            for utility_tab_button_node in root.pane.nodes: ToolbarButton {
                visible: utility_tab_button_node.control_id == "AssetsActivityReferencesTabButton";
                x: (utility_tab_button_node.frame.x - utility_tabs_row_node.frame.x) * 1px;
                y: (utility_tab_button_node.frame.y - utility_tabs_row_node.frame.y) * 1px;
                width: utility_tab_button_node.frame.width * 1px;
                height: utility_tab_button_node.frame.height * 1px;
                min-width: utility_tab_button_node.frame.width * 1px;
                label: utility_tab_button_node.text;
                active: root.utility_tab == "references";
                clicked => { root.control_changed("SetUtilityTab", "references"); }
            }

            for selection_text_node in root.pane.nodes: Text {
                visible: selection_text_node.control_id == "AssetsActivitySelectionText";
                x: (selection_text_node.frame.x - utility_tabs_row_node.frame.x) * 1px;
                y: (selection_text_node.frame.y - utility_tabs_row_node.frame.y) * 1px;
                width: selection_text_node.frame.width * 1px;
                height: selection_text_node.frame.height * 1px;
                horizontal-alignment: right;
                vertical-alignment: center;
                text:
                    root.selection.name != ""
                    ? root.selection.name
                    : selection_text_node.text;
                color: palette.text_dim;
                font-size: selection_text_node.font_size * 1px;
                overflow: elide;
            }
        }

        for utility_divider_node in root.pane.nodes: Rectangle {
            visible: utility_divider_node.control_id == "AssetsActivityUtilityDivider";
            x: (utility_divider_node.frame.x - utility_panel_node.frame.x) * 1px;
            y: (utility_divider_node.frame.y - utility_panel_node.frame.y) * 1px;
            width: utility_divider_node.frame.width * 1px;
            height: utility_divider_node.frame.height * 1px;
            background: palette.border_soft;
        }

        for preview_panel_node in root.pane.nodes: Rectangle {
            visible: root.utility_tab == "preview" && preview_panel_node.control_id == "AssetsActivityPreviewPanel";
            x: (preview_panel_node.frame.x - utility_panel_node.frame.x) * 1px;
            y: (preview_panel_node.frame.y - utility_panel_node.frame.y) * 1px;
            width: preview_panel_node.frame.width * 1px;
            height: preview_panel_node.frame.height * 1px;
            border-radius: preview_panel_node.corner_radius * 1px;
            border-width: preview_panel_node.border_width * 1px;
            border-color: palette.border_soft;
            background: palette.panel_bg_soft;

            for preview_visual_panel_node in root.pane.nodes: Rectangle {
                visible: preview_visual_panel_node.control_id == "AssetsActivityPreviewVisualPanel";
                x: (preview_visual_panel_node.frame.x - preview_panel_node.frame.x) * 1px;
                y: (preview_visual_panel_node.frame.y - preview_panel_node.frame.y) * 1px;
                width: preview_visual_panel_node.frame.width * 1px;
                height: preview_visual_panel_node.frame.height * 1px;
                border-radius: preview_visual_panel_node.corner_radius * 1px;
                border-width: preview_visual_panel_node.border_width * 1px;
                border-color: palette.border_soft;
                background: #16191f;

                AssetSelectionPreviewImage {
                    width: parent.width;
                    height: parent.height;
                    selection: root.selection;
                    icon_size: 28px;
                }
            }

            for preview_name_node in root.pane.nodes: Text {
                visible: preview_name_node.control_id == "AssetsActivityPreviewNameText";
                x: (preview_name_node.frame.x - preview_panel_node.frame.x) * 1px;
                y: (preview_name_node.frame.y - preview_panel_node.frame.y) * 1px;
                width: preview_name_node.frame.width * 1px;
                height: preview_name_node.frame.height * 1px;
                text:
                    root.selection.name != ""
                    ? root.selection.name
                    : preview_name_node.text;
                color: palette.text;
                font-size: preview_name_node.font_size * 1px;
                font-weight: preview_name_node.font_weight;
                vertical-alignment: center;
                overflow: elide;
            }

            for preview_locator_node in root.pane.nodes: Text {
                visible: preview_locator_node.control_id == "AssetsActivityPreviewLocatorText";
                x: (preview_locator_node.frame.x - preview_panel_node.frame.x) * 1px;
                y: (preview_locator_node.frame.y - preview_panel_node.frame.y) * 1px;
                width: preview_locator_node.frame.width * 1px;
                height: preview_locator_node.frame.height * 1px;
                text: root.selection.locator;
                color: palette.text_muted;
                font-size: preview_locator_node.font_size * 1px;
                vertical-alignment: center;
                overflow: elide;
            }

            for preview_kind_node in root.pane.nodes: Text {
                visible: preview_kind_node.control_id == "AssetsActivityPreviewKindText";
                x: (preview_kind_node.frame.x - preview_panel_node.frame.x) * 1px;
                y: (preview_kind_node.frame.y - preview_panel_node.frame.y) * 1px;
                width: preview_kind_node.frame.width * 1px;
                height: preview_kind_node.frame.height * 1px;
                text:
                    root.selection.kind != ""
                    ? root.selection.kind + (root.selection.state != "" ? " • " + root.selection.state : "")
                    : preview_kind_node.text;
                color: palette.text_dim;
                font-size: preview_kind_node.font_size * 1px;
                vertical-alignment: center;
                overflow: elide;
            }

            for preview_identity_node in root.pane.nodes: Text {
                visible:
                    preview_identity_node.control_id == "AssetsActivityPreviewIdentityText"
                    && root.selection.uuid != "";
                x: (preview_identity_node.frame.x - preview_panel_node.frame.x) * 1px;
                y: (preview_identity_node.frame.y - preview_panel_node.frame.y) * 1px;
                width: preview_identity_node.frame.width * 1px;
                height: preview_identity_node.frame.height * 1px;
                text:
                    "UUID " + root.selection.uuid
                    + (root.selection.revision != "" ? " • rev " + root.selection.revision : "");
                color: palette.text_dim;
                font-size: preview_identity_node.font_size * 1px;
                vertical-alignment: center;
                overflow: elide;
            }

            for preview_adapter_node in root.pane.nodes: Text {
                visible:
                    preview_adapter_node.control_id == "AssetsActivityPreviewAdapterText"
                    && root.selection.adapter_key != "";
                x: (preview_adapter_node.frame.x - preview_panel_node.frame.x) * 1px;
                y: (preview_adapter_node.frame.y - preview_panel_node.frame.y) * 1px;
                width: preview_adapter_node.frame.width * 1px;
                height: preview_adapter_node.frame.height * 1px;
                text: "Adapter " + root.selection.adapter_key;
                color: palette.text_dim;
                font-size: preview_adapter_node.font_size * 1px;
                vertical-alignment: center;
                overflow: elide;
            }

            for preview_meta_path_node in root.pane.nodes: Text {
                visible:
                    preview_meta_path_node.control_id == "AssetsActivityPreviewMetaPathText"
                    && root.selection.meta_path != "";
                x: (preview_meta_path_node.frame.x - preview_panel_node.frame.x) * 1px;
                y: (preview_meta_path_node.frame.y - preview_panel_node.frame.y) * 1px;
                width: preview_meta_path_node.frame.width * 1px;
                height: preview_meta_path_node.frame.height * 1px;
                text: root.selection.meta_path;
                color: palette.text_dim;
                font-size: preview_meta_path_node.font_size * 1px;
                vertical-alignment: center;
                overflow: elide;
            }

            for preview_diagnostics_node in root.pane.nodes: Text {
                visible:
                    preview_diagnostics_node.control_id == "AssetsActivityPreviewDiagnosticsText"
                    && root.selection.diagnostics != "";
                x: (preview_diagnostics_node.frame.x - preview_panel_node.frame.x) * 1px;
                y: (preview_diagnostics_node.frame.y - preview_panel_node.frame.y) * 1px;
                width: preview_diagnostics_node.frame.width * 1px;
                height: preview_diagnostics_node.frame.height * 1px;
                text: root.selection.diagnostics;
                color: #d7a3a8;
                font-size: preview_diagnostics_node.font_size * 1px;
                wrap: word-wrap;
            }
        }

        for utility_content_panel_node in root.pane.nodes: Rectangle {
            visible: root.utility_tab == "references" && utility_content_panel_node.control_id == "AssetsActivityUtilityContentPanel";
            x: (utility_content_panel_node.frame.x - utility_panel_node.frame.x) * 1px;
            y: (utility_content_panel_node.frame.y - utility_panel_node.frame.y) * 1px;
            width: utility_content_panel_node.frame.width * 1px;
            height: utility_content_panel_node.frame.height * 1px;
            background: transparent;

            for reference_left_panel_node in root.pane.nodes: ProjectedReferencePanel {
                visible: reference_left_panel_node.control_id == "AssetsActivityReferenceLeftPanel";
                x: (reference_left_panel_node.frame.x - utility_content_panel_node.frame.x) * 1px;
                y: (reference_left_panel_node.frame.y - utility_content_panel_node.frame.y) * 1px;
                width: reference_left_panel_node.frame.width * 1px;
                height: reference_left_panel_node.frame.height * 1px;
                panel: reference_left_panel_node;
                nodes: root.pane.nodes;
                title_control_id: "AssetsActivityReferenceLeftTitleText";
                body_control_id: "AssetsActivityReferenceLeftScrollBody";
                empty_control_id: "AssetsActivityReferenceLeftEmptyText";
                row_control_id: "AssetsActivityReferenceLeftRowPanel";
                row_name_control_id: "AssetsActivityReferenceLeftRowNameText";
                row_locator_control_id: "AssetsActivityReferenceLeftRowLocatorText";
                row_kind_control_id: "AssetsActivityReferenceLeftRowKindText";
                references: root.references;
                hovered_index: root.references_hovered_index;
                scroll_px: root.references_scroll_px;
                pointer_clicked(x, y, width, height) => { root.reference_pointer_clicked("references", x, y, width, height); }
                pointer_moved(x, y, width, height) => { root.reference_pointer_moved("references", x, y, width, height); }
                pointer_scrolled(x, y, delta, width, height) => { root.reference_pointer_scrolled("references", x, y, delta, width, height); }
            }

            for reference_right_panel_node in root.pane.nodes: ProjectedReferencePanel {
                visible: reference_right_panel_node.control_id == "AssetsActivityReferenceRightPanel";
                x: (reference_right_panel_node.frame.x - utility_content_panel_node.frame.x) * 1px;
                y: (reference_right_panel_node.frame.y - utility_content_panel_node.frame.y) * 1px;
                width: reference_right_panel_node.frame.width * 1px;
                height: reference_right_panel_node.frame.height * 1px;
                panel: reference_right_panel_node;
                nodes: root.pane.nodes;
                title_control_id: "AssetsActivityReferenceRightTitleText";
                body_control_id: "AssetsActivityReferenceRightScrollBody";
                empty_control_id: "AssetsActivityReferenceRightEmptyText";
                row_control_id: "AssetsActivityReferenceRightRowPanel";
                row_name_control_id: "AssetsActivityReferenceRightRowNameText";
                row_locator_control_id: "AssetsActivityReferenceRightRowLocatorText";
                row_kind_control_id: "AssetsActivityReferenceRightRowKindText";
                references: root.used_by;
                hovered_index: root.used_by_hovered_index;
                scroll_px: root.used_by_scroll_px;
                pointer_clicked(x, y, width, height) => { root.reference_pointer_clicked("used_by", x, y, width, height); }
                pointer_moved(x, y, width, height) => { root.reference_pointer_moved("used_by", x, y, width, height); }
                pointer_scrolled(x, y, delta, width, height) => { root.reference_pointer_scrolled("used_by", x, y, delta, width, height); }
            }
        }
    }
}

component AssetBrowserPaneView inherits Rectangle {
    in property <AssetBrowserPaneData> pane;
    in property <ProjectOverviewData> project;
    in property <[AssetFolderData]> folder_tree;
    in property <[AssetFolderData]> content_folders;
    in property <[AssetItemData]> content_items;
    in property <AssetSelectionData> selection;
    in property <[AssetReferenceData]> references;
    in property <[AssetReferenceData]> used_by;
    in property <string> search_query;
    in property <string> kind_filter;
    in property <string> view_mode;
    in property <string> utility_tab;
    in property <int> tree_hovered_index: -1;
    in property <float> tree_scroll_px: 0.0;
    in property <int> content_hovered_index: -1;
    in property <float> content_scroll_px: 0.0;
    in property <int> references_hovered_index: -1;
    in property <float> references_scroll_px: 0.0;
    in property <int> used_by_hovered_index: -1;
    in property <float> used_by_scroll_px: 0.0;
    in property <float> details_scroll_px: 0.0;
    in-out property <string> mesh_import_path;
    callback control_changed(control_id: string, value: string);
    callback control_clicked(control_id: string);
    callback tree_pointer_clicked(x: float, y: float, width: float, height: float);
    callback tree_pointer_moved(x: float, y: float, width: float, height: float);
    callback tree_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback content_pointer_clicked(x: float, y: float, width: float, height: float);
    callback content_pointer_moved(x: float, y: float, width: float, height: float);
    callback content_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback reference_pointer_clicked(list_kind: string, x: float, y: float, width: float, height: float);
    callback reference_pointer_moved(list_kind: string, x: float, y: float, width: float, height: float);
    callback reference_pointer_scrolled(list_kind: string, x: float, y: float, delta: float, width: float, height: float);
    callback details_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback mesh_import_path_edited(value: string);

    palette := Palette {}
    background: transparent;
    clip: true;

    for toolbar_panel_node in root.pane.nodes: AssetSurfaceFrame {
        visible: toolbar_panel_node.control_id == "AssetBrowserToolbarPanel";
        x: toolbar_panel_node.frame.x * 1px;
        y: toolbar_panel_node.frame.y * 1px;
        width: toolbar_panel_node.frame.width * 1px;
        height: toolbar_panel_node.frame.height * 1px;
        background: palette.chrome_bg_soft;
        for toolbar_title_row_node in root.pane.nodes: Rectangle {
            visible: toolbar_title_row_node.control_id == "AssetBrowserToolbarTitleRow";
            x: (toolbar_title_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (toolbar_title_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: toolbar_title_row_node.frame.width * 1px;
            height: toolbar_title_row_node.frame.height * 1px;
            background: transparent;

            for title_text_node in root.pane.nodes: Text {
                visible: title_text_node.control_id == "AssetBrowserTitleText";
                x: (title_text_node.frame.x - toolbar_title_row_node.frame.x) * 1px;
                y: (title_text_node.frame.y - toolbar_title_row_node.frame.y) * 1px;
                width: title_text_node.frame.width * 1px;
                height: title_text_node.frame.height * 1px;
                text:
                    root.project.project_name != ""
                    ? root.project.project_name + " / Asset Browser"
                    : title_text_node.text;
                color: palette.text;
                font-size: title_text_node.font_size * 1px;
                font-weight: title_text_node.font_weight;
                vertical-alignment: center;
                overflow: elide;
            }

            for locate_button_node in root.pane.nodes: ShellButton {
                visible: locate_button_node.control_id == "LocateSelectedAsset";
                x: (locate_button_node.frame.x - toolbar_title_row_node.frame.x) * 1px;
                y: (locate_button_node.frame.y - toolbar_title_row_node.frame.y) * 1px;
                width: locate_button_node.frame.width * 1px;
                height: locate_button_node.frame.height * 1px;
                label: locate_button_node.text;
                active: false;
                clicked => { root.control_clicked("LocateSelectedAsset"); }
            }
        }

        for toolbar_subtitle_row_node in root.pane.nodes: Rectangle {
            visible: toolbar_subtitle_row_node.control_id == "AssetBrowserToolbarSubtitleRow";
            x: (toolbar_subtitle_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (toolbar_subtitle_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: toolbar_subtitle_row_node.frame.width * 1px;
            height: toolbar_subtitle_row_node.frame.height * 1px;
            background: transparent;

            for subtitle_text_node in root.pane.nodes: Text {
                visible: subtitle_text_node.control_id == "AssetBrowserSubtitleText";
                x: (subtitle_text_node.frame.x - toolbar_subtitle_row_node.frame.x) * 1px;
                y: (subtitle_text_node.frame.y - toolbar_subtitle_row_node.frame.y) * 1px;
                width: subtitle_text_node.frame.width * 1px;
                height: subtitle_text_node.frame.height * 1px;
                text:
                    root.project.assets_root != ""
                    ? root.project.assets_root
                    : subtitle_text_node.text;
                color: palette.text_dim;
                font-size: subtitle_text_node.font_size * 1px;
                vertical-alignment: center;
                overflow: elide;
            }
        }

        for toolbar_search_row_node in root.pane.nodes: Rectangle {
            visible: toolbar_search_row_node.control_id == "AssetBrowserToolbarSearchRow";
            x: (toolbar_search_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (toolbar_search_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: toolbar_search_row_node.frame.width * 1px;
            height: toolbar_search_row_node.frame.height * 1px;
            background: transparent;

            for search_field_node in root.pane.nodes: SearchField {
                visible: search_field_node.control_id == "SearchEdited";
                x: (search_field_node.frame.x - toolbar_search_row_node.frame.x) * 1px;
                y: (search_field_node.frame.y - toolbar_search_row_node.frame.y) * 1px;
                width: search_field_node.frame.width * 1px;
                height: search_field_node.frame.height * 1px;
                text: root.search_query;
                placeholder: "Search assets";
                edited(value) => { root.control_changed("SearchEdited", value); }
            }
        }

        for kind_primary_row_node in root.pane.nodes: Rectangle {
            visible: kind_primary_row_node.control_id == "AssetBrowserToolbarKindPrimaryRow";
            x: (kind_primary_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (kind_primary_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: kind_primary_row_node.frame.width * 1px;
            height: kind_primary_row_node.frame.height * 1px;
            background: transparent;

            for kind_primary_chip_node in root.pane.nodes: KindChip {
                visible:
                    kind_primary_chip_node.control_id == "AssetBrowserKindAllChip"
                    || kind_primary_chip_node.control_id == "AssetBrowserKindTextureChip"
                    || kind_primary_chip_node.control_id == "AssetBrowserKindMaterialChip"
                    || kind_primary_chip_node.control_id == "AssetBrowserKindSceneChip"
                    || kind_primary_chip_node.control_id == "AssetBrowserKindModelChip"
                    || kind_primary_chip_node.control_id == "AssetBrowserKindShaderChip";
                x: (kind_primary_chip_node.frame.x - kind_primary_row_node.frame.x) * 1px;
                y: (kind_primary_chip_node.frame.y - kind_primary_row_node.frame.y) * 1px;
                width: kind_primary_chip_node.frame.width * 1px;
                height: kind_primary_chip_node.frame.height * 1px;
                label: kind_primary_chip_node.text;
                active:
                    kind_primary_chip_node.control_id == "AssetBrowserKindAllChip"
                    ? root.kind_filter == "" || root.kind_filter == "All"
                    : kind_primary_chip_node.control_id == "AssetBrowserKindTextureChip"
                    ? root.kind_filter == "Texture"
                    : kind_primary_chip_node.control_id == "AssetBrowserKindMaterialChip"
                    ? root.kind_filter == "Material"
                    : kind_primary_chip_node.control_id == "AssetBrowserKindSceneChip"
                    ? root.kind_filter == "Scene"
                    : kind_primary_chip_node.control_id == "AssetBrowserKindModelChip"
                    ? root.kind_filter == "Model"
                    : root.kind_filter == "Shader";
                clicked => {
                    root.control_changed(
                        "SetKindFilter",
                        kind_primary_chip_node.control_id == "AssetBrowserKindAllChip"
                        ? ""
                        : kind_primary_chip_node.control_id == "AssetBrowserKindTextureChip"
                        ? "Texture"
                        : kind_primary_chip_node.control_id == "AssetBrowserKindMaterialChip"
                        ? "Material"
                        : kind_primary_chip_node.control_id == "AssetBrowserKindSceneChip"
                        ? "Scene"
                        : kind_primary_chip_node.control_id == "AssetBrowserKindModelChip"
                        ? "Model"
                        : "Shader",
                    );
                }
            }

            for view_mode_button_node in root.pane.nodes: ToolbarButton {
                visible:
                    view_mode_button_node.control_id == "AssetBrowserViewModeListButton"
                    || view_mode_button_node.control_id == "AssetBrowserViewModeThumbButton";
                x: (view_mode_button_node.frame.x - kind_primary_row_node.frame.x) * 1px;
                y: (view_mode_button_node.frame.y - kind_primary_row_node.frame.y) * 1px;
                width: view_mode_button_node.frame.width * 1px;
                height: view_mode_button_node.frame.height * 1px;
                min-width: view_mode_button_node.frame.width * 1px;
                label: view_mode_button_node.text;
                active:
                    view_mode_button_node.control_id == "AssetBrowserViewModeListButton"
                    ? root.view_mode == "list"
                    : root.view_mode == "thumbnail";
                clicked => {
                    root.control_changed(
                        "SetViewMode",
                        view_mode_button_node.control_id == "AssetBrowserViewModeListButton"
                        ? "list"
                        : "thumbnail",
                    );
                }
            }
        }

        for kind_secondary_row_node in root.pane.nodes: Rectangle {
            visible: kind_secondary_row_node.control_id == "AssetBrowserToolbarKindSecondaryRow";
            x: (kind_secondary_row_node.frame.x - toolbar_panel_node.frame.x) * 1px;
            y: (kind_secondary_row_node.frame.y - toolbar_panel_node.frame.y) * 1px;
            width: kind_secondary_row_node.frame.width * 1px;
            height: kind_secondary_row_node.frame.height * 1px;
            background: transparent;

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetBrowserKindPhysicsChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "PhysicsMaterial";
                clicked => { root.control_changed("SetKindFilter", "PhysicsMaterial"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetBrowserKindSkeletonChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationSkeleton";
                clicked => { root.control_changed("SetKindFilter", "AnimationSkeleton"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetBrowserKindClipChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationClip";
                clicked => { root.control_changed("SetKindFilter", "AnimationClip"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetBrowserKindSequenceChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationSequence";
                clicked => { root.control_changed("SetKindFilter", "AnimationSequence"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetBrowserKindGraphChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationGraph";
                clicked => { root.control_changed("SetKindFilter", "AnimationGraph"); }
            }

            for kind_secondary_chip_node in root.pane.nodes: KindChip {
                visible: kind_secondary_chip_node.control_id == "AssetBrowserKindStateChip";
                x: (kind_secondary_chip_node.frame.x - kind_secondary_row_node.frame.x) * 1px;
                y: (kind_secondary_chip_node.frame.y - kind_secondary_row_node.frame.y) * 1px;
                width: kind_secondary_chip_node.frame.width * 1px;
                height: kind_secondary_chip_node.frame.height * 1px;
                label: kind_secondary_chip_node.text;
                active: root.kind_filter == "AnimationStateMachine";
                clicked => { root.control_changed("SetKindFilter", "AnimationStateMachine"); }
            }
        }
    }

    for import_panel_node in root.pane.nodes: AssetSurfaceFrame {
        visible: import_panel_node.control_id == "AssetBrowserImportPanel";
        x: import_panel_node.frame.x * 1px;
        y: import_panel_node.frame.y * 1px;
        width: import_panel_node.frame.width * 1px;
        height: import_panel_node.frame.height * 1px;
        background: palette.chrome_bg_soft;

        for import_label_node in root.pane.nodes: Text {
            visible: import_label_node.control_id == "AssetBrowserImportLabel";
            x: (import_label_node.frame.x - import_panel_node.frame.x) * 1px;
            y: (import_label_node.frame.y - import_panel_node.frame.y) * 1px;
            width: import_label_node.frame.width * 1px;
            height: import_label_node.frame.height * 1px;
            text: import_label_node.text;
            color: palette.text_dim;
            font-size: import_label_node.font_size * 1px;
            vertical-alignment: center;
            overflow: elide;
        }

        for import_path_node in root.pane.nodes: SearchField {
            visible: import_path_node.control_id == "AssetBrowserImportPathField";
            x: (import_path_node.frame.x - import_panel_node.frame.x) * 1px;
            y: (import_path_node.frame.y - import_panel_node.frame.y) * 1px;
            width: import_path_node.frame.width * 1px;
            height: import_path_node.frame.height * 1px;
            text: root.mesh_import_path;
            placeholder: "Import model (.obj/.gltf/.glb)";
            edited(value) => { root.mesh_import_path_edited(value); }
        }

        for import_button_node in root.pane.nodes: ShellButton {
            visible: import_button_node.control_id == "ImportModel";
            x: (import_button_node.frame.x - import_panel_node.frame.x) * 1px;
            y: (import_button_node.frame.y - import_panel_node.frame.y) * 1px;
            width: import_button_node.frame.width * 1px;
            height: import_button_node.frame.height * 1px;
            label: import_button_node.text;
            active: import_button_node.button_variant == "primary";
            enabled: root.mesh_import_path != "";
            clicked => { root.control_clicked("ImportModel"); }
        }
    }

    for main_panel_node in root.pane.nodes: Rectangle {
        visible: main_panel_node.control_id == "AssetBrowserMainPanel";
        x: main_panel_node.frame.x * 1px;
        y: main_panel_node.frame.y * 1px;
        width: main_panel_node.frame.width * 1px;
        height: main_panel_node.frame.height * 1px;
        background: transparent;

        for sources_panel_node in root.pane.nodes: AssetSurfaceFrame {
            visible: sources_panel_node.control_id == "AssetBrowserSourcesPanel";
            x: (sources_panel_node.frame.x - main_panel_node.frame.x) * 1px;
            y: (sources_panel_node.frame.y - main_panel_node.frame.y) * 1px;
            width: sources_panel_node.frame.width * 1px;
            height: sources_panel_node.frame.height * 1px;

            for sources_header_panel_node in root.pane.nodes: Rectangle {
                visible: sources_header_panel_node.control_id == "AssetBrowserSourcesHeaderPanel";
                x: (sources_header_panel_node.frame.x - sources_panel_node.frame.x) * 1px;
                y: (sources_header_panel_node.frame.y - sources_panel_node.frame.y) * 1px;
                width: sources_header_panel_node.frame.width * 1px;
                height: sources_header_panel_node.frame.height * 1px;
                background: palette.chrome_bg_soft;

                for sources_title_node in root.pane.nodes: Text {
                    visible: sources_title_node.control_id == "AssetBrowserSourcesTitleText";
                    x: (sources_title_node.frame.x - sources_header_panel_node.frame.x) * 1px;
                    y: (sources_title_node.frame.y - sources_header_panel_node.frame.y) * 1px;
                    width: sources_title_node.frame.width * 1px;
                    height: sources_title_node.frame.height * 1px;
                    text: sources_title_node.text;
                    color: palette.text;
                    font-size: sources_title_node.font_size * 1px;
                    font-weight: sources_title_node.font_weight;
                }

                for sources_subtitle_node in root.pane.nodes: Text {
                    visible: sources_subtitle_node.control_id == "AssetBrowserSourcesSubtitleText";
                    x: (sources_subtitle_node.frame.x - sources_header_panel_node.frame.x) * 1px;
                    y: (sources_subtitle_node.frame.y - sources_header_panel_node.frame.y) * 1px;
                    width: sources_subtitle_node.frame.width * 1px;
                    height: sources_subtitle_node.frame.height * 1px;
                    text: sources_subtitle_node.text;
                    color: palette.text_dim;
                    font-size: sources_subtitle_node.font_size * 1px;
                    overflow: elide;
                }
            }

            for sources_divider_node in root.pane.nodes: Rectangle {
                visible: sources_divider_node.control_id == "AssetBrowserSourcesDivider";
                x: (sources_divider_node.frame.x - sources_panel_node.frame.x) * 1px;
                y: (sources_divider_node.frame.y - sources_panel_node.frame.y) * 1px;
                width: sources_divider_node.frame.width * 1px;
                height: sources_divider_node.frame.height * 1px;
                background: palette.border_soft;
            }

            for sources_scroll_body_node in root.pane.nodes: Rectangle {
                visible: sources_scroll_body_node.control_id == "AssetBrowserSourcesScrollBody";
                x: (sources_scroll_body_node.frame.x - sources_panel_node.frame.x) * 1px;
                y: (sources_scroll_body_node.frame.y - sources_panel_node.frame.y) * 1px;
                width: sources_scroll_body_node.frame.width * 1px;
                height: sources_scroll_body_node.frame.height * 1px;
                background: transparent;
                clip: true;

                for sources_row_panel_node in root.pane.nodes: VerticalLayout {
                    visible: sources_row_panel_node.control_id == "AssetBrowserSourcesRowPanel";
                    x: sources_row_panel_node.frame.x * 1px;
                    y: sources_row_panel_node.frame.y * 1px - root.tree_scroll_px * 1px;
                    width: sources_scroll_body_node.frame.width * 1px - 16px;
                    spacing: 4px;

                    for folder[index] in root.folder_tree: Rectangle {
                        height: sources_row_panel_node.frame.height * 1px;
                        border-radius: sources_row_panel_node.corner_radius * 1px;
                        background: folder.selected ? #365880 : root.tree_hovered_index == index ? palette.chrome_bg_soft : transparent;

                        for sources_row_icon_node in root.pane.nodes: ShellIcon {
                            visible: sources_row_icon_node.control_id == "AssetBrowserSourcesRowIcon";
                            x: sources_row_icon_node.frame.x * 1px + folder.depth * 12px;
                            y: sources_row_icon_node.frame.y * 1px;
                            width: sources_row_icon_node.frame.width * 1px;
                            height: sources_row_icon_node.frame.height * 1px;
                            icon_key: "project";
                            icon_color: folder.selected ? #eef4ff : palette.text_muted;
                        }

                        for sources_row_name_node in root.pane.nodes: Text {
                            visible: sources_row_name_node.control_id == "AssetBrowserSourcesRowNameText";
                            x: sources_row_name_node.frame.x * 1px + folder.depth * 12px;
                            y: sources_row_name_node.frame.y * 1px;
                            width: parent.width - (52px + folder.depth * 12px);
                            height: sources_row_name_node.frame.height * 1px;
                            text: folder.name;
                            color: folder.selected ? #eef4ff : palette.text;
                            font-size: sources_row_name_node.font_size * 1px;
                            overflow: elide;
                        }

                        for sources_row_count_node in root.pane.nodes: Text {
                            visible: sources_row_count_node.control_id == "AssetBrowserSourcesRowCountText";
                            x: parent.width - 34px;
                            y: sources_row_count_node.frame.y * 1px;
                            width: sources_row_count_node.frame.width * 1px;
                            height: sources_row_count_node.frame.height * 1px;
                            horizontal-alignment: right;
                            text: folder.count;
                            color: folder.selected ? #dce8ff : palette.text_dim;
                            font-size: sources_row_count_node.font_size * 1px;
                        }
                    }
                }

                TouchArea {
                    width: parent.width;
                    height: parent.height;
                    moved => { root.tree_pointer_moved(self.mouse-x / 1px, self.mouse-y / 1px + sources_scroll_body_node.frame.y + 1.0, root.width / 1px, root.height / 1px); }
                    clicked => { root.tree_pointer_clicked(self.mouse-x / 1px, self.mouse-y / 1px + sources_scroll_body_node.frame.y + 1.0, root.width / 1px, root.height / 1px); }
                    scroll-event(event) => {
                        root.tree_pointer_scrolled(self.mouse-x / 1px, self.mouse-y / 1px + sources_scroll_body_node.frame.y + 1.0, event.delta_y / 1px, root.width / 1px, root.height / 1px);
                        accept
                    }
                }
            }
        }

        for content_panel_node in root.pane.nodes: AssetListView {
            visible: content_panel_node.control_id == "AssetBrowserContentPanel";
            x: (content_panel_node.frame.x - main_panel_node.frame.x) * 1px;
            y: (content_panel_node.frame.y - main_panel_node.frame.y) * 1px;
            width: content_panel_node.frame.width * 1px;
            height: content_panel_node.frame.height * 1px;
            title: "Content Browser";
            subtitle: "Folder first • name sort";
            folders: root.content_folders;
            items: root.content_items;
            view_mode: root.view_mode;
            hovered_index: root.content_hovered_index;
            scroll_px: root.content_scroll_px;
            pointer_clicked(x, y, width, height) => { root.content_pointer_clicked(x, y, width, height); }
            pointer_moved(x, y, width, height) => { root.content_pointer_moved(x, y, width, height); }
            pointer_scrolled(x, y, delta, width, height) => { root.content_pointer_scrolled(x, y, delta, width, height); }
        }

        for details_panel_node in root.pane.nodes: AssetSurfaceFrame {
            visible: details_panel_node.control_id == "AssetBrowserDetailsPanel";
            x: (details_panel_node.frame.x - main_panel_node.frame.x) * 1px;
            y: (details_panel_node.frame.y - main_panel_node.frame.y) * 1px;
            width: details_panel_node.frame.width * 1px;
            height: details_panel_node.frame.height * 1px;

            for details_header_panel_node in root.pane.nodes: Rectangle {
                visible: details_header_panel_node.control_id == "AssetBrowserDetailsHeaderPanel";
                x: (details_header_panel_node.frame.x - details_panel_node.frame.x) * 1px;
                y: (details_header_panel_node.frame.y - details_panel_node.frame.y) * 1px;
                width: details_header_panel_node.frame.width * 1px;
                height: details_header_panel_node.frame.height * 1px;
                background: palette.chrome_bg_soft;

                for header_title_node in root.pane.nodes: Text {
                    visible: header_title_node.control_id == "AssetBrowserDetailsHeaderTitleText";
                    x: (header_title_node.frame.x - details_header_panel_node.frame.x) * 1px;
                    y: (header_title_node.frame.y - details_header_panel_node.frame.y) * 1px;
                    width: header_title_node.frame.width * 1px;
                    height: header_title_node.frame.height * 1px;
                    text: header_title_node.text;
                    color: palette.text;
                    font-size: header_title_node.font_size * 1px;
                    font-weight: header_title_node.font_weight;
                    vertical-alignment: center;
                    overflow: elide;
                }

                for header_selection_node in root.pane.nodes: Text {
                    visible: header_selection_node.control_id == "AssetBrowserDetailsHeaderSelectionText";
                    x: (header_selection_node.frame.x - details_header_panel_node.frame.x) * 1px;
                    y: (header_selection_node.frame.y - details_header_panel_node.frame.y) * 1px;
                    width: header_selection_node.frame.width * 1px;
                    height: header_selection_node.frame.height * 1px;
                    text:
                        root.selection.name != ""
                        ? root.selection.name
                        : header_selection_node.text;
                    color: palette.text_dim;
                    font-size: header_selection_node.font_size * 1px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }

            for details_divider_node in root.pane.nodes: Rectangle {
                visible: details_divider_node.control_id == "AssetBrowserDetailsDivider";
                x: (details_divider_node.frame.x - details_panel_node.frame.x) * 1px;
                y: (details_divider_node.frame.y - details_panel_node.frame.y) * 1px;
                width: details_divider_node.frame.width * 1px;
                height: details_divider_node.frame.height * 1px;
                background: palette.border_soft;
            }

            for details_scroll_body_node in root.pane.nodes: Rectangle {
                visible: details_scroll_body_node.control_id == "AssetBrowserDetailsScrollBody";
                x: (details_scroll_body_node.frame.x - details_panel_node.frame.x) * 1px;
                y: (details_scroll_body_node.frame.y - details_panel_node.frame.y) * 1px;
                width: details_scroll_body_node.frame.width * 1px;
                height: details_scroll_body_node.frame.height * 1px;
                background: transparent;
                clip: true;

                for details_content_panel_node in root.pane.nodes: Rectangle {
                    visible: details_content_panel_node.control_id == "AssetBrowserDetailsContentPanel";
                    x: (details_content_panel_node.frame.x - details_scroll_body_node.frame.x) * 1px;
                    y: (details_content_panel_node.frame.y - details_scroll_body_node.frame.y - root.details_scroll_px) * 1px;
                    width: details_content_panel_node.frame.width * 1px;
                    height: details_content_panel_node.frame.height * 1px;
                    background: transparent;

                    for preview_panel_node in root.pane.nodes: Rectangle {
                        visible: preview_panel_node.control_id == "AssetBrowserDetailsPreviewPanel";
                        x: (preview_panel_node.frame.x - details_content_panel_node.frame.x) * 1px;
                        y: (preview_panel_node.frame.y - details_content_panel_node.frame.y) * 1px;
                        width: preview_panel_node.frame.width * 1px;
                        height: preview_panel_node.frame.height * 1px;
                        border-radius: preview_panel_node.corner_radius * 1px;
                        border-width: preview_panel_node.border_width * 1px;
                        border-color: palette.border_soft;
                        background: palette.panel_bg_soft;

                        for preview_visual_panel_node in root.pane.nodes: Rectangle {
                            visible: preview_visual_panel_node.control_id == "AssetBrowserDetailsPreviewVisualPanel";
                            x: (preview_visual_panel_node.frame.x - preview_panel_node.frame.x) * 1px;
                            y: (preview_visual_panel_node.frame.y - preview_panel_node.frame.y) * 1px;
                            width: preview_visual_panel_node.frame.width * 1px;
                            height: preview_visual_panel_node.frame.height * 1px;
                            border-radius: preview_visual_panel_node.corner_radius * 1px;
                            border-width: preview_visual_panel_node.border_width * 1px;
                            border-color: palette.border_soft;
                            background: #16191f;

                            AssetSelectionDetailsImage {
                                width: parent.width;
                                height: parent.height;
                                selection: root.selection;
                                icon_size: 34px;
                            }
                        }

                        for preview_name_node in root.pane.nodes: Text {
                            visible: preview_name_node.control_id == "AssetBrowserDetailsPreviewNameText";
                            x: (preview_name_node.frame.x - preview_panel_node.frame.x) * 1px;
                            y: (preview_name_node.frame.y - preview_panel_node.frame.y) * 1px;
                            width: preview_name_node.frame.width * 1px;
                            height: preview_name_node.frame.height * 1px;
                            text:
                                root.selection.name != ""
                                ? root.selection.name
                                : preview_name_node.text;
                            color: palette.text;
                            font-size: preview_name_node.font_size * 1px;
                            font-weight: preview_name_node.font_weight;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        for preview_locator_node in root.pane.nodes: Text {
                            visible: preview_locator_node.control_id == "AssetBrowserDetailsPreviewLocatorText";
                            x: (preview_locator_node.frame.x - preview_panel_node.frame.x) * 1px;
                            y: (preview_locator_node.frame.y - preview_panel_node.frame.y) * 1px;
                            width: preview_locator_node.frame.width * 1px;
                            height: preview_locator_node.frame.height * 1px;
                            text: root.selection.locator;
                            color: palette.text_muted;
                            font-size: preview_locator_node.font_size * 1px;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        for preview_kind_node in root.pane.nodes: Text {
                            visible: preview_kind_node.control_id == "AssetBrowserDetailsPreviewKindText";
                            x: (preview_kind_node.frame.x - preview_panel_node.frame.x) * 1px;
                            y: (preview_kind_node.frame.y - preview_panel_node.frame.y) * 1px;
                            width: preview_kind_node.frame.width * 1px;
                            height: preview_kind_node.frame.height * 1px;
                            text:
                                root.selection.kind != ""
                                ? root.selection.kind + (root.selection.state != "" ? " • " + root.selection.state : "")
                                : preview_kind_node.text;
                            color: palette.text_dim;
                            font-size: preview_kind_node.font_size * 1px;
                            vertical-alignment: center;
                            overflow: elide;
                        }

                        for preview_identity_node in root.pane.nodes: Text {
                            visible:
                                preview_identity_node.control_id == "AssetBrowserDetailsPreviewIdentityText"
                                && root.selection.uuid != "";
                            x: (preview_identity_node.frame.x - preview_panel_node.frame.x) * 1px;
                            y: (preview_identity_node.frame.y - preview_panel_node.frame.y) * 1px;
                            width: preview_identity_node.frame.width * 1px;
                            height: preview_identity_node.frame.height * 1px;
                            text:
                                "UUID " + root.selection.uuid
                                + (root.selection.revision != "" ? " • rev " + root.selection.revision : "");
                            color: palette.text_dim;
                            font-size: preview_identity_node.font_size * 1px;
                            vertical-alignment: center;
                            overflow: elide;
                        }

