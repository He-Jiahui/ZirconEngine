import { Palette } from "chrome.slint";
import { HostStatusBarData } from "host_components.slint";

export component HostStatusBar inherits Rectangle {
    in property <HostStatusBarData> status_data: {
        status_bar_frame: { x: 0.0, y: 0.0, width: 0.0, height: 0.0 },
        status_primary: "",
        status_secondary: "",
        viewport_label: "",
    };
    palette := Palette {}
    background: transparent;

    Rectangle {
        x: 0px;
        y: root.status_data.status_bar_frame.y * 1px - 1px;
        width: parent.width;
        height: 1px;
        background: palette.border;
    }

    status_bar_zone := Rectangle {
        x: root.status_data.status_bar_frame.x * 1px;
        y: root.status_data.status_bar_frame.y * 1px;
        width: root.status_data.status_bar_frame.width * 1px;
        height: root.status_data.status_bar_frame.height * 1px;
        background: palette.chrome_bg;

        Text {
            x: 12px;
            y: 4px;
            width: parent.width * 0.55;
            text: root.status_data.status_primary;
            color: palette.text_muted;
            font-size: 10px;
            overflow: elide;
        }

        if root.status_data.status_secondary != "": Text {
            x: parent.width - 224px;
            y: 4px;
            width: 96px;
            horizontal-alignment: right;
            text: root.status_data.status_secondary;
            color: palette.text_dim;
            font-size: 10px;
            overflow: elide;
        }

        Text {
            x: parent.width - 118px;
            y: 4px;
            width: 104px;
            horizontal-alignment: right;
            text: root.status_data.viewport_label;
            color: palette.text_dim;
            font-size: 10px;
            overflow: elide;
        }
    }
}
