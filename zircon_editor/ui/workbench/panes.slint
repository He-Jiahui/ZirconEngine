                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 92px;
                                title: "Theme Tokens";
                                items: root.theme_source.selected_source_token_items;
                                selected_index: root.theme_source.selected_source_kind == "Local" ? root.style_token.selected_index : -1;
                                accent: #d8ba79;
                                item_selected(item_index) => {
                                    if (root.theme_source.selected_source_kind == "Local") {
                                        root.detail_event("style_token", "style.token.select", item_index, "", "");
                                    }
                                }
