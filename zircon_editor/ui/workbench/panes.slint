    in-out property <float> palette_drag_pointer_y: 0.0;
    property <string> palette_drag_label:
        root.palette_drag_source_index >= 0 && root.palette_drag_source_index < root.palette_items.length ?
        root.palette_items[root.palette_drag_source_index] :
        "";
    callback source_edited(value: string);
    callback palette_selected(item_index: int);
    in property <int> palette_drag_target_preview_index: -1;
    in property <string> palette_drag_target_action;
    in property <string> palette_drag_target_label;
    in property <[UiAssetCanvasSlotTargetData]> palette_drag_slot_target_items;
    in property <[string]> palette_drag_candidate_items;
    in property <int> palette_drag_candidate_selected_index: -1;
    in property <bool> palette_target_chooser_active: false;
    callback palette_drag_hovered(surface_x: float, surface_y: float);
    callback palette_drag_dropped();
    callback palette_drag_cancelled();
    callback palette_target_candidate_selected(item_index: int);
    callback palette_target_confirm();
    callback palette_target_cancel();
    callback hierarchy_selected(item_index: int);
    callback hierarchy_activated(item_index: int);
    callback preview_selected(item_index: int);
    callback preview_activated(item_index: int);
    callback source_outline_selected(item_index: int);
    callback preview_mock_selected(item_index: int);
    callback preview_mock_action(action_id: string, value: string);
    callback binding_selected(item_index: int);
    callback binding_event_selected(item_index: int);
    callback binding_action_kind_selected(item_index: int);
    callback binding_payload_selected(item_index: int);
    callback binding_payload_action(action_id: string, payload_key: string, payload_value: string);
    callback slot_semantic_selected(item_index: int);
    callback layout_semantic_selected(item_index: int);

    palette := Palette {}
    property <string> style_class_draft: "";
    property <string> style_rule_selector_draft: "";
    property <string> style_rule_declaration_path_draft: "";
    property <string> style_rule_declaration_value_draft: "";
    property <string> style_token_name_draft: "";
    property <string> style_token_value_draft: "";
    property <string> preview_mock_value_draft: "";
    property <string> binding_payload_key_draft: "";
    property <string> binding_payload_value_draft: "";
    drag_focus_host := FocusScope {
        x: 0px;
        y: 0px;
        width: 0px;
        height: 0px;
        enabled: root.palette_drag_active || root.palette_target_chooser_active;
        key-pressed(event) => {
            if (event.text == Key.LeftArrow || event.text == Key.UpArrow) {
                root.action("palette.target.previous");
                return accept;
            }
            if (
                event.text == Key.RightArrow
                || event.text == Key.DownArrow
                || event.text == Key.Tab
                ) {
                root.action("palette.target.next");
                return accept;
            }
            if (event.text == Key.Return || event.text == "\n") {
                if (root.palette_target_chooser_active) {
                    root.palette_target_confirm();
                    return accept;
                }
                if (root.palette_drag_target_action != "") {
                    root.palette_drag_dropped();
                }
                return accept;
            }
            if (event.text == Key.Escape) {
                if (root.palette_target_chooser_active) {
                    root.palette_target_cancel();
                } else {
                    root.palette_drag_cancelled();
                    root.palette_drag_active = false;
                    root.palette_drag_source_index = -1;
                }
                return accept;
            }
            reject
        }
    }
    background: transparent;
    clip: true;

    Rectangle {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
        height: 56px;
        border-radius: 4px;
        border-width: 1px;
        border-color: palette.border_soft;
        background: #ffffff06;

        Text {
            x: 10px;
            y: 6px;
            text: root.asset_id != "" ? root.asset_id : root.mode;
            color: palette.text;
            font-size: 10px;
            overflow: elide;
        }

        Text {
            x: 10px;
            y: 16px;
            width: parent.width - 20px;
            text:
                root.status != "" ?
                root.mode + " • " + root.selection + " • " + root.status :
                root.mode + " • " + root.selection;
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        HorizontalLayout {
            x: 10px;
            y: 28px;
            width: parent.width - 20px;
            spacing: 4px;

            ShellButton {
                width: 56px;
                label: "Design";
                active: root.mode == "Design";
                clicked => { root.action("mode.design"); }
            }
            ShellButton {
                width: 52px;
                label: "Split";
                active: root.mode == "Split";
                clicked => { root.action("mode.split"); }
            }
            ShellButton {
                width: 56px;
                label: "Source";
                active: root.mode == "Source";
                clicked => { root.action("mode.source"); }
            }
            ShellButton {
                width: 60px;
                label: "Preview";
                active: root.mode == "Preview";
                clicked => { root.action("mode.preview"); }
            }

            Rectangle { width: 1px; height: 20px; background: palette.border_soft; }

            ShellButton {
                width: 58px;
                label: "Docked";
                active: root.preview_preset == "Editor Docked";
                clicked => { root.action("preview.preset.editor_docked"); }
            }
            ShellButton {
                width: 50px;
                label: "Float";
                active: root.preview_preset == "Editor Floating";
                clicked => { root.action("preview.preset.editor_floating"); }
            }
            ShellButton {
                width: 44px;
                label: "HUD";
                active: root.preview_preset == "Game HUD";
                clicked => { root.action("preview.preset.game_hud"); }
            }
            ShellButton {
                width: 58px;
                label: "Dialog";
                active: root.preview_preset == "Dialog";
                clicked => { root.action("preview.preset.dialog"); }
            }

            Rectangle { width: 1px; height: 20px; background: palette.border_soft; }

            ShellButton {
                width: 46px;
                label: "Save";
                enabled: root.can_save;
                active: root.can_save;
                clicked => { root.action("save"); }
            }
            ShellButton {
                width: 48px;
                label: "Undo";
                enabled: root.can_undo;
                clicked => { root.action("undo"); }
            }
            ShellButton {
                width: 48px;
                label: "Redo";
                enabled: root.can_redo;
                clicked => { root.action("redo"); }
            }

            Text {
                text: root.preview_available ? root.preview_summary : "Preview unavailable";
                color: palette.text_dim;
                font-size: 9px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }

    HorizontalLayout {
        x: 10px;
        y: 74px;
        width: parent.width - 20px;
        height: parent.height - 84px;
        spacing: 8px;

        Rectangle {
            width: 240px;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                palette_section := UiAssetSelectableSection {
                    height: parent.height * 0.42;
                    title: "Palette";
                    items: root.palette_items;
                    selected_index: root.palette_selected_index;
                    accent: #9dc07c;
                    drag_enabled: true;
                    item_selected(item_index) => { root.palette_selected(item_index); }
                    item_drag_started(item_index, x, y) => {
                        root.palette_selected(item_index);
                        root.palette_drag_active = true;
                        root.palette_drag_source_index = item_index;
                        root.palette_drag_pointer_x = palette_section.x / 1px + x;
                        root.palette_drag_pointer_y = palette_section.y / 1px + y;
                        drag_focus_host.focus();
                    }
                }

                UiAssetSelectableSection {
                    height: parent.height * 0.58 - 8px;
                    title: "Hierarchy";
                    items: root.hierarchy_items;
                    selected_index: root.hierarchy_selected_index;
                    accent: #7aa2e3;
                    item_selected(item_index) => { root.hierarchy_selected(item_index); }
                    item_activated(item_index) => { root.hierarchy_activated(item_index); }
                }
            }
        }

        Rectangle {
            width: max(240px, parent.width - 536px);
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                Rectangle {
                    height: parent.height * 0.38;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    clip: true;

                    Text {
                        x: 10px;
                        y: 8px;
                        text: "Designer Canvas";
                        color: #e0aa5e;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Text {
                        x: parent.width - self.preferred-width - 10px;
                        y: 8px;
                        text: root.preview_summary;
                        color: palette.text_dim;
                        font-size: 9px;
                    }

                    preview_canvas := UiAssetCanvasSurface {
                        x: 10px;
                        y: 28px;
                        width: parent.width - 20px;
                        height: max(92px, parent.height - 126px);
                        items: root.preview_canvas_items;
                        surface_width: root.preview_surface_width;
                        surface_height: root.preview_surface_height;
                        selected_index: root.preview_selected_index;
                        palette_has_selection: root.palette_selected_index >= 0;
                        can_insert_child: root.can_insert_child;
                        can_insert_after: root.can_insert_after;
                        can_move_up: root.can_move_up;
                        can_move_down: root.can_move_down;
                        can_reparent_into_previous: root.can_reparent_into_previous;
                        can_reparent_into_next: root.can_reparent_into_next;
                        can_reparent_outdent: root.can_reparent_outdent;
                        can_open_reference: root.can_open_reference;
                        can_convert_to_reference: root.can_convert_to_reference;
                        can_extract_component: root.can_extract_component;
                        can_promote_to_external_widget: root.can_promote_to_external_widget;
                        can_wrap_in_vertical_box: root.can_wrap_in_vertical_box;
                        can_unwrap: root.can_unwrap;
                        external_drag_active: root.palette_drag_active;
                        external_drag_target_index: root.palette_drag_target_preview_index;
                        external_drag_target_action: root.palette_drag_target_action;
                        external_drag_target_label: root.palette_drag_target_label;
                        external_slot_target_items: root.palette_drag_slot_target_items;
                        external_drag_pointer_x: root.palette_drag_pointer_x - preview_canvas.x / 1px;
                        external_drag_pointer_y: root.palette_drag_pointer_y - preview_canvas.y / 1px;
                        item_selected(item_index) => { root.preview_selected(item_index); }
                        item_activated(item_index) => { root.preview_activated(item_index); }
                        action_requested(action_id) => { root.action(action_id); }
                    }

                    UiAssetSelectableSection {
                        x: 10px;
                        y: parent.height - 90px;
                        width: parent.width - 20px;
                        height: 80px;
                        title: "Render Stack";
                        items: root.preview_items;
                        selected_index: root.preview_selected_index;
                        accent: #e0aa5e;
                        item_selected(item_index) => { root.preview_selected(item_index); }
                        item_activated(item_index) => { root.preview_activated(item_index); }
                    }
                }

                Rectangle {
                    height: 54px;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;

                    VerticalLayout {
