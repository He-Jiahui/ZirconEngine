                                text: root.inspector_binding.binding_action_target;
                                placeholder: "EditorActions.SaveProject";
                                enabled: root.inspector_binding.can_edit;
                edited(value) => { root.detail_event("binding", "binding.action_target.set", -1, value, ""); }
                            }

