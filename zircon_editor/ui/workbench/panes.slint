                        width: parent.width - 20px;
                        height: 72px;
                        title: "Source Outline";
                        items: root.source_outline_items;
                        selected_index: root.source_outline_selected_index;
                        accent: #d8d28a;
                        item_selected(item_index) => { root.source_outline_selected(item_index); }
                    }

                    UiAssetSelectableSection {
                        x: 10px;
                        y: 170px;
                        width: parent.width - 20px;
                        height: 72px;
                        title: "Mock Preview";
                        items: root.preview_mock_items;
                        selected_index: root.preview_mock_selected_index;
                        accent: #c98fe3;
                        item_selected(item_index) => {
                            root.preview_mock_selected(item_index);
                            root.preview_mock_value_draft = root.preview_mock_value;
                        }
                    }

                    Text {
                        x: 10px;
                        y: 248px;
                        width: 88px;
                        text: root.preview_mock_property;
                        color: palette.text;
                        font-size: 9px;
                        font-weight: 600;
                    }

                    Text {
                        x: 102px;
                        y: 248px;
                        width: parent.width - 112px;
                        text: root.preview_mock_kind;
                        color: palette.text_dim;
                        font-size: 9px;
                        horizontal-alignment: right;
                    }

                    TextEdit {
                        x: 10px;
                        y: 262px;
                        width: parent.width - 148px;
                        height: 28px;
                        text:
                            root.preview_mock_value_draft != "" ?
                            root.preview_mock_value_draft :
                            root.preview_mock_value;
                        enabled: root.preview_mock_can_edit;
                        font-size: 9px;
                        font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                        edited(value) => { root.preview_mock_value_draft = value; }
                    }

                    ShellButton {
                        x: parent.width - 132px;
                        y: 262px;
                        width: 56px;
                        label: "Apply";
                        enabled: root.preview_mock_can_edit;
                        clicked => {
                            root.preview_mock_action("preview.mock.value.set", root.preview_mock_value_draft != "" ? root.preview_mock_value_draft : root.preview_mock_value);
                            root.preview_mock_value_draft = "";
                        }
                    }

                    ShellButton {
                        x: parent.width - 68px;
                        y: 262px;
                        width: 58px;
                        label: "Clear";
                        enabled: root.preview_mock_can_clear;
                        clicked => {
                            root.preview_mock_action("preview.mock.clear", "");
                            root.preview_mock_value_draft = "";
                        }
                    }

                    TextEdit {
                        x: 10px;
                        y: 298px;
                        width: parent.width - 20px;
                        height: max(120px, parent.height - 348px);
                        text: root.source_text;
                        enabled: true;
                        font-size: 10px;
                        font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                        wrap: word-wrap;
                        edited(value) => { root.source_edited(value); }
                    }

                    Text {
                        x: 10px;
                        y: parent.height - 42px;
                        width: parent.width - 20px;
                        text: root.source_selected_excerpt;
                        color: palette.text_dim;
                        font-size: 9px;
                        wrap: word-wrap;
                    }
                }
            }
        }

        Rectangle {
            width: 280px;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                Rectangle {
                    height: parent.height * 0.5;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
