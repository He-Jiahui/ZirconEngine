                                accent: #7cc6b9;
                                item_selected(item_index) => {
                                    root.collection_event("binding_payload", "selected", item_index);
                                    root.binding_payload_key_draft = root.inspector_binding.payload_key;
                                    root.binding_payload_value_draft = root.inspector_binding.payload_value;
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.binding_payload_key_draft != "" ?
                                    root.binding_payload_key_draft :
                                    root.inspector_binding.payload_key;
                                placeholder: "payload key";
                                enabled: root.inspector_binding.can_edit;
                                edited(value) => { root.binding_payload_key_draft = value; }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.binding_payload_value_draft != "" ?
                                    root.binding_payload_value_draft :
                                    root.inspector_binding.payload_value;
