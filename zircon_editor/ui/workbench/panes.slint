                                active: root.can_promote_to_external_widget;
                                clicked => { root.action("canvas.promote.widget"); }
                            }

                            ShellButton {
                                width: 82px;
                                label: "Wrap VBox";
                                enabled: root.can_wrap_in_vertical_box;
                                active: root.can_wrap_in_vertical_box;
                                clicked => { root.action("canvas.wrap.vertical_box"); }
                            }

                            ShellButton {
                                width: 58px;
                                label: "Unwrap";
                                enabled: root.can_unwrap;
                                active: root.can_unwrap;
                                clicked => { root.action("canvas.unwrap"); }
                            }
                        }
                    }
                }

                Rectangle {
                    height: parent.height * 0.62 - 62px;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    clip: true;

                    Text {
                        x: 10px;
                        y: 8px;
                        text: "Source";
