                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 92px;
                                title: "Theme Rules";
                                items: root.theme_source.selected_source_rule_items;
                                selected_index: root.theme_source.selected_source_kind == "Local" ? root.style_rule.selected_index : -1;
                                accent: #d8ba79;
                                item_selected(item_index) => {
