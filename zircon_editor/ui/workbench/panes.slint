                                width: parent.width;
                                text: root.inspector_binding.binding_route_target;
                                placeholder: "MenuAction.SaveProject";
                                enabled: root.inspector_binding.can_edit;
                edited(value) => { root.detail_event("binding", "binding.route_target.set", -1, value, ""); }
                            }

                            if root.inspector_binding.action_kind_collection.selected_index == 2: Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: parent.width;
                                    text: "Action Target";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

