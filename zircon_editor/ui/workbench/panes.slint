                                color: palette.text_dim;
                                font-size: 10px;
                            }

                            for item in root.inspector_widget.items: Text {
                                text: item;
                                color: palette.text_muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                Rectangle {
                    height: parent.height * 0.5 - 8px;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    clip: true;

                    Text {
                        x: 10px;
                        y: 6px;
                        text: "Stylesheet";
                        color: #8dc8c1;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    HorizontalLayout {
                        x: 10px;
                        y: 26px;
                        width: parent.width - 20px;
                        spacing: 4px;

                        ShellButton {
                            width: 42px;
                            label: "Rule";
                enabled: root.pane.can_create_rule;
                active: root.pane.can_create_rule;
                            clicked => {
                                root.style_rule_selector_draft = "";
                                root.action("style.rule.create");
                            }
                        }

                        ShellButton {
                            width: 58px;
                            label: "Extract";
                enabled: root.pane.can_extract_rule;
                active: root.pane.can_extract_rule;
                            clicked => {
