                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_layout.scrollbar_visibility; placeholder: "container.scrollbar_visibility"; enabled: root.inspector_widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.scrollbar_visibility.set", -1, value, ""); } }
                            }

                            if root.inspector_layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Extent"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_layout.virtualization_item_extent; placeholder: "container.virtualization.item_extent"; enabled: root.inspector_widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.virtualization.item_extent.set", -1, value, ""); } }
