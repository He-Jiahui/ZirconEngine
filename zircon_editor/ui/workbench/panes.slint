component UiAssetSelectableSection inherits Rectangle {
    in property <string> title;
    in property <[string]> items;
    in property <int> selected_index: -1;
    in property <color> accent: #7aa2e3;
    in property <bool> drag_enabled: false;
    callback item_selected(item_index: int);
    callback item_activated(item_index: int);
    callback item_drag_started(item_index: int, x: float, y: float);

    palette := Palette {}
    background: palette.panel_bg_soft;
    border-radius: 4px;
    border-width: 1px;
    border-color: palette.border_soft;
    clip: true;
    property <float> content_origin_x: 10.0;
    property <float> content_origin_y: 34.0;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 26px;
        background: #ffffff06;

        Text {
            x: 10px;
            y: 6px;
            text: root.title;
            color: root.accent;
            font-size: 11px;
            font-weight: 700;
        }
    }

    Rectangle {
        x: 0px;
        y: 26px;
        width: parent.width;
        height: parent.height - 26px;
        clip: true;

        VerticalLayout {
            x: 10px;
            y: 8px;
            width: parent.width - 20px;
            spacing: 4px;

            if root.items.length == 0: Text {
                text: "No entries";
                color: palette.text_dim;
                font-size: 10px;
            }

            for item[index] in root.items: item_row := Rectangle {
                height: max(20px, item_text.preferred-height + 6px);
                border-radius: 3px;
                background:
                    index == root.selected_index ? #ffffff10 :
                    row_touch.has-hover ? #ffffff09 :
                    transparent;

                item_text := Text {
                    x: 6px;
                    y: 3px;
                    width: parent.width - 12px;
                    text: item;
                    color: palette.text_muted;
                    font-size: 10px;
                    wrap: word-wrap;
                }

                row_touch := TouchArea {
                    property <float> drag_threshold_px: 8.0;
                    property <bool> drag_pressed: false;
                    property <bool> drag_active: false;
                    property <bool> suppress_click: false;
                    property <float> press_x: 0.0;
                    property <float> press_y: 0.0;
                    width: parent.width;
                    height: parent.height;
                    clicked => {
                        if (!self.suppress_click) {
                            root.item_selected(index);
                        }
                        self.suppress_click = false;
                    }
                    double-clicked => {
                        if (!self.suppress_click) {
                            root.item_activated(index);
                        }
                        self.suppress_click = false;
                    }
                    pointer-event(event) => {
                        if (!root.drag_enabled || event.button != PointerEventButton.left) {
                            return;
                        }
                        if (event.kind == PointerEventKind.down) {
                            self.drag_pressed = true;
                            self.drag_active = false;
                            self.suppress_click = false;
                            self.press_x = self.mouse-x / 1px;
                            self.press_y = self.mouse-y / 1px;
                        } else if (event.kind == PointerEventKind.up) {
                            self.drag_pressed = false;
                            self.drag_active = false;
                        }
                    }
                    moved => {
                        if (!root.drag_enabled || !self.drag_pressed || self.drag_active) {
                            return;
                        }
                        if (
                            (
                                (self.mouse-x / 1px - self.press_x) * (self.mouse-x / 1px - self.press_x)
                                + (self.mouse-y / 1px - self.press_y) * (self.mouse-y / 1px - self.press_y)
                            ) >= self.drag_threshold_px * self.drag_threshold_px
                        ) {
                            self.drag_active = true;
                            self.suppress_click = true;
                            root.item_drag_started(
                                index,
                                root.content_origin_x + item_row.x / 1px + self.mouse-x / 1px,
                                root.content_origin_y + item_row.y / 1px + self.mouse-y / 1px,
                            );
                        }
                    }
                }
            }
        }
    }
}

component UiAssetCanvasSurface inherits Rectangle {
    in property <[UiAssetCanvasNodeData]> items;
    in property <float> surface_width: 0.0;
    in property <float> surface_height: 0.0;
    in property <int> selected_index: -1;
    in property <bool> palette_has_selection: false;
    in property <bool> can_insert_child: false;
    in property <bool> can_insert_after: false;
    in property <bool> can_move_up: false;
    in property <bool> can_move_down: false;
    in property <bool> can_reparent_into_previous: false;
    in property <bool> can_reparent_into_next: false;
    in property <bool> can_reparent_outdent: false;
    in property <bool> can_open_reference: false;
    in property <bool> can_convert_to_reference: false;
    in property <bool> can_extract_component: false;
    in property <bool> can_promote_to_external_widget: false;
    in property <bool> can_wrap_in_vertical_box: false;
    in property <bool> can_unwrap: false;
    in property <bool> external_drag_active: false;
    in property <int> external_drag_target_index: -1;
    in property <string> external_drag_target_action;
    in property <string> external_drag_target_label;
    in property <[UiAssetCanvasSlotTargetData]> external_slot_target_items;
    in property <float> external_drag_pointer_x: 0.0;
    in property <float> external_drag_pointer_y: 0.0;
    callback item_selected(item_index: int);
    callback item_activated(item_index: int);
    callback action_requested(action_id: string);

    palette := Palette {}
    background: palette.panel_bg_soft;
    border-radius: 4px;
    border-width: 1px;
    border-color: palette.border_soft;
    clip: true;

    property <float> safe_surface_width: root.surface_width > 1.0 ? root.surface_width : 1.0;
    property <float> safe_surface_height: root.surface_height > 1.0 ? root.surface_height : 1.0;
    property <float> available_width: max(root.width / 1px - 24.0, 1.0);
    property <float> available_height: max(root.height / 1px - 24.0, 1.0);
    property <float> scale:
        min(root.available_width / root.safe_surface_width, root.available_height / root.safe_surface_height);
    out property <float> surface_scale: root.scale;
    property <float> scaled_surface_width: root.safe_surface_width * root.scale;
    property <float> scaled_surface_height: root.safe_surface_height * root.scale;
    property <float> surface_offset_x: ((root.width / 1px) - root.scaled_surface_width) * 0.5;
    property <float> surface_offset_y: ((root.height / 1px) - root.scaled_surface_height) * 0.5;
    out property <float> surface_origin_x: root.surface_offset_x;
    out property <float> surface_origin_y: root.surface_offset_y;
    property <float> target_pad_thickness: 14.0;
    property <float> drag_threshold_px: 8.0;
    property <bool> drag_pressed: false;
    property <bool> drag_active: false;
    property <bool> drag_suppress_click: false;
    property <int> drag_source_index: -1;
    property <float> drag_press_x: 0.0;
    property <float> drag_press_y: 0.0;
    property <float> drag_pointer_x: 0.0;
    property <float> drag_pointer_y: 0.0;
    property <int> overlay_index:
        root.drag_source_index >= 0 && root.drag_source_index < root.items.length && (root.drag_pressed || root.drag_active) ? root.drag_source_index :
        root.selected_index >= 0 && root.selected_index < root.items.length ? root.selected_index : -1;
    property <float> overlay_frame_x:
        root.overlay_index >= 0 ? root.surface_offset_x + root.items[root.overlay_index].x * root.scale : 0.0;
    property <float> overlay_frame_y:
        root.overlay_index >= 0 ? root.surface_offset_y + root.items[root.overlay_index].y * root.scale : 0.0;
    property <float> overlay_frame_width:
        root.overlay_index >= 0 ? max(root.items[root.overlay_index].width * root.scale, 2.0) : 0.0;
    property <float> overlay_frame_height:
        root.overlay_index >= 0 ? max(root.items[root.overlay_index].height * root.scale, 2.0) : 0.0;
    property <string> drag_target_action:
        !root.drag_active ? "" :
        root.can_insert_child
            && root.drag_pointer_x >= root.overlay_frame_x
            && root.drag_pointer_x <= root.overlay_frame_x + root.overlay_frame_width
            && root.drag_pointer_y >= root.overlay_frame_y
            && root.drag_pointer_y <= root.overlay_frame_y + root.overlay_frame_height ? "palette.insert.child" :
        root.can_insert_after
            && root.drag_pointer_x >= root.overlay_frame_x
            && root.drag_pointer_x <= root.overlay_frame_x + root.overlay_frame_width
            && root.drag_pointer_y >= root.overlay_frame_y + root.overlay_frame_height + 4.0
            && root.drag_pointer_y <= root.overlay_frame_y + root.overlay_frame_height + 4.0 + root.target_pad_thickness ? "palette.insert.after" :
        root.can_reparent_into_previous
            && root.drag_pointer_x >= max(root.overlay_frame_x - root.target_pad_thickness - 4.0, 4.0)
            && root.drag_pointer_x <= max(root.overlay_frame_x - 4.0, 4.0)
            && root.drag_pointer_y >= root.overlay_frame_y
            && root.drag_pointer_y <= root.overlay_frame_y + root.overlay_frame_height ? "canvas.reparent.into_previous" :
        root.can_reparent_into_next
            && root.drag_pointer_x >= min(root.overlay_frame_x + root.overlay_frame_width + 4.0, root.width / 1px - root.target_pad_thickness - 4.0)
            && root.drag_pointer_x <= min(root.overlay_frame_x + root.overlay_frame_width + root.target_pad_thickness + 4.0, root.width / 1px - 4.0)
            && root.drag_pointer_y >= root.overlay_frame_y
            && root.drag_pointer_y <= root.overlay_frame_y + root.overlay_frame_height ? "canvas.reparent.into_next" :
        root.can_reparent_outdent
            && root.drag_pointer_x >= root.overlay_frame_x
            && root.drag_pointer_x <= root.overlay_frame_x + root.overlay_frame_width
            && root.drag_pointer_y >= max(root.overlay_frame_y - root.target_pad_thickness - 4.0, 4.0)
            && root.drag_pointer_y <= max(root.overlay_frame_y - 4.0, 4.0) ? "canvas.reparent.outdent" :
        "";
    property <string> drag_target_label:
        root.drag_target_action == "palette.insert.child" ? "Insert In" :
        root.drag_target_action == "palette.insert.after" ? "Insert After" :
        root.drag_target_action == "canvas.reparent.into_previous" ? "Into Prev" :
        root.drag_target_action == "canvas.reparent.into_next" ? "Into Next" :
        root.drag_target_action == "canvas.reparent.outdent" ? "Outdent" :
        "";

    Rectangle {
        x: root.surface_offset_x * 1px;
        y: root.surface_offset_y * 1px;
        width: root.scaled_surface_width * 1px;
        height: root.scaled_surface_height * 1px;
        border-radius: 4px;
        border-width: 1px;
        border-color: #ffffff12;
        background: #12161c;
    }

    if root.items.length == 0: Text {
        x: 10px;
        y: 10px;
        text: "No preview frames";
        color: palette.text_dim;
        font-size: 10px;
    }

    for item[index] in root.items: frame_rect := Rectangle {
        x: root.surface_offset_x * 1px + item.x * root.scale * 1px;
        y: root.surface_offset_y * 1px + item.y * root.scale * 1px;
        width: max(item.width * root.scale * 1px, 2px);
        height: max(item.height * root.scale * 1px, 2px);
        property <bool> external_target_active:
            root.external_drag_active && root.external_drag_target_index == index;
        property <bool> external_child_target_active:
            self.external_target_active
            && root.external_drag_target_action == "palette.insert.child"
            && root.external_slot_target_items.length == 0;
        property <bool> external_after_target_active:
            self.external_target_active && root.external_drag_target_action == "palette.insert.after";
        border-radius: 3px;
        border-width:
            self.external_target_active ? 2px :
            index == root.selected_index || item.selected ? 2px :
            1px;
        border-color:
            self.external_target_active ? #53c98a :
            index == root.selected_index || item.selected ? #ffd479 :
            frame_touch.has-hover ? #9ec1ff :
            #7f8b9b;
        background:
            self.external_target_active ? #53c98a22 :
            index == root.selected_index || item.selected ? #ffd47922 :
            frame_touch.has-hover ? #8ab7ff16 :
            #ffffff08;
        clip: true;

        Text {
            visible: parent.width >= 48px && parent.height >= 16px;
            x: 4px;
            y: 3px;
            width: parent.width - 8px;
            text: item.label;
            color: index == root.selected_index || item.selected ? #fff3d6 : #d7dce4;
            font-size: 9px;
            font-weight: 600;
            overflow: elide;
        }

        if frame_rect.external_child_target_active: drop_inside_overlay := Rectangle {
            x: 6px;
            y: 6px;
            width: max(parent.width - 12px, 18px);
            height: max(parent.height - 12px, 18px);
            border-radius: 3px;
            border-width: 1px;
            border-color: #53c98acc;
            background: #53c98a12;

            Text {
                visible: parent.width >= 56px;
                x: 6px;
                y: 4px;
                width: parent.width - 12px;
                text: root.external_drag_target_label;
                color: #dff8e8;
                font-size: 8px;
                font-weight: 700;
                overflow: elide;
            }
        }

        frame_touch := TouchArea {
            mouse-cursor:
                root.drag_source_index == index && (root.drag_pressed || root.drag_active) ? MouseCursor.grabbing :
                MouseCursor.grab;
            width: parent.width;
            height: parent.height;
            clicked => {
                if (!root.drag_suppress_click) {
                    root.item_selected(index);
                }
                root.drag_suppress_click = false;
            }
            double-clicked => {
                if (!root.drag_suppress_click) {
                    root.item_activated(index);
                }
                root.drag_suppress_click = false;
            }
            pointer-event(event) => {
                if (event.button != PointerEventButton.left) {
                    return;
                }
                if (event.kind == PointerEventKind.down) {
                    root.drag_pressed = true;
                    root.drag_active = false;
                    root.drag_suppress_click = false;
                    root.drag_source_index = index;
                    root.drag_press_x = frame_rect.x / 1px + self.mouse-x / 1px;
                    root.drag_press_y = frame_rect.y / 1px + self.mouse-y / 1px;
                    root.drag_pointer_x = frame_rect.x / 1px + self.mouse-x / 1px;
                    root.drag_pointer_y = frame_rect.y / 1px + self.mouse-y / 1px;
                } else if (event.kind == PointerEventKind.up && root.drag_source_index == index) {
                    root.drag_pointer_x = frame_rect.x / 1px + self.mouse-x / 1px;
                    root.drag_pointer_y = frame_rect.y / 1px + self.mouse-y / 1px;
                    if (root.drag_active && root.drag_target_action != "") {
                        root.action_requested(root.drag_target_action);
                    }
                    root.drag_pressed = false;
                    root.drag_active = false;
                    root.drag_source_index = -1;
                }
            }
            moved => {
                if (!root.drag_pressed || root.drag_source_index != index) {
                    return;
                }
                root.drag_pointer_x = frame_rect.x / 1px + self.mouse-x / 1px;
                root.drag_pointer_y = frame_rect.y / 1px + self.mouse-y / 1px;
                if (
                    !root.drag_active
                    && (
                        (root.drag_pointer_x - root.drag_press_x) * (root.drag_pointer_x - root.drag_press_x)
                        + (root.drag_pointer_y - root.drag_press_y) * (root.drag_pointer_y - root.drag_press_y)
                    ) >= root.drag_threshold_px * root.drag_threshold_px
                ) {
                    root.drag_active = true;
                    root.drag_suppress_click = true;
                    root.item_selected(index);
                }
            }
        }
    }

    for target[index] in root.external_slot_target_items: external_slot_target := Rectangle {
        visible:
            root.external_drag_active
            && root.external_drag_target_action == "palette.insert.child";
        x: root.surface_offset_x * 1px + target.x * root.scale * 1px;
        y: root.surface_offset_y * 1px + target.y * root.scale * 1px;
        width: max(target.width * root.scale * 1px, 10px);
        height: max(target.height * root.scale * 1px, 10px);
        border-radius: 3px;
        border-width: target.selected ? 2px : 1px;
        border-color: target.selected ? #53c98acc : #53c98a66;
        background: target.selected ? #53c98a28 : #53c98a10;

        Text {
            visible: parent.width >= 34px && parent.height >= 14px;
            x: 4px;
            y: 3px;
            width: parent.width - 8px;
            text: target.label;
            color: target.selected ? #dff8e8 : #b9d8c4;
            font-size: 8px;
            font-weight: target.selected ? 700 : 600;
            overflow: elide;
        }
    }

    for item[index] in root.items: drop_after_overlay := Rectangle {
        visible:
            root.external_drag_active
            && root.external_drag_target_index == index
            && root.external_drag_target_action == "palette.insert.after";
        x: root.surface_offset_x * 1px + item.x * root.scale * 1px + 4px;
        y: root.surface_offset_y * 1px + (item.y + item.height) * root.scale * 1px + 6px;
        width: max(item.width * root.scale * 1px - 8px, 44px);
        height: 18px;
        border-radius: 9px;
        border-width: 1px;
        border-color: #53c98acc;
        background: #0f1a13ee;

        Text {
            x: 8px;
            y: 4px;
            width: parent.width - 16px;
            text: root.external_drag_target_label;
            color: #dff8e8;
            font-size: 8px;
            font-weight: 700;
            overflow: elide;
        }
    }

    if root.drag_active: drag_overlay := Rectangle {
        x: min(max(root.drag_pointer_x * 1px + 12px, 8px), max(root.width - self.width - 8px, 8px));
        y: min(max(root.drag_pointer_y * 1px - self.height - 12px, 8px), max(root.height - self.height - 8px, 8px));
        width: 116px;
        height: 24px;
        border-radius: 4px;
        border-width: 1px;
        border-color: root.drag_target_label != "" ? #53c98a88 : #7f8b9b88;
        background: root.drag_target_label != "" ? #0f1a13ee : #10161eea;

        Text {
            x: 8px;
            y: 5px;
            width: parent.width - 16px;
            text: root.drag_target_label != "" ? root.drag_target_label : "Drag Authoring";
            color: root.drag_target_label != "" ? #dff8e8 : #d7dce4;
            font-size: 9px;
            font-weight: 700;
            overflow: elide;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: MouseCursor.grabbing;
        }
    }

    if root.external_drag_active: external_drag_overlay := Rectangle {
        x: min(max(root.external_drag_pointer_x * 1px + 12px, 8px), max(root.width - self.width - 8px, 8px));
        y: min(max(root.external_drag_pointer_y * 1px - self.height - 12px, 8px), max(root.height - self.height - 8px, 8px));
        width: 122px;
        height: 24px;
        border-radius: 4px;
        border-width: 1px;
        border-color: root.external_drag_target_label != "" ? #53c98a88 : #7f8b9b88;
        background: root.external_drag_target_label != "" ? #0f1a13ee : #10161eea;

        Text {
            x: 8px;
            y: 5px;
            width: parent.width - 16px;
            text: root.external_drag_target_label != "" ? root.external_drag_target_label : "Drop On Canvas";
            color: root.external_drag_target_label != "" ? #dff8e8 : #d7dce4;
            font-size: 9px;
            font-weight: 700;
            overflow: elide;
        }
    }

    if root.overlay_index >= 0 && root.can_insert_child: insert_child_target := Rectangle {
        x: root.overlay_frame_x * 1px;
        y: root.overlay_frame_y * 1px;
        width: root.overlay_frame_width * 1px;
        height: root.overlay_frame_height * 1px;
        border-radius: 3px;
        border-width: 2px;
        border-color: #53c98a;
        background: #53c98a22;

        Text {
            x: 6px;
            y: 4px;
            text: "Insert In";
            color: #dff8e8;
            font-size: 9px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("palette.insert.child"); }
        }
    }

    if root.overlay_index >= 0 && root.can_insert_after: insert_after_target := Rectangle {
        x: root.overlay_frame_x * 1px;
        y: (root.overlay_frame_y + root.overlay_frame_height + 4.0) * 1px;
        width: root.overlay_frame_width * 1px;
        height: root.target_pad_thickness * 1px;
        border-radius: 3px;
        border-width: 1px;
        border-color: #53c98a;
        background: #53c98a2a;

        Text {
            x: 6px;
            y: 2px;
            text: "Insert After";
            color: #dff8e8;
            font-size: 8px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("palette.insert.after"); }
        }
    }

    if root.overlay_index >= 0 && root.can_reparent_into_previous: reparent_prev_target := Rectangle {
        x: max(root.overlay_frame_x - root.target_pad_thickness - 4.0, 4.0) * 1px;
        y: root.overlay_frame_y * 1px;
        width: root.target_pad_thickness * 1px;
        height: root.overlay_frame_height * 1px;
        border-radius: 3px;
        border-width: 1px;
        border-color: #7db8ff;
        background: #7db8ff24;

        Text {
            x: parent.width + 4px;
            y: 4px;
            text: "Into Prev";
            color: #dbeafe;
            font-size: 8px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("canvas.reparent.into_previous"); }
        }
    }

    if root.overlay_index >= 0 && root.can_reparent_into_next: reparent_next_target := Rectangle {
        x: min(root.overlay_frame_x + root.overlay_frame_width + 4.0, root.width / 1px - root.target_pad_thickness - 4.0) * 1px;
        y: root.overlay_frame_y * 1px;
        width: root.target_pad_thickness * 1px;
        height: root.overlay_frame_height * 1px;
        border-radius: 3px;
        border-width: 1px;
        border-color: #7db8ff;
        background: #7db8ff24;

        Text {
            x: -52px;
            y: 4px;
            text: "Into Next";
            color: #dbeafe;
            font-size: 8px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("canvas.reparent.into_next"); }
        }
    }

    if root.overlay_index >= 0 && root.can_reparent_outdent: outdent_target := Rectangle {
        x: root.overlay_frame_x * 1px;
        y: max(root.overlay_frame_y - root.target_pad_thickness - 4.0, 4.0) * 1px;
        width: root.overlay_frame_width * 1px;
        height: root.target_pad_thickness * 1px;
        border-radius: 3px;
        border-width: 1px;
        border-color: #f0b667;
        background: #f0b66724;

        Text {
            x: 6px;
            y: 2px;
            text: "Outdent";
            color: #fff3d6;
            font-size: 8px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("canvas.reparent.outdent"); }
        }
    }

    if root.overlay_index >= 0: overlay := Rectangle {
        x: min(root.overlay_frame_x * 1px, max(root.width - 256px, 8px));
        y: min((root.overlay_frame_y + root.overlay_frame_height + 8.0) * 1px, max(root.height - 96px, 8px));
        width: 248px;
        height: 88px;
        border-radius: 4px;
        border-width: 1px;
        border-color: #ffd47988;
        background: #10161eea;

        VerticalLayout {
            x: 8px;
            y: 7px;
            width: parent.width - 16px;
            height: parent.height - 14px;
            spacing: 4px;

            Text {
                text: root.items[root.overlay_index].label + " • " + root.items[root.overlay_index].kind;
                color: #fff3d6;
                font-size: 9px;
                font-weight: 700;
                overflow: elide;
            }

            HorizontalLayout {
                width: parent.width;
                spacing: 2px;

                ShellButton {
                    width: 52px;
                    label: "Add In";
                    enabled: root.can_insert_child;
                    active: root.can_insert_child;
                    clicked => { root.action_requested("palette.insert.child"); }
                }

                ShellButton {
                    width: 66px;
                    label: "Add After";
                    enabled: root.can_insert_after;
                    active: root.can_insert_after;
                    clicked => { root.action_requested("palette.insert.after"); }
                }

                ShellButton {
                    width: 36px;
                    label: "Up";
                    enabled: root.can_move_up;
                    active: root.can_move_up;
                    clicked => { root.action_requested("canvas.move.up"); }
                }

                ShellButton {
                    width: 46px;
                    label: "Down";
                    enabled: root.can_move_down;
                    active: root.can_move_down;
                    clicked => { root.action_requested("canvas.move.down"); }
                }
            }

            HorizontalLayout {
                width: parent.width;
                spacing: 2px;

                ShellButton {
                    width: 44px;
                    label: "Prev";
                    enabled: root.can_reparent_into_previous;
                    active: root.can_reparent_into_previous;
                    clicked => { root.action_requested("canvas.reparent.into_previous"); }
                }

                ShellButton {
                    width: 44px;
                    label: "Next";
                    enabled: root.can_reparent_into_next;
                    active: root.can_reparent_into_next;
                    clicked => { root.action_requested("canvas.reparent.into_next"); }
                }

                ShellButton {
                    width: 40px;
                    label: "Out";
                    enabled: root.can_reparent_outdent;
                    active: root.can_reparent_outdent;
                    clicked => { root.action_requested("canvas.reparent.outdent"); }
                }

                ShellButton {
                    width: 50px;
                    label: "Wrap";
                    enabled: root.can_wrap_in_vertical_box;
                    active: root.can_wrap_in_vertical_box;
                    clicked => { root.action_requested("canvas.wrap.vertical_box"); }
                }

                ShellButton {
                    width: 58px;
                    label: "Unwrap";
                    enabled: root.can_unwrap;
                    active: root.can_unwrap;
                    clicked => { root.action_requested("canvas.unwrap"); }
                }
            }

            HorizontalLayout {
                width: parent.width;
                spacing: 2px;

                ShellButton {
                    width: 48px;
                    label: "Open";
                    enabled: root.can_open_reference;
                    active: root.can_open_reference;
                    clicked => { root.action_requested("reference.open"); }
                }

                ShellButton {
                    width: 54px;
                    label: "To Ref";
                    enabled: root.can_convert_to_reference;
                    active: root.can_convert_to_reference;
                    clicked => { root.action_requested("canvas.convert.reference"); }
                }

                ShellButton {
                    width: 58px;
                    label: "Extract";
                    enabled: root.can_extract_component;
                    active: root.can_extract_component;
                    clicked => { root.action_requested("canvas.extract.component"); }
                }

                ShellButton {
                    width: 64px;
                    label: "Promote";
                    enabled: root.can_promote_to_external_widget;
                    active: root.can_promote_to_external_widget;
                    clicked => { root.action_requested("canvas.promote.widget"); }
                }
            }
        }
    }

    Text {
        x: 10px;
        y: parent.height - 18px;
        text:
            root.surface_width > 0.0 && root.surface_height > 0.0 ?
            root.surface_width + " x " + root.surface_height + " • " + root.items.length + " draw nodes" :
            "";
        color: palette.text_dim;
        font-size: 9px;
    }
}

component CompactField inherits Rectangle {
    in property <string> text;
    in property <string> placeholder;
    in property <bool> enabled: true;
    callback edited(value: string);

    palette := Palette {}
    height: 22px;
    border-radius: 3px;
    border-width: 1px;
    border-color: palette.border;
    background: enabled ? palette.panel_bg_soft : palette.panel_bg;
    opacity: enabled ? 1.0 : 0.55;

    LineEdit {
        x: 6px;
        y: 1px;
        width: parent.width - 12px;
        height: parent.height - 2px;
        text: root.text;
        placeholder-text: root.placeholder;
        enabled: root.enabled;
        font-size: 11px;
        edited(value) => { root.edited(value); }
    }
}

component AxisField inherits Rectangle {
    in property <string> axis;
    in property <color> axis_color;
    in property <string> value;
    callback edited(value: string);

    palette := Palette {}
    height: 22px;
    border-radius: 3px;
    border-width: 1px;
    border-color: palette.border;
    background: palette.panel_bg_soft;

    Text {
        x: 7px;
        y: 5px;
        text: root.axis;
        color: root.axis_color;
        font-size: 10px;
        font-weight: 700;
    }

    LineEdit {
        x: 18px;
        y: 1px;
        width: parent.width - 24px;
        height: parent.height - 2px;
        text: root.value;
        placeholder-text: root.axis;
        font-size: 11px;
        edited(value) => { root.edited(value); }
    }
}

export component ToolWindowEmptyState inherits Rectangle {
    in property <string> eyebrow;
    in property <string> title;
    in property <string> body;
    in property <string> primary_action_label;
    in property <string> primary_action_id;
    in property <string> secondary_hint;
    callback trigger_action(action_id: string);

    palette := Palette {}
    background: transparent;

    Rectangle {
        x: 12px;
        y: 18px;
        width: parent.width - 24px;
        height: min(parent.height - 24px, 188px);
        background: transparent;

        VerticalLayout {
            width: parent.width;
            spacing: 8px;

            if root.eyebrow != "": Text {
                text: root.eyebrow;
                color: palette.accent;
                font-size: 10px;
                font-weight: 600;
            }

            Text {
                text: root.title;
                color: palette.text;
                font-size: 14px;
                font-weight: 600;
            }

            Text {
                text: root.body;
                color: palette.text_muted;
                font-size: 11px;
                wrap: word-wrap;
            }

            if root.primary_action_label != "": ShellButton {
                width: 96px;
                label: root.primary_action_label;
                active: true;
                clicked => { root.trigger_action(root.primary_action_id); }
            }

            if root.secondary_hint != "": Text {
                text: root.secondary_hint;
                color: palette.text_dim;
                font-size: 10px;
                wrap: word-wrap;
            }
        }
    }
}

export component HierarchyPane inherits Rectangle {
    in property <[SceneNodeData]> hierarchy_nodes;
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: transparent;
    clip: true;

    Rectangle {
        width: parent.width;
        height: parent.height;
        clip: true;

        rows := VerticalLayout {
            x: 8px;
            y: 8px - root.scroll_px * 1px;
            width: parent.width - 16px;
            spacing: 1px;

            for node[index] in root.hierarchy_nodes: Rectangle {
                height: 22px;
                border-radius: 3px;
                background: node.selected ? #365880 : root.hovered_index == index ? palette.chrome_bg_soft : transparent;

                Text {
                    x: 10px + node.depth * 14px;
                    y: 4px;
                    text: node.name;
                    color: node.selected ? #eef4ff : palette.text_muted;
                    font-size: 11px;
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px,
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}

export component InspectorPane inherits Rectangle {
    in property <string> info;
    in property <string> inspector_name;
    in property <string> inspector_parent;
    in property <string> inspector_x;
    in property <string> inspector_y;
    in property <string> inspector_z;
    in property <float> scroll_px: 0.0;
    in property <bool> delete_enabled;
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback control_changed(control_id: string, value: string);
    callback control_clicked(control_id: string);

    palette := Palette {}
    background: transparent;
    clip: true;

    scroll_capture := TouchArea {
        width: parent.width;
        height: parent.height;
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            clip: true;

            content := VerticalLayout {
                x: 10px;
                y: 10px - root.scroll_px * 1px;
                width: parent.width - 20px;
                spacing: 4px;

                Rectangle {
                    width: parent.width;
                    height: 22px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    background: palette.panel_bg_soft;

                    Text {
                        x: 8px;
                        y: 3px;
                        text: "Transform";
                        color: palette.text;
                        font-size: 11px;
                        font-weight: 600;
                    }

                    Text {
                        x: parent.width - self.preferred-width - 8px;
                        y: 4px;
                        text: root.info;
                        color: palette.text_dim;
                        font-size: 9px;
                        overflow: elide;
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 22px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Name";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    CompactField {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        text: root.inspector_name;
                        placeholder: "Name";
                        edited(value) => { root.control_changed("NameField", value); }
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 22px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Parent";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    CompactField {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        text: root.inspector_parent;
                        placeholder: "Parent Id";
                        edited(value) => { root.control_changed("ParentField", value); }
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 22px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Position";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    HorizontalLayout {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        spacing: 4px;

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "X";
                            axis_color: #c75450;
                            value: root.inspector_x;
                            edited(value) => { root.control_changed("PositionXField", value); }
                        }

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "Y";
                            axis_color: #7fb062;
                            value: root.inspector_y;
                            edited(value) => { root.control_changed("PositionYField", value); }
                        }

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "Z";
                            axis_color: #5a88d2;
                            value: root.inspector_z;
                            edited(value) => { root.control_changed("PositionZField", value); }
                        }
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 1px;
                    background: palette.border_soft;
                }

                Rectangle {
                    width: parent.width;
                    height: 24px;
                    background: transparent;

                    ShellButton {
                        x: parent.width - 126px;
                        y: 0px;
                        width: 58px;
                        label: "Apply";
                        active: true;
                        clicked => { root.control_clicked("ApplyBatchButton"); }
                    }

                    ShellButton {
                        x: parent.width - 62px;
                        y: 0px;
                        width: 58px;
                        label: "Delete";
                        active: false;
                        enabled: root.delete_enabled;
                        clicked => { root.control_clicked("DeleteSelected"); }
                    }
                }
            }
        }
    }
}

export component ConsolePane inherits Rectangle {
    in property <bool> show_empty;
    in property <string> empty_title;
    in property <string> empty_body;
    in property <string> status_text;
    in property <float> scroll_px: 0.0;
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: #17191c;
    clip: true;

    Rectangle {
        width: parent.width;
        height: parent.height;
        clip: true;

        lines := VerticalLayout {
            x: 10px;
            y: 8px - root.scroll_px * 1px;
            width: parent.width - 20px;
            spacing: 6px;

            if root.show_empty: Text {
                text: root.status_text != "" ? "> " + root.status_text : "> No output yet";
                color: #c3ccd8;
                font-size: 11px;
                font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                wrap: word-wrap;
            }

            if root.show_empty && root.empty_body != "": Text {
                text: root.empty_body;
                color: palette.text_dim;
                font-size: 10px;
                wrap: word-wrap;
            }

            if !root.show_empty: Text {
                text: root.status_text;
                color: #c3ccd8;
                font-size: 11px;
                font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                wrap: word-wrap;
            }
        }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }
    }
}

component UiAssetSourceTextInput inherits TextInput {
    in property <int> desired_cursor_byte_offset: 0;
    callback source_text_edited(value: string);
    callback source_cursor_moved(byte_offset: int);

    init => {
        root.set-selection-offsets(root.desired_cursor_byte_offset, root.desired_cursor_byte_offset);
    }
    changed desired_cursor_byte_offset => {
        root.set-selection-offsets(root.desired_cursor_byte_offset, root.desired_cursor_byte_offset);
    }
    cursor-position-changed(_cursor_position) => {
        root.source_cursor_moved(root.cursor-position-byte-offset);
    }
    edited => {
        root.source_text_edited(root.text);
    }
}

export component UiAssetEditorPane inherits Rectangle {
    in property <UiAssetEditorPaneData> pane;
    property <[string]> stylesheet_items: root.pane.stylesheet_items;
    callback action(action_id: string);
    callback style_class_action(action_id: string, class_name: string);
    callback detail_event(detail_id: string, action_id: string, item_index: int, primary: string, secondary: string);
    in-out property <bool> palette_drag_active: false;
    in-out property <int> palette_drag_source_index: -1;
    in-out property <float> palette_drag_pointer_x: 0.0;
    in-out property <float> palette_drag_pointer_y: 0.0;
    property <string> palette_drag_label:
        root.palette_drag_source_index >= 0 && root.palette_drag_source_index < root.palette_collection.items.length ?
        root.palette_collection.items[root.palette_drag_source_index] :
        "";
    callback source_edited(value: string);
    callback palette_drag_hovered(surface_x: float, surface_y: float);
    callback palette_drag_dropped();
    callback palette_drag_cancelled();
    callback collection_event(collection_id: string, event_kind: string, item_index: int);
    callback palette_target_confirm();
    callback palette_target_cancel();
    callback source_cursor_changed(byte_offset: int);
    property <UiAssetStringSelectionData> palette_collection: root.pane.palette_collection;
    property <UiAssetStringSelectionData> hierarchy_collection: root.pane.hierarchy_collection;
    property <UiAssetStringSelectionData> preview_collection: root.pane.preview_collection;
    property <UiAssetSourceDetailData> source_detail: root.pane.source_detail;
    property <UiAssetPreviewMockData> preview_mock: root.pane.preview_mock;
    property <UiAssetInspectorWidgetData> inspector_widget: root.pane.inspector_widget;
    property <UiAssetInspectorSlotData> inspector_slot: root.pane.inspector_slot;
    property <UiAssetInspectorLayoutData> inspector_layout: root.pane.inspector_layout;
    property <UiAssetInspectorBindingData> inspector_binding: root.pane.inspector_binding;
    property <UiAssetThemeSourceData> theme_source: root.pane.theme_source;
    property <[string]> style_class_items: root.pane.style_class_items;
    property <UiAssetStyleRuleData> style_rule: root.pane.style_rule;
    property <UiAssetMatchedStyleRuleData> matched_style_rule: root.pane.matched_style_rule;
    property <UiAssetStyleRuleDeclarationData> style_rule_declaration: root.pane.style_rule_declaration;
    property <UiAssetStyleTokenData> style_token: root.pane.style_token;
    property <UiAssetPaletteDragData> palette_drag_projection: root.pane.palette_drag;
    palette := Palette {}
    property <string> style_class_draft: "";
    property <string> style_rule_selector_draft: "";
    property <string> style_rule_declaration_path_draft: "";
    property <string> style_rule_declaration_value_draft: "";
    property <string> style_token_name_draft: "";
    property <string> style_token_value_draft: "";
    property <string> preview_mock_value_draft: "";
    property <string> binding_payload_key_draft: "";
    property <string> binding_payload_value_draft: "";
    drag_focus_host := FocusScope {
        x: 0px;
        y: 0px;
        width: 0px;
        height: 0px;
        enabled: root.palette_drag_active || root.palette_drag_projection.target_chooser_active;
        key-pressed(event) => {
            if (event.text == Key.LeftArrow || event.text == Key.UpArrow) {
                root.action("palette.target.previous");
                return accept;
            }
            if (
                event.text == Key.RightArrow
                || event.text == Key.DownArrow
                || event.text == Key.Tab
                ) {
                root.action("palette.target.next");
                return accept;
            }
            if (event.text == Key.Return || event.text == "\n") {
                if (root.palette_drag_projection.target_chooser_active) {
                    root.palette_target_confirm();
                    return accept;
                }
                if (root.palette_drag_projection.target_action != "") {
                    root.palette_drag_dropped();
                }
                return accept;
            }
            if (event.text == Key.Escape) {
                if (root.palette_drag_projection.target_chooser_active) {
                    root.palette_target_cancel();
                } else {
                    root.palette_drag_cancelled();
                    root.palette_drag_active = false;
                    root.palette_drag_source_index = -1;
                }
                return accept;
            }
            reject
        }
    }
    background: transparent;
    clip: true;

    Rectangle {
        x: 10px;
        y: 10px;
        width: parent.width - 20px;
        height: 56px;
        border-radius: 4px;
        border-width: 1px;
        border-color: palette.border_soft;
        background: #ffffff06;

        Text {
            x: 10px;
            y: 6px;
            text: root.pane.asset_id != "" ? root.pane.asset_id : root.pane.mode;
            color: palette.text;
            font-size: 10px;
            overflow: elide;
        }

        Text {
            x: 10px;
            y: 16px;
            width: parent.width - 20px;
            text:
                root.pane.status != "" ?
                root.pane.mode + " • " + root.pane.selection + " • " + root.pane.status :
                root.pane.mode + " • " + root.pane.selection;
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        HorizontalLayout {
            x: 10px;
            y: 28px;
            width: parent.width - 20px;
            spacing: 4px;

            ShellButton {
                width: 56px;
                label: "Design";
                active: root.pane.mode == "Design";
                clicked => { root.action("mode.design"); }
            }
            ShellButton {
                width: 52px;
                label: "Split";
                active: root.pane.mode == "Split";
                clicked => { root.action("mode.split"); }
            }
            ShellButton {
                width: 56px;
                label: "Source";
                active: root.pane.mode == "Source";
                clicked => { root.action("mode.source"); }
            }
            ShellButton {
                width: 60px;
                label: "Preview";
                active: root.pane.mode == "Preview";
                clicked => { root.action("mode.preview"); }
            }

            Rectangle { width: 1px; height: 20px; background: palette.border_soft; }

            ShellButton {
                width: 58px;
                label: "Docked";
                active: root.pane.preview_preset == "Editor Docked";
                clicked => { root.action("preview.preset.editor_docked"); }
            }
            ShellButton {
                width: 50px;
                label: "Float";
                active: root.pane.preview_preset == "Editor Floating";
                clicked => { root.action("preview.preset.editor_floating"); }
            }
            ShellButton {
                width: 44px;
                label: "HUD";
                active: root.pane.preview_preset == "Game HUD";
                clicked => { root.action("preview.preset.game_hud"); }
            }
            ShellButton {
                width: 58px;
                label: "Dialog";
                active: root.pane.preview_preset == "Dialog";
                clicked => { root.action("preview.preset.dialog"); }
            }

            Rectangle { width: 1px; height: 20px; background: palette.border_soft; }

            ShellButton {
                width: 46px;
                label: "Save";
                enabled: root.pane.can_save;
                active: root.pane.can_save;
                clicked => { root.action("save"); }
            }
            ShellButton {
                width: 48px;
                label: "Undo";
                enabled: root.pane.can_undo;
                clicked => { root.action("undo"); }
            }
            ShellButton {
                width: 48px;
                label: "Redo";
                enabled: root.pane.can_redo;
                clicked => { root.action("redo"); }
            }

            Text {
                text: root.pane.preview_available ? root.pane.preview_summary : "Preview unavailable";
                color: palette.text_dim;
                font-size: 9px;
                vertical-alignment: center;
                overflow: elide;
            }
        }
    }

    HorizontalLayout {
        x: 10px;
        y: 74px;
        width: parent.width - 20px;
        height: parent.height - 84px;
        spacing: 8px;

        Rectangle {
            width: 240px;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                palette_section := UiAssetSelectableSection {
                    height: parent.height * 0.42;
                    title: "Palette";
                    items: root.palette_collection.items;
                    selected_index: root.palette_collection.selected_index;
                    accent: #9dc07c;
                    drag_enabled: true;
                    item_selected(item_index) => { root.collection_event("palette", "selected", item_index); }
                    item_drag_started(item_index, x, y) => {
                        root.collection_event("palette", "selected", item_index);
                        root.palette_drag_active = true;
                        root.palette_drag_source_index = item_index;
                        root.palette_drag_pointer_x = palette_section.x / 1px + x;
                        root.palette_drag_pointer_y = palette_section.y / 1px + y;
                        drag_focus_host.focus();
                    }
                }

                UiAssetSelectableSection {
                    height: parent.height * 0.58 - 8px;
                    title: "Hierarchy";
                    items: root.hierarchy_collection.items;
                    selected_index: root.hierarchy_collection.selected_index;
                    accent: #7aa2e3;
                    item_selected(item_index) => { root.collection_event("hierarchy", "selected", item_index); }
                    item_activated(item_index) => { root.collection_event("hierarchy", "activated", item_index); }
                }
            }
        }

        Rectangle {
            width: max(240px, parent.width - 536px);
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                Rectangle {
                    height: parent.height * 0.38;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    clip: true;

                    Text {
                        x: 10px;
                        y: 8px;
                        text: "Designer Canvas";
                        color: #e0aa5e;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Text {
                        x: parent.width - self.preferred-width - 10px;
                        y: 8px;
                        text: root.pane.preview_summary;
                        color: palette.text_dim;
                        font-size: 9px;
                    }

                    preview_canvas := UiAssetCanvasSurface {
                        x: 10px;
                        y: 28px;
                        width: parent.width - 20px;
                        height: max(92px, parent.height - 126px);
                        items: root.pane.preview_canvas_items;
                        surface_width: root.pane.preview_surface_width;
                        surface_height: root.pane.preview_surface_height;
                        selected_index: root.preview_collection.selected_index;
                        palette_has_selection: root.palette_collection.selected_index >= 0;
                        can_insert_child: root.pane.can_insert_child;
                        can_insert_after: root.pane.can_insert_after;
                        can_move_up: root.pane.can_move_up;
                        can_move_down: root.pane.can_move_down;
                        can_reparent_into_previous: root.pane.can_reparent_into_previous;
                        can_reparent_into_next: root.pane.can_reparent_into_next;
                        can_reparent_outdent: root.pane.can_reparent_outdent;
                        can_open_reference: root.pane.can_open_reference;
                        can_convert_to_reference: root.pane.can_convert_to_reference;
                        can_extract_component: root.pane.can_extract_component;
                        can_promote_to_external_widget: root.pane.can_promote_to_external_widget;
                        can_wrap_in_vertical_box: root.pane.can_wrap_in_vertical_box;
                        can_unwrap: root.pane.can_unwrap;
                        external_drag_active: root.palette_drag_active;
                        external_drag_target_index: root.palette_drag_projection.target_preview_index;
                        external_drag_target_action: root.palette_drag_projection.target_action;
                        external_drag_target_label: root.palette_drag_projection.target_label;
                        external_slot_target_items: root.palette_drag_projection.slot_target_items;
                        external_drag_pointer_x: root.palette_drag_pointer_x - preview_canvas.x / 1px;
                        external_drag_pointer_y: root.palette_drag_pointer_y - preview_canvas.y / 1px;
                        item_selected(item_index) => { root.collection_event("preview", "selected", item_index); }
                        item_activated(item_index) => { root.collection_event("preview", "activated", item_index); }
                        action_requested(action_id) => { root.action(action_id); }
                    }

                    UiAssetSelectableSection {
                        x: 10px;
                        y: parent.height - 90px;
                        width: parent.width - 20px;
                        height: 80px;
                        title: "Render Stack";
                        items: root.preview_collection.items;
                        selected_index: root.preview_collection.selected_index;
                        accent: #e0aa5e;
                        item_selected(item_index) => { root.collection_event("preview", "selected", item_index); }
                        item_activated(item_index) => { root.collection_event("preview", "activated", item_index); }
                    }
                }

                Rectangle {
                    height: 54px;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;

                    VerticalLayout {
                        x: 10px;
                        y: 8px;
                        width: parent.width - 20px;
                        spacing: 4px;

                        HorizontalLayout {
                            width: parent.width;
                            spacing: 4px;

                            ShellButton {
                                width: 56px;
                                label: "Add In";
                enabled: root.pane.can_insert_child;
                active: root.pane.can_insert_child;
                                clicked => { root.action("palette.insert.child"); }
                            }

                            ShellButton {
                                width: 68px;
                                label: "Add After";
                enabled: root.pane.can_insert_after;
                active: root.pane.can_insert_after;
                                clicked => { root.action("palette.insert.after"); }
                            }

                            ShellButton {
                                width: 44px;
                                label: "Up";
                enabled: root.pane.can_move_up;
                active: root.pane.can_move_up;
                                clicked => { root.action("canvas.move.up"); }
                            }

                            ShellButton {
                                width: 56px;
                                label: "Down";
                enabled: root.pane.can_move_down;
                active: root.pane.can_move_down;
                                clicked => { root.action("canvas.move.down"); }
                            }
                        }

                        HorizontalLayout {
                            width: parent.width;
                            spacing: 4px;

                            ShellButton {
                                width: 84px;
                                label: "Into Prev";
                enabled: root.pane.can_reparent_into_previous;
                active: root.pane.can_reparent_into_previous;
                                clicked => { root.action("canvas.reparent.into_previous"); }
                            }

                            ShellButton {
                                width: 78px;
                                label: "Into Next";
                enabled: root.pane.can_reparent_into_next;
                active: root.pane.can_reparent_into_next;
                                clicked => { root.action("canvas.reparent.into_next"); }
                            }

                            ShellButton {
                                width: 64px;
                                label: "Outdent";
                enabled: root.pane.can_reparent_outdent;
                active: root.pane.can_reparent_outdent;
                                clicked => { root.action("canvas.reparent.outdent"); }
                            }

                        }

                        HorizontalLayout {
                            width: parent.width;
                            spacing: 4px;

                            ShellButton {
                                width: 74px;
                                label: "Open Ref";
                enabled: root.pane.can_open_reference;
                active: root.pane.can_open_reference;
                                clicked => { root.action("reference.open"); }
                            }

                            ShellButton {
                                width: 58px;
                                label: "To Ref";
                enabled: root.pane.can_convert_to_reference;
                active: root.pane.can_convert_to_reference;
                                clicked => { root.action("canvas.convert.reference"); }
                            }

                            ShellButton {
                                width: 64px;
                                label: "Extract";
                enabled: root.pane.can_extract_component;
                active: root.pane.can_extract_component;
                                clicked => { root.action("canvas.extract.component"); }
                            }

                            ShellButton {
                                width: 70px;
                                label: "Promote";
                enabled: root.pane.can_promote_to_external_widget;
                active: root.pane.can_promote_to_external_widget;
                                clicked => { root.action("canvas.promote.widget"); }
                            }

                            ShellButton {
                                width: 82px;
                                label: "Wrap VBox";
                enabled: root.pane.can_wrap_in_vertical_box;
                active: root.pane.can_wrap_in_vertical_box;
                                clicked => { root.action("canvas.wrap.vertical_box"); }
                            }

                            ShellButton {
                                width: 58px;
                                label: "Unwrap";
                enabled: root.pane.can_unwrap;
                active: root.pane.can_unwrap;
                                clicked => { root.action("canvas.unwrap"); }
                            }
                        }
                    }
                }

                Rectangle {
                    height: parent.height * 0.62 - 62px;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    clip: true;

                    Text {
                        x: 10px;
                        y: 8px;
                        text: "Source";
                        color: #d8d28a;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Rectangle {
                        x: 10px;
                        y: 26px;
                        width: parent.width - 20px;
                        height: 58px;
                        background: #ffffff05;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: palette.border_soft;

                        VerticalLayout {
                            x: 8px;
                            y: 6px;
                            width: parent.width - 16px;
                            spacing: 2px;

                            Text {
                                text: root.source_detail.block_label != "" ? root.source_detail.block_label : "No source block";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                                wrap: word-wrap;
                            }

                            Text {
                                text: root.source_detail.selected_line >= 0 ? "line " + root.source_detail.selected_line : "";
                                color: palette.text_dim;
                                font-size: 9px;
                            }

                            Text {
                                text: root.source_detail.roundtrip_status;
                                color: palette.text_muted;
                                font-size: 9px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    UiAssetSelectableSection {
                        x: 10px;
                        y: 92px;
                        width: parent.width - 20px;
                        height: 72px;
                        title: "Source Outline";
                        items: root.source_detail.outline.items;
                        selected_index: root.source_detail.outline.selected_index;
                        accent: #d8d28a;
                        item_selected(item_index) => { root.collection_event("source_outline", "selected", item_index); }
                    }

                    UiAssetSelectableSection {
                        x: 10px;
                        y: 170px;
                        width: parent.width - 20px;
                        height: 72px;
                        title: "Mock Preview";
                        items: root.preview_mock.collection.items;
                        selected_index: root.preview_mock.collection.selected_index;
                        accent: #c98fe3;
                        item_selected(item_index) => {
                            root.collection_event("preview_mock", "selected", item_index);
                            root.preview_mock_value_draft = root.preview_mock.value;
                        }
                    }

                    Text {
                        x: 10px;
                        y: 248px;
                        width: 88px;
                        text: root.preview_mock.property;
                        color: palette.text;
                        font-size: 9px;
                        font-weight: 600;
                    }

                    Text {
                        x: 102px;
                        y: 248px;
                        width: parent.width - 112px;
                        text: root.preview_mock.kind;
                        color: palette.text_dim;
                        font-size: 9px;
                        horizontal-alignment: right;
                    }

                    TextEdit {
                        x: 10px;
                        y: 262px;
                        width: parent.width - 148px;
                        height: 28px;
                        text:
                            root.preview_mock_value_draft != "" ?
                            root.preview_mock_value_draft :
                            root.preview_mock.value;
                        enabled: root.preview_mock.can_edit;
                        font-size: 9px;
                        font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                        edited(value) => { root.preview_mock_value_draft = value; }
                    }

                    ShellButton {
                        x: parent.width - 132px;
                        y: 262px;
                        width: 56px;
                        label: "Apply";
                        enabled: root.preview_mock.can_edit;
                        clicked => {
                            root.detail_event("preview_mock", "preview.mock.value.set", root.preview_mock.collection.selected_index, root.preview_mock_value_draft != "" ? root.preview_mock_value_draft : root.preview_mock.value, "");
                            root.preview_mock_value_draft = "";
                        }
                    }

                    ShellButton {
                        x: parent.width - 68px;
                        y: 262px;
                        width: 58px;
                        label: "Clear";
                        enabled: root.preview_mock.can_clear;
                        clicked => {
                            root.detail_event("preview_mock", "preview.mock.clear", root.preview_mock.collection.selected_index, "", "");
                            root.preview_mock_value_draft = "";
                        }
                    }

                    UiAssetSelectableSection {
                        x: 10px;
                        y: 298px;
                        width: parent.width - 20px;
                        height: 72px;
                        title: "Preview State Graph";
                        items: root.preview_mock.state_graph_items;
                        selected_index: -1;
                        accent: #c98fe3;
                    }

                    Rectangle {
                        x: 10px;
                        y: 376px;
                        width: parent.width - 20px;
                        height: max(120px, parent.height - 426px);
                        clip: true;
                        border-radius: 4px;
                        border-width: 1px;
                        border-color: palette.border_soft;
                        background: #00000018;

                        UiAssetSourceTextInput {
                            x: 8px;
                            y: 8px;
                            width: max(parent.width - 16px, self.preferred-width);
                            height: max(parent.height - 16px, self.preferred-height);
            text: root.pane.source_text;
                            desired_cursor_byte_offset: root.source_detail.cursor_byte_offset;
                            enabled: true;
                            read-only: false;
                            single-line: false;
                            font-size: 10px;
                            font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                            color: palette.text;
                            wrap: word-wrap;
                            source_cursor_moved(byte_offset) => { root.source_cursor_changed(byte_offset); }
                            source_text_edited(value) => { root.source_edited(value); }
                        }
                    }

                    Text {
                        x: 10px;
                        y: parent.height - 42px;
                        width: parent.width - 20px;
                        text: root.source_detail.selected_excerpt;
                        color: palette.text_dim;
                        font-size: 9px;
                        wrap: word-wrap;
                    }
                }
            }
        }

        Rectangle {
            width: 280px;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 8px;

                Rectangle {
                    height: parent.height * 0.5;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    clip: true;

                    Text {
                        x: 10px;
                        y: 6px;
                        text: "Inspector";
                        color: #d98bb5;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    Rectangle {
                        x: 0px;
                        y: 26px;
                        width: parent.width;
                        height: parent.height - 26px;
                        clip: true;

                        VerticalLayout {
                            x: 10px;
                            y: 8px;
                            width: parent.width - 20px;
                            spacing: 4px;

                            Text {
                                text: "Widget";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: 52px;
                                    text: "Node";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                Text {
                                    x: 56px;
                                    y: 3px;
                                    width: parent.width - 56px;
                                    text: root.inspector_widget.selected_node_id != "" ? root.inspector_widget.selected_node_id : "No selection";
                                    color: palette.text_muted;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
