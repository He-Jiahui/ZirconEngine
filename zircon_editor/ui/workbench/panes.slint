                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_layout.clip; placeholder: "clip"; enabled: root.inspector_widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.clip.set", -1, value, ""); } }
