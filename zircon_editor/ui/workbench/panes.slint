                                    overflow: elide;
                                }
                            }

                            if root.inspector_binding_action_kind_selected_index == 2: CompactField {
                                width: parent.width;
                                text: root.inspector_binding_action_target;
                                placeholder: "EditorActions.SaveProject";
                                enabled: root.inspector_can_edit_binding;
                                edited(value) => { root.inspector_widget_action("binding.action_target.set", value); }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 104px;
                                title: "Payload";
                                items: root.inspector_binding_payload_items;
                                selected_index: root.inspector_binding_payload_selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => {
                                    root.binding_payload_selected(item_index);
                                    root.binding_payload_key_draft = root.inspector_binding_payload_key;
                                    root.binding_payload_value_draft = root.inspector_binding_payload_value;
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.binding_payload_key_draft != "" ?
                                    root.binding_payload_key_draft :
                                    root.inspector_binding_payload_key;
                                placeholder: "payload key";
                                enabled: root.inspector_can_edit_binding;
                                edited(value) => { root.binding_payload_key_draft = value; }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.binding_payload_value_draft != "" ?
                                    root.binding_payload_value_draft :
                                    root.inspector_binding_payload_value;
                                placeholder: "payload value";
                                enabled: root.inspector_can_edit_binding;
                                edited(value) => { root.binding_payload_value_draft = value; }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 64px;
                                    label: "Add Click";
                                    enabled: root.inspector_selected_node_id != "";
                                    active: root.inspector_selected_node_id != "";
                                    clicked => { root.inspector_widget_action("binding.add", ""); }
                                }

                                ShellButton {
                                    width: 52px;
                                    label: "Delete";
                                    enabled: root.inspector_can_delete_binding;
                                    clicked => { root.inspector_widget_action("binding.delete", ""); }
                                }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 48px;
                                    label: "Upsert";
                                    enabled:
                                        root.inspector_can_edit_binding &&
                                        ((root.binding_payload_key_draft != "" ? root.binding_payload_key_draft : root.inspector_binding_payload_key) != "");
                                    active:
                                        root.inspector_can_edit_binding &&
                                        ((root.binding_payload_key_draft != "" ? root.binding_payload_key_draft : root.inspector_binding_payload_key) != "");
                                    clicked => {
                                        root.binding_payload_action("binding.payload.upsert", root.binding_payload_key_draft != "" ? root.binding_payload_key_draft : root.inspector_binding_payload_key, root.binding_payload_value_draft != "" ? root.binding_payload_value_draft : root.inspector_binding_payload_value);
                                        root.binding_payload_key_draft = "";
                                        root.binding_payload_value_draft = "";
                                    }
                                }

                                ShellButton {
                                    width: 56px;
                                    label: "Delete";
                                    enabled: root.inspector_binding_payload_selected_index >= 0;
                                    clicked => {
                                        root.binding_payload_action("binding.payload.delete", "", "");
                                        root.binding_payload_key_draft = "";
                                        root.binding_payload_value_draft = "";
                                    }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 1px;
                                background: palette.border_soft;
                            }

                            if root.inspector_items.length == 0: Text {
                                text: "No inspector summary entries";
                                color: palette.text_dim;
                                font-size: 10px;
                            }

                            for item in root.inspector_items: Text {
                                text: item;
                                color: palette.text_muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }

                Rectangle {
                    height: parent.height * 0.5 - 8px;
                    background: palette.panel_bg_soft;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    clip: true;

                    Text {
                        x: 10px;
                        y: 6px;
                        text: "Stylesheet";
                        color: #8dc8c1;
                        font-size: 11px;
                        font-weight: 700;
                    }

                    HorizontalLayout {
                        x: 10px;
                        y: 26px;
                        width: parent.width - 20px;
                        spacing: 4px;

                        ShellButton {
                            width: 42px;
                            label: "Rule";
                            enabled: root.can_create_rule;
                            active: root.can_create_rule;
                            clicked => {
                                root.style_rule_selector_draft = "";
                                root.action("style.rule.create");
                            }
                        }

                        ShellButton {
                            width: 58px;
                            label: "Extract";
                            enabled: root.can_extract_rule;
                            active: root.can_extract_rule;
                            clicked => {
                                root.style_rule_selector_draft = "";
                                root.action("style.rule.extract_inline");
                            }
                        }
                    }

                    HorizontalLayout {
                        x: 10px;
                        y: 54px;
                        width: parent.width - 20px;
                        spacing: 4px;

                        ShellButton {
                            width: 46px;
                            label: "Hover";
                            active: root.state_hover;
                            clicked => { root.action("style.state.hover"); }
                        }

                        ShellButton {
                            width: 46px;
                            label: "Focus";
                            active: root.state_focus;
                            clicked => { root.action("style.state.focus"); }
                        }

                        ShellButton {
                            width: 60px;
                            label: "Pressed";
                            active: root.state_pressed;
                            clicked => { root.action("style.state.pressed"); }
                        }
                    }

                    HorizontalLayout {
                        x: 10px;
                        y: 82px;
                        width: parent.width - 20px;
                        spacing: 4px;

                        ShellButton {
                            width: 62px;
                            label: "Disabled";
                            active: root.state_disabled;
                            clicked => { root.action("style.state.disabled"); }
                        }

                        ShellButton {
                            width: 58px;
                            label: "Selected";
                            active: root.state_selected;
                            clicked => { root.action("style.state.selected"); }
                        }
                    }

                    Rectangle {
                        x: 10px;
                        y: 112px;
                        width: parent.width - 20px;
                        height: 1px;
                        background: palette.border_soft;
                    }

                    Rectangle {
                        x: 0px;
                        y: 118px;
                        width: parent.width;
                        height: parent.height - 118px;
                        clip: true;

                        VerticalLayout {
                            x: 10px;
                            y: 8px;
                            width: parent.width - 20px;
                            spacing: 4px;

                            Text {
                                text: "Classes";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.style_class_items.length == 0: Text {
                                text: "No classes on selection";
                                color: palette.text_dim;
                                font-size: 10px;
                            }

                            for class_name in root.style_class_items: Text {
                                text: "." + class_name;
                                color: palette.text_muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            CompactField {
                                width: parent.width;
                                text: root.style_class_draft;
                                placeholder: "class-name";
                                edited(value) => { root.style_class_draft = value; }
                            }

                              HorizontalLayout {
                                  width: parent.width;
                                  spacing: 4px;

                                  ShellButton {
                                    width: 46px;
                                    label: "Add";
                                    enabled: root.style_class_draft != "";
                                    active: root.style_class_draft != "";
                                    clicked => {
                                        root.style_class_action("style.class.add", root.style_class_draft);
                                        root.style_class_draft = "";
                                    }
                                }

                                ShellButton {
                                    width: 62px;
                                    label: "Remove";
                                    enabled: root.style_class_draft != "";
                                    clicked => {
                                        root.style_class_action("style.class.remove", root.style_class_draft);
                                        root.style_class_draft = "";
                                    }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 1px;
                                background: palette.border_soft;
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 118px;
                                title: "Tokens";
                                items: root.style_token_items;
                                selected_index: root.style_token_selected_index;
                                accent: #8dc8c1;
                                item_selected(item_index) => {
                                    root.style_token_action("style.token.select", item_index, "", "");
                                    root.style_token_name_draft = root.selected_token_name;
                                    root.style_token_value_draft = root.selected_token_value;
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.style_token_name_draft != "" ?
                                    root.style_token_name_draft :
                                    root.selected_token_name;
                                placeholder: "token-name";
                                edited(value) => { root.style_token_name_draft = value; }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.style_token_value_draft != "" ?
                                    root.style_token_value_draft :
                                    root.selected_token_value;
                                placeholder: "token-value";
                                edited(value) => { root.style_token_value_draft = value; }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 48px;
                                    label: "Apply";
                                    enabled: root.style_token_name_draft != "" || root.selected_token_name != "";
                                    active: root.style_token_name_draft != "" || root.selected_token_name != "";
                                    clicked => {
                                        root.style_token_action("style.token.upsert", root.style_token_selected_index, root.style_token_name_draft != "" ? root.style_token_name_draft : root.selected_token_name, root.style_token_value_draft != "" ? root.style_token_value_draft : root.selected_token_value);
                                        root.style_token_name_draft = "";
                                        root.style_token_value_draft = "";
                                    }
                                }

                                ShellButton {
                                    width: 56px;
                                    label: "Delete";
                                    enabled: root.can_delete_token;
                                    clicked => {
                                        root.style_token_action("style.token.delete", root.style_token_selected_index, "", "");
                                        root.style_token_name_draft = "";
                                        root.style_token_value_draft = "";
                                    }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 1px;
                                background: palette.border_soft;
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 126px;
                                title: "Rules";
                                items: root.style_rule_items;
                                selected_index: root.style_rule_selected_index;
                                accent: #8dc8c1;
                                item_selected(item_index) => {
                                    root.style_rule_selector_draft = root.style_rule_items[item_index];
                                    root.style_rule_action("style.rule.select", item_index, "");
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.style_rule_selector_draft != "" ?
                                    root.style_rule_selector_draft :
                                    root.selected_rule_selector;
                                placeholder: "selector";
                                enabled: root.can_edit_rule;
                                edited(value) => { root.style_rule_selector_draft = value; }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 48px;
                                    label: "Apply";
                                    enabled: root.can_edit_rule && (root.style_rule_selector_draft != "" || root.selected_rule_selector != "");
                                    active: root.can_edit_rule && (root.style_rule_selector_draft != "" || root.selected_rule_selector != "");
                                    clicked => {
                                        root.style_rule_action("style.rule.rename", root.style_rule_selected_index, root.style_rule_selector_draft != "" ? root.style_rule_selector_draft : root.selected_rule_selector);
                                        root.style_rule_selector_draft = "";
                                    }
                                }

                                ShellButton {
                                    width: 56px;
                                    label: "Delete";
                                    enabled: root.can_delete_rule;
                                    clicked => {
                                        root.style_rule_action("style.rule.delete", root.style_rule_selected_index, "");
                                        root.style_rule_selector_draft = "";
                                      }
                                  }
                              }

                              Rectangle {
                                  width: parent.width;
                                  height: 1px;
                                  background: palette.border_soft;
                              }

                              UiAssetSelectableSection {
                                  width: parent.width;
                                  height: 126px;
                                  title: "Declarations";
                                  items: root.style_rule_declaration_items;
                                  selected_index: root.style_rule_declaration_selected_index;
                                  accent: #8dc8c1;
                                  item_selected(item_index) => {
                                      root.style_rule_declaration_action("style.rule.declaration.select", item_index, "", "");
                                      root.style_rule_declaration_path_draft = root.selected_rule_declaration_path;
                                      root.style_rule_declaration_value_draft = root.selected_rule_declaration_value;
                                  }
                              }

                              CompactField {
                                  width: parent.width;
                                  text:
                                      root.style_rule_declaration_path_draft != "" ?
                                      root.style_rule_declaration_path_draft :
                                      root.selected_rule_declaration_path;
                                  placeholder: "self.background.color";
                                  enabled: root.can_edit_rule_declaration;
                                  edited(value) => { root.style_rule_declaration_path_draft = value; }
                              }

                              CompactField {
                                  width: parent.width;
                                  text:
                                      root.style_rule_declaration_value_draft != "" ?
                                      root.style_rule_declaration_value_draft :
                                      root.selected_rule_declaration_value;
                                  placeholder: "value";
                                  enabled: root.can_edit_rule_declaration;
                                  edited(value) => { root.style_rule_declaration_value_draft = value; }
                              }

                              HorizontalLayout {
                                  width: parent.width;
                                  spacing: 4px;

                                  ShellButton {
                                      width: 48px;
                                      label: "Apply";
                                      enabled: root.can_edit_rule_declaration;
                                      active: root.can_edit_rule_declaration;
                                      clicked => {
                                          root.style_rule_declaration_action("style.rule.declaration.upsert", root.style_rule_declaration_selected_index, root.style_rule_declaration_path_draft != "" ? root.style_rule_declaration_path_draft : root.selected_rule_declaration_path, root.style_rule_declaration_value_draft != "" ? root.style_rule_declaration_value_draft : root.selected_rule_declaration_value);
                                          root.style_rule_declaration_path_draft = "";
                                          root.style_rule_declaration_value_draft = "";
                                      }
                                  }

                                  ShellButton {
                                      width: 56px;
                                      label: "Delete";
                                      enabled: root.can_delete_rule_declaration;
                                      clicked => {
                                          root.style_rule_declaration_action("style.rule.declaration.delete", root.style_rule_declaration_selected_index, "", "");
                                          root.style_rule_declaration_path_draft = "";
                                          root.style_rule_declaration_value_draft = "";
                                      }
                                  }
                              }

                              Rectangle {
                                  width: parent.width;
                                  height: 1px;
                                  background: palette.border_soft;
                              }

                              UiAssetSelectableSection {
                                  width: parent.width;
                                  height: 126px;
                                  title: "Matched Rules";
                                  items: root.style_matched_rule_items;
                                  selected_index: root.style_matched_rule_selected_index;
                                  accent: #8dc8c1;
                                  item_selected(item_index) => {
                                      // matched_style_rule_selected(item_index) => {
                                      root.matched_style_rule_selected(item_index);
                                  }
                              }

                              Rectangle {
                                  width: parent.width;
                                  height: 78px;
                                  background: palette.panel_bg_soft;
                                  border-radius: 4px;
                                  border-width: 1px;
                                  border-color: palette.border_soft;
                                  clip: true;

                                  VerticalLayout {
                                      x: 10px;
                                      y: 8px;
                                      width: parent.width - 20px;
                                      spacing: 3px;

                                      Text {
                                          text: root.selected_matched_rule_origin != "" ? root.selected_matched_rule_origin : "No matched rule selected";
                                          color: palette.text;
                                          font-size: 10px;
                                          font-weight: 600;
                                          wrap: word-wrap;
                                      }

                                      Text {
                                          text: root.selected_matched_rule_selector;
                                          color: palette.text_muted;
                                          font-size: 10px;
                                          wrap: word-wrap;
                                      }

                                      Text {
                                          text: root.selected_matched_rule_specificity >= 0 ? "specificity " + root.selected_matched_rule_specificity + " • order " + root.selected_matched_rule_source_order : "";
                                          color: palette.text_dim;
                                          font-size: 10px;
                                          wrap: word-wrap;
                                      }

                                      for item in root.selected_matched_rule_declaration_items: Text {
                                          text: item;
                                          color: palette.text_muted;
                                          font-size: 10px;
                                          wrap: word-wrap;
                                      }
                                  }
                              }

                              if root.stylesheet_items.length == 0: Text {
                                  text: "No stylesheet entries";
                                  color: palette.text_dim;
                                  font-size: 10px;
                            }

                            for item in root.stylesheet_items: Text {
                                text: item;
                                color: palette.text_muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }
    }

    if root.palette_drag_active: TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: MouseCursor.grabbing;
        moved => {
            root.palette_drag_pointer_x = self.mouse-x / 1px;
            root.palette_drag_pointer_y = self.mouse-y / 1px;
            root.palette_drag_hovered(
                (root.palette_drag_pointer_x - preview_canvas.x / 1px - preview_canvas.surface_origin_x)
                / max(preview_canvas.surface_scale, 0.0001),
                (root.palette_drag_pointer_y - preview_canvas.y / 1px - preview_canvas.surface_origin_y)
                / max(preview_canvas.surface_scale, 0.0001),
            );
        }
        pointer-event(event) => {
            if (event.button != PointerEventButton.left) {
                return;
            }
            if (event.kind == PointerEventKind.up) {
                root.palette_drag_pointer_x = self.mouse-x / 1px;
                root.palette_drag_pointer_y = self.mouse-y / 1px;
                root.palette_drag_hovered(
                    (root.palette_drag_pointer_x - preview_canvas.x / 1px - preview_canvas.surface_origin_x)
                    / max(preview_canvas.surface_scale, 0.0001),
                    (root.palette_drag_pointer_y - preview_canvas.y / 1px - preview_canvas.surface_origin_y)
                    / max(preview_canvas.surface_scale, 0.0001),
                );
                if (root.palette_drag_target_action != "") {
                    root.palette_drag_dropped();
                } else {
                    root.palette_drag_cancelled();
                }
                root.palette_drag_active = false;
                root.palette_drag_source_index = -1;
            }
        }
    }

    if root.palette_drag_candidate_items.length > 1 && (root.palette_drag_active || root.palette_target_chooser_active): Rectangle {
        x: min(
            max(preview_canvas.x + preview_canvas.width - self.width - 12px, 8px),
            max(root.width - self.width - 8px, 8px)
        );
        y: max(preview_canvas.y - 2px, 8px);
        width: 248px;
        height: min(224px, max(118px, 68px + root.palette_drag_candidate_items.length * 22px));
        background: transparent;

        UiAssetSelectableSection {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height - 38px;
            title: "Target Cycle";
            items: root.palette_drag_candidate_items;
            selected_index: root.palette_drag_candidate_selected_index;
            accent: #53c98a;
            item_selected(item_index) => {
                root.palette_target_candidate_selected(item_index);
            }
            item_activated(item_index) => {
                root.palette_target_candidate_selected(item_index);
                root.palette_target_confirm();
            }
        }

        HorizontalLayout {
            x: 10px;
            y: parent.height - 34px;
            width: parent.width - 20px;
            spacing: 6px;

            ShellButton {
                width: 56px;
                label: "Apply";
                active: true;
                clicked => { root.palette_target_confirm(); }
            }

            ShellButton {
                width: 58px;
                label: "Cancel";
                clicked => { root.palette_target_cancel(); }
            }

            Text {
                width: parent.width - 120px;
                y: 4px;
                text: "Tab / arrows cycle  Enter apply  Esc cancel";
                color: palette.text_dim;
                font-size: 9px;
                overflow: elide;
            }
        }
    }
}

export component FallbackPane inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> hint;
    in property <bool> compact: true;

    background: transparent;

    EmptyStateCard {
        width: parent.width;
        height: parent.height;
        compact: root.compact;
        eyebrow: "";
        title: root.title;
        body: root.body;
        primary_action_label: "";
        primary_action_id: "";
        secondary_action_label: "";
        secondary_action_id: "";
        secondary_hint: root.hint;
    }
}
