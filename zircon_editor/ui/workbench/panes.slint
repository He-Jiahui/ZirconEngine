import { LineEdit, TextEdit } from "std-widgets.slint";
import { EmptyStateCard, Palette, ShellButton } from "chrome.slint";

export struct SceneNodeData {
    id: string,
    name: string,
    depth: int,
    selected: bool,
}

export struct UiAssetCanvasNodeData {
    node_id: string,
    label: string,
    kind: string,
    x: float,
    y: float,
    width: float,
    height: float,
    depth: int,
    z_index: int,
    selected: bool,
}

export struct UiAssetCanvasSlotTargetData {
    label: string,
    detail: string,
    x: float,
    y: float,
    width: float,
    height: float,
    selected: bool,
}

component UiAssetSelectableSection inherits Rectangle {
    in property <string> title;
    in property <[string]> items;
    in property <int> selected_index: -1;
    in property <color> accent: #7aa2e3;
    in property <bool> drag_enabled: false;
    callback item_selected(item_index: int);
    callback item_activated(item_index: int);
    callback item_drag_started(item_index: int, x: float, y: float);

    palette := Palette {}
    background: palette.panel_bg_soft;
    border-radius: 4px;
    border-width: 1px;
    border-color: palette.border_soft;
    clip: true;
    property <float> content_origin_x: 10.0;
    property <float> content_origin_y: 34.0;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: 26px;
        background: #ffffff06;

        Text {
            x: 10px;
            y: 6px;
            text: root.title;
            color: root.accent;
            font-size: 11px;
            font-weight: 700;
        }
    }

    Rectangle {
        x: 0px;
        y: 26px;
        width: parent.width;
        height: parent.height - 26px;
        clip: true;

        VerticalLayout {
            x: 10px;
            y: 8px;
            width: parent.width - 20px;
            spacing: 4px;

            if root.items.length == 0: Text {
                text: "No entries";
                color: palette.text_dim;
                font-size: 10px;
            }

            for item[index] in root.items: item_row := Rectangle {
                height: max(20px, item_text.preferred-height + 6px);
                border-radius: 3px;
                background:
                    index == root.selected_index ? #ffffff10 :
                    row_touch.has-hover ? #ffffff09 :
                    transparent;

                item_text := Text {
                    x: 6px;
                    y: 3px;
                    width: parent.width - 12px;
                    text: item;
                    color: palette.text_muted;
                    font-size: 10px;
                    wrap: word-wrap;
                }

                row_touch := TouchArea {
                    property <float> drag_threshold_px: 8.0;
                    property <bool> drag_pressed: false;
                    property <bool> drag_active: false;
                    property <bool> suppress_click: false;
                    property <float> press_x: 0.0;
                    property <float> press_y: 0.0;
                    width: parent.width;
                    height: parent.height;
                    clicked => {
                        if (!self.suppress_click) {
                            root.item_selected(index);
                        }
                        self.suppress_click = false;
                    }
                    double-clicked => {
                        if (!self.suppress_click) {
                            root.item_activated(index);
                        }
                        self.suppress_click = false;
                    }
                    pointer-event(event) => {
                        if (!root.drag_enabled || event.button != PointerEventButton.left) {
                            return;
                        }
                        if (event.kind == PointerEventKind.down) {
                            self.drag_pressed = true;
                            self.drag_active = false;
                            self.suppress_click = false;
                            self.press_x = self.mouse-x / 1px;
                            self.press_y = self.mouse-y / 1px;
                        } else if (event.kind == PointerEventKind.up) {
                            self.drag_pressed = false;
                            self.drag_active = false;
                        }
                    }
                    moved => {
                        if (!root.drag_enabled || !self.drag_pressed || self.drag_active) {
                            return;
                        }
                        if (
                            (
                                (self.mouse-x / 1px - self.press_x) * (self.mouse-x / 1px - self.press_x)
                                + (self.mouse-y / 1px - self.press_y) * (self.mouse-y / 1px - self.press_y)
                            ) >= self.drag_threshold_px * self.drag_threshold_px
                        ) {
                            self.drag_active = true;
                            self.suppress_click = true;
                            root.item_drag_started(
                                index,
                                root.content_origin_x + item_row.x / 1px + self.mouse-x / 1px,
                                root.content_origin_y + item_row.y / 1px + self.mouse-y / 1px,
                            );
                        }
                    }
                }
            }
        }
    }
}

component UiAssetCanvasSurface inherits Rectangle {
    in property <[UiAssetCanvasNodeData]> items;
    in property <float> surface_width: 0.0;
    in property <float> surface_height: 0.0;
    in property <int> selected_index: -1;
    in property <bool> palette_has_selection: false;
    in property <bool> can_insert_child: false;
    in property <bool> can_insert_after: false;
    in property <bool> can_move_up: false;
    in property <bool> can_move_down: false;
    in property <bool> can_reparent_into_previous: false;
    in property <bool> can_reparent_into_next: false;
    in property <bool> can_reparent_outdent: false;
    in property <bool> can_open_reference: false;
    in property <bool> can_convert_to_reference: false;
    in property <bool> can_extract_component: false;
    in property <bool> can_promote_to_external_widget: false;
    in property <bool> can_wrap_in_vertical_box: false;
    in property <bool> can_unwrap: false;
    in property <bool> external_drag_active: false;
    in property <int> external_drag_target_index: -1;
    in property <string> external_drag_target_action;
    in property <string> external_drag_target_label;
    in property <[UiAssetCanvasSlotTargetData]> external_slot_target_items;
    in property <float> external_drag_pointer_x: 0.0;
    in property <float> external_drag_pointer_y: 0.0;
    callback item_selected(item_index: int);
    callback item_activated(item_index: int);
    callback action_requested(action_id: string);

    palette := Palette {}
    background: palette.panel_bg_soft;
    border-radius: 4px;
    border-width: 1px;
    border-color: palette.border_soft;
    clip: true;

    property <float> safe_surface_width: root.surface_width > 1.0 ? root.surface_width : 1.0;
    property <float> safe_surface_height: root.surface_height > 1.0 ? root.surface_height : 1.0;
    property <float> available_width: max(root.width / 1px - 24.0, 1.0);
    property <float> available_height: max(root.height / 1px - 24.0, 1.0);
    property <float> scale:
        min(root.available_width / root.safe_surface_width, root.available_height / root.safe_surface_height);
    out property <float> surface_scale: root.scale;
    property <float> scaled_surface_width: root.safe_surface_width * root.scale;
    property <float> scaled_surface_height: root.safe_surface_height * root.scale;
    property <float> surface_offset_x: ((root.width / 1px) - root.scaled_surface_width) * 0.5;
    property <float> surface_offset_y: ((root.height / 1px) - root.scaled_surface_height) * 0.5;
    out property <float> surface_origin_x: root.surface_offset_x;
    out property <float> surface_origin_y: root.surface_offset_y;
    property <float> target_pad_thickness: 14.0;
    property <float> drag_threshold_px: 8.0;
    property <bool> drag_pressed: false;
    property <bool> drag_active: false;
    property <bool> drag_suppress_click: false;
    property <int> drag_source_index: -1;
    property <float> drag_press_x: 0.0;
    property <float> drag_press_y: 0.0;
    property <float> drag_pointer_x: 0.0;
    property <float> drag_pointer_y: 0.0;
    property <int> overlay_index:
        root.drag_source_index >= 0 && root.drag_source_index < root.items.length && (root.drag_pressed || root.drag_active) ? root.drag_source_index :
        root.selected_index >= 0 && root.selected_index < root.items.length ? root.selected_index : -1;
    property <float> overlay_frame_x:
        root.overlay_index >= 0 ? root.surface_offset_x + root.items[root.overlay_index].x * root.scale : 0.0;
    property <float> overlay_frame_y:
        root.overlay_index >= 0 ? root.surface_offset_y + root.items[root.overlay_index].y * root.scale : 0.0;
    property <float> overlay_frame_width:
        root.overlay_index >= 0 ? max(root.items[root.overlay_index].width * root.scale, 2.0) : 0.0;
    property <float> overlay_frame_height:
        root.overlay_index >= 0 ? max(root.items[root.overlay_index].height * root.scale, 2.0) : 0.0;
    property <string> drag_target_action:
        !root.drag_active ? "" :
        root.can_insert_child
            && root.drag_pointer_x >= root.overlay_frame_x
            && root.drag_pointer_x <= root.overlay_frame_x + root.overlay_frame_width
            && root.drag_pointer_y >= root.overlay_frame_y
            && root.drag_pointer_y <= root.overlay_frame_y + root.overlay_frame_height ? "palette.insert.child" :
        root.can_insert_after
            && root.drag_pointer_x >= root.overlay_frame_x
            && root.drag_pointer_x <= root.overlay_frame_x + root.overlay_frame_width
            && root.drag_pointer_y >= root.overlay_frame_y + root.overlay_frame_height + 4.0
            && root.drag_pointer_y <= root.overlay_frame_y + root.overlay_frame_height + 4.0 + root.target_pad_thickness ? "palette.insert.after" :
        root.can_reparent_into_previous
            && root.drag_pointer_x >= max(root.overlay_frame_x - root.target_pad_thickness - 4.0, 4.0)
            && root.drag_pointer_x <= max(root.overlay_frame_x - 4.0, 4.0)
            && root.drag_pointer_y >= root.overlay_frame_y
            && root.drag_pointer_y <= root.overlay_frame_y + root.overlay_frame_height ? "canvas.reparent.into_previous" :
        root.can_reparent_into_next
            && root.drag_pointer_x >= min(root.overlay_frame_x + root.overlay_frame_width + 4.0, root.width / 1px - root.target_pad_thickness - 4.0)
            && root.drag_pointer_x <= min(root.overlay_frame_x + root.overlay_frame_width + root.target_pad_thickness + 4.0, root.width / 1px - 4.0)
            && root.drag_pointer_y >= root.overlay_frame_y
            && root.drag_pointer_y <= root.overlay_frame_y + root.overlay_frame_height ? "canvas.reparent.into_next" :
        root.can_reparent_outdent
            && root.drag_pointer_x >= root.overlay_frame_x
            && root.drag_pointer_x <= root.overlay_frame_x + root.overlay_frame_width
            && root.drag_pointer_y >= max(root.overlay_frame_y - root.target_pad_thickness - 4.0, 4.0)
            && root.drag_pointer_y <= max(root.overlay_frame_y - 4.0, 4.0) ? "canvas.reparent.outdent" :
        "";
    property <string> drag_target_label:
        root.drag_target_action == "palette.insert.child" ? "Insert In" :
        root.drag_target_action == "palette.insert.after" ? "Insert After" :
        root.drag_target_action == "canvas.reparent.into_previous" ? "Into Prev" :
        root.drag_target_action == "canvas.reparent.into_next" ? "Into Next" :
        root.drag_target_action == "canvas.reparent.outdent" ? "Outdent" :
        "";

    Rectangle {
        x: root.surface_offset_x * 1px;
        y: root.surface_offset_y * 1px;
        width: root.scaled_surface_width * 1px;
        height: root.scaled_surface_height * 1px;
        border-radius: 4px;
        border-width: 1px;
        border-color: #ffffff12;
        background: #12161c;
    }

    if root.items.length == 0: Text {
        x: 10px;
        y: 10px;
        text: "No preview frames";
        color: palette.text_dim;
        font-size: 10px;
    }

    for item[index] in root.items: frame_rect := Rectangle {
        x: root.surface_offset_x * 1px + item.x * root.scale * 1px;
        y: root.surface_offset_y * 1px + item.y * root.scale * 1px;
        width: max(item.width * root.scale * 1px, 2px);
        height: max(item.height * root.scale * 1px, 2px);
        property <bool> external_target_active:
            root.external_drag_active && root.external_drag_target_index == index;
        property <bool> external_child_target_active:
            self.external_target_active
            && root.external_drag_target_action == "palette.insert.child"
            && root.external_slot_target_items.length == 0;
        property <bool> external_after_target_active:
            self.external_target_active && root.external_drag_target_action == "palette.insert.after";
        border-radius: 3px;
        border-width:
            self.external_target_active ? 2px :
            index == root.selected_index || item.selected ? 2px :
            1px;
        border-color:
            self.external_target_active ? #53c98a :
            index == root.selected_index || item.selected ? #ffd479 :
            frame_touch.has-hover ? #9ec1ff :
            #7f8b9b;
        background:
            self.external_target_active ? #53c98a22 :
            index == root.selected_index || item.selected ? #ffd47922 :
            frame_touch.has-hover ? #8ab7ff16 :
            #ffffff08;
        clip: true;

        Text {
            visible: parent.width >= 48px && parent.height >= 16px;
            x: 4px;
            y: 3px;
            width: parent.width - 8px;
            text: item.label;
            color: index == root.selected_index || item.selected ? #fff3d6 : #d7dce4;
            font-size: 9px;
            font-weight: 600;
            overflow: elide;
        }

        if frame_rect.external_child_target_active: drop_inside_overlay := Rectangle {
            x: 6px;
            y: 6px;
            width: max(parent.width - 12px, 18px);
            height: max(parent.height - 12px, 18px);
            border-radius: 3px;
            border-width: 1px;
            border-color: #53c98acc;
            background: #53c98a12;

            Text {
                visible: parent.width >= 56px;
                x: 6px;
                y: 4px;
                width: parent.width - 12px;
                text: root.external_drag_target_label;
                color: #dff8e8;
                font-size: 8px;
                font-weight: 700;
                overflow: elide;
            }
        }

        frame_touch := TouchArea {
            mouse-cursor:
                root.drag_source_index == index && (root.drag_pressed || root.drag_active) ? MouseCursor.grabbing :
                MouseCursor.grab;
            width: parent.width;
            height: parent.height;
            clicked => {
                if (!root.drag_suppress_click) {
                    root.item_selected(index);
                }
                root.drag_suppress_click = false;
            }
            double-clicked => {
                if (!root.drag_suppress_click) {
                    root.item_activated(index);
                }
                root.drag_suppress_click = false;
            }
            pointer-event(event) => {
                if (event.button != PointerEventButton.left) {
                    return;
                }
                if (event.kind == PointerEventKind.down) {
                    root.drag_pressed = true;
                    root.drag_active = false;
                    root.drag_suppress_click = false;
                    root.drag_source_index = index;
                    root.drag_press_x = frame_rect.x / 1px + self.mouse-x / 1px;
                    root.drag_press_y = frame_rect.y / 1px + self.mouse-y / 1px;
                    root.drag_pointer_x = frame_rect.x / 1px + self.mouse-x / 1px;
                    root.drag_pointer_y = frame_rect.y / 1px + self.mouse-y / 1px;
                } else if (event.kind == PointerEventKind.up && root.drag_source_index == index) {
                    root.drag_pointer_x = frame_rect.x / 1px + self.mouse-x / 1px;
                    root.drag_pointer_y = frame_rect.y / 1px + self.mouse-y / 1px;
                    if (root.drag_active && root.drag_target_action != "") {
                        root.action_requested(root.drag_target_action);
                    }
                    root.drag_pressed = false;
                    root.drag_active = false;
                    root.drag_source_index = -1;
                }
            }
            moved => {
                if (!root.drag_pressed || root.drag_source_index != index) {
                    return;
                }
                root.drag_pointer_x = frame_rect.x / 1px + self.mouse-x / 1px;
                root.drag_pointer_y = frame_rect.y / 1px + self.mouse-y / 1px;
                if (
                    !root.drag_active
                    && (
                        (root.drag_pointer_x - root.drag_press_x) * (root.drag_pointer_x - root.drag_press_x)
                        + (root.drag_pointer_y - root.drag_press_y) * (root.drag_pointer_y - root.drag_press_y)
                    ) >= root.drag_threshold_px * root.drag_threshold_px
                ) {
                    root.drag_active = true;
                    root.drag_suppress_click = true;
                    root.item_selected(index);
                }
            }
        }
    }

    for target[index] in root.external_slot_target_items: external_slot_target := Rectangle {
        visible:
            root.external_drag_active
            && root.external_drag_target_action == "palette.insert.child";
        x: root.surface_offset_x * 1px + target.x * root.scale * 1px;
        y: root.surface_offset_y * 1px + target.y * root.scale * 1px;
        width: max(target.width * root.scale * 1px, 10px);
        height: max(target.height * root.scale * 1px, 10px);
        border-radius: 3px;
        border-width: target.selected ? 2px : 1px;
        border-color: target.selected ? #53c98acc : #53c98a66;
        background: target.selected ? #53c98a28 : #53c98a10;

        Text {
            visible: parent.width >= 34px && parent.height >= 14px;
            x: 4px;
            y: 3px;
            width: parent.width - 8px;
            text: target.label;
            color: target.selected ? #dff8e8 : #b9d8c4;
            font-size: 8px;
            font-weight: target.selected ? 700 : 600;
            overflow: elide;
        }
    }

    for item[index] in root.items: drop_after_overlay := Rectangle {
        visible:
            root.external_drag_active
            && root.external_drag_target_index == index
            && root.external_drag_target_action == "palette.insert.after";
        x: root.surface_offset_x * 1px + item.x * root.scale * 1px + 4px;
        y: root.surface_offset_y * 1px + (item.y + item.height) * root.scale * 1px + 6px;
        width: max(item.width * root.scale * 1px - 8px, 44px);
        height: 18px;
        border-radius: 9px;
        border-width: 1px;
        border-color: #53c98acc;
        background: #0f1a13ee;

        Text {
            x: 8px;
            y: 4px;
            width: parent.width - 16px;
            text: root.external_drag_target_label;
            color: #dff8e8;
            font-size: 8px;
            font-weight: 700;
            overflow: elide;
        }
    }

    if root.drag_active: drag_overlay := Rectangle {
        x: min(max(root.drag_pointer_x * 1px + 12px, 8px), max(root.width - self.width - 8px, 8px));
        y: min(max(root.drag_pointer_y * 1px - self.height - 12px, 8px), max(root.height - self.height - 8px, 8px));
        width: 116px;
        height: 24px;
        border-radius: 4px;
        border-width: 1px;
        border-color: root.drag_target_label != "" ? #53c98a88 : #7f8b9b88;
        background: root.drag_target_label != "" ? #0f1a13ee : #10161eea;

        Text {
            x: 8px;
            y: 5px;
            width: parent.width - 16px;
            text: root.drag_target_label != "" ? root.drag_target_label : "Drag Authoring";
            color: root.drag_target_label != "" ? #dff8e8 : #d7dce4;
            font-size: 9px;
            font-weight: 700;
            overflow: elide;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            mouse-cursor: MouseCursor.grabbing;
        }
    }

    if root.external_drag_active: external_drag_overlay := Rectangle {
        x: min(max(root.external_drag_pointer_x * 1px + 12px, 8px), max(root.width - self.width - 8px, 8px));
        y: min(max(root.external_drag_pointer_y * 1px - self.height - 12px, 8px), max(root.height - self.height - 8px, 8px));
        width: 122px;
        height: 24px;
        border-radius: 4px;
        border-width: 1px;
        border-color: root.external_drag_target_label != "" ? #53c98a88 : #7f8b9b88;
        background: root.external_drag_target_label != "" ? #0f1a13ee : #10161eea;

        Text {
            x: 8px;
            y: 5px;
            width: parent.width - 16px;
            text: root.external_drag_target_label != "" ? root.external_drag_target_label : "Drop On Canvas";
            color: root.external_drag_target_label != "" ? #dff8e8 : #d7dce4;
            font-size: 9px;
            font-weight: 700;
            overflow: elide;
        }
    }

    if root.overlay_index >= 0 && root.can_insert_child: insert_child_target := Rectangle {
        x: root.overlay_frame_x * 1px;
        y: root.overlay_frame_y * 1px;
        width: root.overlay_frame_width * 1px;
        height: root.overlay_frame_height * 1px;
        border-radius: 3px;
        border-width: 2px;
        border-color: #53c98a;
        background: #53c98a22;

        Text {
            x: 6px;
            y: 4px;
            text: "Insert In";
            color: #dff8e8;
            font-size: 9px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("palette.insert.child"); }
        }
    }

    if root.overlay_index >= 0 && root.can_insert_after: insert_after_target := Rectangle {
        x: root.overlay_frame_x * 1px;
        y: (root.overlay_frame_y + root.overlay_frame_height + 4.0) * 1px;
        width: root.overlay_frame_width * 1px;
        height: root.target_pad_thickness * 1px;
        border-radius: 3px;
        border-width: 1px;
        border-color: #53c98a;
        background: #53c98a2a;

        Text {
            x: 6px;
            y: 2px;
            text: "Insert After";
            color: #dff8e8;
            font-size: 8px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("palette.insert.after"); }
        }
    }

    if root.overlay_index >= 0 && root.can_reparent_into_previous: reparent_prev_target := Rectangle {
        x: max(root.overlay_frame_x - root.target_pad_thickness - 4.0, 4.0) * 1px;
        y: root.overlay_frame_y * 1px;
        width: root.target_pad_thickness * 1px;
        height: root.overlay_frame_height * 1px;
        border-radius: 3px;
        border-width: 1px;
        border-color: #7db8ff;
        background: #7db8ff24;

        Text {
            x: parent.width + 4px;
            y: 4px;
            text: "Into Prev";
            color: #dbeafe;
            font-size: 8px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("canvas.reparent.into_previous"); }
        }
    }

    if root.overlay_index >= 0 && root.can_reparent_into_next: reparent_next_target := Rectangle {
        x: min(root.overlay_frame_x + root.overlay_frame_width + 4.0, root.width / 1px - root.target_pad_thickness - 4.0) * 1px;
        y: root.overlay_frame_y * 1px;
        width: root.target_pad_thickness * 1px;
        height: root.overlay_frame_height * 1px;
        border-radius: 3px;
        border-width: 1px;
        border-color: #7db8ff;
        background: #7db8ff24;

        Text {
            x: -52px;
            y: 4px;
            text: "Into Next";
            color: #dbeafe;
            font-size: 8px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("canvas.reparent.into_next"); }
        }
    }

    if root.overlay_index >= 0 && root.can_reparent_outdent: outdent_target := Rectangle {
        x: root.overlay_frame_x * 1px;
        y: max(root.overlay_frame_y - root.target_pad_thickness - 4.0, 4.0) * 1px;
        width: root.overlay_frame_width * 1px;
        height: root.target_pad_thickness * 1px;
        border-radius: 3px;
        border-width: 1px;
        border-color: #f0b667;
        background: #f0b66724;

        Text {
            x: 6px;
            y: 2px;
            text: "Outdent";
            color: #fff3d6;
            font-size: 8px;
            font-weight: 700;
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => { root.action_requested("canvas.reparent.outdent"); }
        }
    }

    if root.overlay_index >= 0: overlay := Rectangle {
        x: min(root.overlay_frame_x * 1px, max(root.width - 256px, 8px));
        y: min((root.overlay_frame_y + root.overlay_frame_height + 8.0) * 1px, max(root.height - 96px, 8px));
        width: 248px;
        height: 88px;
        border-radius: 4px;
        border-width: 1px;
        border-color: #ffd47988;
        background: #10161eea;

        VerticalLayout {
            x: 8px;
            y: 7px;
            width: parent.width - 16px;
            height: parent.height - 14px;
            spacing: 4px;

            Text {
                text: root.items[root.overlay_index].label + " • " + root.items[root.overlay_index].kind;
                color: #fff3d6;
                font-size: 9px;
                font-weight: 700;
                overflow: elide;
            }

            HorizontalLayout {
                width: parent.width;
                spacing: 2px;

                ShellButton {
                    width: 52px;
                    label: "Add In";
                    enabled: root.can_insert_child;
                    active: root.can_insert_child;
                    clicked => { root.action_requested("palette.insert.child"); }
                }

                ShellButton {
                    width: 66px;
                    label: "Add After";
                    enabled: root.can_insert_after;
                    active: root.can_insert_after;
                    clicked => { root.action_requested("palette.insert.after"); }
                }

                ShellButton {
                    width: 36px;
                    label: "Up";
                    enabled: root.can_move_up;
                    active: root.can_move_up;
                    clicked => { root.action_requested("canvas.move.up"); }
                }

                ShellButton {
                    width: 46px;
                    label: "Down";
                    enabled: root.can_move_down;
                    active: root.can_move_down;
                    clicked => { root.action_requested("canvas.move.down"); }
                }
            }

            HorizontalLayout {
                width: parent.width;
                spacing: 2px;

                ShellButton {
                    width: 44px;
                    label: "Prev";
                    enabled: root.can_reparent_into_previous;
                    active: root.can_reparent_into_previous;
                    clicked => { root.action_requested("canvas.reparent.into_previous"); }
                }

                ShellButton {
                    width: 44px;
                    label: "Next";
                    enabled: root.can_reparent_into_next;
                    active: root.can_reparent_into_next;
                    clicked => { root.action_requested("canvas.reparent.into_next"); }
                }

                ShellButton {
                    width: 40px;
                    label: "Out";
                    enabled: root.can_reparent_outdent;
                    active: root.can_reparent_outdent;
                    clicked => { root.action_requested("canvas.reparent.outdent"); }
                }

                ShellButton {
                    width: 50px;
                    label: "Wrap";
                    enabled: root.can_wrap_in_vertical_box;
                    active: root.can_wrap_in_vertical_box;
                    clicked => { root.action_requested("canvas.wrap.vertical_box"); }
                }

                ShellButton {
                    width: 58px;
                    label: "Unwrap";
                    enabled: root.can_unwrap;
                    active: root.can_unwrap;
                    clicked => { root.action_requested("canvas.unwrap"); }
                }
            }

            HorizontalLayout {
                width: parent.width;
                spacing: 2px;

                ShellButton {
                    width: 48px;
                    label: "Open";
                    enabled: root.can_open_reference;
                    active: root.can_open_reference;
                    clicked => { root.action_requested("reference.open"); }
                }

                ShellButton {
                    width: 54px;
                    label: "To Ref";
                    enabled: root.can_convert_to_reference;
                    active: root.can_convert_to_reference;
                    clicked => { root.action_requested("canvas.convert.reference"); }
                }

                ShellButton {
                    width: 58px;
                    label: "Extract";
                    enabled: root.can_extract_component;
                    active: root.can_extract_component;
                    clicked => { root.action_requested("canvas.extract.component"); }
                }

                ShellButton {
                    width: 64px;
                    label: "Promote";
                    enabled: root.can_promote_to_external_widget;
                    active: root.can_promote_to_external_widget;
                    clicked => { root.action_requested("canvas.promote.widget"); }
                }
            }
        }
    }

    Text {
        x: 10px;
        y: parent.height - 18px;
        text:
            root.surface_width > 0.0 && root.surface_height > 0.0 ?
            root.surface_width + " x " + root.surface_height + " • " + root.items.length + " draw nodes" :
            "";
        color: palette.text_dim;
        font-size: 9px;
    }
}

component CompactField inherits Rectangle {
    in property <string> text;
    in property <string> placeholder;
    in property <bool> enabled: true;
    callback edited(value: string);

    palette := Palette {}
    height: 22px;
    border-radius: 3px;
    border-width: 1px;
    border-color: palette.border;
    background: enabled ? palette.panel_bg_soft : palette.panel_bg;
    opacity: enabled ? 1.0 : 0.55;

    LineEdit {
        x: 6px;
        y: 1px;
        width: parent.width - 12px;
        height: parent.height - 2px;
        text: root.text;
        placeholder-text: root.placeholder;
        enabled: root.enabled;
        font-size: 11px;
        edited(value) => { root.edited(value); }
    }
}

component AxisField inherits Rectangle {
    in property <string> axis;
    in property <color> axis_color;
    in property <string> value;
    callback edited(value: string);

    palette := Palette {}
    height: 22px;
    border-radius: 3px;
    border-width: 1px;
    border-color: palette.border;
    background: palette.panel_bg_soft;

    Text {
        x: 7px;
        y: 5px;
        text: root.axis;
        color: root.axis_color;
        font-size: 10px;
        font-weight: 700;
    }

    LineEdit {
        x: 18px;
        y: 1px;
        width: parent.width - 24px;
        height: parent.height - 2px;
        text: root.value;
        placeholder-text: root.axis;
        font-size: 11px;
        edited(value) => { root.edited(value); }
    }
}

export component ToolWindowEmptyState inherits Rectangle {
    in property <string> eyebrow;
    in property <string> title;
    in property <string> body;
    in property <string> primary_action_label;
    in property <string> primary_action_id;
    in property <string> secondary_hint;
    callback trigger_action(action_id: string);

    palette := Palette {}
    background: transparent;

    Rectangle {
        x: 12px;
        y: 18px;
        width: parent.width - 24px;
        height: min(parent.height - 24px, 188px);
        background: transparent;

        VerticalLayout {
            width: parent.width;
            spacing: 8px;

            if root.eyebrow != "": Text {
                text: root.eyebrow;
                color: palette.accent;
                font-size: 10px;
                font-weight: 600;
            }

            Text {
                text: root.title;
                color: palette.text;
                font-size: 14px;
                font-weight: 600;
            }

            Text {
                text: root.body;
                color: palette.text_muted;
                font-size: 11px;
                wrap: word-wrap;
            }

            if root.primary_action_label != "": ShellButton {
                width: 96px;
                label: root.primary_action_label;
                active: true;
                clicked => { root.trigger_action(root.primary_action_id); }
            }

            if root.secondary_hint != "": Text {
                text: root.secondary_hint;
                color: palette.text_dim;
                font-size: 10px;
                wrap: word-wrap;
            }
        }
    }
}

export component HierarchyPane inherits Rectangle {
    in property <[SceneNodeData]> hierarchy_nodes;
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: transparent;
    clip: true;

    Rectangle {
        width: parent.width;
        height: parent.height;
        clip: true;

        rows := VerticalLayout {
            x: 8px;
            y: 8px - root.scroll_px * 1px;
            width: parent.width - 16px;
            spacing: 1px;

            for node[index] in root.hierarchy_nodes: Rectangle {
                height: 22px;
                border-radius: 3px;
                background: node.selected ? #365880 : root.hovered_index == index ? palette.chrome_bg_soft : transparent;

                Text {
                    x: 10px + node.depth * 14px;
                    y: 4px;
                    text: node.name;
                    color: node.selected ? #eef4ff : palette.text_muted;
                    font-size: 11px;
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px,
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}

export component InspectorPane inherits Rectangle {
    in property <string> info;
    in property <string> inspector_name;
    in property <string> inspector_parent;
    in property <string> inspector_x;
    in property <string> inspector_y;
    in property <string> inspector_z;
    in property <float> scroll_px: 0.0;
    in property <bool> delete_enabled;
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback control_changed(control_id: string, value: string);
    callback control_clicked(control_id: string);

    palette := Palette {}
    background: transparent;
    clip: true;

    scroll_capture := TouchArea {
        width: parent.width;
        height: parent.height;
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }

        Rectangle {
            width: parent.width;
            height: parent.height;
            clip: true;

            content := VerticalLayout {
                x: 10px;
                y: 10px - root.scroll_px * 1px;
                width: parent.width - 20px;
                spacing: 4px;

                Rectangle {
                    width: parent.width;
                    height: 22px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    background: palette.panel_bg_soft;

                    Text {
                        x: 8px;
                        y: 3px;
                        text: "Transform";
                        color: palette.text;
                        font-size: 11px;
                        font-weight: 600;
                    }

                    Text {
                        x: parent.width - self.preferred-width - 8px;
                        y: 4px;
                        text: root.info;
                        color: palette.text_dim;
                        font-size: 9px;
                        overflow: elide;
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 22px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Name";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    CompactField {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        text: root.inspector_name;
                        placeholder: "Name";
                        edited(value) => { root.control_changed("NameField", value); }
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 22px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Parent";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    CompactField {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        text: root.inspector_parent;
                        placeholder: "Parent Id";
                        edited(value) => { root.control_changed("ParentField", value); }
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 22px;
                    background: transparent;

                    Text {
                        x: 0px;
                        y: 4px;
                        width: 58px;
                        text: "Position";
                        color: palette.text_dim;
                        font-size: 10px;
                    }

                    HorizontalLayout {
                        x: 62px;
                        y: 0px;
                        width: parent.width - 62px;
                        spacing: 4px;

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "X";
                            axis_color: #c75450;
                            value: root.inspector_x;
                            edited(value) => { root.control_changed("PositionXField", value); }
                        }

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "Y";
                            axis_color: #7fb062;
                            value: root.inspector_y;
                            edited(value) => { root.control_changed("PositionYField", value); }
                        }

                        AxisField {
                            width: (parent.width - 8px) / 3;
                            axis: "Z";
                            axis_color: #5a88d2;
                            value: root.inspector_z;
                            edited(value) => { root.control_changed("PositionZField", value); }
                        }
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 1px;
                    background: palette.border_soft;
                }

                Rectangle {
                    width: parent.width;
                    height: 24px;
                    background: transparent;

                    ShellButton {
                        x: parent.width - 126px;
                        y: 0px;
                        width: 58px;
                        label: "Apply";
                        active: true;
                        clicked => { root.control_clicked("ApplyBatchButton"); }
                    }

                    ShellButton {
                        x: parent.width - 62px;
                        y: 0px;
                        width: 58px;
                        label: "Delete";
                        active: false;
                        enabled: root.delete_enabled;
                        clicked => { root.control_clicked("DeleteSelected"); }
                    }
                }
            }
        }
    }
}

export component ConsolePane inherits Rectangle {
    in property <bool> show_empty;
    in property <string> empty_title;
    in property <string> empty_body;
    in property <string> status_text;
    in property <float> scroll_px: 0.0;
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: #17191c;
    clip: true;

    Rectangle {
        width: parent.width;
        height: parent.height;
        clip: true;

        lines := VerticalLayout {
            x: 10px;
            y: 8px - root.scroll_px * 1px;
            width: parent.width - 20px;
            spacing: 6px;

            if root.show_empty: Text {
                text: root.status_text != "" ? "> " + root.status_text : "> No output yet";
                color: #c3ccd8;
                font-size: 11px;
                font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                wrap: word-wrap;
            }

            if root.show_empty && root.empty_body != "": Text {
                text: root.empty_body;
                color: palette.text_dim;
                font-size: 10px;
                wrap: word-wrap;
            }

            if !root.show_empty: Text {
                text: root.status_text;
                color: #c3ccd8;
                font-size: 11px;
                font-family: "JetBrains Mono, Cascadia Mono, Consolas";
                wrap: word-wrap;
            }
        }
    }

    TouchArea {
        width: parent.width;
        height: parent.height;
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }
    }
}

