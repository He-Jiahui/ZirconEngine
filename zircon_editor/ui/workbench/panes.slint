                        border-color: palette.border_soft;

                        VerticalLayout {
                            x: 8px;
                            y: 6px;
                            width: parent.width - 16px;
                            spacing: 2px;

                            Text {
                                text: root.source_selected_block_label != "" ? root.source_selected_block_label : "No source block";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                                wrap: word-wrap;
