                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_layout.virtualization_overscan; placeholder: "container.virtualization.overscan"; enabled: root.inspector_widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.virtualization.overscan.set", -1, value, ""); } }
                            }

