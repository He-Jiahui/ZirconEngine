                            if root.inspector_layout.semantic.title != "": UiAssetSelectableSection {
                                width: parent.width;
                                height: 92px;
                                title: root.inspector_layout.semantic.title;
                                items: root.inspector_layout.semantic.collection.items;
                                selected_index: root.inspector_layout.semantic.collection.selected_index;
                                accent: #d7a86b;
                                item_selected(item_index) => { root.collection_event("layout_semantic", "selected", item_index); }
                            }

                            if root.inspector_layout.semantic.title != "": Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: parent.width;
                                    text:
                                        root.inspector_layout.semantic.path != "" ?
                                        root.inspector_layout.semantic.path :
                                        "Select layout semantic";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            if root.inspector_layout.semantic.title != "": CompactField {
                                width: parent.width;
                                text: root.inspector_layout.semantic.value;
                                placeholder: root.inspector_layout.semantic.path;
                                enabled: root.inspector_layout.semantic.collection.selected_index >= 0;
                edited(value) => { root.detail_event("layout", "layout.semantic.value.set", -1, value, ""); }
                            }

                            if root.inspector_layout.semantic.title != "": HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 52px;
                                    label: "Clear";
                                    enabled: root.inspector_layout.semantic.collection.selected_index >= 0;
                clicked => { root.detail_event("layout", "layout.semantic.delete", -1, "", ""); }
                                }
                            }

                            Text {
                                text: "Bindings";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 104px;
                                title: "Bindings";
                                items: root.inspector_binding.collection.items;
                                selected_index: root.inspector_binding.collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => { root.collection_event("binding", "selected", item_index); }
                            }

                            CompactField {
                                width: parent.width;
                                text: root.inspector_binding.binding_id;
                                placeholder: "binding id";
                                enabled: root.inspector_binding.can_edit;
                edited(value) => { root.detail_event("binding", "binding.id.set", -1, value, ""); }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 86px;
                                title: "Event";
                                items: root.inspector_binding.event_collection.items;
                                selected_index: root.inspector_binding.event_collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => { root.collection_event("binding_event", "selected", item_index); }
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 68px;
                                title: "Action Kind";
                                items: root.inspector_binding.action_kind_collection.items;
                                selected_index: root.inspector_binding.action_kind_collection.selected_index;
                                accent: #7cc6b9;
                                item_selected(item_index) => { root.collection_event("binding_action_kind", "selected", item_index); }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: parent.width;
                                    text: root.inspector_binding.action_kind_collection.selected_index == 2 ? "Binding Target" : "Route";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text: root.inspector_binding.binding_route;
                                placeholder:
                                    root.inspector_binding.action_kind_collection.selected_index == 2 ?
                                    "EditorActions.SaveProject" :
                                    "MenuAction.SaveProject";
                                enabled: root.inspector_binding.can_edit;
                edited(value) => { root.detail_event("binding", "binding.route.set", -1, value, ""); }
                            }

                            if root.inspector_binding.action_kind_collection.selected_index != 2: Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

