                            clicked => { root.action("style.state.hover"); }
                        }

                        ShellButton {
                            width: 46px;
                            label: "Focus";
                active: root.pane.state_focus;
                            clicked => { root.action("style.state.focus"); }
                        }

                        ShellButton {
                            width: 60px;
                            label: "Pressed";
                active: root.pane.state_pressed;
                            clicked => { root.action("style.state.pressed"); }
                        }
                    }

                    HorizontalLayout {
                        x: 10px;
                        y: 82px;
                        width: parent.width - 20px;
                        spacing: 4px;

                        ShellButton {
                            width: 62px;
                            label: "Disabled";
                active: root.pane.state_disabled;
                            clicked => { root.action("style.state.disabled"); }
                        }

                        ShellButton {
                            width: 58px;
                            label: "Selected";
                active: root.pane.state_selected;
                            clicked => { root.action("style.state.selected"); }
                        }
                    }

                    Rectangle {
                        x: 10px;
                        y: 112px;
                        width: parent.width - 20px;
                        height: 1px;
                        background: palette.border_soft;
                    }

                    Rectangle {
                        x: 0px;
                        y: 118px;
                        width: parent.width;
                        height: parent.height - 118px;
                        clip: true;

                        VerticalLayout {
                            x: 10px;
                            y: 8px;
                            width: parent.width - 20px;
                            spacing: 4px;

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 104px;
                                title: "Theme Sources";
                                items: root.theme_source.collection.items;
                                selected_index: root.theme_source.collection.selected_index;
                                accent: #d8ba79;
                                item_selected(item_index) => {
                                    root.action("theme.source.select." + item_index);
                                }
                                item_activated(item_index) => {
                                    root.action("theme.source.select." + item_index);
                                    root.action("theme.source.open");
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 188px;
                                background: palette.panel_bg_soft;
                                border-radius: 4px;
                                border-width: 1px;
                                border-color: palette.border_soft;
                                clip: true;

                                VerticalLayout {
                                    x: 10px;
                                    y: 8px;
                                    width: parent.width - 20px;
                                    spacing: 3px;

                                    Text {
                                        text: root.theme_source.selected_source_kind != "" ? root.theme_source.selected_source_kind + " Theme" : "No theme source selected";
                                        color: palette.text;
                                        font-size: 10px;
                                        font-weight: 600;
                                        wrap: word-wrap;
                                    }

                                    Text {
                                        text: root.theme_source.selected_source_reference;
                                        color: palette.text_muted;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }

                                    Text {
                                        text: root.theme_source.selected_source_kind != "" ? root.theme_source.selected_source_token_count + " tokens • " + root.theme_source.selected_source_rule_count + " rules" : "";
                                        color: palette.text_dim;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }

                                    Text {
                                        text: root.theme_source.selected_source_kind != "" ? (root.theme_source.selected_source_available ? "available" : "missing import") : "";
                                        color: root.theme_source.selected_source_available ? palette.text_dim : #d69f7e;
                                        font-size: 10px;
                                        wrap: word-wrap;
                                    }

                                    HorizontalLayout {
                                        width: parent.width;
                                        spacing: 4px;

                                        ShellButton {
                                            width: 48px;
                                            label: "Open";
                                            enabled: root.theme_source.selected_source_kind == "Imported" && root.theme_source.selected_source_available;
                                            active: root.theme_source.selected_source_kind == "Imported" && root.theme_source.selected_source_available;
                                            clicked => { root.action("theme.source.open"); }
                                        }

                                        ShellButton {
                                            width: 58px;
                                            label: "Detach";
                                            enabled: root.theme_source.selected_source_kind == "Imported" && root.theme_source.selected_source_available;
                                            active: root.theme_source.selected_source_kind == "Imported" && root.theme_source.selected_source_available;
                                            clicked => { root.action("theme.source.detach_local"); }
                                        }

                                        ShellButton {
                                            width: 52px;
                                            label: "Clone";
                                            enabled: root.theme_source.selected_source_kind == "Imported" && root.theme_source.selected_source_available;
                                            active: root.theme_source.selected_source_kind == "Imported" && root.theme_source.selected_source_available;
                                            clicked => { root.action("theme.source.clone_local"); }
                                        }

                                        ShellButton {
                                            width: 68px;
                                            label: "Promote";
                                            enabled: root.theme_source.selected_source_kind == "Local" && root.theme_source.can_promote_local;
                                            active: root.theme_source.selected_source_kind == "Local" && root.theme_source.can_promote_local;
                                            clicked => { root.action("theme.local.promote"); }
                                        }
