                            if root.inspector_layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Axis"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_layout.scroll_axis; placeholder: "container.axis"; enabled: root.inspector_widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.axis.set", -1, value, ""); } }
                            }

                            if root.inspector_layout.kind == "ScrollableBox": Rectangle {
                                width: parent.width; height: 22px; background: transparent;
                                Text { x: 0px; y: 4px; width: 58px; text: "Gap"; color: palette.text_dim; font-size: 10px; }
                CompactField { x: 62px; y: 0px; width: parent.width - 62px; text: root.inspector_layout.scroll_gap; placeholder: "container.gap"; enabled: root.inspector_widget.selected_node_id != ""; edited(value) => { root.detail_event("layout", "layout.scroll.gap.set", -1, value, ""); } }
