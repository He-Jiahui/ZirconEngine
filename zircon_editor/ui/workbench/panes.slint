                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 92px;
                                title: "Cascade Rules";
                                items: root.theme_source.cascade_rule_items;
                                selected_index: -1;
                                accent: #d8ba79;
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 124px;
                                title: "Merge Preview";
                                items: root.theme_source.merge_preview_items;
                                selected_index: -1;
                                accent: #d8ba79;
                            }

                            Rectangle {
                                width: parent.width;
                                height: 1px;
                                background: palette.border_soft;
                            }

                            Text {
                                text: "Classes";
                                color: palette.text;
                                font-size: 10px;
                                font-weight: 600;
                            }

                            if root.style_class_items.length == 0: Text {
                                text: "No classes on selection";
                                color: palette.text_dim;
                                font-size: 10px;
                            }

                            for class_name in root.style_class_items: Text {
                                text: "." + class_name;
                                color: palette.text_muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }

                            CompactField {
                                width: parent.width;
                                text: root.style_class_draft;
                                placeholder: "class-name";
                                edited(value) => { root.style_class_draft = value; }
                            }

                              HorizontalLayout {
                                  width: parent.width;
                                  spacing: 4px;

                                  ShellButton {
                                    width: 46px;
                                    label: "Add";
                                    enabled: root.style_class_draft != "";
                                    active: root.style_class_draft != "";
                                    clicked => {
                                        root.style_class_action("style.class.add", root.style_class_draft);
                                        root.style_class_draft = "";
                                    }
                                }

                                ShellButton {
                                    width: 62px;
                                    label: "Remove";
                                    enabled: root.style_class_draft != "";
                                    clicked => {
                                        root.style_class_action("style.class.remove", root.style_class_draft);
                                        root.style_class_draft = "";
                                    }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 1px;
                                background: palette.border_soft;
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 118px;
                                title: "Tokens";
                                items: root.style_token.items;
                                selected_index: root.style_token.selected_index;
                                accent: #8dc8c1;
                                item_selected(item_index) => {
                                    root.detail_event("style_token", "style.token.select", item_index, "", "");
                                    root.style_token_name_draft = root.style_token.selected_name;
                                    root.style_token_value_draft = root.style_token.selected_value;
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.style_token_name_draft != "" ?
                                    root.style_token_name_draft :
                                    root.style_token.selected_name;
                                placeholder: "token-name";
                                edited(value) => { root.style_token_name_draft = value; }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.style_token_value_draft != "" ?
                                    root.style_token_value_draft :
                                    root.style_token.selected_value;
                                placeholder: "token-value";
                                edited(value) => { root.style_token_value_draft = value; }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 48px;
                                    label: "Apply";
                                    enabled: root.style_token_name_draft != "" || root.style_token.selected_name != "";
                                    active: root.style_token_name_draft != "" || root.style_token.selected_name != "";
                                    clicked => {
                                        root.detail_event("style_token", "style.token.upsert", root.style_token.selected_index, root.style_token_name_draft != "" ? root.style_token_name_draft : root.style_token.selected_name, root.style_token_value_draft != "" ? root.style_token_value_draft : root.style_token.selected_value);
                                        root.style_token_name_draft = "";
                                        root.style_token_value_draft = "";
                                    }
                                }

                                ShellButton {
                                    width: 56px;
                                    label: "Delete";
                                    enabled: root.style_token.can_delete;
                                    clicked => {
                                        root.detail_event("style_token", "style.token.delete", root.style_token.selected_index, "", "");
                                        root.style_token_name_draft = "";
                                        root.style_token_value_draft = "";
                                    }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 1px;
                                background: palette.border_soft;
                            }

                            UiAssetSelectableSection {
                                width: parent.width;
                                height: 126px;
                                title: "Rules";
                                items: root.style_rule.items;
                                selected_index: root.style_rule.selected_index;
                                accent: #8dc8c1;
                                item_selected(item_index) => {
                                    root.style_rule_selector_draft = root.style_rule.items[item_index];
                                    root.detail_event("style_rule", "style.rule.select", item_index, "", "");
                                }
                            }

                            CompactField {
                                width: parent.width;
                                text:
                                    root.style_rule_selector_draft != "" ?
                                    root.style_rule_selector_draft :
                                    root.style_rule.selected_selector;
                                placeholder: "selector";
                                enabled: root.style_rule.can_edit;
                                edited(value) => { root.style_rule_selector_draft = value; }
                            }

                            HorizontalLayout {
                                width: parent.width;
                                spacing: 4px;

                                ShellButton {
                                    width: 48px;
                                    label: "Apply";
                                    enabled: root.style_rule.can_edit && (root.style_rule_selector_draft != "" || root.style_rule.selected_selector != "");
                                    active: root.style_rule.can_edit && (root.style_rule_selector_draft != "" || root.style_rule.selected_selector != "");
                                    clicked => {
                                        root.detail_event("style_rule", "style.rule.rename", root.style_rule.selected_index, root.style_rule_selector_draft != "" ? root.style_rule_selector_draft : root.style_rule.selected_selector, "");
                                        root.style_rule_selector_draft = "";
                                    }
                                }

                                ShellButton {
                                    width: 56px;
                                    label: "Delete";
                                    enabled: root.style_rule.can_delete;
                                    clicked => {
                                        root.detail_event("style_rule", "style.rule.delete", root.style_rule.selected_index, "", "");
                                        root.style_rule_selector_draft = "";
                                      }
                                  }
                              }

                              Rectangle {
                                  width: parent.width;
                                  height: 1px;
                                  background: palette.border_soft;
                              }

                              UiAssetSelectableSection {
                                  width: parent.width;
                                  height: 126px;
                                  title: "Declarations";
                                  items: root.style_rule_declaration.items;
                                  selected_index: root.style_rule_declaration.selected_index;
                                  accent: #8dc8c1;
                                  item_selected(item_index) => {
                                      root.detail_event("style_rule_declaration", "style.rule.declaration.select", item_index, "", "");
                                      root.style_rule_declaration_path_draft = root.style_rule_declaration.selected_path;
                                      root.style_rule_declaration_value_draft = root.style_rule_declaration.selected_value;
                                  }
                              }

                              CompactField {
                                  width: parent.width;
                                  text:
                                      root.style_rule_declaration_path_draft != "" ?
                                      root.style_rule_declaration_path_draft :
                                      root.style_rule_declaration.selected_path;
                                  placeholder: "self.background.color";
                                  enabled: root.style_rule_declaration.can_edit;
                                  edited(value) => { root.style_rule_declaration_path_draft = value; }
                              }

                              CompactField {
                                  width: parent.width;
                                  text:
                                      root.style_rule_declaration_value_draft != "" ?
                                      root.style_rule_declaration_value_draft :
                                      root.style_rule_declaration.selected_value;
                                  placeholder: "value";
                                  enabled: root.style_rule_declaration.can_edit;
                                  edited(value) => { root.style_rule_declaration_value_draft = value; }
                              }

                              HorizontalLayout {
                                  width: parent.width;
                                  spacing: 4px;

                                  ShellButton {
                                      width: 48px;
                                      label: "Apply";
                                      enabled: root.style_rule_declaration.can_edit;
                                      active: root.style_rule_declaration.can_edit;
                                      clicked => {
                                          root.detail_event("style_rule_declaration", "style.rule.declaration.upsert", root.style_rule_declaration.selected_index, root.style_rule_declaration_path_draft != "" ? root.style_rule_declaration_path_draft : root.style_rule_declaration.selected_path, root.style_rule_declaration_value_draft != "" ? root.style_rule_declaration_value_draft : root.style_rule_declaration.selected_value);
                                          root.style_rule_declaration_path_draft = "";
                                          root.style_rule_declaration_value_draft = "";
                                      }
                                  }

                                  ShellButton {
                                      width: 56px;
                                      label: "Delete";
                                      enabled: root.style_rule_declaration.can_delete;
                                      clicked => {
                                          root.detail_event("style_rule_declaration", "style.rule.declaration.delete", root.style_rule_declaration.selected_index, "", "");
                                          root.style_rule_declaration_path_draft = "";
                                          root.style_rule_declaration_value_draft = "";
                                      }
                                  }
                              }

                              Rectangle {
                                  width: parent.width;
                                  height: 1px;
                                  background: palette.border_soft;
                              }

                              UiAssetSelectableSection {
                                  width: parent.width;
                                  height: 126px;
                                  title: "Matched Rules";
                                  items: root.matched_style_rule.collection.items;
                                  selected_index: root.matched_style_rule.collection.selected_index;
                                  accent: #8dc8c1;
                                  item_selected(item_index) => {
                                      root.collection_event("matched_style_rule", "selected", item_index);
                                  }
                              }

                              Rectangle {
                                  width: parent.width;
                                  height: 78px;
                                  background: palette.panel_bg_soft;
                                  border-radius: 4px;
                                  border-width: 1px;
                                  border-color: palette.border_soft;
                                  clip: true;

                                  VerticalLayout {
                                      x: 10px;
                                      y: 8px;
                                      width: parent.width - 20px;
                                      spacing: 3px;

                                      Text {
                                          text: root.matched_style_rule.selected_origin != "" ? root.matched_style_rule.selected_origin : "No matched rule selected";
                                          color: palette.text;
                                          font-size: 10px;
                                          font-weight: 600;
                                          wrap: word-wrap;
                                      }

                                      Text {
                                          text: root.matched_style_rule.selected_selector;
                                          color: palette.text_muted;
                                          font-size: 10px;
                                          wrap: word-wrap;
                                      }

                                      Text {
                                          text: root.matched_style_rule.selected_specificity >= 0 ? "specificity " + root.matched_style_rule.selected_specificity + " • order " + root.matched_style_rule.selected_source_order : "";
                                          color: palette.text_dim;
                                          font-size: 10px;
                                          wrap: word-wrap;
                                      }

                                      for item in root.matched_style_rule.selected_declaration_items: Text {
                                          text: item;
                                          color: palette.text_muted;
                                          font-size: 10px;
                                          wrap: word-wrap;
                                      }
                                  }
                              }

                              if root.stylesheet_items.length == 0: Text {
                                  text: "No stylesheet entries";
                                  color: palette.text_dim;
                                  font-size: 10px;
                            }

                            for item in root.stylesheet_items: Text {
                                text: item;
                                color: palette.text_muted;
                                font-size: 10px;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }
    }

    if root.palette_drag_active: TouchArea {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        mouse-cursor: MouseCursor.grabbing;
        drag_focus := FocusScope {
            x: 0px;
            y: 0px;
            width: 0px;
            height: 0px;
            enabled: true;
            key-pressed(event) => {
                if (event.text == Key.LeftArrow || event.text == Key.UpArrow) {
                    root.action("palette.target.previous");
                    return accept;
                }
                if (
                    event.text == Key.RightArrow
                    || event.text == Key.DownArrow
                    || event.text == Key.Tab
                    ) {
                    root.action("palette.target.next");
                    return accept;
                }
                if (event.text == Key.Return || event.text == "\n") {
                    if (root.palette_drag_projection.target_chooser_active) {
                        root.palette_target_confirm();
                        return accept;
                    }
                    if (root.palette_drag_projection.target_action != "") {
                        root.palette_drag_dropped();
                    }
                    return accept;
                }
                if (event.text == Key.Escape) {
                    if (root.palette_drag_projection.target_chooser_active) {
                        root.palette_target_cancel();
                    } else {
                        root.palette_drag_cancelled();
                        root.palette_drag_active = false;
                        root.palette_drag_source_index = -1;
                    }
                    return accept;
                }
                reject
            }
        }
        moved => {
            root.palette_drag_pointer_x = self.mouse-x / 1px;
            root.palette_drag_pointer_y = self.mouse-y / 1px;
            root.palette_drag_hovered(
                (root.palette_drag_pointer_x - preview_canvas.x / 1px - preview_canvas.surface_origin_x)
                / max(preview_canvas.surface_scale, 0.0001),
                (root.palette_drag_pointer_y - preview_canvas.y / 1px - preview_canvas.surface_origin_y)
                / max(preview_canvas.surface_scale, 0.0001),
            );
        }
        pointer-event(event) => {
            if (event.button != PointerEventButton.left) {
                return;
            }
            if (event.kind == PointerEventKind.up) {
                root.palette_drag_pointer_x = self.mouse-x / 1px;
                root.palette_drag_pointer_y = self.mouse-y / 1px;
                root.palette_drag_hovered(
                    (root.palette_drag_pointer_x - preview_canvas.x / 1px - preview_canvas.surface_origin_x)
                    / max(preview_canvas.surface_scale, 0.0001),
                    (root.palette_drag_pointer_y - preview_canvas.y / 1px - preview_canvas.surface_origin_y)
                    / max(preview_canvas.surface_scale, 0.0001),
                );
                if (root.palette_drag_projection.target_action != "") {
                    root.palette_drag_dropped();
                } else {
                    root.palette_drag_cancelled();
                }
                root.palette_drag_active = false;
                root.palette_drag_source_index = -1;
            }
        }
    }

    if root.palette_drag_projection.candidate_items.length > 1 && (root.palette_drag_active || root.palette_drag_projection.target_chooser_active): Rectangle {
        x: min(
            max(preview_canvas.x + preview_canvas.width - self.width - 12px, 8px),
            max(root.width - self.width - 8px, 8px)
        );
        y: max(preview_canvas.y - 2px, 8px);
        width: 248px;
        height: min(224px, max(118px, 68px + root.palette_drag_projection.candidate_items.length * 22px));
        background: transparent;
        chooser_focus := FocusScope {
            x: 0px;
            y: 0px;
            width: 0px;
            height: 0px;
            enabled: root.palette_drag_projection.target_chooser_active && !root.palette_drag_active;
            key-pressed(event) => {
                if (event.text == Key.LeftArrow || event.text == Key.UpArrow) {
                    root.action("palette.target.previous");
                    return accept;
                }
                if (
                    event.text == Key.RightArrow
                    || event.text == Key.DownArrow
                    || event.text == Key.Tab
                    ) {
                    root.action("palette.target.next");
                    return accept;
                }
                if (event.text == Key.Return || event.text == "\n") {
                    root.palette_target_confirm();
                    return accept;
                }
                if (event.text == Key.Escape) {
                    root.palette_target_cancel();
                    return accept;
                }
                reject
            }
        }

        UiAssetSelectableSection {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height - 38px;
            title: "Target Cycle";
            items: root.palette_drag_projection.candidate_items;
            selected_index: root.palette_drag_projection.candidate_selected_index;
            accent: #53c98a;
            item_selected(item_index) => {
                root.collection_event("palette_target_candidate", "selected", item_index);
            }
            item_activated(item_index) => {
                root.collection_event("palette_target_candidate", "selected", item_index);
                root.palette_target_confirm();
            }
        }

        HorizontalLayout {
            x: 10px;
            y: parent.height - 34px;
            width: parent.width - 20px;
            spacing: 6px;

            ShellButton {
                width: 56px;
                label: "Apply";
                active: true;
                clicked => { root.palette_target_confirm(); }
            }

            ShellButton {
                width: 58px;
                label: "Cancel";
                clicked => { root.palette_target_cancel(); }
            }

            Text {
                width: parent.width - 120px;
                y: 4px;
                text:
                    root.palette_drag_projection.target_chooser_active ?
                    "Sticky target chooser  Tab/arrows cycle  Enter apply" :
                    "Tab / arrows cycle  Enter apply  Esc cancel";
                color: palette.text_dim;
                font-size: 9px;
                overflow: elide;
            }
        }
    }
}

export component FallbackPane inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> hint;
    in property <bool> compact: true;

    background: transparent;

    EmptyStateCard {
        width: parent.width;
        height: parent.height;
        compact: root.compact;
        eyebrow: "";
        title: root.title;
        body: root.body;
        primary_action_label: "";
        primary_action_id: "";
        secondary_action_label: "";
        secondary_action_id: "";
        secondary_hint: root.hint;
    }
}
