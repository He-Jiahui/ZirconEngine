                                    color: palette.text_muted;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: 52px;
                                    text: "Type";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                Text {
                                    x: 56px;
                                    y: 3px;
                                    width: parent.width - 56px;
                                    text:
                                        root.inspector_widget_label != "" ?
                                        root.inspector_widget_kind + " • " + root.inspector_widget_label :
                                        "";
                                    color: palette.text_muted;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 18px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 3px;
                                    width: 52px;
                                    text: "Parent";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                Text {
                                    x: 56px;
                                    y: 3px;
                                    width: parent.width - 56px;
                                    text:
                                        root.inspector_parent_node_id != "" ?
                                        (root.inspector_mount != "" ? root.inspector_parent_node_id + " • " + root.inspector_mount : root.inspector_parent_node_id) :
                                        "";
                                    color: palette.text_muted;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Control Id";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
                                    text: root.inspector_control_id;
                                    placeholder: "control-id";
                                    enabled: root.inspector_can_edit_control_id;
                                    edited(value) => { root.inspector_widget_action("widget.control_id.set", value); }
                                }
                            }

                            Rectangle {
                                width: parent.width;
                                height: 22px;
                                background: transparent;

                                Text {
                                    x: 0px;
                                    y: 4px;
                                    width: 58px;
                                    text: "Text";
                                    color: palette.text_dim;
                                    font-size: 10px;
                                }

                                CompactField {
                                    x: 62px;
                                    y: 0px;
                                    width: parent.width - 62px;
