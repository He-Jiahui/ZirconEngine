import { UiAssetEditorPaneData } from "ui_asset_editor_data.slint";
import { TemplateNodeFrameData, TemplatePaneNodeData } from "template_node_data.slint";

export struct ProjectOverviewData {
    project_name: string,
    project_root: string,
    assets_root: string,
    library_root: string,
    default_scene_uri: string,
    catalog_revision: string,
    folder_count: string,
    asset_count: string,
}

export struct SceneNodeData {
    id: string,
    name: string,
    depth: int,
    selected: bool,
}

export struct HierarchyPaneData {
    nodes: [TemplatePaneNodeData],
    hierarchy_nodes: [SceneNodeData],
}

export struct AnimationEditorPaneData {
    nodes: [TemplatePaneNodeData],
    mode: string,
    asset_path: string,
    status: string,
    selection: string,
    current_frame: int,
    timeline_start_frame: int,
    timeline_end_frame: int,
    playback_label: string,
    track_items: [string],
    parameter_items: [string],
    node_items: [string],
    state_items: [string],
    transition_items: [string],
}

export struct InspectorPaneData {
    nodes: [TemplatePaneNodeData],
    info: string,
    inspector_name: string,
    inspector_parent: string,
    inspector_x: string,
    inspector_y: string,
    inspector_z: string,
    delete_enabled: bool,
}

export struct SceneViewportChromeData {
    tool: string,
    transform_space: string,
    projection_mode: string,
    view_orientation: string,
    display_mode: string,
    grid_mode: string,
    gizmos_enabled: bool,
    preview_lighting: bool,
    preview_skybox: bool,
    translate_snap: float,
    rotate_snap_deg: float,
    scale_snap: float,
    translate_snap_label: string,
    rotate_snap_label: string,
    scale_snap_label: string,
}

export struct ConsolePaneData {
    nodes: [TemplatePaneNodeData],
    status_text: string,
}

export struct AssetsActivityPaneData {
    nodes: [TemplatePaneNodeData],
}

export struct AssetBrowserPaneData {
    nodes: [TemplatePaneNodeData],
}

export struct ProjectOverviewPaneData {
    nodes: [TemplatePaneNodeData],
}

export struct ModulePluginStatusData {
    plugin_id: string,
    display_name: string,
    package_source: string,
    load_state: string,
    enabled: bool,
    required: bool,
    runtime_crate: string,
    editor_crate: string,
    capabilities: string,
    diagnostics: string,
}

export struct ModulePluginsPaneData {
    plugins: [ModulePluginStatusData],
    diagnostics: string,
}

export struct PaneData {
    id: string,
    slot: string,
    kind: string,
    title: string,
    icon_key: string,
    subtitle: string,
    info: string,
    show_empty: bool,
    empty_title: string,
    empty_body: string,
    primary_action_label: string,
    primary_action_id: string,
    secondary_action_label: string,
    secondary_action_id: string,
    secondary_hint: string,
    show_toolbar: bool,
    viewport: SceneViewportChromeData,
    hierarchy: HierarchyPaneData,
    inspector: InspectorPaneData,
    console: ConsolePaneData,
    assets_activity: AssetsActivityPaneData,
    asset_browser: AssetBrowserPaneData,
    project_overview: ProjectOverviewPaneData,
    module_plugins: ModulePluginsPaneData,
    ui_asset: UiAssetEditorPaneData,
    animation: AnimationEditorPaneData,
}
