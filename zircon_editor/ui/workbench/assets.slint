import { LineEdit } from "std-widgets.slint";
import { Palette, ShellButton, ShellIcon, ToolbarButton } from "chrome.slint";

export struct AssetFolderData {
    id: string,
    name: string,
    count: int,
    depth: int,
    selected: bool,
}

export struct AssetItemData {
    uuid: string,
    locator: string,
    name: string,
    file_name: string,
    kind: string,
    extension: string,
    dirty: bool,
    has_error: bool,
    has_preview: bool,
    state: string,
    revision: string,
    selected: bool,
    preview: image,
}

export struct AssetReferenceData {
    uuid: string,
    locator: string,
    name: string,
    kind: string,
    known_project_asset: bool,
}

export struct ProjectOverviewData {
    project_name: string,
    project_root: string,
    assets_root: string,
    library_root: string,
    default_scene_uri: string,
    catalog_revision: string,
    folder_count: string,
    asset_count: string,
}

export struct AssetSelectionData {
    uuid: string,
    name: string,
    locator: string,
    kind: string,
    meta_path: string,
    adapter_key: string,
    state: string,
    revision: string,
    diagnostics: string,
    has_preview: bool,
    preview: image,
}

component SearchField inherits Rectangle {
    in property <string> text;
    in property <string> placeholder;
    callback edited(value: string);

    palette := Palette {}
    border-radius: 4px;
    border-width: 1px;
    border-color: palette.border;
    background: palette.panel_bg_soft;

    LineEdit {
        x: 8px;
        y: 2px;
        width: parent.width - 16px;
        height: parent.height - 4px;
        text: root.text;
        placeholder-text: root.placeholder;
        font-size: 11px;
        edited(value) => { root.edited(value); }
    }
}

component KindChip inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();

    palette := Palette {}
    height: 24px;
    border-radius: 12px;
    border-width: 1px;
    border-color: active ? palette.accent : palette.border_soft;
    background: active ? #2c527944 : palette.chrome_bg_soft;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: active ? palette.text : palette.text_dim;
        font-size: 10px;
        font-weight: active ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea { clicked => { root.clicked(); } }
}

component AssetSurfaceFrame inherits Rectangle {
    palette := Palette {}
    border-radius: 8px;
    border-width: 1px;
    border-color: palette.border_soft;
    background: palette.panel_bg_soft;
    clip: true;
}

component FolderTreeView inherits AssetSurfaceFrame {
    in property <[AssetFolderData]> folders;
    in property <string> title: "Sources";
    in property <string> subtitle: "Project assets";
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    private property <length> header_height: 48px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: root.header_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 10px;
            text: root.title;
            color: palette.text;
            font-size: 11px;
            font-weight: 700;
        }

        Text {
            x: 12px;
            y: 25px;
            width: parent.width - 24px;
            text: root.subtitle;
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }
    }

    Rectangle {
        x: 0px;
        y: root.header_height;
        width: parent.width;
        height: 1px;
        background: palette.border_soft;
    }

    Rectangle {
        x: 0px;
        y: root.header_height + 1px;
        width: parent.width;
        height: parent.height - root.header_height - 1px;
        clip: true;

        rows := VerticalLayout {
            x: 8px;
            y: 8px - root.scroll_px * 1px;
            width: parent.width - 16px;
            spacing: 4px;

            for folder[index] in root.folders: Rectangle {
                height: 28px;
                border-radius: 6px;
                background: folder.selected ? #365880 : root.hovered_index == index ? palette.chrome_bg_soft : transparent;

                ShellIcon {
                    x: 8px + folder.depth * 12px;
                    y: 7px;
                    width: 14px;
                    height: 14px;
                    icon_key: "project";
                    icon_color: folder.selected ? #eef4ff : palette.text_muted;
                }

                Text {
                    x: 28px + folder.depth * 12px;
                    y: 6px;
                    width: parent.width - (52px + folder.depth * 12px);
                    text: folder.name;
                    color: folder.selected ? #eef4ff : palette.text;
                    font-size: 11px;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 34px;
                    y: 5px;
                    width: 24px;
                    horizontal-alignment: right;
                    text: folder.count;
                    color: folder.selected ? #dce8ff : palette.text_dim;
                    font-size: 10px;
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}

component AssetListView inherits AssetSurfaceFrame {
    in property <[AssetFolderData]> folders;
    in property <[AssetItemData]> items;
    in property <string> view_mode;
    in property <string> title: "Content";
    in property <string> subtitle: "Folder contents";
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    private property <length> header_height: 52px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: root.header_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 10px;
            text: root.title;
            color: palette.text;
            font-size: 11px;
            font-weight: 700;
        }

        Text {
            x: 12px;
            y: 26px;
            width: parent.width - 120px;
            text: root.subtitle;
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        Text {
            x: parent.width - 72px;
            y: 18px;
            width: 60px;
            horizontal-alignment: right;
            text: root.view_mode == "thumbnail" ? "Tiles" : "List";
            color: palette.text_muted;
            font-size: 9px;
        }
    }

    Rectangle {
        x: 0px;
        y: root.header_height;
        width: parent.width;
        height: 1px;
        background: palette.border_soft;
    }

    Rectangle {
        x: 0px;
        y: root.header_height + 1px;
        width: parent.width;
        height: parent.height - root.header_height - 1px;
        clip: true;

        entries := VerticalLayout {
            x: 8px;
            y: 8px - root.scroll_px * 1px;
            width: parent.width - 16px;
            spacing: 8px;
            for folder[index] in root.folders: Rectangle {
                height: root.view_mode == "thumbnail" ? 60px : 32px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: root.hovered_index == index ? palette.chrome_bg_soft : palette.panel_bg_soft;

                ShellIcon {
                    x: 10px;
                    y: root.view_mode == "thumbnail" ? 21px : 9px;
                    width: 14px;
                    height: 14px;
                    icon_key: "project";
                    icon_color: palette.text_muted;
                }

                Text {
                    x: 30px;
                    y: root.view_mode == "thumbnail" ? 14px : 7px;
                    text: folder.name;
                    color: palette.text;
                    font-size: 11px;
                    font-weight: 600;
                }

                Text {
                    x: 30px;
                    y: root.view_mode == "thumbnail" ? 31px : 7px;
                    visible: root.view_mode == "thumbnail";
                    text: folder.count + " assets";
                    color: palette.text_dim;
                    font-size: 10px;
                }
            }

            for item[index] in root.items: Rectangle {
                height: root.view_mode == "thumbnail" ? 88px : 38px;
                border-radius: 6px;
                border-width: 1px;
                border-color: item.selected ? palette.accent : palette.border_soft;
                background: item.selected ? #2c527933 : root.hovered_index == root.folders.length + index ? palette.chrome_bg_soft : palette.panel_bg_soft;

                if root.view_mode == "thumbnail": Rectangle {
                    x: 8px;
                    y: 8px;
                    width: 68px;
                    height: 72px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    background: #16191f;

                    if item.has_preview: Image {
                        width: parent.width;
                        height: parent.height;
                        source: item.preview;
                        image-fit: contain;
                    }

                    if !item.has_preview: ShellIcon {
                        width: 22px;
                        height: 22px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        icon_key: item.kind == "Texture" ? "assets" :
                            item.kind == "Material" ? "inspector" :
                            item.kind == "Scene" ? "scene" :
                            item.kind == "Model" ? "prefab" :
                            "console";
                        icon_color: palette.text_dim;
                    }
                }

                if root.view_mode == "list": Rectangle {
                    x: 8px;
                    y: 7px;
                    width: 18px;
                    height: 18px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    background: #16191f;

                    if item.has_preview: Image {
                        width: parent.width;
                        height: parent.height;
                        source: item.preview;
                        image-fit: contain;
                    }

                    if !item.has_preview: ShellIcon {
                        width: 12px;
                        height: 12px;
                        x: 3px;
                        y: 3px;
                        icon_key: item.kind == "Texture" ? "assets" :
                            item.kind == "Material" ? "inspector" :
                            item.kind == "Scene" ? "scene" :
                            item.kind == "Model" ? "prefab" :
                            "console";
                        icon_color: palette.text_dim;
                    }
                }

                Text {
                    x: root.view_mode == "thumbnail" ? 86px : 34px;
                    y: root.view_mode == "thumbnail" ? 12px : 9px;
                    width: parent.width - (root.view_mode == "thumbnail" ? 174px : 162px);
                    text: item.name;
                    color: palette.text;
                    font-size: 11px;
                    font-weight: 600;
                    overflow: elide;
                }

                if root.view_mode == "thumbnail": Text {
                    x: 86px;
                    y: 29px;
                    width: parent.width - 154px;
                    text: item.locator;
                    color: palette.text_muted;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 94px;
                    y: root.view_mode == "thumbnail" ? 12px : 9px;
                    width: 86px;
                    horizontal-alignment: right;
                    text: item.state != "" ? item.state + (item.revision != "" ? " r" + item.revision : "") : item.kind;
                    color: palette.text_dim;
                    font-size: 10px;
                    overflow: elide;
                }

                if item.dirty: Rectangle {
                    x: root.view_mode == "thumbnail" ? 86px : 132px;
                    y: root.view_mode == "thumbnail" ? 55px : 11px;
                    width: 36px;
                    height: 16px;
                    border-radius: 8px;
                    background: #8a683022;
                    border-width: 1px;
                    border-color: #caa35d;
                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: "Dirty";
                        color: #f1d28c;
                        font-size: 9px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if item.has_error: Rectangle {
                    x: root.view_mode == "thumbnail" ? 128px : 172px;
                    y: root.view_mode == "thumbnail" ? 55px : 11px;
                    width: 36px;
                    height: 16px;
                    border-radius: 8px;
                    background: #7f323522;
                    border-width: 1px;
                    border-color: #d46d72;
                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: "Error";
                        color: #f0b2b6;
                        font-size: 9px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}

component ReferenceListView inherits Rectangle {
    in property <string> title;
    in property <[AssetReferenceData]> references;
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: transparent;
    private property <length> header_height: 20px;

    Text {
        x: 0px;
        y: 0px;
        text: root.title;
        color: palette.text;
        font-size: 11px;
        font-weight: 600;
    }

    Rectangle {
        x: 0px;
        y: root.header_height;
        width: parent.width;
        height: max(0px, parent.height - root.header_height);
        clip: true;

        rows := VerticalLayout {
            x: 0px;
            y: 0px - root.scroll_px * 1px;
            width: parent.width - 4px;
            spacing: 4px;

            if root.references.length == 0: Text {
                text: "No direct references";
                color: palette.text_dim;
                font-size: 10px;
            }

            for reference[index] in root.references: Rectangle {
                height: 34px;
                border-radius: 6px;
                background: root.hovered_index == index ? palette.chrome_bg_soft : palette.panel_bg_soft;
                border-width: 1px;
                border-color: palette.border_soft;

                Text {
                    x: 8px;
                    y: 4px;
                    width: parent.width - 78px;
                    text: reference.name;
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: 8px;
                    y: 15px;
                    width: parent.width - 78px;
                    text: reference.locator;
                    color: palette.text_dim;
                    font-size: 9px;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 64px;
                    y: 8px;
                    width: 56px;
                    horizontal-alignment: right;
                    text: reference.kind != "" ? reference.kind : "External";
                    color: palette.text_dim;
                    font-size: 9px;
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px,
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}

component SelectionPreviewCard inherits Rectangle {
    in property <AssetSelectionData> selection;

    palette := Palette {}
    border-width: 1px;
    border-color: palette.border_soft;
    border-radius: 6px;
    background: palette.panel_bg_soft;

    Rectangle {
        x: 10px;
        y: 10px;
        width: 108px;
        height: parent.height - 20px;
        border-radius: 6px;
        border-width: 1px;
        border-color: palette.border_soft;
        background: #16191f;

        if root.selection.has_preview: Image {
            width: parent.width;
            height: parent.height;
            source: root.selection.preview;
            image-fit: contain;
        }

        if !root.selection.has_preview: ShellIcon {
            width: 28px;
            height: 28px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            icon_key: root.selection.kind == "Texture" ? "assets" :
                root.selection.kind == "Material" ? "inspector" :
                root.selection.kind == "Scene" ? "scene" :
                root.selection.kind == "Model" ? "prefab" :
                "console";
            icon_color: palette.text_dim;
        }
    }

    Text {
        x: 132px;
        y: 12px;
        width: parent.width - 142px;
        text: root.selection.name != "" ? root.selection.name : "No Asset Selected";
        color: palette.text;
        font-size: 12px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 132px;
        y: 32px;
        width: parent.width - 142px;
        text: root.selection.locator;
        color: palette.text_muted;
        font-size: 10px;
        overflow: elide;
    }

    Text {
        x: 132px;
        y: 50px;
        width: parent.width - 142px;
        text: root.selection.kind + (root.selection.state != "" ? " • " + root.selection.state : "");
        color: palette.text_dim;
        font-size: 10px;
        overflow: elide;
    }

    if root.selection.uuid != "": Text {
        x: 132px;
        y: 66px;
        width: parent.width - 142px;
        text: "UUID " + root.selection.uuid + (root.selection.revision != "" ? " • rev " + root.selection.revision : "");
        color: palette.text_dim;
        font-size: 9px;
        overflow: elide;
    }

    if root.selection.adapter_key != "": Text {
        x: 132px;
        y: 82px;
        width: parent.width - 142px;
        text: "Adapter " + root.selection.adapter_key;
        color: palette.text_dim;
        font-size: 9px;
        overflow: elide;
    }

    if root.selection.meta_path != "": Text {
        x: 132px;
        y: 98px;
        width: parent.width - 142px;
        text: root.selection.meta_path;
        color: palette.text_dim;
        font-size: 9px;
        overflow: elide;
    }

    if root.selection.diagnostics != "": Text {
        x: 132px;
        y: parent.height - 38px;
        width: parent.width - 142px;
        text: root.selection.diagnostics;
        color: #d7a3a8;
        font-size: 9px;
        wrap: word-wrap;
    }
}

component SelectionDetailsRail inherits AssetSurfaceFrame {
    in property <AssetSelectionData> selection;
    in property <float> scroll_px: 0.0;
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    private property <length> header_height: 48px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: root.header_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 10px;
            text: "Details";
            color: palette.text;
            font-size: 11px;
            font-weight: 700;
        }

        Text {
            x: 12px;
            y: 25px;
            width: parent.width - 24px;
            text: root.selection.name != "" ? root.selection.name : "No Asset Selected";
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }
    }

    Rectangle {
        x: 0px;
        y: root.header_height;
        width: parent.width;
        height: 1px;
        background: palette.border_soft;
    }

    Rectangle {
        x: 0px;
        y: root.header_height + 1px;
        width: parent.width;
        height: parent.height - root.header_height - 1px;
        clip: true;

        detail_rows := VerticalLayout {
            x: 12px;
            y: 12px - root.scroll_px * 1px;
            width: parent.width - 24px;
            spacing: 10px;

            Rectangle {
                height: 180px;
                border-radius: 8px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: #16191f;

                if root.selection.has_preview: Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.selection.preview;
                    image-fit: contain;
                }

                if !root.selection.has_preview: ShellIcon {
                    width: 34px;
                    height: 34px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    icon_key: root.selection.kind == "Texture" ? "assets" :
                        root.selection.kind == "Material" ? "inspector" :
                        root.selection.kind == "Scene" ? "scene" :
                        root.selection.kind == "Model" ? "prefab" :
                        "console";
                    icon_color: palette.text_dim;
                }
            }

            Rectangle {
                height: 54px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Locator";
                    color: palette.text_dim;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 23px;
                    width: parent.width - 20px;
                    text: root.selection.locator != "" ? root.selection.locator : "No project locator";
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }
            }

            Rectangle {
                height: 50px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Type";
                    color: palette.text_dim;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 22px;
                    width: parent.width - 20px;
                    text: root.selection.kind + (root.selection.state != "" ? " • " + root.selection.state : "");
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }
            }

            Rectangle {
                height: 58px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Identity";
                    color: palette.text_dim;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 22px;
                    width: parent.width - 20px;
                    text: root.selection.uuid != "" ? "UUID " + root.selection.uuid : "No UUID";
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: 10px;
                    y: 37px;
                    width: parent.width - 20px;
                    text: root.selection.revision != "" ? "Revision " + root.selection.revision : "Revision pending";
                    color: palette.text_dim;
                    font-size: 9px;
                    overflow: elide;
                }
            }

            Rectangle {
                height: 64px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Metadata";
                    color: palette.text_dim;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 22px;
                    width: parent.width - 20px;
                    text: root.selection.meta_path != "" ? root.selection.meta_path : "No meta path";
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: 10px;
                    y: 38px;
                    width: parent.width - 20px;
                    text: root.selection.adapter_key != "" ? "Adapter " + root.selection.adapter_key : "No adapter";
                    color: palette.text_dim;
                    font-size: 9px;
                    overflow: elide;
                }
            }

            Rectangle {
                visible: root.selection.diagnostics != "";
                height: 82px;
                border-radius: 6px;
                border-width: 1px;
                border-color: #7a4a4f;
                background: #341f22;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Diagnostics";
                    color: #f2d7da;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 24px;
                    width: parent.width - 20px;
                    text: root.selection.diagnostics;
                    color: #ffd4d8;
                    font-size: 9px;
                    wrap: word-wrap;
                }
            }
        }
    }

    TouchArea {
        x: 0px;
        y: root.header_height + 1px;
        width: parent.width;
        height: parent.height - root.header_height - 1px;
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px + root.header_height / 1px + 1.0,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }
    }
}

export component ProjectOverviewPane inherits Rectangle {
    in property <ProjectOverviewData> project;
    callback surface_control_clicked(control_id: string, action_id: string);
    callback asset_control_clicked(control_id: string);

    palette := Palette {}
    background: transparent;
    clip: true;

    Rectangle {
        x: 16px;
        y: 14px;
        width: parent.width - 32px;
        height: parent.height - 28px;
        border-radius: 8px;
        border-width: 1px;
        border-color: palette.border_soft;
        background: palette.panel_bg_soft;

        Text {
            x: 16px;
            y: 16px;
            text: root.project.project_name != "" ? root.project.project_name : "Directory Project";
            color: palette.text;
            font-size: 16px;
            font-weight: 700;
        }

        Text {
            x: 16px;
            y: 38px;
            width: parent.width - 32px;
            text: root.project.project_root;
            color: palette.text_dim;
            font-size: 10px;
            overflow: elide;
        }

        Rectangle {
            x: 16px;
            y: 68px;
            width: parent.width - 32px;
            height: 108px;
            border-radius: 6px;
            border-width: 1px;
            border-color: palette.border_soft;
            background: palette.chrome_bg_soft;

            Text { x: 12px; y: 10px; text: "Default Scene"; color: palette.text_dim; font-size: 10px; }
            Text { x: 12px; y: 26px; width: parent.width - 24px; text: root.project.default_scene_uri; color: palette.text; font-size: 11px; overflow: elide; }
            Text { x: 12px; y: 50px; text: "Assets Root"; color: palette.text_dim; font-size: 10px; }
            Text { x: 12px; y: 66px; width: parent.width - 24px; text: root.project.assets_root; color: palette.text; font-size: 11px; overflow: elide; }
            Text { x: 12px; y: 82px; width: parent.width - 24px; text: "Library " + root.project.library_root + " • rev " + root.project.catalog_revision; color: palette.text_dim; font-size: 10px; overflow: elide; }
        }

        Rectangle {
            x: 16px;
            y: 192px;
            width: parent.width - 32px;
            height: 68px;
            border-radius: 6px;
            border-width: 1px;
            border-color: palette.border_soft;
            background: palette.chrome_bg_soft;

            Text { x: 12px; y: 12px; text: "Catalog"; color: palette.text_dim; font-size: 10px; }
            Text { x: 12px; y: 30px; text: root.project.folder_count + " folders • " + root.project.asset_count + " assets"; color: palette.text; font-size: 12px; font-weight: 600; }

            ShellButton {
                x: parent.width - 218px;
                y: 18px;
                width: 94px;
                label: "Open Assets";
                active: true;
                clicked => { root.surface_control_clicked("TriggerAction", "OpenView.editor.assets"); }
            }

            ShellButton {
                x: parent.width - 112px;
                y: 18px;
                width: 100px;
                label: "Asset Browser";
                active: false;
                clicked => { root.asset_control_clicked("OpenAssetBrowser"); }
            }
        }
    }
}

export component AssetsActivityPane inherits Rectangle {
    in property <[AssetFolderData]> folder_tree;
    in property <[AssetFolderData]> content_folders;
    in property <[AssetItemData]> content_items;
    in property <AssetSelectionData> selection;
    in property <[AssetReferenceData]> references;
    in property <[AssetReferenceData]> used_by;
    in property <string> search_query;
    in property <string> kind_filter;
    in property <string> view_mode;
    in property <string> utility_tab;
    in property <int> tree_hovered_index: -1;
    in property <float> tree_scroll_px: 0.0;
    in property <int> content_hovered_index: -1;
    in property <float> content_scroll_px: 0.0;
    in property <int> references_hovered_index: -1;
    in property <float> references_scroll_px: 0.0;
    in property <int> used_by_hovered_index: -1;
    in property <float> used_by_scroll_px: 0.0;
    callback control_changed(control_id: string, value: string);
    callback control_clicked(control_id: string);
    callback tree_pointer_clicked(x: float, y: float, width: float, height: float);
    callback tree_pointer_moved(x: float, y: float, width: float, height: float);
    callback tree_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback content_pointer_clicked(x: float, y: float, width: float, height: float);
    callback content_pointer_moved(x: float, y: float, width: float, height: float);
    callback content_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback reference_pointer_clicked(list_kind: string, x: float, y: float, width: float, height: float);
    callback reference_pointer_moved(list_kind: string, x: float, y: float, width: float, height: float);
    callback reference_pointer_scrolled(list_kind: string, x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: transparent;
    private property <length> outer_margin: 10px;
    private property <length> section_gap: 10px;
    private property <length> toolbar_height: 92px;
    private property <length> utility_height: min(max(22% * root.height, 132px), 176px);
    private property <length> tree_width: min(max(28% * root.width, 206px), 272px);
    private property <length> main_top: root.outer_margin + root.toolbar_height + root.section_gap;
    private property <length> main_height: max(root.height - root.main_top - root.utility_height - root.section_gap - root.outer_margin, 160px);

    AssetSurfaceFrame {
        x: root.outer_margin;
        y: root.outer_margin;
        width: parent.width - root.outer_margin * 2;
        height: root.toolbar_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 10px;
            text: "Assets";
            color: palette.text;
            font-size: 12px;
            font-weight: 700;
        }

        Text {
            x: 12px;
            y: 27px;
            width: parent.width - 120px;
            text: "Browse project assets";
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        ShellButton {
            x: parent.width - 94px;
            y: 12px;
            width: 82px;
            label: "Browser";
            active: false;
            clicked => { root.control_clicked("OpenAssetBrowser"); }
        }

        SearchField {
            x: 12px;
            y: 46px;
            width: parent.width - 132px;
            height: 28px;
            text: root.search_query;
            placeholder: "Search assets";
            edited(value) => { root.control_changed("SearchEdited", value); }
        }

        ToolbarButton {
            x: parent.width - 108px;
            y: 48px;
            label: "List";
            active: root.view_mode == "list";
            min-width: 44px;
            clicked => { root.control_changed("SetViewMode", "list"); }
        }

        ToolbarButton {
            x: parent.width - 56px;
            y: 48px;
            label: "Thumb";
            active: root.view_mode == "thumbnail";
            min-width: 52px;
            clicked => { root.control_changed("SetViewMode", "thumbnail"); }
        }

        KindChip { x: 12px; y: 78px; width: 34px; label: "All"; active: root.kind_filter == "" || root.kind_filter == "All"; clicked => { root.control_changed("SetKindFilter", ""); } }
        KindChip { x: 50px; y: 78px; width: 52px; label: "Texture"; active: root.kind_filter == "Texture"; clicked => { root.control_changed("SetKindFilter", "Texture"); } }
        KindChip { x: 106px; y: 78px; width: 56px; label: "Material"; active: root.kind_filter == "Material"; clicked => { root.control_changed("SetKindFilter", "Material"); } }
        KindChip { x: 166px; y: 78px; width: 46px; label: "Scene"; active: root.kind_filter == "Scene"; clicked => { root.control_changed("SetKindFilter", "Scene"); } }
        KindChip { x: 216px; y: 78px; width: 50px; label: "Model"; active: root.kind_filter == "Model"; clicked => { root.control_changed("SetKindFilter", "Model"); } }
        KindChip { x: 270px; y: 78px; width: 54px; label: "Shader"; active: root.kind_filter == "Shader"; clicked => { root.control_changed("SetKindFilter", "Shader"); } }
    }

    Rectangle {
        x: root.outer_margin;
        y: root.main_top;
        width: parent.width - root.outer_margin * 2;
        height: root.main_height;
        background: transparent;

        FolderTreeView {
            x: 0px;
            y: 0px;
            width: root.tree_width;
            height: parent.height;
            title: "Folders";
            subtitle: "Project/assets";
            folders: root.folder_tree;
            hovered_index: root.tree_hovered_index;
            scroll_px: root.tree_scroll_px;
            pointer_clicked(x, y, width, height) => { root.tree_pointer_clicked(x, y, width, height); }
            pointer_moved(x, y, width, height) => { root.tree_pointer_moved(x, y, width, height); }
            pointer_scrolled(x, y, delta, width, height) => { root.tree_pointer_scrolled(x, y, delta, width, height); }
        }

        AssetListView {
            x: root.tree_width + root.section_gap;
            y: 0px;
            width: parent.width - root.tree_width - root.section_gap;
            height: parent.height;
            title: "Content";
            subtitle: "Folder first • name sort";
            folders: root.content_folders;
            items: root.content_items;
            view_mode: root.view_mode;
            hovered_index: root.content_hovered_index;
            scroll_px: root.content_scroll_px;
            pointer_clicked(x, y, width, height) => { root.content_pointer_clicked(x, y, width, height); }
            pointer_moved(x, y, width, height) => { root.content_pointer_moved(x, y, width, height); }
            pointer_scrolled(x, y, delta, width, height) => { root.content_pointer_scrolled(x, y, delta, width, height); }
        }
    }

    AssetSurfaceFrame {
        x: root.outer_margin;
        y: parent.height - root.outer_margin - root.utility_height;
        width: parent.width - root.outer_margin * 2;
        height: root.utility_height;

        ToolbarButton { x: 12px; y: 10px; label: "Preview"; active: root.utility_tab == "preview"; min-width: 56px; clicked => { root.control_changed("SetUtilityTab", "preview"); } }
        ToolbarButton { x: 76px; y: 10px; label: "References"; active: root.utility_tab == "references"; min-width: 74px; clicked => { root.control_changed("SetUtilityTab", "references"); } }

        Text {
            x: parent.width - 180px;
            y: 15px;
            width: 168px;
            horizontal-alignment: right;
            text: root.selection.name != "" ? root.selection.name : "No asset selected";
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        Rectangle {
            x: 0px;
            y: 40px;
            width: parent.width;
            height: 1px;
            background: palette.border_soft;
        }

        if root.utility_tab == "preview": SelectionPreviewCard {
            x: 12px;
            y: 50px;
            width: parent.width - 24px;
            height: parent.height - 62px;
            selection: root.selection;
        }

        if root.utility_tab == "references": Rectangle {
            x: 12px;
            y: 50px;
            width: parent.width - 24px;
            height: parent.height - 62px;
            background: transparent;

            ReferenceListView {
                x: 0px;
                y: 0px;
                width: (parent.width - 12px) / 2;
                height: parent.height;
                title: "References";
                references: root.references;
                hovered_index: root.references_hovered_index;
                scroll_px: root.references_scroll_px;
                pointer_clicked(x, y, width, height) => { root.reference_pointer_clicked("references", x, y, width, height); }
                pointer_moved(x, y, width, height) => { root.reference_pointer_moved("references", x, y, width, height); }
                pointer_scrolled(x, y, delta, width, height) => { root.reference_pointer_scrolled("references", x, y, delta, width, height); }
            }

            ReferenceListView {
                x: (parent.width + 12px) / 2;
                y: 0px;
                width: (parent.width - 12px) / 2;
                height: parent.height;
                title: "Used By";
                references: root.used_by;
                hovered_index: root.used_by_hovered_index;
                scroll_px: root.used_by_scroll_px;
                pointer_clicked(x, y, width, height) => { root.reference_pointer_clicked("used_by", x, y, width, height); }
                pointer_moved(x, y, width, height) => { root.reference_pointer_moved("used_by", x, y, width, height); }
                pointer_scrolled(x, y, delta, width, height) => { root.reference_pointer_scrolled("used_by", x, y, delta, width, height); }
            }
        }
    }
}

export component AssetBrowserPane inherits Rectangle {
    in property <ProjectOverviewData> project;
    in property <[AssetFolderData]> folder_tree;
    in property <[AssetFolderData]> content_folders;
    in property <[AssetItemData]> content_items;
    in property <AssetSelectionData> selection;
    in property <[AssetReferenceData]> references;
    in property <[AssetReferenceData]> used_by;
    in property <string> search_query;
    in property <string> kind_filter;
    in property <string> view_mode;
    in property <string> utility_tab;
    in property <int> tree_hovered_index: -1;
    in property <float> tree_scroll_px: 0.0;
    in property <int> content_hovered_index: -1;
    in property <float> content_scroll_px: 0.0;
    in property <int> references_hovered_index: -1;
    in property <float> references_scroll_px: 0.0;
    in property <int> used_by_hovered_index: -1;
    in property <float> used_by_scroll_px: 0.0;
    in property <float> details_scroll_px: 0.0;
    in-out property <string> mesh_import_path;
    callback control_changed(control_id: string, value: string);
    callback control_clicked(control_id: string);
    callback tree_pointer_clicked(x: float, y: float, width: float, height: float);
    callback tree_pointer_moved(x: float, y: float, width: float, height: float);
    callback tree_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback content_pointer_clicked(x: float, y: float, width: float, height: float);
    callback content_pointer_moved(x: float, y: float, width: float, height: float);
    callback content_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback reference_pointer_clicked(list_kind: string, x: float, y: float, width: float, height: float);
    callback reference_pointer_moved(list_kind: string, x: float, y: float, width: float, height: float);
    callback reference_pointer_scrolled(list_kind: string, x: float, y: float, delta: float, width: float, height: float);
    callback details_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback mesh_import_path_edited(value: string);

    palette := Palette {}
    background: transparent;
    private property <length> outer_margin: 10px;
    private property <length> section_gap: 12px;
    private property <length> toolbar_height: 82px;
    private property <length> import_height: 44px;
    private property <length> utility_height: min(max(24% * root.height, 176px), 240px);
    private property <length> sources_width: min(max(20% * root.width, 220px), 280px);
    private property <length> details_width: min(max(30% * root.width, 300px), 360px);
    private property <length> main_top: root.outer_margin + root.toolbar_height + root.section_gap + root.import_height + root.section_gap;
    private property <length> main_height: max(root.height - root.main_top - root.utility_height - root.section_gap - root.outer_margin, 220px);
    private property <length> content_width: root.width - root.outer_margin * 2 - root.sources_width - root.details_width - root.section_gap * 2;

    AssetSurfaceFrame {
        x: root.outer_margin;
        y: root.outer_margin;
        width: parent.width - root.outer_margin * 2;
        height: root.toolbar_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 10px;
            width: 320px;
            text: root.project.project_name != "" ? root.project.project_name + " / Asset Browser" : "Asset Browser";
            color: palette.text;
            font-size: 12px;
            font-weight: 700;
            overflow: elide;
        }

        Text {
            x: 12px;
            y: 28px;
            width: 420px;
            text: root.project.assets_root != "" ? root.project.assets_root : "Project/assets";
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        ShellButton {
            x: parent.width - 136px;
            y: 14px;
            width: 124px;
            label: "Locate In Assets";
            active: false;
            clicked => { root.control_clicked("LocateSelectedAsset"); }
        }

        SearchField {
            x: 12px;
            y: 46px;
            width: 236px;
            height: 28px;
            text: root.search_query;
            placeholder: "Search assets";
            edited(value) => { root.control_changed("SearchEdited", value); }
        }

        KindChip { x: 260px; y: 48px; width: 34px; label: "All"; active: root.kind_filter == "" || root.kind_filter == "All"; clicked => { root.control_changed("SetKindFilter", ""); } }
        KindChip { x: 298px; y: 48px; width: 52px; label: "Texture"; active: root.kind_filter == "Texture"; clicked => { root.control_changed("SetKindFilter", "Texture"); } }
        KindChip { x: 354px; y: 48px; width: 56px; label: "Material"; active: root.kind_filter == "Material"; clicked => { root.control_changed("SetKindFilter", "Material"); } }
        KindChip { x: 414px; y: 48px; width: 46px; label: "Scene"; active: root.kind_filter == "Scene"; clicked => { root.control_changed("SetKindFilter", "Scene"); } }
        KindChip { x: 464px; y: 48px; width: 50px; label: "Model"; active: root.kind_filter == "Model"; clicked => { root.control_changed("SetKindFilter", "Model"); } }
        KindChip { x: 518px; y: 48px; width: 54px; label: "Shader"; active: root.kind_filter == "Shader"; clicked => { root.control_changed("SetKindFilter", "Shader"); } }

        ToolbarButton {
            x: parent.width - 114px;
            y: 48px;
            label: "List";
            active: root.view_mode == "list";
            min-width: 44px;
            clicked => { root.control_changed("SetViewMode", "list"); }
        }

        ToolbarButton {
            x: parent.width - 60px;
            y: 48px;
            label: "Thumb";
            active: root.view_mode == "thumbnail";
            min-width: 52px;
            clicked => { root.control_changed("SetViewMode", "thumbnail"); }
        }
    }

    AssetSurfaceFrame {
        x: root.outer_margin;
        y: root.outer_margin + root.toolbar_height + root.section_gap;
        width: parent.width - root.outer_margin * 2;
        height: root.import_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 13px;
            text: "Quick Import";
            color: palette.text_dim;
            font-size: 9px;
        }

        SearchField {
            x: 88px;
            y: 8px;
            width: parent.width - 180px;
            height: 28px;
            text: root.mesh_import_path;
            placeholder: "Import model (.obj/.gltf/.glb)";
            edited(value) => { root.mesh_import_path_edited(value); }
        }

        ShellButton {
            x: parent.width - 80px;
            y: 9px;
            width: 68px;
            label: "Import";
            active: true;
            enabled: root.mesh_import_path != "";
            clicked => { root.control_clicked("ImportModel"); }
        }
    }

    Rectangle {
        x: root.outer_margin;
        y: root.main_top;
        width: parent.width - root.outer_margin * 2;
        height: root.main_height;
        background: transparent;

        FolderTreeView {
            x: 0px;
            y: 0px;
            width: root.sources_width;
            height: parent.height;
            title: "Sources";
            subtitle: "Project/assets";
            folders: root.folder_tree;
            hovered_index: root.tree_hovered_index;
            scroll_px: root.tree_scroll_px;
            pointer_clicked(x, y, width, height) => { root.tree_pointer_clicked(x, y, width, height); }
            pointer_moved(x, y, width, height) => { root.tree_pointer_moved(x, y, width, height); }
            pointer_scrolled(x, y, delta, width, height) => { root.tree_pointer_scrolled(x, y, delta, width, height); }
        }

        AssetListView {
            x: root.sources_width + root.section_gap;
            y: 0px;
            width: root.content_width;
            height: parent.height;
            title: "Content Browser";
            subtitle: "Folder first • name sort";
            folders: root.content_folders;
            items: root.content_items;
            view_mode: root.view_mode;
            hovered_index: root.content_hovered_index;
            scroll_px: root.content_scroll_px;
            pointer_clicked(x, y, width, height) => { root.content_pointer_clicked(x, y, width, height); }
            pointer_moved(x, y, width, height) => { root.content_pointer_moved(x, y, width, height); }
            pointer_scrolled(x, y, delta, width, height) => { root.content_pointer_scrolled(x, y, delta, width, height); }
        }

        SelectionDetailsRail {
            x: parent.width - root.details_width;
            y: 0px;
            width: root.details_width;
            height: parent.height;
            selection: root.selection;
            scroll_px: root.details_scroll_px;
            pointer_scrolled(x, y, delta, width, height) => { root.details_pointer_scrolled(x, y, delta, width, height); }
        }
    }

    AssetSurfaceFrame {
        x: root.outer_margin;
        y: parent.height - root.outer_margin - root.utility_height;
        width: parent.width - root.outer_margin * 2;
        height: root.utility_height;

        ToolbarButton { x: 12px; y: 10px; label: "Preview"; active: root.utility_tab == "preview"; min-width: 56px; clicked => { root.control_changed("SetUtilityTab", "preview"); } }
        ToolbarButton { x: 76px; y: 10px; label: "References"; active: root.utility_tab == "references"; min-width: 74px; clicked => { root.control_changed("SetUtilityTab", "references"); } }
        ToolbarButton { x: 156px; y: 10px; label: "Metadata"; active: root.utility_tab == "metadata"; min-width: 74px; clicked => { root.control_changed("SetUtilityTab", "metadata"); } }
        ToolbarButton { x: 236px; y: 10px; label: "Plugins"; active: root.utility_tab == "plugins"; min-width: 64px; clicked => { root.control_changed("SetUtilityTab", "plugins"); } }

        Text {
            x: parent.width - 240px;
            y: 15px;
            width: 228px;
            horizontal-alignment: right;
            text: root.selection.locator != "" ? root.selection.locator : "Select an asset to inspect";
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        Rectangle {
            x: 0px;
            y: 40px;
            width: parent.width;
            height: 1px;
            background: palette.border_soft;
        }

        if root.utility_tab == "preview": SelectionPreviewCard {
            x: 12px;
            y: 50px;
            width: parent.width - 24px;
            height: parent.height - 62px;
            selection: root.selection;
        }

        if root.utility_tab == "references": Rectangle {
            x: 12px;
            y: 50px;
            width: parent.width - 24px;
            height: parent.height - 62px;
            background: transparent;

            ReferenceListView {
                x: 0px;
                y: 0px;
                width: (parent.width - 12px) / 2;
                height: parent.height;
                title: "References";
                references: root.references;
                hovered_index: root.references_hovered_index;
                scroll_px: root.references_scroll_px;
                pointer_clicked(x, y, width, height) => { root.reference_pointer_clicked("references", x, y, width, height); }
                pointer_moved(x, y, width, height) => { root.reference_pointer_moved("references", x, y, width, height); }
                pointer_scrolled(x, y, delta, width, height) => { root.reference_pointer_scrolled("references", x, y, delta, width, height); }
            }

            ReferenceListView {
                x: (parent.width + 12px) / 2;
                y: 0px;
                width: (parent.width - 12px) / 2;
                height: parent.height;
                title: "Used By";
                references: root.used_by;
                hovered_index: root.used_by_hovered_index;
                scroll_px: root.used_by_scroll_px;
                pointer_clicked(x, y, width, height) => { root.reference_pointer_clicked("used_by", x, y, width, height); }
                pointer_moved(x, y, width, height) => { root.reference_pointer_moved("used_by", x, y, width, height); }
                pointer_scrolled(x, y, delta, width, height) => { root.reference_pointer_scrolled("used_by", x, y, delta, width, height); }
            }
        }

        if root.utility_tab == "metadata": Rectangle {
            x: 12px;
            y: 50px;
            width: parent.width - 24px;
            height: parent.height - 62px;
            background: transparent;

            Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: 48px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text { x: 10px; y: 8px; text: "Meta Path"; color: palette.text_dim; font-size: 9px; }
                Text { x: 10px; y: 22px; width: parent.width - 20px; text: root.selection.meta_path; color: palette.text; font-size: 10px; overflow: elide; }
            }

            Rectangle {
                x: 0px;
                y: 56px;
                width: parent.width;
                height: 48px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text { x: 10px; y: 8px; text: "Adapter"; color: palette.text_dim; font-size: 9px; }
                Text { x: 10px; y: 22px; width: parent.width - 20px; text: root.selection.adapter_key; color: palette.text; font-size: 10px; overflow: elide; }
            }

            Rectangle {
                x: 0px;
                y: 112px;
                width: parent.width;
                height: parent.height - 112px;
                border-radius: 6px;
                border-width: 1px;
                border-color: root.selection.diagnostics != "" ? #7a4a4f : palette.border_soft;
                background: root.selection.diagnostics != "" ? #341f22 : palette.chrome_bg_soft;

                Text { x: 10px; y: 8px; text: "Diagnostics"; color: root.selection.diagnostics != "" ? #f2d7da : palette.text_dim; font-size: 9px; }
                Text {
                    x: 10px;
                    y: 24px;
                    width: parent.width - 20px;
                    text: root.selection.diagnostics != "" ? root.selection.diagnostics : "No active diagnostics";
                    color: root.selection.diagnostics != "" ? #ffd4d8 : palette.text;
                    font-size: 10px;
                    wrap: word-wrap;
                }
            }
        }

        if root.utility_tab == "plugins": Rectangle {
            x: 12px;
            y: 50px;
            width: parent.width - 24px;
            height: parent.height - 62px;
            border-radius: 6px;
            border-width: 1px;
            border-color: palette.border_soft;
            background: palette.chrome_bg_soft;

            Text {
                width: parent.width;
                height: parent.height;
                text: "Plugin utility tabs can mount here.";
                color: palette.text_dim;
                font-size: 11px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}
