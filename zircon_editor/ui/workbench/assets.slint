import { LineEdit } from "std-widgets.slint";
import { Palette, ShellButton, ShellIcon, ToolbarButton } from "chrome.slint";
import { ProjectOverviewData } from "pane_data.slint";

export struct AssetFolderData {
    id: string,
    name: string,
    count: int,
    depth: int,
    selected: bool,
}

export struct AssetItemData {
    uuid: string,
    locator: string,
    name: string,
    file_name: string,
    kind: string,
    extension: string,
    dirty: bool,
    has_error: bool,
    has_preview: bool,
    state: string,
    revision: string,
    selected: bool,
    preview: image,
}

export struct AssetReferenceData {
    uuid: string,
    locator: string,
    name: string,
    kind: string,
    known_project_asset: bool,
}

export struct AssetSelectionData {
    uuid: string,
    name: string,
    locator: string,
    kind: string,
    meta_path: string,
    adapter_key: string,
    state: string,
    revision: string,
    diagnostics: string,
    has_preview: bool,
    preview: image,
}

export component SearchField inherits Rectangle {
    in property <string> text;
    in property <string> placeholder;
    callback edited(value: string);

    palette := Palette {}
    border-radius: 4px;
    border-width: 1px;
    border-color: palette.border;
    background: palette.panel_bg_soft;

    LineEdit {
        x: 8px;
        y: 2px;
        width: parent.width - 16px;
        height: parent.height - 4px;
        text: root.text;
        placeholder-text: root.placeholder;
        font-size: 11px;
        edited(value) => { root.edited(value); }
    }
}

export component KindChip inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();

    palette := Palette {}
    height: 24px;
    border-radius: 12px;
    border-width: 1px;
    border-color: active ? palette.accent : palette.border_soft;
    background: active ? #2c527944 : palette.chrome_bg_soft;

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: active ? palette.text : palette.text_dim;
        font-size: 10px;
        font-weight: active ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    TouchArea { clicked => { root.clicked(); } }
}

export component AssetSurfaceFrame inherits Rectangle {
    palette := Palette {}
    border-radius: 8px;
    border-width: 1px;
    border-color: palette.border_soft;
    background: palette.panel_bg_soft;
    clip: true;
}

export component FolderTreeView inherits AssetSurfaceFrame {
    in property <[AssetFolderData]> folders;
    in property <string> title: "Sources";
    in property <string> subtitle: "Project assets";
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    private property <length> header_height: 48px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: root.header_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 10px;
            text: root.title;
            color: palette.text;
            font-size: 11px;
            font-weight: 700;
        }

        Text {
            x: 12px;
            y: 25px;
            width: parent.width - 24px;
            text: root.subtitle;
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }
    }

    Rectangle {
        x: 0px;
        y: root.header_height;
        width: parent.width;
        height: 1px;
        background: palette.border_soft;
    }

    Rectangle {
        x: 0px;
        y: root.header_height + 1px;
        width: parent.width;
        height: parent.height - root.header_height - 1px;
        clip: true;

        rows := VerticalLayout {
            x: 8px;
            y: 8px - root.scroll_px * 1px;
            width: parent.width - 16px;
            spacing: 4px;

            for folder[index] in root.folders: Rectangle {
                height: 28px;
                border-radius: 6px;
                background: folder.selected ? #365880 : root.hovered_index == index ? palette.chrome_bg_soft : transparent;

                ShellIcon {
                    x: 8px + folder.depth * 12px;
                    y: 7px;
                    width: 14px;
                    height: 14px;
                    icon_key: "project";
                    icon_color: folder.selected ? #eef4ff : palette.text_muted;
                }

                Text {
                    x: 28px + folder.depth * 12px;
                    y: 6px;
                    width: parent.width - (52px + folder.depth * 12px);
                    text: folder.name;
                    color: folder.selected ? #eef4ff : palette.text;
                    font-size: 11px;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 34px;
                    y: 5px;
                    width: 24px;
                    horizontal-alignment: right;
                    text: folder.count;
                    color: folder.selected ? #dce8ff : palette.text_dim;
                    font-size: 10px;
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}

export component AssetListView inherits AssetSurfaceFrame {
    in property <[AssetFolderData]> folders;
    in property <[AssetItemData]> items;
    in property <string> view_mode;
    in property <string> title: "Content";
    in property <string> subtitle: "Folder contents";
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    private property <length> header_height: 52px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: root.header_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 10px;
            text: root.title;
            color: palette.text;
            font-size: 11px;
            font-weight: 700;
        }

        Text {
            x: 12px;
            y: 26px;
            width: parent.width - 120px;
            text: root.subtitle;
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }

        Text {
            x: parent.width - 72px;
            y: 18px;
            width: 60px;
            horizontal-alignment: right;
            text: root.view_mode == "thumbnail" ? "Tiles" : "List";
            color: palette.text_muted;
            font-size: 9px;
        }
    }

    Rectangle {
        x: 0px;
        y: root.header_height;
        width: parent.width;
        height: 1px;
        background: palette.border_soft;
    }

    Rectangle {
        x: 0px;
        y: root.header_height + 1px;
        width: parent.width;
        height: parent.height - root.header_height - 1px;
        clip: true;

        entries := VerticalLayout {
            x: 8px;
            y: 8px - root.scroll_px * 1px;
            width: parent.width - 16px;
            spacing: 8px;
            for folder[index] in root.folders: Rectangle {
                height: root.view_mode == "thumbnail" ? 60px : 32px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: root.hovered_index == index ? palette.chrome_bg_soft : palette.panel_bg_soft;

                ShellIcon {
                    x: 10px;
                    y: root.view_mode == "thumbnail" ? 21px : 9px;
                    width: 14px;
                    height: 14px;
                    icon_key: "project";
                    icon_color: palette.text_muted;
                }

                Text {
                    x: 30px;
                    y: root.view_mode == "thumbnail" ? 14px : 7px;
                    text: folder.name;
                    color: palette.text;
                    font-size: 11px;
                    font-weight: 600;
                }

                Text {
                    x: 30px;
                    y: root.view_mode == "thumbnail" ? 31px : 7px;
                    visible: root.view_mode == "thumbnail";
                    text: folder.count + " assets";
                    color: palette.text_dim;
                    font-size: 10px;
                }
            }

            for item[index] in root.items: Rectangle {
                height: root.view_mode == "thumbnail" ? 88px : 38px;
                border-radius: 6px;
                border-width: 1px;
                border-color: item.selected ? palette.accent : palette.border_soft;
                background: item.selected ? #2c527933 : root.hovered_index == root.folders.length + index ? palette.chrome_bg_soft : palette.panel_bg_soft;

                if root.view_mode == "thumbnail": Rectangle {
                    x: 8px;
                    y: 8px;
                    width: 68px;
                    height: 72px;
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    background: #16191f;

                    if item.has_preview: Image {
                        width: parent.width;
                        height: parent.height;
                        source: item.preview;
                        image-fit: contain;
                    }

                    if !item.has_preview: ShellIcon {
                        width: 22px;
                        height: 22px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        icon_key: item.kind == "Texture" ? "assets" :
                            item.kind == "Material" ? "inspector" :
                            item.kind == "PhysicsMaterial" ? "physics-material" :
                            item.kind == "AnimationSkeleton" ? "hierarchy" :
                            item.kind == "AnimationClip" ? "tool-play" :
                            item.kind == "AnimationSequence" ? "animation-sequence" :
                            item.kind == "AnimationGraph" ? "animation-graph" :
                            item.kind == "AnimationStateMachine" ? "animation-graph" :
                            item.kind == "Scene" ? "scene" :
                            item.kind == "Model" ? "prefab" :
                            "console";
                        icon_color: palette.text_dim;
                    }
                }

                if root.view_mode == "list": Rectangle {
                    x: 8px;
                    y: 7px;
                    width: 18px;
                    height: 18px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: palette.border_soft;
                    background: #16191f;

                    if item.has_preview: Image {
                        width: parent.width;
                        height: parent.height;
                        source: item.preview;
                        image-fit: contain;
                    }

                    if !item.has_preview: ShellIcon {
                        width: 12px;
                        height: 12px;
                        x: 3px;
                        y: 3px;
                        icon_key: item.kind == "Texture" ? "assets" :
                            item.kind == "Material" ? "inspector" :
                            item.kind == "PhysicsMaterial" ? "physics-material" :
                            item.kind == "AnimationSkeleton" ? "hierarchy" :
                            item.kind == "AnimationClip" ? "tool-play" :
                            item.kind == "AnimationSequence" ? "animation-sequence" :
                            item.kind == "AnimationGraph" ? "animation-graph" :
                            item.kind == "AnimationStateMachine" ? "animation-graph" :
                            item.kind == "Scene" ? "scene" :
                            item.kind == "Model" ? "prefab" :
                            "console";
                        icon_color: palette.text_dim;
                    }
                }

                Text {
                    x: root.view_mode == "thumbnail" ? 86px : 34px;
                    y: root.view_mode == "thumbnail" ? 12px : 9px;
                    width: parent.width - (root.view_mode == "thumbnail" ? 174px : 162px);
                    text: item.name;
                    color: palette.text;
                    font-size: 11px;
                    font-weight: 600;
                    overflow: elide;
                }

                if root.view_mode == "thumbnail": Text {
                    x: 86px;
                    y: 29px;
                    width: parent.width - 154px;
                    text: item.locator;
                    color: palette.text_muted;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 94px;
                    y: root.view_mode == "thumbnail" ? 12px : 9px;
                    width: 86px;
                    horizontal-alignment: right;
                    text: item.state != "" ? item.state + (item.revision != "" ? " r" + item.revision : "") : item.kind;
                    color: palette.text_dim;
                    font-size: 10px;
                    overflow: elide;
                }

                if item.dirty: Rectangle {
                    x: root.view_mode == "thumbnail" ? 86px : 132px;
                    y: root.view_mode == "thumbnail" ? 55px : 11px;
                    width: 36px;
                    height: 16px;
                    border-radius: 8px;
                    background: #8a683022;
                    border-width: 1px;
                    border-color: #caa35d;
                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: "Dirty";
                        color: #f1d28c;
                        font-size: 9px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                if item.has_error: Rectangle {
                    x: root.view_mode == "thumbnail" ? 128px : 172px;
                    y: root.view_mode == "thumbnail" ? 55px : 11px;
                    width: 36px;
                    height: 16px;
                    border-radius: 8px;
                    background: #7f323522;
                    border-width: 1px;
                    border-color: #d46d72;
                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: "Error";
                        color: #f0b2b6;
                        font-size: 9px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px + 1.0,
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}

export component ReferenceListView inherits Rectangle {
    in property <string> title;
    in property <[AssetReferenceData]> references;
    in property <int> hovered_index: -1;
    in property <float> scroll_px: 0.0;
    callback pointer_clicked(x: float, y: float, width: float, height: float);
    callback pointer_moved(x: float, y: float, width: float, height: float);
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    background: transparent;
    private property <length> header_height: 20px;

    Text {
        x: 0px;
        y: 0px;
        text: root.title;
        color: palette.text;
        font-size: 11px;
        font-weight: 600;
    }

    Rectangle {
        x: 0px;
        y: root.header_height;
        width: parent.width;
        height: max(0px, parent.height - root.header_height);
        clip: true;

        rows := VerticalLayout {
            x: 0px;
            y: 0px - root.scroll_px * 1px;
            width: parent.width - 4px;
            spacing: 4px;

            if root.references.length == 0: Text {
                text: "No direct references";
                color: palette.text_dim;
                font-size: 10px;
            }

            for reference[index] in root.references: Rectangle {
                height: 34px;
                border-radius: 6px;
                background: root.hovered_index == index ? palette.chrome_bg_soft : palette.panel_bg_soft;
                border-width: 1px;
                border-color: palette.border_soft;

                Text {
                    x: 8px;
                    y: 4px;
                    width: parent.width - 78px;
                    text: reference.name;
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: 8px;
                    y: 15px;
                    width: parent.width - 78px;
                    text: reference.locator;
                    color: palette.text_dim;
                    font-size: 9px;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 64px;
                    y: 8px;
                    width: 56px;
                    horizontal-alignment: right;
                    text: reference.kind != "" ? reference.kind : "External";
                    color: palette.text_dim;
                    font-size: 9px;
                }
            }
        }

        TouchArea {
            width: parent.width;
            height: parent.height;
            moved => {
                root.pointer_moved(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            clicked => {
                root.pointer_clicked(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
            }
            scroll-event(event) => {
                root.pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px + root.header_height / 1px,
                    event.delta_y / 1px,
                    root.width / 1px,
                    root.height / 1px,
                );
                accept
            }
        }
    }
}

export component SelectionPreviewCard inherits Rectangle {
    in property <AssetSelectionData> selection;

    palette := Palette {}
    border-width: 1px;
    border-color: palette.border_soft;
    border-radius: 6px;
    background: palette.panel_bg_soft;

    Rectangle {
        x: 10px;
        y: 10px;
        width: 108px;
        height: parent.height - 20px;
        border-radius: 6px;
        border-width: 1px;
        border-color: palette.border_soft;
        background: #16191f;

        if root.selection.has_preview: Image {
            width: parent.width;
            height: parent.height;
            source: root.selection.preview;
            image-fit: contain;
        }

        if !root.selection.has_preview: ShellIcon {
            width: 28px;
            height: 28px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            icon_key: root.selection.kind == "Texture" ? "assets" :
                root.selection.kind == "Material" ? "inspector" :
                root.selection.kind == "PhysicsMaterial" ? "physics-material" :
                root.selection.kind == "AnimationSkeleton" ? "hierarchy" :
                root.selection.kind == "AnimationClip" ? "tool-play" :
                root.selection.kind == "AnimationSequence" ? "animation-sequence" :
                root.selection.kind == "AnimationGraph" ? "animation-graph" :
                root.selection.kind == "AnimationStateMachine" ? "animation-graph" :
                root.selection.kind == "Scene" ? "scene" :
                root.selection.kind == "Model" ? "prefab" :
                "console";
            icon_color: palette.text_dim;
        }
    }

    Text {
        x: 132px;
        y: 12px;
        width: parent.width - 142px;
        text: root.selection.name != "" ? root.selection.name : "No Asset Selected";
        color: palette.text;
        font-size: 12px;
        font-weight: 700;
        overflow: elide;
    }

    Text {
        x: 132px;
        y: 32px;
        width: parent.width - 142px;
        text: root.selection.locator;
        color: palette.text_muted;
        font-size: 10px;
        overflow: elide;
    }

    Text {
        x: 132px;
        y: 50px;
        width: parent.width - 142px;
        text: root.selection.kind + (root.selection.state != "" ? " • " + root.selection.state : "");
        color: palette.text_dim;
        font-size: 10px;
        overflow: elide;
    }

    if root.selection.uuid != "": Text {
        x: 132px;
        y: 66px;
        width: parent.width - 142px;
        text: "UUID " + root.selection.uuid + (root.selection.revision != "" ? " • rev " + root.selection.revision : "");
        color: palette.text_dim;
        font-size: 9px;
        overflow: elide;
    }

    if root.selection.adapter_key != "": Text {
        x: 132px;
        y: 82px;
        width: parent.width - 142px;
        text: "Adapter " + root.selection.adapter_key;
        color: palette.text_dim;
        font-size: 9px;
        overflow: elide;
    }

    if root.selection.meta_path != "": Text {
        x: 132px;
        y: 98px;
        width: parent.width - 142px;
        text: root.selection.meta_path;
        color: palette.text_dim;
        font-size: 9px;
        overflow: elide;
    }

    if root.selection.diagnostics != "": Text {
        x: 132px;
        y: parent.height - 38px;
        width: parent.width - 142px;
        text: root.selection.diagnostics;
        color: #d7a3a8;
        font-size: 9px;
        wrap: word-wrap;
    }
}

export component SelectionDetailsRail inherits AssetSurfaceFrame {
    in property <AssetSelectionData> selection;
    in property <float> scroll_px: 0.0;
    callback pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);

    palette := Palette {}
    private property <length> header_height: 48px;

    Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: root.header_height;
        background: palette.chrome_bg_soft;

        Text {
            x: 12px;
            y: 10px;
            text: "Details";
            color: palette.text;
            font-size: 11px;
            font-weight: 700;
        }

        Text {
            x: 12px;
            y: 25px;
            width: parent.width - 24px;
            text: root.selection.name != "" ? root.selection.name : "No Asset Selected";
            color: palette.text_dim;
            font-size: 9px;
            overflow: elide;
        }
    }

    Rectangle {
        x: 0px;
        y: root.header_height;
        width: parent.width;
        height: 1px;
        background: palette.border_soft;
    }

    Rectangle {
        x: 0px;
        y: root.header_height + 1px;
        width: parent.width;
        height: parent.height - root.header_height - 1px;
        clip: true;

        detail_rows := VerticalLayout {
            x: 12px;
            y: 12px - root.scroll_px * 1px;
            width: parent.width - 24px;
            spacing: 10px;

            Rectangle {
                height: 180px;
                border-radius: 8px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: #16191f;

                if root.selection.has_preview: Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.selection.preview;
                    image-fit: contain;
                }

                if !root.selection.has_preview: ShellIcon {
                    width: 34px;
                    height: 34px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    icon_key: root.selection.kind == "Texture" ? "assets" :
                        root.selection.kind == "Material" ? "inspector" :
                        root.selection.kind == "PhysicsMaterial" ? "physics-material" :
                        root.selection.kind == "AnimationSkeleton" ? "hierarchy" :
                        root.selection.kind == "AnimationClip" ? "tool-play" :
                        root.selection.kind == "AnimationSequence" ? "animation-sequence" :
                        root.selection.kind == "AnimationGraph" ? "animation-graph" :
                        root.selection.kind == "AnimationStateMachine" ? "animation-graph" :
                        root.selection.kind == "Scene" ? "scene" :
                        root.selection.kind == "Model" ? "prefab" :
                        "console";
                    icon_color: palette.text_dim;
                }
            }

            Rectangle {
                height: 54px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Locator";
                    color: palette.text_dim;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 23px;
                    width: parent.width - 20px;
                    text: root.selection.locator != "" ? root.selection.locator : "No project locator";
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }
            }

            Rectangle {
                height: 50px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Type";
                    color: palette.text_dim;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 22px;
                    width: parent.width - 20px;
                    text: root.selection.kind + (root.selection.state != "" ? " • " + root.selection.state : "");
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }
            }

            Rectangle {
                height: 58px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Identity";
                    color: palette.text_dim;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 22px;
                    width: parent.width - 20px;
                    text: root.selection.uuid != "" ? "UUID " + root.selection.uuid : "No UUID";
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: 10px;
                    y: 37px;
                    width: parent.width - 20px;
                    text: root.selection.revision != "" ? "Revision " + root.selection.revision : "Revision pending";
                    color: palette.text_dim;
                    font-size: 9px;
                    overflow: elide;
                }
            }

            Rectangle {
                height: 64px;
                border-radius: 6px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: palette.chrome_bg_soft;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Metadata";
                    color: palette.text_dim;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 22px;
                    width: parent.width - 20px;
                    text: root.selection.meta_path != "" ? root.selection.meta_path : "No meta path";
                    color: palette.text;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: 10px;
                    y: 38px;
                    width: parent.width - 20px;
                    text: root.selection.adapter_key != "" ? "Adapter " + root.selection.adapter_key : "No adapter";
                    color: palette.text_dim;
                    font-size: 9px;
                    overflow: elide;
                }
            }

            Rectangle {
                visible: root.selection.diagnostics != "";
                height: 82px;
                border-radius: 6px;
                border-width: 1px;
                border-color: #7a4a4f;
                background: #341f22;

                Text {
                    x: 10px;
                    y: 8px;
                    text: "Diagnostics";
                    color: #f2d7da;
                    font-size: 9px;
                }

                Text {
                    x: 10px;
                    y: 24px;
                    width: parent.width - 20px;
                    text: root.selection.diagnostics;
                    color: #ffd4d8;
                    font-size: 9px;
                    wrap: word-wrap;
                }
            }
        }
    }

    TouchArea {
        x: 0px;
        y: root.header_height + 1px;
        width: parent.width;
        height: parent.height - root.header_height - 1px;
        scroll-event(event) => {
            root.pointer_scrolled(
                self.mouse-x / 1px,
                self.mouse-y / 1px + root.header_height / 1px + 1.0,
                event.delta_y / 1px,
                root.width / 1px,
                root.height / 1px,
            );
            accept
        }
    }
}
