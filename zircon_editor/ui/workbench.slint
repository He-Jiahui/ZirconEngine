                                    viewport_middle_released() => { root.viewport_middle_released(); }
                                    viewport_scrolled(delta) => { root.viewport_scrolled(delta); }
                                }
                            }

            }

            if root.right_stack_width > 0px: right_stack_zone := Rectangle {
                x: root.right_region_frame.x * 1px;
                y: root.right_region_frame.y * 1px;
                width: root.right_region_frame.width * 1px;
                height: root.right_region_frame.height * 1px;
                background: transparent;
                clip: true;
                        HorizontalLayout {
                            spacing: 0px;

