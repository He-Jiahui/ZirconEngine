                        welcome_open_recent_project(path) => { root.welcome_open_recent_project(path); }
                        welcome_remove_recent_project(path) => { root.welcome_remove_recent_project(path); }
                        viewport_pointer_moved(x, y) => { root.viewport_pointer_moved(x, y); }
                        viewport_left_pressed(x, y) => { root.viewport_left_pressed(x, y); }
                        viewport_left_released() => { root.viewport_left_released(); }
                        viewport_right_pressed(x, y) => { root.viewport_right_pressed(x, y); }
                        viewport_right_released() => { root.viewport_right_released(); }
                        viewport_middle_pressed(x, y) => { root.viewport_middle_pressed(x, y); }
                        viewport_middle_released() => { root.viewport_middle_released(); }
                        viewport_scrolled(delta) => { root.viewport_scrolled(delta); }
                    }
                }
            }

            Rectangle {
                x: 0px;
                y: root.status_bar_frame.y * 1px - 1px;
                width: parent.width;
                height: 1px;
                background: palette.border;
            }

            status_bar_zone := Rectangle {
                x: root.status_bar_frame.x * 1px;
                y: root.status_bar_frame.y * 1px;
                width: root.status_bar_frame.width * 1px;
                height: root.status_bar_frame.height * 1px;
                background: palette.chrome_bg;
                Text {
                    x: 12px;
                    y: 4px;
                    width: parent.width * 0.55;
                    text: root.status_primary;
                    color: palette.text_muted;
                    font-size: 10px;
                    overflow: elide;
                }

                if root.status_secondary != "": Text {
                    x: parent.width - 224px;
                    y: 4px;
                    width: 96px;
                    horizontal-alignment: right;
                    text: root.status_secondary;
                    color: palette.text_dim;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 118px;
                    y: 4px;
                    width: 104px;
                    horizontal-alignment: right;
                    text: root.viewport_label;
                    color: palette.text_dim;
                    font-size: 10px;
                    overflow: elide;
                }
            }
            }

        if root.left_splitter_frame.width > 0.0: left_splitter := Rectangle {
            x: root.left_splitter_frame.x * 1px;
            y: root.left_splitter_frame.y * 1px;
            width: root.left_splitter_frame.width * 1px;
            height: root.left_splitter_frame.height * 1px;
            background: transparent;

            Rectangle {
                x: (parent.width - 1px) / 2;
                width: 1px;
                height: parent.height;
                background: root.resize_active && root.resize_group == "left" ? palette.accent : palette.border_soft;
                opacity: left_splitter_touch.has-hover || (root.resize_active && root.resize_group == "left") ? 1.0 : 0.0;
            }

            left_splitter_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: ew-resize;
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.resize_active = true;
                        root.resize_group = "left";
                        root.begin_drawer_resize(
                            "left",
                            (left_splitter.x + self.mouse-x) / 1px,
                            (left_splitter.y + self.mouse-y) / 1px,
                        );
                    }
                }
            }
        }

        if root.right_splitter_frame.width > 0.0: right_splitter := Rectangle {
            x: root.right_splitter_frame.x * 1px;
            y: root.right_splitter_frame.y * 1px;
            width: root.right_splitter_frame.width * 1px;
            height: root.right_splitter_frame.height * 1px;
            background: transparent;

            Rectangle {
                x: (parent.width - 1px) / 2;
                width: 1px;
                height: parent.height;
                background: root.resize_active && root.resize_group == "right" ? palette.accent : palette.border_soft;
                opacity: right_splitter_touch.has-hover || (root.resize_active && root.resize_group == "right") ? 1.0 : 0.0;
            }

            right_splitter_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: ew-resize;
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.resize_active = true;
                        root.resize_group = "right";
                        root.begin_drawer_resize(
                            "right",
                            (right_splitter.x + self.mouse-x) / 1px,
                            (right_splitter.y + self.mouse-y) / 1px,
                        );
                    }
                }
            }
        }

        if root.bottom_splitter_frame.height > 0.0: bottom_splitter := Rectangle {
            x: root.bottom_splitter_frame.x * 1px;
            y: root.bottom_splitter_frame.y * 1px;
            width: root.bottom_splitter_frame.width * 1px;
            height: root.bottom_splitter_frame.height * 1px;
            background: transparent;

            Rectangle {
                y: (parent.height - 1px) / 2;
                width: parent.width;
                height: 1px;
                background: root.resize_active && root.resize_group == "bottom" ? palette.accent : palette.border_soft;
                opacity: bottom_splitter_touch.has-hover || (root.resize_active && root.resize_group == "bottom") ? 1.0 : 0.0;
            }

            bottom_splitter_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: ns-resize;
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.resize_active = true;
                        root.resize_group = "bottom";
                        root.begin_drawer_resize(
                            "bottom",
                            (bottom_splitter.x + self.mouse-x) / 1px,
                            (bottom_splitter.y + self.mouse-y) / 1px,
                        );
                    }
                }
            }
        }

        if root.resize_active: TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: root.resize_group == "bottom" ? ns-resize : ew-resize;
            moved => {
                root.update_drawer_resize(self.mouse-x / 1px, self.mouse-y / 1px);
            }
            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                    root.finish_drawer_resize(self.mouse-x / 1px, self.mouse-y / 1px);
                    root.resize_active = false;
                    root.resize_group = "";
                }
            }
        }

        if root.drag_active: Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: transparent;

            drag_capture := TouchArea {
                width: parent.width;
                height: parent.height;
                moved => {
                    root.drag_pointer_x = self.mouse-x / 1px;
                    root.drag_pointer_y = self.mouse-y / 1px;
                }
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                        root.drag_pointer_x = self.mouse-x / 1px;
                        root.drag_pointer_y = self.mouse-y / 1px;
                        if (root.drag_tab_id != "" && root.drag_target_group != "") {
                            root.drop_tab(
                                root.drag_tab_id,
                                root.drag_target_group,
                                root.drag_pointer_x,
                                root.drag_pointer_y,
                            );
                        }
                        root.drag_active = false;
                        root.drag_tab_id = "";
                        root.drag_tab_title = "";
                        root.drag_source_group = "";
                        root.drag_pointer_x = 0.0;
                        root.drag_pointer_y = 0.0;
                    }
                }
            }

            if root.left_drop_enabled: Rectangle {
                x: 8px;
                y: root.main_content_y + 8px;
                width: root.left_drop_width - 16px;
                height: root.main_content_height - 16px;
                border-radius: 6px;
                border-width: 1px;
                border-color: root.drag_target_group == "left" ? palette.accent : palette.border_soft;
                background: root.drag_target_group == "left" ? #2c527933 : #17191d22;
                Text {
                    x: 12px;
                    y: 12px;
                    text: "Left";
                    color: root.drag_target_group == "left" ? palette.text : palette.text_dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }

            Rectangle {
                x: root.document_zone_x + 8px;
                y: root.main_content_y + 8px;
                width: max(root.document_zone_width - 16px, 80px);
                height: root.main_content_height - 16px;
                border-radius: 8px;
                border-width: 1px;
                border-color: root.drag_target_group == "document" ? palette.accent : palette.border_soft;
                background: root.drag_target_group == "document" ? #2c527933 : #17191d11;
                Text {
                    x: 12px;
                    y: 12px;
                    text: "Document";
                    color: root.drag_target_group == "document" ? palette.text : palette.text_dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }

            if root.right_drop_enabled: Rectangle {
                x: parent.width - root.right_drop_width + 8px;
                y: root.main_content_y + 8px;
                width: root.right_drop_width - 16px;
                height: root.main_content_height - 16px;
                border-radius: 6px;
                border-width: 1px;
                border-color: root.drag_target_group == "right" ? palette.accent : palette.border_soft;
                background: root.drag_target_group == "right" ? #2c527933 : #17191d22;
                Text {
                    x: parent.width - self.preferred-width - 12px;
                    y: 12px;
                    text: "Right";
                    color: root.drag_target_group == "right" ? palette.text : palette.text_dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }

            if root.bottom_drop_enabled: Rectangle {
                x: 8px;
                y: root.bottom_drop_top_px * 1px + 8px;
                width: parent.width - 16px;
                height: root.bottom_drop_height - 16px;
                border-radius: 6px;
                border-width: 1px;
                border-color: root.drag_target_group == "bottom" ? palette.accent : palette.border_soft;
                background: root.drag_target_group == "bottom" ? #2c527933 : #17191d22;
                Text {
                    x: 12px;
                    y: 12px;
                    text: "Bottom";
                    color: root.drag_target_group == "bottom" ? palette.text : palette.text_dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }

            Rectangle {
                x: (parent.width - 220px) / 2;
                y: root.main_content_y + 12px;
                width: 220px;
                height: 26px;
                border-radius: 4px;
                border-width: 1px;
                border-color: root.drag_target_group != "" ? palette.accent : palette.border_soft;
                background: #1d2027ee;
                Text {
                    width: parent.width;
                    height: parent.height;
                    text: root.drag_tab_title != "" ? root.drag_tab_title + " -> " + root.drag_target_label : root.drag_target_label;
                    color: palette.text;
                    font-size: 10px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
        }

        if root.open_menu_index != -1: TouchArea {
            x: 0px;
            y: root.popup_y;
            width: parent.width;
            height: parent.height - root.popup_y;
            clicked => { root.open_menu_index = -1; }
        }

        if root.open_menu_index == 0: Rectangle {
            x: root.outer_margin + 10px;
            y: root.popup_y;
            width: 208px;
            height: 146px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Open Project"; shortcut: "Ctrl+O"; clicked => { root.menu_action("OpenProject"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Save Project"; shortcut: "Ctrl+S"; enabled: root.save_project_enabled; clicked => { root.menu_action("SaveProject"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Save Layout"; shortcut: ""; clicked => { root.menu_action("SaveLayout"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Reset Layout"; shortcut: ""; clicked => { root.menu_action("ResetLayout"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Recent Projects"; shortcut: ""; enabled: false; }
            }
        }

        if root.open_menu_index == 1: Rectangle {
            x: root.outer_margin + 62px;
            y: root.popup_y;
            width: 186px;
            height: 66px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Undo"; shortcut: "Ctrl+Z"; enabled: root.undo_enabled; clicked => { root.menu_action("Undo"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Redo"; shortcut: "Ctrl+Shift+Z"; enabled: root.redo_enabled; clicked => { root.menu_action("Redo"); root.open_menu_index = -1; } }
            }
        }

        if root.open_menu_index == 2: Rectangle {
            x: root.outer_margin + 117px;
            y: root.popup_y;
            width: 218px;
            height: 118px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Create Cube"; shortcut: ""; clicked => { root.menu_action("CreateNode.Cube"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Create Camera"; shortcut: ""; clicked => { root.menu_action("CreateNode.Camera"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Create Directional Light"; shortcut: ""; clicked => { root.menu_action("CreateNode.DirectionalLight"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Delete Selection"; shortcut: "Delete"; enabled: root.delete_enabled; clicked => { root.menu_action("DeleteSelected"); root.open_menu_index = -1; } }
            }
        }

        if root.open_menu_index == 3: Rectangle {
            x: root.outer_margin + 196px;
            y: root.popup_y;
            width: 198px;
            height: 234px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Project"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.project"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Hierarchy"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.hierarchy"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Inspector"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.inspector"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Scene"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.scene"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Game"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.game"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Assets"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.assets"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Console"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.console"); root.open_menu_index = -1; } }
                MenuItemRow { label: "Prefab Editor"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.prefab"); root.open_menu_index = -1; } }
            }
        }

        if root.open_menu_index == 4: Rectangle {
            x: root.outer_margin + 245px;
            y: root.popup_y;
            width: 224px;
            height: 72px + root.preset_names.length * 30px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Save Preset Asset"; shortcut: root.resolved_preset_name; clicked => { root.menu_action("SavePreset." + root.resolved_preset_name); root.open_menu_index = -1; } }
                MenuItemRow { label: "Reset Layout"; shortcut: ""; clicked => { root.menu_action("ResetLayout"); root.open_menu_index = -1; } }
                for preset in root.preset_names: MenuItemRow {
                    label: preset;
                    shortcut: preset == root.active_preset_name ? "active" : "";
                    clicked => { root.menu_action("LoadPreset." + preset); root.open_menu_index = -1; }
                }
            }
        }

        if root.open_menu_index == 5: Rectangle {
            x: root.outer_margin + 307px;
            y: root.popup_y;
            width: 194px;
            height: 38px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Workbench Guide"; shortcut: ""; clicked => { root.menu_action("OpenView.editor.asset_browser"); root.open_menu_index = -1; } }
            }
        }
    }
