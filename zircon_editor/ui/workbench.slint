        content_scroll_px: root.browser_asset_content_scroll_px;
        references_hovered_index: root.browser_asset_references_hovered_index;
        references_scroll_px: root.browser_asset_references_scroll_px;
        used_by_hovered_index: root.browser_asset_used_by_hovered_index;
        used_by_scroll_px: root.browser_asset_used_by_scroll_px;
        details_scroll_px: root.browser_asset_details_scroll_px;
        mesh_import_path: root.mesh_import_path;
        control_changed(control_id, value) => { root.asset_control_changed("browser", control_id, value); }
        control_clicked(control_id) => { root.asset_control_clicked("browser", control_id); }
        tree_pointer_clicked(x, y, width, height) => { root.asset_tree_pointer_clicked("browser", x, y, width, height); }
        tree_pointer_moved(x, y, width, height) => { root.asset_tree_pointer_moved("browser", x, y, width, height); }
        tree_pointer_scrolled(x, y, delta, width, height) => { root.asset_tree_pointer_scrolled("browser", x, y, delta, width, height); }
        content_pointer_clicked(x, y, width, height) => { root.asset_content_pointer_clicked("browser", x, y, width, height); }
        content_pointer_moved(x, y, width, height) => { root.asset_content_pointer_moved("browser", x, y, width, height); }
        content_pointer_scrolled(x, y, delta, width, height) => { root.asset_content_pointer_scrolled("browser", x, y, delta, width, height); }
        reference_pointer_clicked(list_kind, x, y, width, height) => { root.asset_reference_pointer_clicked("browser", list_kind, x, y, width, height); }
        reference_pointer_moved(list_kind, x, y, width, height) => { root.asset_reference_pointer_moved("browser", list_kind, x, y, width, height); }
        reference_pointer_scrolled(list_kind, x, y, delta, width, height) => { root.asset_reference_pointer_scrolled("browser", list_kind, x, y, delta, width, height); }
        details_pointer_scrolled(x, y, delta, width, height) => { root.browser_asset_details_pointer_scrolled(x, y, delta, width, height); }
        mesh_import_path_edited(value) => { root.mesh_import_path_edited(value); }
    }

    if !root.pane.show_empty && root.pane.kind == "Hierarchy": HierarchyPane {
