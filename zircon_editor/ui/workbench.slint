    callback ui_asset_hierarchy_activated(instance_id: string, item_index: int);
    callback ui_asset_preview_selected(instance_id: string, item_index: int);
    callback ui_asset_preview_activated(instance_id: string, item_index: int);
    callback ui_asset_source_outline_selected(instance_id: string, item_index: int);
    callback ui_asset_preview_mock_selected(instance_id: string, item_index: int);
    callback ui_asset_preview_mock_action(instance_id: string, action_id: string, value: string);
    callback ui_asset_binding_selected(instance_id: string, item_index: int);
    callback ui_asset_binding_event_selected(instance_id: string, item_index: int);
    callback ui_asset_binding_action_kind_selected(instance_id: string, item_index: int);
    callback ui_asset_binding_payload_selected(instance_id: string, item_index: int);
    callback ui_asset_binding_payload_action(instance_id: string, action_id: string, payload_key: string, payload_value: string);
    callback ui_asset_slot_semantic_selected(instance_id: string, item_index: int);
    callback ui_asset_layout_semantic_selected(instance_id: string, item_index: int);
    in-out property <string> mesh_import_path;
    in property <bool> show_header: true;
    in property <bool> compact_empty: true;
    out property <float> viewport_width: root.pane.kind == "Scene" || root.pane.kind == "Game" ? self.width / 1px : 0.0;
    out property <float> viewport_height:
        root.pane.kind == "Scene" || root.pane.kind == "Game" ?
        (self.height - root.chrome_height - root.viewport_toolbar_height) / 1px :
        0.0;

    palette := Palette {}
    background: transparent;
    clip: true;
    property <length> chrome_height: root.show_header ? 34px : 0px;
    property <length> viewport_toolbar_height: root.pane.kind == "Scene" ? 28px : 0px;
    property <string> empty_eyebrow:
        root.pane.kind == "Scene" || root.pane.kind == "Game" ? "Welcome" :
        root.pane.kind == "Project" || root.pane.kind == "Assets" ? "Workspace" :
        root.pane.kind == "Console" ? "Task Output" :
        "";

    if root.show_header: Rectangle {
        width: parent.width;
        height: 34px;
        background: palette.panel_bg_soft;
        border-color: palette.border_soft;
        border-width: 1px;

        ShellIcon {
            width: 14px;
            height: 14px;
            x: 10px;
            y: 10px;
            icon_key: root.pane.icon_key;
            icon_color: palette.text_muted;
        }

        Text {
            x: 30px;
            y: 7px;
            text: root.pane.title;
            color: palette.text;
            font-size: 12px;
            font-weight: 600;
        }

        Text {
            x: parent.width - self.preferred-width - 12px;
            y: 8px;
            text: root.pane.subtitle;
            color: palette.text_dim;
            font-size: 11px;
        }
    }

    if root.pane.kind == "Welcome": WelcomePane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        welcome: root.welcome_pane;
        recent_projects: root.recent_projects;
        hovered_recent_project_index: root.hovered_welcome_recent_index;
        hovered_recent_action: root.hovered_welcome_recent_action;
        recent_projects_scroll_px: root.welcome_recent_scroll_px;
        control_changed(control_id, value) => { root.welcome_control_changed(control_id, value); }
        control_clicked(control_id) => { root.welcome_control_clicked(control_id); }
        recent_projects_pointer_clicked(x, y, width, height) => { root.welcome_recent_pointer_clicked(x, y, width, height); }
        recent_projects_pointer_moved(x, y, width, height) => { root.welcome_recent_pointer_moved(x, y, width, height); }
        recent_projects_pointer_scrolled(x, y, delta, width, height) => { root.welcome_recent_pointer_scrolled(x, y, delta, width, height); }
    }

    if root.pane.kind == "Scene" || root.pane.kind == "Game": Rectangle {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        background: #1c1f24;
        clip: true;

        if root.pane.kind == "Scene": SceneViewportToolbar {
            width: parent.width;
            viewport: root.pane.viewport;
            pointer_clicked(control_id, control_x, control_y, control_width, control_height, point_x, point_y) => { root.viewport_toolbar_pointer_clicked(root.pane.id, control_id, control_x, control_y, control_width, control_height, point_x, point_y); }
        }

        viewport_canvas := Rectangle {
            y: root.viewport_toolbar_height;
            width: parent.width;
            height: parent.height - root.viewport_toolbar_height;
            background: #171a20;
            clip: true;

            if !root.pane.show_empty: Rectangle {
                x: 0px;
                y: parent.height / 2;
                width: parent.width;
                height: 1px;
                background: #ffffff09;
            }

            if !root.pane.show_empty: Rectangle {
                x: parent.width / 2;
                y: 0px;
                width: 1px;
                height: parent.height;
                background: #ffffff09;
            }

            if !root.pane.show_empty: Image {
                width: parent.width;
                height: parent.height;
                source: root.viewport_image;
                image-fit: contain;
            }

            if !root.pane.show_empty: Rectangle {
                x: 10px;
                y: 10px;
                width: 94px;
                height: 18px;
                border-radius: 3px;
                border-width: 1px;
                border-color: palette.border_soft;
                background: #1d2027dd;
                Text {
                    text: root.pane.subtitle;
                    x: 8px;
                    y: 2px;
                    color: palette.text;
                    font-size: 10px;
                }
            }

            if root.pane.show_empty: EmptyStateCard {
                width: parent.width;
                height: parent.height;
                compact: false;
                eyebrow: root.empty_eyebrow;
                title: root.pane.empty_title;
                body: root.pane.empty_body;
                primary_action_label: root.pane.primary_action_label;
                primary_action_id: root.pane.primary_action_id;
                secondary_action_label: root.pane.secondary_action_label;
                secondary_action_id: root.pane.secondary_action_id;
                secondary_hint: root.pane.secondary_hint;
                trigger_action(action_id) => { root.surface_control_clicked("TriggerAction", action_id); }
            }

            viewport_touch := TouchArea {
                enabled: !root.pane.show_empty;
                width: parent.width;
                height: parent.height;
                mouse-cursor: crosshair;
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.viewport_pointer_event(0, 1, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                        root.viewport_pointer_event(2, 1, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                        root.viewport_pointer_event(0, 2, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.right && event.kind == PointerEventKind.up) {
                        root.viewport_pointer_event(2, 2, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.middle && event.kind == PointerEventKind.down) {
                        root.viewport_pointer_event(0, 3, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    } else if (event.button == PointerEventButton.middle && event.kind == PointerEventKind.up) {
                        root.viewport_pointer_event(2, 3, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                    }
                }
                moved => {
                    root.viewport_pointer_event(1, 0, self.mouse-x / 1px, self.mouse-y / 1px, 0.0);
                }
                scroll-event(event) => {
                    root.viewport_pointer_event(3, 0, self.mouse-x / 1px, self.mouse-y / 1px, event.delta_y / 1px);
                    accept
                }
            }
        }
    }

    if !(root.pane.kind == "Scene" || root.pane.kind == "Game") && root.pane.show_empty && root.pane.kind != "Console" && root.compact_empty: ToolWindowEmptyState {
        width: parent.width;
        height: parent.height - root.chrome_height;
        y: root.chrome_height;
        eyebrow: root.empty_eyebrow;
        title: root.pane.empty_title;
        body: root.pane.empty_body;
        primary_action_label: root.pane.primary_action_label;
        primary_action_id: root.pane.primary_action_id;
        secondary_hint: root.pane.secondary_hint;
        trigger_action(action_id) => { root.surface_control_clicked("TriggerAction", action_id); }
    }

    if !(root.pane.kind == "Scene" || root.pane.kind == "Game") && root.pane.show_empty && root.pane.kind != "Console" && !root.compact_empty: EmptyStateCard {
        width: parent.width;
        height: parent.height - root.chrome_height;
        y: root.chrome_height;
        compact: false;
        eyebrow: root.empty_eyebrow;
        title: root.pane.empty_title;
        body: root.pane.empty_body;
        primary_action_label: root.pane.primary_action_label;
        primary_action_id: root.pane.primary_action_id;
        secondary_action_label: root.pane.secondary_action_label;
        secondary_action_id: root.pane.secondary_action_id;
        secondary_hint: root.pane.secondary_hint;
        trigger_action(action_id) => { root.surface_control_clicked("TriggerAction", action_id); }
    }

    if !root.pane.show_empty && root.pane.kind == "Project": ProjectOverviewPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        project: root.project_overview;
        surface_control_clicked(control_id, action_id) => { root.surface_control_clicked(control_id, action_id); }
        asset_control_clicked(control_id) => { root.asset_control_clicked("project", control_id); }
    }

    if !root.pane.show_empty && root.pane.kind == "Assets": AssetsActivityPane {
        y: root.chrome_height;
        width: parent.width;
        height: parent.height - root.chrome_height;
        folder_tree: root.activity_asset_tree_folders;
        content_folders: root.activity_asset_content_folders;
        content_items: root.activity_asset_content_items;
        selection: root.activity_asset_selection;
        references: root.activity_asset_references;
        used_by: root.activity_asset_used_by;
        search_query: root.activity_asset_search_query;
        kind_filter: root.activity_asset_kind_filter;
        view_mode: root.activity_asset_view_mode;
        utility_tab: root.activity_asset_utility_tab;
        tree_hovered_index: root.activity_asset_tree_hovered_index;
        tree_scroll_px: root.activity_asset_tree_scroll_px;
        content_hovered_index: root.activity_asset_content_hovered_index;
        content_scroll_px: root.activity_asset_content_scroll_px;
        references_hovered_index: root.activity_asset_references_hovered_index;
        references_scroll_px: root.activity_asset_references_scroll_px;
        used_by_hovered_index: root.activity_asset_used_by_hovered_index;
        used_by_scroll_px: root.activity_asset_used_by_scroll_px;
        control_changed(control_id, value) => { root.asset_control_changed("activity", control_id, value); }
        control_clicked(control_id) => { root.asset_control_clicked("activity", control_id); }
        tree_pointer_clicked(x, y, width, height) => { root.asset_tree_pointer_clicked("activity", x, y, width, height); }
        tree_pointer_moved(x, y, width, height) => { root.asset_tree_pointer_moved("activity", x, y, width, height); }
        tree_pointer_scrolled(x, y, delta, width, height) => { root.asset_tree_pointer_scrolled("activity", x, y, delta, width, height); }
        content_pointer_clicked(x, y, width, height) => { root.asset_content_pointer_clicked("activity", x, y, width, height); }
        content_pointer_moved(x, y, width, height) => { root.asset_content_pointer_moved("activity", x, y, width, height); }
        content_pointer_scrolled(x, y, delta, width, height) => { root.asset_content_pointer_scrolled("activity", x, y, delta, width, height); }
        reference_pointer_clicked(list_kind, x, y, width, height) => { root.asset_reference_pointer_clicked("activity", list_kind, x, y, width, height); }
        reference_pointer_moved(list_kind, x, y, width, height) => { root.asset_reference_pointer_moved("activity", list_kind, x, y, width, height); }
        reference_pointer_scrolled(list_kind, x, y, delta, width, height) => { root.asset_reference_pointer_scrolled("activity", list_kind, x, y, delta, width, height); }
    }

    if !root.pane.show_empty && root.pane.kind == "AssetBrowser": AssetBrowserPane {
        y: root.chrome_height;
