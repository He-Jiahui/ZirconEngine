                                        spacing: 2px;
                                        for tab[index] in root.document_tabs: document_tab := TabChip {
                                            label: tab.title;
                                            icon_key: tab.icon_key;
                                            active: tab.active;
                                            closeable: tab.closeable;
                                            drag_origin_x: (root.document_tab_origin_x + self.x) / 1px;
                                            drag_origin_y: (root.document_tab_origin_y + self.y) / 1px;
                                            pointer_clicked(x, y) => {
                                                root.document_tab_pointer_clicked(
                                                    "main",
                                                    index,
                                                    8.0 + self.x / 1px,
                                                    self.width / 1px,
                                                    8.0 + self.x / 1px + x,
                                                    1.0 + self.y / 1px + y,
                                                );
                                            }
                                            close_pointer_clicked(x, y) => {
                                                root.document_tab_close_pointer_clicked(
                                                    "main",
                                                    index,
                                                    8.0 + self.x / 1px,
                                                    self.width / 1px,
                                                    8.0 + self.x / 1px + self.width / 1px - 24.0 + x,
                                                    1.0 + self.y / 1px + 7.0 + y,
                                                );
                                            }
                                            drag_started(x, y) => {
                                                root.drag_active = true;
                                                root.drag_tab_id = tab.id;
                                                root.drag_tab_title = tab.title;
                                                root.drag_tab_icon_key = tab.icon_key;
                                                root.drag_source_group = "document";
                                                root.drag_pointer_x = x;
                                                root.drag_pointer_y = y;
                                                root.workbench_drag_pointer_event(1, root.drag_pointer_x, root.drag_pointer_y);
                                            }
                                            drag_moved(x, y) => {
                                                if (root.drag_tab_id == tab.id) {
                                                    root.drag_pointer_x = x;
                                                    root.drag_pointer_y = y;
                                                    root.workbench_drag_pointer_event(1, root.drag_pointer_x, root.drag_pointer_y);
                                                }
                                            }
                                        }
                                    }

