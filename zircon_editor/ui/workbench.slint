                                        viewport_left_pressed(x, y) => { root.viewport_left_pressed(x, y); }
                                        viewport_left_released() => { root.viewport_left_released(); }
                                        viewport_right_pressed(x, y) => { root.viewport_right_pressed(x, y); }
                                        viewport_right_released() => { root.viewport_right_released(); }
                                        viewport_middle_pressed(x, y) => { root.viewport_middle_pressed(x, y); }
                                        viewport_middle_released() => { root.viewport_middle_released(); }
                                        viewport_scrolled(delta) => { root.viewport_scrolled(delta); }
                                    }
                                }
                            }

                            if root.right_panel_width > 0px: Rectangle { width: 1px; background: palette.border_soft; }

                            Rectangle {
                                width: root.right_rail_width;
                                background: palette.rail_bg;

                                VerticalLayout {
                                    x: 3px;
                                    y: 6px;
                                    spacing: 2px;
                                    for tab in root.right_tabs: RailButton {
                                        icon_key: tab.icon_key;
                                        active: tab.active;
                                        clicked => { root.toggle_drawer_tab(tab.slot, tab.id); }
                                    }
                                }
                            }
                        }

            }

            if root.bottom_panel_height > 0px: bottom_panel_zone := Rectangle {
                x: root.bottom_region_frame.x * 1px;
                y: root.bottom_region_frame.y * 1px;
                width: root.bottom_region_frame.width * 1px;
                height: root.bottom_region_frame.height * 1px;
                background: palette.panel_bg;
                clip: true;
                VerticalLayout {
                    spacing: 0px;

                    Rectangle {
                        height: root.panel_header_height;
                        background: palette.chrome_bg;

                        HorizontalLayout {
                            x: 6px;
                            y: 2px;
                            spacing: 4px;

                            for tab in root.bottom_tabs: bottom_header_tab := DockTabButton {
                                    label: tab.title;
                                    icon_key: tab.icon_key;
                                    active: tab.active;
                                    drag_enabled: true;
                                    drag_origin_x: (root.bottom_tab_origin_x + self.x) / 1px;
                                    drag_origin_y: (root.bottom_tab_origin_y + self.y) / 1px;
                                    clicked => { root.toggle_drawer_tab(tab.slot, tab.id); }
                                    drag_started(x, y) => {
                                        root.drag_active = true;
                                        root.drag_tab_id = tab.id;
                                        root.drag_tab_title = tab.title;
                                        root.drag_source_group = "bottom";
                                        root.drag_pointer_x = x;
                                        root.drag_pointer_y = y;
                                    }
                                    drag_moved(x, y) => {
                                        if (root.drag_tab_id == tab.id) {
                                            root.drag_pointer_x = x;
                                            root.drag_pointer_y = y;
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if root.bottom_expanded: Rectangle { height: 1px; background: palette.border_soft; }

                    if root.bottom_expanded: PaneSurface {
                        width: parent.width;
                        height: parent.height - root.panel_header_height - 1px;
                        pane: root.bottom_pane;
                        welcome_pane: root.welcome_pane;
                        recent_projects: root.recent_projects;
                        hierarchy_nodes: root.hierarchy_nodes;
