            status_bar_zone := Rectangle {
                x: root.status_bar_frame.x * 1px;
                y: root.status_bar_frame.y * 1px;
                width: root.status_bar_frame.width * 1px;
                height: root.status_bar_frame.height * 1px;
                background: palette.chrome_bg;
                Text {
                    x: 12px;
                    y: 4px;
                    width: parent.width * 0.55;
                    text: root.status_primary;
                    color: palette.text_muted;
                    font-size: 10px;
                    overflow: elide;
                }

                if root.status_secondary != "": Text {
                    x: parent.width - 224px;
                    y: 4px;
                    width: 96px;
                    horizontal-alignment: right;
                    text: root.status_secondary;
                    color: palette.text_dim;
                    font-size: 10px;
                    overflow: elide;
                }

                Text {
                    x: parent.width - 118px;
                    y: 4px;
                    width: 104px;
                    horizontal-alignment: right;
                    text: root.viewport_label;
                    color: palette.text_dim;
                    font-size: 10px;
                    overflow: elide;
                }
            }
            }

        if root.left_splitter_frame.width > 0.0: left_splitter := Rectangle {
            x: root.left_splitter_frame.x * 1px;
            y: root.left_splitter_frame.y * 1px;
            width: root.left_splitter_frame.width * 1px;
            height: root.left_splitter_frame.height * 1px;
            background: transparent;

            Rectangle {
                x: (parent.width - 1px) / 2;
                width: 1px;
                height: parent.height;
                background: root.resize_active && root.resize_group == "left" ? palette.accent : palette.border_soft;
                opacity: left_splitter_touch.has-hover || (root.resize_active && root.resize_group == "left") ? 1.0 : 0.0;
            }

            left_splitter_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: ew-resize;
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.resize_active = true;
                        root.resize_group = "left";
                        root.workbench_resize_pointer_event(
                            0,
                            (left_splitter.x + self.mouse-x) / 1px,
                            (left_splitter.y + self.mouse-y) / 1px,
                        );
                    }
                }
            }
        }

        if root.right_splitter_frame.width > 0.0: right_splitter := Rectangle {
            x: root.right_splitter_frame.x * 1px;
            y: root.right_splitter_frame.y * 1px;
            width: root.right_splitter_frame.width * 1px;
            height: root.right_splitter_frame.height * 1px;
            background: transparent;

            Rectangle {
                x: (parent.width - 1px) / 2;
                width: 1px;
                height: parent.height;
                background: root.resize_active && root.resize_group == "right" ? palette.accent : palette.border_soft;
                opacity: right_splitter_touch.has-hover || (root.resize_active && root.resize_group == "right") ? 1.0 : 0.0;
            }

            right_splitter_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: ew-resize;
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.resize_active = true;
                        root.resize_group = "right";
                        root.workbench_resize_pointer_event(
                            0,
                            (right_splitter.x + self.mouse-x) / 1px,
                            (right_splitter.y + self.mouse-y) / 1px,
                        );
                    }
                }
            }
        }

        if root.bottom_splitter_frame.height > 0.0: bottom_splitter := Rectangle {
            x: root.bottom_splitter_frame.x * 1px;
            y: root.bottom_splitter_frame.y * 1px;
            width: root.bottom_splitter_frame.width * 1px;
            height: root.bottom_splitter_frame.height * 1px;
            background: transparent;

            Rectangle {
                y: (parent.height - 1px) / 2;
                width: parent.width;
                height: 1px;
                background: root.resize_active && root.resize_group == "bottom" ? palette.accent : palette.border_soft;
                opacity: bottom_splitter_touch.has-hover || (root.resize_active && root.resize_group == "bottom") ? 1.0 : 0.0;
            }

            bottom_splitter_touch := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: ns-resize;
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.down) {
                        root.resize_active = true;
                        root.resize_group = "bottom";
                        root.workbench_resize_pointer_event(
                            0,
                            (bottom_splitter.x + self.mouse-x) / 1px,
                            (bottom_splitter.y + self.mouse-y) / 1px,
                        );
                    }
                }
            }
        }

        for window[index] in root.floating_windows: floating_window_card := Rectangle {
            property <bool> attach_drop_active: root.active_drag_target_group == window.target_group;
            property <bool> left_edge_drop_active: root.active_drag_target_group == window.left_edge_target_group;
            property <bool> right_edge_drop_active: root.active_drag_target_group == window.right_edge_target_group;
            property <bool> top_edge_drop_active: root.active_drag_target_group == window.top_edge_target_group;
            property <bool> bottom_edge_drop_active: root.active_drag_target_group == window.bottom_edge_target_group;
            property <bool> any_drop_active:
                attach_drop_active ||
                left_edge_drop_active ||
                right_edge_drop_active ||
                top_edge_drop_active ||
                bottom_edge_drop_active;
            x: window.frame.x * 1px;
            y: window.frame.y * 1px;
            width: window.frame.width * 1px;
            height: window.frame.height * 1px;
            border-radius: 8px;
            border-width: 1px;
            border-color: any_drop_active ? palette.accent : palette.border_soft;
            background: any_drop_active ? #223448f0 : #20242be8;
            clip: true;

            Rectangle {
                width: parent.width;
                height: parent.height;
                border-radius: 8px;
                background: transparent;

                VerticalLayout {
                    spacing: 0px;

                    Rectangle {
                        height: root.document_header_height;
                        background: palette.chrome_bg;

                        header_touch := TouchArea {
                            x: max(parent.width - 170px, floating_tabs_row.x + floating_tabs_row.width + 8px);
                            width: max(parent.width - self.x, 0px);
                            height: parent.height;
                            clicked => {
                                root.floating_window_header_pointer_clicked(
                                    floating_window_card.x / 1px + self.x / 1px + self.mouse-x / 1px,
                                    floating_window_card.y / 1px + self.mouse-y / 1px,
                                );
                            }
                        }

                        floating_tabs_row := HorizontalLayout {
                            x: 8px;
                            y: 1px;
                            spacing: 2px;
                            for tab[index] in window.tabs: floating_tab := TabChip {
                                label: tab.title;
                                icon_key: tab.icon_key;
                                active: tab.active;
                                closeable: tab.closeable;
                                drag_origin_x: (floating_window_card.x + floating_tabs_row.x + self.x) / 1px;
                                drag_origin_y: (floating_window_card.y + floating_tabs_row.y + self.y) / 1px;
                                pointer_clicked(x, y) => {
                                    root.document_tab_pointer_clicked(
                                        window.window_id,
                                        index,
                                        8.0 + self.x / 1px,
                                        self.width / 1px,
                                        8.0 + self.x / 1px + x,
                                        1.0 + self.y / 1px + y,
                                    );
                                }
                                close_pointer_clicked(x, y) => {
                                    root.document_tab_close_pointer_clicked(
                                        window.window_id,
                                        index,
                                        8.0 + self.x / 1px,
                                        self.width / 1px,
                                        8.0 + self.x / 1px + self.width / 1px - 24.0 + x,
                                        1.0 + self.y / 1px + 7.0 + y,
                                    );
                                }
                                drag_started(x, y) => {
                                    root.drag_active = true;
                                    root.drag_tab_id = tab.id;
                                    root.drag_tab_title = tab.title;
                                    root.drag_tab_icon_key = tab.icon_key;
                                    root.drag_source_group = window.window_id;
                                    root.drag_pointer_x = x;
                                    root.drag_pointer_y = y;
                                    root.workbench_drag_pointer_event(1, root.drag_pointer_x, root.drag_pointer_y);
                                }
                                drag_moved(x, y) => {
                                    if (root.drag_tab_id == tab.id) {
                                        root.drag_pointer_x = x;
                                        root.drag_pointer_y = y;
                                        root.workbench_drag_pointer_event(1, root.drag_pointer_x, root.drag_pointer_y);
                                    }
                                }
                            }
                        }

                        Text {
                            x: parent.width - 170px;
                            y: 9px;
                            width: 158px;
                            horizontal-alignment: right;
                            text: window.title;
                            color: palette.text_dim;
                            font-size: 10px;
                            overflow: elide;
                        }
                    }

                    Rectangle { height: 1px; background: palette.border_soft; }

                    PaneSurface {
                        width: parent.width;
                        height: parent.height - root.document_header_height - 1px;
                        pane: window.active_pane;
                        welcome_pane: root.welcome_pane;
                        recent_projects: root.recent_projects;
                        hovered_welcome_recent_index: root.hovered_welcome_recent_index;
                        hovered_welcome_recent_action: root.hovered_welcome_recent_action;
                        welcome_recent_scroll_px: root.welcome_recent_scroll_px;
                        hierarchy_nodes: root.hierarchy_nodes;
                        hovered_hierarchy_index: root.hovered_hierarchy_index;
                        hierarchy_scroll_px: root.hierarchy_scroll_px;
                        project_overview: root.project_overview;
                        activity_asset_tree_folders: root.activity_asset_tree_folders;
                        activity_asset_content_folders: root.activity_asset_content_folders;
                        activity_asset_content_items: root.activity_asset_content_items;
                        activity_asset_selection: root.activity_asset_selection;
                        activity_asset_references: root.activity_asset_references;
                        activity_asset_used_by: root.activity_asset_used_by;
                        activity_asset_search_query: root.activity_asset_search_query;
                        activity_asset_kind_filter: root.activity_asset_kind_filter;
                        activity_asset_view_mode: root.activity_asset_view_mode;
                        activity_asset_utility_tab: root.activity_asset_utility_tab;
                        activity_asset_tree_hovered_index: root.activity_asset_tree_hovered_index;
                        activity_asset_tree_scroll_px: root.activity_asset_tree_scroll_px;
                        activity_asset_content_hovered_index: root.activity_asset_content_hovered_index;
                        activity_asset_content_scroll_px: root.activity_asset_content_scroll_px;
                        activity_asset_references_hovered_index: root.activity_asset_references_hovered_index;
                        activity_asset_references_scroll_px: root.activity_asset_references_scroll_px;
                        activity_asset_used_by_hovered_index: root.activity_asset_used_by_hovered_index;
                        activity_asset_used_by_scroll_px: root.activity_asset_used_by_scroll_px;
                        browser_asset_tree_folders: root.browser_asset_tree_folders;
                        browser_asset_content_folders: root.browser_asset_content_folders;
                        browser_asset_content_items: root.browser_asset_content_items;
                        browser_asset_selection: root.browser_asset_selection;
                        browser_asset_references: root.browser_asset_references;
                        browser_asset_used_by: root.browser_asset_used_by;
                        browser_asset_search_query: root.browser_asset_search_query;
                        browser_asset_kind_filter: root.browser_asset_kind_filter;
                        browser_asset_view_mode: root.browser_asset_view_mode;
                        browser_asset_utility_tab: root.browser_asset_utility_tab;
                        browser_asset_tree_hovered_index: root.browser_asset_tree_hovered_index;
                        browser_asset_tree_scroll_px: root.browser_asset_tree_scroll_px;
                        browser_asset_content_hovered_index: root.browser_asset_content_hovered_index;
                        browser_asset_content_scroll_px: root.browser_asset_content_scroll_px;
                        browser_asset_references_hovered_index: root.browser_asset_references_hovered_index;
                        browser_asset_references_scroll_px: root.browser_asset_references_scroll_px;
                        browser_asset_used_by_hovered_index: root.browser_asset_used_by_hovered_index;
                        browser_asset_used_by_scroll_px: root.browser_asset_used_by_scroll_px;
                        browser_asset_details_scroll_px: root.browser_asset_details_scroll_px;
                        viewport_image: root.viewport_image;
                        project_path: root.project_path;
                        inspector_name: root.inspector_name;
                        inspector_parent: root.inspector_parent;
                        inspector_x: root.inspector_x;
                        inspector_y: root.inspector_y;
                        inspector_z: root.inspector_z;
                        inspector_scroll_px: root.inspector_scroll_px;
                        status_text: root.status_primary;
                        console_scroll_px: root.console_scroll_px;
                        delete_enabled: root.delete_enabled;
                        mesh_import_path: root.mesh_import_path;
                        show_header: false;
                        compact_empty: false;
                        surface_control_clicked(control_id, action_id) => { root.pane_surface_control_clicked(control_id, action_id); }
                        inspector_control_changed(control_id, value) => { root.inspector_control_changed(control_id, value); }
                        inspector_control_clicked(control_id) => { root.inspector_control_clicked(control_id); }
                        mesh_import_path_edited(value) => { root.mesh_import_path_edited(value); }
                        asset_control_changed(source, control_id, value) => { root.asset_control_changed(source, control_id, value); }
                        asset_control_clicked(source, control_id) => { root.asset_control_clicked(source, control_id); }
                        asset_tree_pointer_clicked(surface_mode, x, y, width, height) => { root.asset_tree_pointer_clicked(surface_mode, x, y, width, height); }
                        asset_tree_pointer_moved(surface_mode, x, y, width, height) => { root.asset_tree_pointer_moved(surface_mode, x, y, width, height); }
                        asset_tree_pointer_scrolled(surface_mode, x, y, delta, width, height) => { root.asset_tree_pointer_scrolled(surface_mode, x, y, delta, width, height); }
                        asset_content_pointer_clicked(surface_mode, x, y, width, height) => { root.asset_content_pointer_clicked(surface_mode, x, y, width, height); }
                        asset_content_pointer_moved(surface_mode, x, y, width, height) => { root.asset_content_pointer_moved(surface_mode, x, y, width, height); }
                        asset_content_pointer_scrolled(surface_mode, x, y, delta, width, height) => { root.asset_content_pointer_scrolled(surface_mode, x, y, delta, width, height); }
                        asset_reference_pointer_clicked(surface_mode, list_kind, x, y, width, height) => { root.asset_reference_pointer_clicked(surface_mode, list_kind, x, y, width, height); }
                        asset_reference_pointer_moved(surface_mode, list_kind, x, y, width, height) => { root.asset_reference_pointer_moved(surface_mode, list_kind, x, y, width, height); }
                        asset_reference_pointer_scrolled(surface_mode, list_kind, x, y, delta, width, height) => { root.asset_reference_pointer_scrolled(surface_mode, list_kind, x, y, delta, width, height); }
                        welcome_control_changed(control_id, value) => { root.welcome_control_changed(control_id, value); }
                        welcome_control_clicked(control_id) => { root.welcome_control_clicked(control_id); }
                        welcome_recent_pointer_clicked(x, y, width, height) => { root.welcome_recent_pointer_clicked(x, y, width, height); }
                        welcome_recent_pointer_moved(x, y, width, height) => { root.welcome_recent_pointer_moved(x, y, width, height); }
                        welcome_recent_pointer_scrolled(x, y, delta, width, height) => { root.welcome_recent_pointer_scrolled(x, y, delta, width, height); }
                        hierarchy_pointer_clicked(x, y, width, height) => { root.hierarchy_pointer_clicked(x, y, width, height); }
                        hierarchy_pointer_moved(x, y, width, height) => { root.hierarchy_pointer_moved(x, y, width, height); }
                        hierarchy_pointer_scrolled(x, y, delta, width, height) => { root.hierarchy_pointer_scrolled(x, y, delta, width, height); }
                        viewport_pointer_event(kind, button, x, y, delta) => { root.viewport_pointer_event(kind, button, x, y, delta); }
                        viewport_toolbar_pointer_clicked(surface_key, control_id, control_x, control_y, control_width, control_height, point_x, point_y) => { root.viewport_toolbar_pointer_clicked(surface_key, control_id, control_x, control_y, control_width, control_height, point_x, point_y); }
                        ui_asset_action(instance_id, action_id) => { root.ui_asset_action(instance_id, action_id); }
                        ui_asset_style_class_action(instance_id, action_id, class_name) => { root.ui_asset_style_class_action(instance_id, action_id, class_name); }
                        ui_asset_inspector_widget_action(instance_id, action_id, value) => { root.ui_asset_inspector_widget_action(instance_id, action_id, value); }
                        ui_asset_style_rule_action(instance_id, action_id, item_index, selector) => { root.ui_asset_style_rule_action(instance_id, action_id, item_index, selector); }
                        ui_asset_matched_style_rule_selected(instance_id, item_index) => { root.ui_asset_matched_style_rule_selected(instance_id, item_index); }
                        ui_asset_style_rule_declaration_action(instance_id, action_id, item_index, declaration_path, declaration_value) => { root.ui_asset_style_rule_declaration_action(instance_id, action_id, item_index, declaration_path, declaration_value); }
                        ui_asset_style_token_action(instance_id, action_id, item_index, token_name, token_value) => { root.ui_asset_style_token_action(instance_id, action_id, item_index, token_name, token_value); }
                        ui_asset_source_edited(instance_id, value) => { root.ui_asset_source_edited(instance_id, value); }
                        ui_asset_source_cursor_changed(instance_id, byte_offset) => { root.ui_asset_source_cursor_changed(instance_id, byte_offset); }
                        ui_asset_palette_selected(instance_id, item_index) => { root.ui_asset_palette_selected(instance_id, item_index); }
                        ui_asset_palette_drag_hover(instance_id, surface_x, surface_y) => { root.ui_asset_palette_drag_hover(instance_id, surface_x, surface_y); }
                        ui_asset_palette_drag_drop(instance_id) => { root.ui_asset_palette_drag_drop(instance_id); }
                        ui_asset_palette_drag_cancel(instance_id) => { root.ui_asset_palette_drag_cancel(instance_id); }
                        ui_asset_hierarchy_selected(instance_id, item_index) => { root.ui_asset_hierarchy_selected(instance_id, item_index); }
                                            ui_asset_hierarchy_activated(instance_id, item_index) => { root.ui_asset_hierarchy_activated(instance_id, item_index); }
                        ui_asset_preview_selected(instance_id, item_index) => { root.ui_asset_preview_selected(instance_id, item_index); }
                        ui_asset_binding_selected(instance_id, item_index) => { root.ui_asset_binding_selected(instance_id, item_index); }
                        ui_asset_binding_event_selected(instance_id, item_index) => { root.ui_asset_binding_event_selected(instance_id, item_index); }
                        ui_asset_binding_action_kind_selected(instance_id, item_index) => { root.ui_asset_binding_action_kind_selected(instance_id, item_index); }
                        ui_asset_binding_payload_selected(instance_id, item_index) => { root.ui_asset_binding_payload_selected(instance_id, item_index); }
                        ui_asset_binding_payload_action(instance_id, action_id, payload_key, payload_value) => { root.ui_asset_binding_payload_action(instance_id, action_id, payload_key, payload_value); }
                        ui_asset_slot_semantic_selected(instance_id, item_index) => { root.ui_asset_slot_semantic_selected(instance_id, item_index); }
                        ui_asset_layout_semantic_selected(instance_id, item_index) => { root.ui_asset_layout_semantic_selected(instance_id, item_index); }
                    }
                }

                if left_edge_drop_active: Rectangle {
                    x: 12px;
                    y: 34px;
                    width: min(max(72px, parent.width * 0.24), parent.width * 0.45);
                    height: max(parent.height - 68px, 56px);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.accent;
                    background: #2c527955;
                }

                if right_edge_drop_active: Rectangle {
                    x: parent.width - self.width - 12px;
                    y: 34px;
                    width: min(max(72px, parent.width * 0.24), parent.width * 0.45);
                    height: max(parent.height - 68px, 56px);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.accent;
                    background: #2c527955;
                }

                if top_edge_drop_active: Rectangle {
                    x: 12px;
                    y: 34px;
                    width: max(parent.width - 24px, 56px);
                    height: min(max(54px, parent.height * 0.2), parent.height * 0.4);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.accent;
                    background: #2c527955;
                }

                if bottom_edge_drop_active: Rectangle {
                    x: 12px;
                    y: parent.height - self.height - 12px;
                    width: max(parent.width - 24px, 56px);
                    height: min(max(54px, parent.height * 0.2), parent.height * 0.4);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.accent;
                    background: #2c527955;
                }
            }
        }

        if root.resize_active: TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            mouse-cursor: root.resize_group == "bottom" ? ns-resize : ew-resize;
            moved => {
                root.workbench_resize_pointer_event(1, self.mouse-x / 1px, self.mouse-y / 1px);
            }
            pointer-event(event) => {
                if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                    root.workbench_resize_pointer_event(2, self.mouse-x / 1px, self.mouse-y / 1px);
                    root.resize_active = false;
                    root.resize_group = "";
                }
            }
        }

        if root.drag_active: Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            background: transparent;
            property <bool> document_drop_active:
                root.active_drag_target_group == "document" ||
                root.active_drag_target_group == "document-left" ||
                root.active_drag_target_group == "document-right" ||
                root.active_drag_target_group == "document-top" ||
                root.active_drag_target_group == "document-bottom";
            property <bool> document_left_drop_active: root.active_drag_target_group == "document-left";
            property <bool> document_right_drop_active: root.active_drag_target_group == "document-right";
            property <bool> document_top_drop_active: root.active_drag_target_group == "document-top";
            property <bool> document_bottom_drop_active: root.active_drag_target_group == "document-bottom";

            drag_capture := TouchArea {
                width: parent.width;
                height: parent.height;
                mouse-cursor: MouseCursor.grabbing;
                moved => {
                    root.drag_pointer_x = self.mouse-x / 1px;
                    root.drag_pointer_y = self.mouse-y / 1px;
                    root.workbench_drag_pointer_event(1, root.drag_pointer_x, root.drag_pointer_y);
                }
                pointer-event(event) => {
                    if (event.button == PointerEventButton.left && event.kind == PointerEventKind.up) {
                        root.drag_pointer_x = self.mouse-x / 1px;
                        root.drag_pointer_y = self.mouse-y / 1px;
                        root.workbench_drag_pointer_event(2, root.drag_pointer_x, root.drag_pointer_y);
                        root.drag_active = false;
                        root.drag_tab_id = "";
                        root.drag_tab_title = "";
                        root.drag_tab_icon_key = "";
                        root.drag_source_group = "";
                        root.drag_pointer_x = 0.0;
                        root.drag_pointer_y = 0.0;
                        root.active_drag_target_group = "";
                    }
                }
            }

            if root.left_drop_enabled: Rectangle {
                x: 8px;
                y: root.main_content_y + 8px;
                width: root.left_drop_width - 16px;
                height: root.main_content_height - 16px;
                border-radius: 6px;
                border-width: 1px;
                border-color: root.active_drag_target_group == "left" ? palette.accent : palette.border_soft;
                background: root.active_drag_target_group == "left" ? #2c527933 : #17191d22;
                opacity: root.active_drag_target_group == "left" ? 1.0 : 0.78;
                animate opacity { duration: 60ms; }
                Text {
                    x: 12px;
                    y: 12px;
                    text: "Dock Left";
                    color: root.active_drag_target_group == "left" ? palette.text : palette.text_dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }

            Rectangle {
                x: root.document_zone_x + 8px;
                y: root.main_content_y + 8px;
                width: max(root.document_zone_width - 16px, 80px);
                height: root.main_content_height - 16px;
                border-radius: 8px;
                border-width: 1px;
                border-color: document_drop_active ? palette.accent : palette.border_soft;
                background: document_drop_active ? #2c527933 : #17191d11;
                opacity: document_drop_active ? 1.0 : 0.7;
                animate opacity { duration: 60ms; }
                Text {
                    x: 12px;
                    y: 12px;
                    text: "Dock Document";
                    color: document_drop_active ? palette.text : palette.text_dim;
                    font-size: 10px;
                    font-weight: 600;
                }

                if document_left_drop_active: Rectangle {
                    x: 12px;
                    y: 34px;
                    width: min(max(72px, parent.width * 0.22), parent.width * 0.45);
                    height: max(parent.height - 68px, 56px);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.accent;
                    background: #2c527955;

                    Text {
                        x: 10px;
                        y: 10px;
                        text: "Split Left";
                        color: palette.text;
                        font-size: 10px;
                        font-weight: 600;
                    }
                }

                if document_right_drop_active: Rectangle {
                    x: parent.width - self.width - 12px;
                    y: 34px;
                    width: min(max(72px, parent.width * 0.22), parent.width * 0.45);
                    height: max(parent.height - 68px, 56px);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.accent;
                    background: #2c527955;

                    Text {
                        x: parent.width - self.preferred-width - 10px;
                        y: 10px;
                        text: "Split Right";
                        color: palette.text;
                        font-size: 10px;
                        font-weight: 600;
                    }
                }

                if document_top_drop_active: Rectangle {
                    x: 12px;
                    y: 34px;
                    width: max(parent.width - 24px, 56px);
                    height: min(max(54px, parent.height * 0.18), parent.height * 0.38);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.accent;
                    background: #2c527955;

                    Text {
                        x: 10px;
                        y: 10px;
                        text: "Split Top";
                        color: palette.text;
                        font-size: 10px;
                        font-weight: 600;
                    }
                }

                if document_bottom_drop_active: Rectangle {
                    x: 12px;
                    y: parent.height - self.height - 12px;
                    width: max(parent.width - 24px, 56px);
                    height: min(max(54px, parent.height * 0.18), parent.height * 0.38);
                    border-radius: 6px;
                    border-width: 1px;
                    border-color: palette.accent;
                    background: #2c527955;

                    Text {
                        x: 10px;
                        y: 10px;
                        text: "Split Bottom";
                        color: palette.text;
                        font-size: 10px;
                        font-weight: 600;
                    }
                }
            }

            if root.right_drop_enabled: Rectangle {
                x: parent.width - root.right_drop_width + 8px;
                y: root.main_content_y + 8px;
                width: root.right_drop_width - 16px;
                height: root.main_content_height - 16px;
                border-radius: 6px;
                border-width: 1px;
                border-color: root.active_drag_target_group == "right" ? palette.accent : palette.border_soft;
                background: root.active_drag_target_group == "right" ? #2c527933 : #17191d22;
                opacity: root.active_drag_target_group == "right" ? 1.0 : 0.78;
                animate opacity { duration: 60ms; }
                Text {
                    x: parent.width - self.preferred-width - 12px;
                    y: 12px;
                    text: "Dock Right";
                    color: root.active_drag_target_group == "right" ? palette.text : palette.text_dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }

            if root.bottom_drop_enabled: Rectangle {
                x: 8px;
                y: root.bottom_drop_top_px * 1px + 8px;
                width: parent.width - 16px;
                height: root.bottom_drop_height - 16px;
                border-radius: 6px;
                border-width: 1px;
                border-color: root.active_drag_target_group == "bottom" ? palette.accent : palette.border_soft;
                background: root.active_drag_target_group == "bottom" ? #2c527933 : #17191d22;
                opacity: root.active_drag_target_group == "bottom" ? 1.0 : 0.78;
                animate opacity { duration: 60ms; }
                Text {
                    x: 12px;
                    y: 12px;
                    text: "Dock Bottom";
                    color: root.active_drag_target_group == "bottom" ? palette.text : palette.text_dim;
                    font-size: 10px;
                    font-weight: 600;
                }
            }

            drag_preview := Rectangle {
                width: min(max(188px, drag_preview_title.preferred-width + 126px), 360px);
                height: 44px;
                x: clamp(root.drag_pointer_x * 1px + 18px, 12px, parent.width - self.width - 12px);
                y: clamp(
                    root.drag_pointer_y * 1px - self.height - 14px,
                    root.main_content_y + 12px,
                    root.drag_overlay_bottom_px * 1px - self.height - 12px
                );
                border-radius: 7px;
                border-width: 1px;
                border-color: root.active_drag_target_group != "" ? palette.accent : palette.border_soft;
                background: root.active_drag_target_group != "" ? #16202cf4 : #1b1e24f4;
                opacity: 0.99;

                Rectangle {
                    width: 4px;
                    height: parent.height;
                    border-radius: 7px;
                    background: root.active_drag_target_group != "" ? palette.accent : palette.border;
                }

                ShellIcon {
                    width: 14px;
                    height: 14px;
                    x: 14px;
                    y: 13px;
                    icon_key: root.drag_tab_icon_key != "" ? root.drag_tab_icon_key : "project";
                    icon_color: palette.text;
                }

                drag_preview_title := Text {
                    x: 36px;
                    y: 7px;
                    width: parent.width - 146px;
                    text: root.drag_tab_title != "" ? root.drag_tab_title : root.drag_target_label;
                    color: palette.text;
                    font-size: 11px;
                    font-weight: 600;
                    overflow: elide;
                }

                Text {
                    x: 36px;
                    y: 24px;
                    width: parent.width - 146px;
                    text: root.active_drag_target_group != "" ? "Release to dock" : "Drag to dock or reorder";
                    color: root.active_drag_target_group != "" ? palette.accent : palette.text_dim;
                    font-size: 9px;
                    overflow: elide;
                }

                drag_target_badge := Rectangle {
                    x: parent.width - self.width - 10px;
                    y: 10px;
                    width: min(max(72px, badge_text.preferred-width + 18px), 132px);
                    height: 22px;
                    border-radius: 11px;
                    border-width: 1px;
                    border-color: root.active_drag_target_group != "" ? palette.accent : palette.border_soft;
                    background: root.active_drag_target_group != "" ? #2c527944 : #20242b;

                    badge_text := Text {
                        width: parent.width;
                        height: parent.height;
                        text: root.active_drag_target_group != "" ? root.drag_target_label : "Move Tab";
                        color: root.active_drag_target_group != "" ? palette.text : palette.text_dim;
                        font-size: 9px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }

        if root.open_menu_index == 0: Rectangle {
            x: root.file_menu_button_frame.x * 1px;
            y: (root.file_menu_button_frame.y + root.file_menu_button_frame.height + 3) * 1px;
            width: 208px;
            height: 146px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Open Project"; shortcut: "Ctrl+O"; hovered: root.hovered_menu_item_index == 0; interactive: false; }
                MenuItemRow { label: "Save Project"; shortcut: "Ctrl+S"; enabled: root.save_project_enabled; hovered: root.hovered_menu_item_index == 1; interactive: false; }
                MenuItemRow { label: "Save Layout"; shortcut: ""; hovered: root.hovered_menu_item_index == 2; interactive: false; }
                MenuItemRow { label: "Reset Layout"; shortcut: ""; hovered: root.hovered_menu_item_index == 3; interactive: false; }
                MenuItemRow { label: "Recent Projects"; shortcut: ""; enabled: false; hovered: root.hovered_menu_item_index == 4; interactive: false; }
            }
        }

        if root.open_menu_index == 1: Rectangle {
            x: root.edit_menu_button_frame.x * 1px;
            y: (root.edit_menu_button_frame.y + root.edit_menu_button_frame.height + 3) * 1px;
            width: 186px;
            height: 66px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Undo"; shortcut: "Ctrl+Z"; enabled: root.undo_enabled; hovered: root.hovered_menu_item_index == 0; interactive: false; }
                MenuItemRow { label: "Redo"; shortcut: "Ctrl+Shift+Z"; enabled: root.redo_enabled; hovered: root.hovered_menu_item_index == 1; interactive: false; }
            }
        }

        if root.open_menu_index == 2: Rectangle {
            x: root.selection_menu_button_frame.x * 1px;
            y: (root.selection_menu_button_frame.y + root.selection_menu_button_frame.height + 3) * 1px;
            width: 218px;
            height: 118px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Create Cube"; shortcut: ""; hovered: root.hovered_menu_item_index == 0; interactive: false; }
                MenuItemRow { label: "Create Camera"; shortcut: ""; hovered: root.hovered_menu_item_index == 1; interactive: false; }
                MenuItemRow { label: "Create Directional Light"; shortcut: ""; hovered: root.hovered_menu_item_index == 2; interactive: false; }
                MenuItemRow { label: "Delete Selection"; shortcut: "Delete"; enabled: root.delete_enabled; hovered: root.hovered_menu_item_index == 3; interactive: false; }
            }
        }

        if root.open_menu_index == 3: Rectangle {
            x: root.view_menu_button_frame.x * 1px;
            y: (root.view_menu_button_frame.y + root.view_menu_button_frame.height + 3) * 1px;
            width: 198px;
            height: 234px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Project"; shortcut: ""; hovered: root.hovered_menu_item_index == 0; interactive: false; }
                MenuItemRow { label: "Hierarchy"; shortcut: ""; hovered: root.hovered_menu_item_index == 1; interactive: false; }
                MenuItemRow { label: "Inspector"; shortcut: ""; hovered: root.hovered_menu_item_index == 2; interactive: false; }
                MenuItemRow { label: "Scene"; shortcut: ""; hovered: root.hovered_menu_item_index == 3; interactive: false; }
                MenuItemRow { label: "Game"; shortcut: ""; hovered: root.hovered_menu_item_index == 4; interactive: false; }
                MenuItemRow { label: "Assets"; shortcut: ""; hovered: root.hovered_menu_item_index == 5; interactive: false; }
                MenuItemRow { label: "Console"; shortcut: ""; hovered: root.hovered_menu_item_index == 6; interactive: false; }
                MenuItemRow { label: "Prefab Editor"; shortcut: ""; hovered: root.hovered_menu_item_index == 7; interactive: false; }
            }
        }

        if root.open_menu_index == 4: Rectangle {
            x: root.window_menu_button_frame.x * 1px;
            y: (root.window_menu_button_frame.y + root.window_menu_button_frame.height + 3) * 1px;
            width: 224px;
            height: root.window_menu_popup_height_px * 1px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            clip: true;
            VerticalLayout {
                x: 6px;
                y: 6px - root.window_menu_scroll_px * 1px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Save Preset Asset"; shortcut: root.resolved_preset_name; hovered: root.hovered_menu_item_index == 0; interactive: false; }
                MenuItemRow { label: "Reset Layout"; shortcut: ""; hovered: root.hovered_menu_item_index == 1; interactive: false; }
                for preset[index] in root.preset_names: MenuItemRow {
                    label: preset;
                    shortcut: preset == root.active_preset_name ? "active" : "";
                    hovered: root.hovered_menu_item_index == index + 2;
                    interactive: false;
                }
            }
        }

        if root.open_menu_index == 5: Rectangle {
            x: root.help_menu_button_frame.x * 1px;
            y: (root.help_menu_button_frame.y + root.help_menu_button_frame.height + 3) * 1px;
            width: 194px;
            height: 38px;
            border-radius: 8px;
            background: palette.panel_bg;
            border-width: 1px;
            border-color: palette.border;
            VerticalLayout {
                x: 6px;
                y: 6px;
                width: parent.width - 12px;
                spacing: 2px;
                MenuItemRow { label: "Workbench Guide"; shortcut: ""; hovered: root.hovered_menu_item_index == 0; interactive: false; }
            }
        }

        if root.open_menu_index != -1: TouchArea {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            moved => {
                root.menu_pointer_moved(self.mouse-x / 1px, self.mouse-y / 1px);
            }
            clicked => {
                root.menu_pointer_clicked(self.mouse-x / 1px, self.mouse-y / 1px);
            }
            scroll-event(event) => {
                root.menu_pointer_scrolled(
                    self.mouse-x / 1px,
                    self.mouse-y / 1px,
                    event.delta_y / 1px,
                );
                accept
            }
        }
    if root.native_floating_window_mode: Rectangle {
            width: parent.width;
            height: parent.height;
            background: palette.shell_bg;

            for window[index] in root.floating_windows: Rectangle {
                visible: window.window_id == root.native_floating_window_id;
                x: 0px;
                y: 0px;
                width: parent.width;
                height: parent.height;
                background: #20242be8;
                clip: true;

                VerticalLayout {
                    spacing: 0px;

                    Rectangle {
                        height: root.document_header_height;
                        background: palette.chrome_bg;

                        native_header_touch := TouchArea {
                            x: max(parent.width - 170px, native_floating_tabs_row.x + native_floating_tabs_row.width + 8px);
                            width: max(parent.width - self.x, 0px);
                            height: parent.height;
                            clicked => {
                                root.floating_window_header_pointer_clicked(
                                    root.native_window_bounds.x + self.x / 1px + self.mouse-x / 1px,
                                    root.native_window_bounds.y + self.mouse-y / 1px,
                                );
                            }
                        }

                        native_floating_tabs_row := HorizontalLayout {
                            x: 8px;
                            y: 1px;
                            spacing: 2px;
                            for tab[index] in window.tabs: TabChip {
                                label: tab.title;
                                icon_key: tab.icon_key;
                                active: tab.active;
                                closeable: tab.closeable;
                                drag_enabled: false;
                                pointer_clicked(x, y) => {
                                    root.document_tab_pointer_clicked(
                                        window.window_id,
                                        index,
                                        8.0 + self.x / 1px,
                                        self.width / 1px,
                                        8.0 + self.x / 1px + x,
                                        1.0 + self.y / 1px + y,
                                    );
                                }
                                close_pointer_clicked(x, y) => {
                                    root.document_tab_close_pointer_clicked(
                                        window.window_id,
                                        index,
                                        8.0 + self.x / 1px,
                                        self.width / 1px,
                                        8.0 + self.x / 1px + self.width / 1px - 24.0 + x,
                                        1.0 + self.y / 1px + 7.0 + y,
                                    );
                                }
                            }
                        }

                        Text {
                            x: parent.width - 170px;
                            y: 9px;
                            width: 158px;
                            horizontal-alignment: right;
                            text: window.title;
                            color: palette.text_dim;
                            font-size: 10px;
                            overflow: elide;
                        }
                    }

                    Rectangle { height: 1px; background: palette.border_soft; }

                    PaneSurface {
                        width: parent.width;
                        height: parent.height - root.document_header_height - 1px;
                        pane: window.active_pane;
                        welcome_pane: root.welcome_pane;
                        recent_projects: root.recent_projects;
                        hovered_welcome_recent_index: root.hovered_welcome_recent_index;
                        hovered_welcome_recent_action: root.hovered_welcome_recent_action;
                        welcome_recent_scroll_px: root.welcome_recent_scroll_px;
                        hierarchy_nodes: root.hierarchy_nodes;
                        hovered_hierarchy_index: root.hovered_hierarchy_index;
                        hierarchy_scroll_px: root.hierarchy_scroll_px;
                        project_overview: root.project_overview;
                        activity_asset_tree_folders: root.activity_asset_tree_folders;
                        activity_asset_content_folders: root.activity_asset_content_folders;
                        activity_asset_content_items: root.activity_asset_content_items;
                        activity_asset_selection: root.activity_asset_selection;
                        activity_asset_references: root.activity_asset_references;
                        activity_asset_used_by: root.activity_asset_used_by;
                        activity_asset_search_query: root.activity_asset_search_query;
                        activity_asset_kind_filter: root.activity_asset_kind_filter;
                        activity_asset_view_mode: root.activity_asset_view_mode;
                        activity_asset_utility_tab: root.activity_asset_utility_tab;
                        activity_asset_tree_hovered_index: root.activity_asset_tree_hovered_index;
                        activity_asset_tree_scroll_px: root.activity_asset_tree_scroll_px;
                        activity_asset_content_hovered_index: root.activity_asset_content_hovered_index;
                        activity_asset_content_scroll_px: root.activity_asset_content_scroll_px;
                        activity_asset_references_hovered_index: root.activity_asset_references_hovered_index;
                        activity_asset_references_scroll_px: root.activity_asset_references_scroll_px;
                        activity_asset_used_by_hovered_index: root.activity_asset_used_by_hovered_index;
                        activity_asset_used_by_scroll_px: root.activity_asset_used_by_scroll_px;
                        browser_asset_tree_folders: root.browser_asset_tree_folders;
                        browser_asset_content_folders: root.browser_asset_content_folders;
                        browser_asset_content_items: root.browser_asset_content_items;
                        browser_asset_selection: root.browser_asset_selection;
                        browser_asset_references: root.browser_asset_references;
                        browser_asset_used_by: root.browser_asset_used_by;
                        browser_asset_search_query: root.browser_asset_search_query;
                        browser_asset_kind_filter: root.browser_asset_kind_filter;
                        browser_asset_view_mode: root.browser_asset_view_mode;
                        browser_asset_utility_tab: root.browser_asset_utility_tab;
                        browser_asset_tree_hovered_index: root.browser_asset_tree_hovered_index;
                        browser_asset_tree_scroll_px: root.browser_asset_tree_scroll_px;
                        browser_asset_content_hovered_index: root.browser_asset_content_hovered_index;
                        browser_asset_content_scroll_px: root.browser_asset_content_scroll_px;
                        browser_asset_references_hovered_index: root.browser_asset_references_hovered_index;
                        browser_asset_references_scroll_px: root.browser_asset_references_scroll_px;
                        browser_asset_used_by_hovered_index: root.browser_asset_used_by_hovered_index;
                        browser_asset_used_by_scroll_px: root.browser_asset_used_by_scroll_px;
                        browser_asset_details_scroll_px: root.browser_asset_details_scroll_px;
                        viewport_image: root.viewport_image;
                        project_path: root.project_path;
                        inspector_name: root.inspector_name;
                        inspector_parent: root.inspector_parent;
                        inspector_x: root.inspector_x;
                        inspector_y: root.inspector_y;
                        inspector_z: root.inspector_z;
                        inspector_scroll_px: root.inspector_scroll_px;
                        status_text: root.status_primary;
                        console_scroll_px: root.console_scroll_px;
                        delete_enabled: root.delete_enabled;
                        mesh_import_path: root.mesh_import_path;
                        show_header: false;
                        compact_empty: false;
                        surface_control_clicked(control_id, action_id) => { root.pane_surface_control_clicked(control_id, action_id); }
                        inspector_control_changed(control_id, value) => { root.inspector_control_changed(control_id, value); }
                        inspector_control_clicked(control_id) => { root.inspector_control_clicked(control_id); }
                        mesh_import_path_edited(value) => { root.mesh_import_path_edited(value); }
                        asset_control_changed(source, control_id, value) => { root.asset_control_changed(source, control_id, value); }
                        asset_control_clicked(source, control_id) => { root.asset_control_clicked(source, control_id); }
                        asset_tree_pointer_clicked(surface_mode, x, y, width, height) => { root.asset_tree_pointer_clicked(surface_mode, x, y, width, height); }
                        asset_tree_pointer_moved(surface_mode, x, y, width, height) => { root.asset_tree_pointer_moved(surface_mode, x, y, width, height); }
                        asset_tree_pointer_scrolled(surface_mode, x, y, delta, width, height) => { root.asset_tree_pointer_scrolled(surface_mode, x, y, delta, width, height); }
                        asset_content_pointer_clicked(surface_mode, x, y, width, height) => { root.asset_content_pointer_clicked(surface_mode, x, y, width, height); }
                        asset_content_pointer_moved(surface_mode, x, y, width, height) => { root.asset_content_pointer_moved(surface_mode, x, y, width, height); }
                        asset_content_pointer_scrolled(surface_mode, x, y, delta, width, height) => { root.asset_content_pointer_scrolled(surface_mode, x, y, delta, width, height); }
                        asset_reference_pointer_clicked(surface_mode, list_kind, x, y, width, height) => { root.asset_reference_pointer_clicked(surface_mode, list_kind, x, y, width, height); }
                        asset_reference_pointer_moved(surface_mode, list_kind, x, y, width, height) => { root.asset_reference_pointer_moved(surface_mode, list_kind, x, y, width, height); }
                        asset_reference_pointer_scrolled(surface_mode, list_kind, x, y, delta, width, height) => { root.asset_reference_pointer_scrolled(surface_mode, list_kind, x, y, delta, width, height); }
                        browser_asset_details_pointer_scrolled(x, y, delta, width, height) => { root.browser_asset_details_pointer_scrolled(x, y, delta, width, height); }
                        welcome_control_changed(control_id, value) => { root.welcome_control_changed(control_id, value); }
                        welcome_control_clicked(control_id) => { root.welcome_control_clicked(control_id); }
                        welcome_recent_pointer_clicked(x, y, width, height) => { root.welcome_recent_pointer_clicked(x, y, width, height); }
                        welcome_recent_pointer_moved(x, y, width, height) => { root.welcome_recent_pointer_moved(x, y, width, height); }
                        welcome_recent_pointer_scrolled(x, y, delta, width, height) => { root.welcome_recent_pointer_scrolled(x, y, delta, width, height); }
