                                    active: tab.active;
                                    drag_enabled: true;
                                    drag_origin_x: (root.bottom_tab_origin_x + self.x) / 1px;
                                    drag_origin_y: (root.bottom_tab_origin_y + self.y) / 1px;
                                    pointer_clicked(x, y) => {
