export struct FrameRect {
    x: float,
    y: float,
    width: float,
    height: float,
}

export struct FloatingWindowData {
    window_id: string,
    title: string,
    frame: FrameRect,
    target_group: string,
    left_edge_target_group: string,
    right_edge_target_group: string,
    top_edge_target_group: string,
    bottom_edge_target_group: string,
    focus_target_id: string,
    tabs: [TabData],
    active_pane: PaneData,
}

component SceneViewportToolbar inherits Rectangle {
    in property <SceneViewportChromeData> viewport;
    callback pointer_clicked(control_id: string, control_x: float, control_y: float, control_width: float, control_height: float, point_x: float, point_y: float);

    palette := Palette {}
    height: 28px;
    background: #2b2d30;
    border-width: 1px;
    border-color: palette.border_soft;
    clip: true;

    right_group := Rectangle {
        x: parent.width - self.width - 8px;
        y: 4px;
        width: 314px;
        height: 20px;

        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 4px;

            ToolbarButton {
                label: "Persp";
                active: root.viewport.projection_mode == "Perspective";
                min-width: 44px;
                pointer_clicked(x, y) => { root.pointer_clicked("projection.perspective", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Ortho";
                active: root.viewport.projection_mode == "Orthographic";
                min-width: 44px;
                pointer_clicked(x, y) => { root.pointer_clicked("projection.orthographic", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "+X";
                active: root.viewport.view_orientation == "PosX";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.pos_x", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "-X";
                active: root.viewport.view_orientation == "NegX";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.neg_x", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "+Y";
                active: root.viewport.view_orientation == "PosY";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.pos_y", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "-Y";
                active: root.viewport.view_orientation == "NegY";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.neg_y", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "+Z";
                active: root.viewport.view_orientation == "PosZ";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.pos_z", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "-Z";
                active: root.viewport.view_orientation == "NegZ";
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("align.neg_z", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
        }
    }

    left_group := Rectangle {
        x: 8px;
        y: 4px;
        width: max(0px, parent.width - right_group.width - 24px);
        height: 20px;
        clip: true;

        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 4px;

            ToolbarButton {
                label: "Drag";
                active: root.viewport.tool == "Drag";
                min-width: 38px;
                pointer_clicked(x, y) => { root.pointer_clicked("tool.drag", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Move";
                active: root.viewport.tool == "Move";
                min-width: 38px;
                pointer_clicked(x, y) => { root.pointer_clicked("tool.move", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Rotate";
                active: root.viewport.tool == "Rotate";
                min-width: 44px;
                pointer_clicked(x, y) => { root.pointer_clicked("tool.rotate", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Scale";
                active: root.viewport.tool == "Scale";
                min-width: 40px;
                pointer_clicked(x, y) => { root.pointer_clicked("tool.scale", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: 3px;
                background: palette.border;
            }

            ToolbarButton {
                label: "Local";
                active: root.viewport.transform_space == "Local";
                min-width: 40px;
                pointer_clicked(x, y) => { root.pointer_clicked("space.local", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Global";
                active: root.viewport.transform_space == "Global";
                min-width: 42px;
                pointer_clicked(x, y) => { root.pointer_clicked("space.global", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: 3px;
                background: palette.border;
            }

            ToolbarButton {
                label:
                    root.viewport.display_mode == "Shaded" ? "Shade" :
                    root.viewport.display_mode == "WireOverlay" ? "Wire+" :
                    "Wire";
                active: root.viewport.display_mode != "Shaded";
                min-width: 48px;
                pointer_clicked(x, y) => { root.pointer_clicked("display.cycle", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label:
                    root.viewport.grid_mode == "Hidden" ? "Grid Off" :
                    root.viewport.grid_mode == "VisibleNoSnap" ? "Grid" :
                    "Snap";
                active: root.viewport.grid_mode != "Hidden";
                min-width: 52px;
                pointer_clicked(x, y) => { root.pointer_clicked("grid.cycle", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: root.viewport.translate_snap_label;
                active: root.viewport.grid_mode == "VisibleAndSnap";
                min-width: 42px;
                pointer_clicked(x, y) => { root.pointer_clicked("snap.translate", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: root.viewport.rotate_snap_label;
                active: root.viewport.grid_mode == "VisibleAndSnap";
                min-width: 42px;
                pointer_clicked(x, y) => { root.pointer_clicked("snap.rotate", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: root.viewport.scale_snap_label;
                active: root.viewport.grid_mode == "VisibleAndSnap";
                min-width: 42px;
                pointer_clicked(x, y) => { root.pointer_clicked("snap.scale", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }

            Rectangle {
                width: 1px;
                height: 14px;
                y: 3px;
                background: palette.border;
            }

            ToolbarButton {
                label: "Light";
                active: root.viewport.preview_lighting;
                min-width: 38px;
                pointer_clicked(x, y) => { root.pointer_clicked("toggle.lighting", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Sky";
                active: root.viewport.preview_skybox;
                min-width: 34px;
                pointer_clicked(x, y) => { root.pointer_clicked("toggle.skybox", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarButton {
                label: "Gz";
                active: root.viewport.gizmos_enabled;
                min-width: 30px;
                pointer_clicked(x, y) => { root.pointer_clicked("toggle.gizmos", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
            ToolbarIconButton {
                icon_key: "tool-fit";
                active: false;
                pointer_clicked(x, y) => { root.pointer_clicked("frame.selection", self.x / 1px, self.y / 1px, self.width / 1px, self.height / 1px, self.x / 1px + x, self.y / 1px + y); }
            }
        }
    }
}

component PaneSurface inherits Rectangle {
    in property <PaneData> pane;
    in property <WelcomePaneData> welcome_pane;
    in property <[RecentProjectData]> recent_projects;
    in property <int> hovered_welcome_recent_index: -1;
    in property <int> hovered_welcome_recent_action: -1;
    in property <float> welcome_recent_scroll_px: 0.0;
    in property <[SceneNodeData]> hierarchy_nodes;
    in property <int> hovered_hierarchy_index: -1;
    in property <float> hierarchy_scroll_px: 0.0;
    in property <ProjectOverviewData> project_overview;
    in property <[AssetFolderData]> activity_asset_tree_folders;
    in property <[AssetFolderData]> activity_asset_content_folders;
    in property <[AssetItemData]> activity_asset_content_items;
    in property <AssetSelectionData> activity_asset_selection;
    in property <[AssetReferenceData]> activity_asset_references;
    in property <[AssetReferenceData]> activity_asset_used_by;
    in property <string> activity_asset_search_query;
    in property <string> activity_asset_kind_filter;
    in property <string> activity_asset_view_mode;
    in property <string> activity_asset_utility_tab;
    in property <int> activity_asset_tree_hovered_index: -1;
    in property <float> activity_asset_tree_scroll_px: 0.0;
    in property <int> activity_asset_content_hovered_index: -1;
    in property <float> activity_asset_content_scroll_px: 0.0;
    in property <int> activity_asset_references_hovered_index: -1;
    in property <float> activity_asset_references_scroll_px: 0.0;
    in property <int> activity_asset_used_by_hovered_index: -1;
    in property <float> activity_asset_used_by_scroll_px: 0.0;
    in property <[AssetFolderData]> browser_asset_tree_folders;
    in property <[AssetFolderData]> browser_asset_content_folders;
    in property <[AssetItemData]> browser_asset_content_items;
    in property <AssetSelectionData> browser_asset_selection;
    in property <[AssetReferenceData]> browser_asset_references;
    in property <[AssetReferenceData]> browser_asset_used_by;
    in property <string> browser_asset_search_query;
    in property <string> browser_asset_kind_filter;
    in property <string> browser_asset_view_mode;
    in property <string> browser_asset_utility_tab;
    in property <int> browser_asset_tree_hovered_index: -1;
    in property <float> browser_asset_tree_scroll_px: 0.0;
    in property <int> browser_asset_content_hovered_index: -1;
    in property <float> browser_asset_content_scroll_px: 0.0;
    in property <int> browser_asset_references_hovered_index: -1;
    in property <float> browser_asset_references_scroll_px: 0.0;
    in property <int> browser_asset_used_by_hovered_index: -1;
    in property <float> browser_asset_used_by_scroll_px: 0.0;
    in property <float> browser_asset_details_scroll_px: 0.0;
    in property <image> viewport_image;
    in property <string> project_path;
    in property <string> inspector_name;
    in property <string> inspector_parent;
    in property <string> inspector_x;
    in property <string> inspector_y;
    in property <string> inspector_z;
    in property <float> inspector_scroll_px: 0.0;
    in property <string> status_text;
    in property <float> console_scroll_px: 0.0;
    in property <bool> delete_enabled;
    callback surface_control_clicked(control_id: string, action_id: string);
    callback hierarchy_pointer_clicked(x: float, y: float, width: float, height: float);
    callback hierarchy_pointer_moved(x: float, y: float, width: float, height: float);
    callback hierarchy_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback console_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback inspector_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback inspector_control_changed(control_id: string, value: string);
    callback inspector_control_clicked(control_id: string);
    callback mesh_import_path_edited(value: string);
    callback asset_control_changed(source: string, control_id: string, value: string);
    callback asset_control_clicked(source: string, control_id: string);
    callback asset_tree_pointer_clicked(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_tree_pointer_moved(surface_mode: string, x: float, y: float, width: float, height: float);
