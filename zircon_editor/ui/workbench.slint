export struct TabData {
    id: string,
    slot: string,
    title: string,
    icon_key: string,
    active: bool,
    closeable: bool,
}

export struct BreadcrumbData {
    label: string,
}

export struct SceneViewportChromeData {
    tool: string,
    transform_space: string,
    projection_mode: string,
    view_orientation: string,
    display_mode: string,
    grid_mode: string,
    gizmos_enabled: bool,
    preview_lighting: bool,
    preview_skybox: bool,
    translate_snap: float,
    rotate_snap_deg: float,
    scale_snap: float,
    translate_snap_label: string,
    rotate_snap_label: string,
    scale_snap_label: string,
}

