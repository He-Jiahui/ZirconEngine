    callback menu_pointer_scrolled(x: float, y: float, delta: float);
    callback activity_rail_pointer_clicked(side: string, x: float, y: float);
    callback host_page_pointer_clicked(tab_index: int, tab_x: float, tab_width: float, point_x: float, point_y: float);
    callback drawer_header_pointer_clicked(surface_key: string, tab_index: int, tab_x: float, tab_width: float, point_x: float, point_y: float);
    callback document_tab_pointer_clicked(surface_key: string, tab_index: int, tab_x: float, tab_width: float, point_x: float, point_y: float);
    callback document_tab_close_pointer_clicked(surface_key: string, tab_index: int, tab_x: float, tab_width: float, point_x: float, point_y: float);
    callback floating_window_header_pointer_clicked(x: float, y: float);
    callback workbench_drag_pointer_event(kind: int, x: float, y: float);
    callback workbench_resize_pointer_event(kind: int, x: float, y: float);
    callback hierarchy_pointer_clicked(x: float, y: float, width: float, height: float);
    callback hierarchy_pointer_moved(x: float, y: float, width: float, height: float);
    callback hierarchy_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback console_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback inspector_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback inspector_control_changed(control_id: string, value: string);
    callback inspector_control_clicked(control_id: string);
    callback mesh_import_path_edited(value: string);
    callback asset_control_changed(source: string, control_id: string, value: string);
    callback asset_control_clicked(source: string, control_id: string);
    callback asset_tree_pointer_clicked(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_tree_pointer_moved(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_tree_pointer_scrolled(surface_mode: string, x: float, y: float, delta: float, width: float, height: float);
    callback asset_content_pointer_clicked(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_content_pointer_moved(surface_mode: string, x: float, y: float, width: float, height: float);
    callback asset_content_pointer_scrolled(surface_mode: string, x: float, y: float, delta: float, width: float, height: float);
    callback asset_reference_pointer_clicked(surface_mode: string, list_kind: string, x: float, y: float, width: float, height: float);
    callback asset_reference_pointer_moved(surface_mode: string, list_kind: string, x: float, y: float, width: float, height: float);
    callback asset_reference_pointer_scrolled(surface_mode: string, list_kind: string, x: float, y: float, delta: float, width: float, height: float);
    callback browser_asset_details_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback welcome_control_changed(control_id: string, value: string);
    callback welcome_control_clicked(control_id: string);
    callback welcome_recent_pointer_clicked(x: float, y: float, width: float, height: float);
    callback welcome_recent_pointer_moved(x: float, y: float, width: float, height: float);
    callback welcome_recent_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback viewport_pointer_event(kind: int, button: int, x: float, y: float, delta: float);
    callback viewport_toolbar_pointer_clicked(surface_key: string, control_id: string, control_x: float, control_y: float, control_width: float, control_height: float, point_x: float, point_y: float);
    callback ui_asset_action(instance_id: string, action_id: string);
    callback ui_asset_style_class_action(instance_id: string, action_id: string, class_name: string);
    callback ui_asset_inspector_widget_action(instance_id: string, action_id: string, value: string);
    callback ui_asset_style_rule_action(instance_id: string, action_id: string, item_index: int, selector: string);
    callback ui_asset_matched_style_rule_selected(instance_id: string, item_index: int);
    callback ui_asset_style_rule_declaration_action(instance_id: string, action_id: string, item_index: int, declaration_path: string, declaration_value: string);
    callback ui_asset_style_token_action(instance_id: string, action_id: string, item_index: int, token_name: string, token_value: string);
    callback ui_asset_source_edited(instance_id: string, value: string);
    callback ui_asset_source_cursor_changed(instance_id: string, byte_offset: int);
    callback ui_asset_palette_selected(instance_id: string, item_index: int);
    callback ui_asset_palette_drag_hover(instance_id: string, surface_x: float, surface_y: float);
    callback ui_asset_palette_drag_drop(instance_id: string);
    callback ui_asset_palette_drag_cancel(instance_id: string);
    callback ui_asset_palette_target_candidate_selected(instance_id: string, item_index: int);
    callback ui_asset_palette_target_confirm(instance_id: string);
    callback ui_asset_palette_target_cancel(instance_id: string);
    callback ui_asset_hierarchy_selected(instance_id: string, item_index: int);
    callback ui_asset_hierarchy_activated(instance_id: string, item_index: int);
    callback ui_asset_preview_selected(instance_id: string, item_index: int);
    callback ui_asset_preview_activated(instance_id: string, item_index: int);
    callback ui_asset_source_outline_selected(instance_id: string, item_index: int);
    callback ui_asset_preview_mock_selected(instance_id: string, item_index: int);
    callback ui_asset_preview_mock_action(instance_id: string, action_id: string, value: string);
    callback ui_asset_binding_selected(instance_id: string, item_index: int);
    callback ui_asset_binding_event_selected(instance_id: string, item_index: int);
    callback ui_asset_binding_action_kind_selected(instance_id: string, item_index: int);
    callback ui_asset_binding_payload_selected(instance_id: string, item_index: int);
    callback ui_asset_binding_payload_action(instance_id: string, action_id: string, payload_key: string, payload_value: string);
    callback ui_asset_slot_semantic_selected(instance_id: string, item_index: int);
    callback ui_asset_layout_semantic_selected(instance_id: string, item_index: int);

    palette := Palette {}
    property <length> outer_margin: 0px;
    property <length> rail_width: 34px;
    property <length> top_bar_height: 25px;
    property <length> host_bar_height: 24px;
    property <length> status_bar_height: 20px;
    property <length> panel_header_height: 25px;
    property <length> document_header_height: 31px;
    property <length> splitter_hit_size: 8px;
    property <bool> resize_active: false;
    property <string> resize_group: "";
    property <length> left_rail_width: root.left_region_frame.width > 0.0 && root.left_tabs.length > 0 ? root.rail_width : 0px;
    property <length> right_rail_width: root.right_region_frame.width > 0.0 && root.right_tabs.length > 0 ? root.rail_width : 0px;
    property <length> left_stack_width: root.left_region_frame.width * 1px;
    property <length> right_stack_width: root.right_region_frame.width * 1px;
    property <length> left_panel_width: root.left_expanded && root.left_stack_width > root.left_rail_width ? max(0px, root.left_stack_width - root.left_rail_width) : 0px;
    property <length> right_panel_width: root.right_expanded && root.right_stack_width > root.right_rail_width ? max(0px, root.right_stack_width - root.right_rail_width) : 0px;
    property <length> bottom_panel_height: root.bottom_region_frame.height * 1px;
    property <length> popup_y: root.top_bar_height + 1px;
    property <length> main_content_y: root.center_band_frame.y * 1px;
    property <length> main_content_height: root.center_band_frame.height * 1px;
    property <length> document_zone_x: root.document_region_frame.x * 1px;
    property <length> document_zone_width: root.document_region_frame.width * 1px;
    property <length> right_stack_x: root.right_region_frame.x * 1px;
    property <length> bottom_panel_y: root.bottom_region_frame.y * 1px;
    property <length> left_tab_origin_x: root.left_rail_width + (root.left_panel_width > 0px ? 1px : 0px) + 6px;
    property <length> left_tab_origin_y: root.main_content_y + 2px;
    property <length> document_tab_origin_x: root.document_zone_x + 8px;
    property <length> document_tab_origin_y: root.main_content_y + 1px;
    property <length> right_tab_origin_x: root.right_stack_x + 6px;
    property <length> right_tab_origin_y: root.main_content_y + 2px;
    property <length> bottom_tab_origin_x: 6px;
    property <length> bottom_tab_origin_y: root.bottom_panel_y + 2px;
    property <length> left_drop_width: max(root.left_stack_width, 92px);
    property <length> right_drop_width: max(root.right_stack_width, 92px);
    property <length> bottom_drop_height: max(root.bottom_panel_height, 92px);
    property <bool> left_drop_enabled: root.drawers_visible;
    property <bool> right_drop_enabled: root.drawers_visible;
    property <bool> bottom_drop_enabled: root.drawers_visible;
    in-out property <string> active_drag_target_group: "";
    in-out property <bool> drag_active: false;
    in-out property <string> drag_tab_id: "";
    in-out property <string> drag_tab_title: "";
    in-out property <string> drag_tab_icon_key: "";
    in-out property <string> drag_source_group: "";
    in-out property <float> drag_pointer_x: 0.0;
    in-out property <float> drag_pointer_y: 0.0;
    property <float> drag_overlay_top_px: root.center_band_frame.y;
    property <float> drag_overlay_bottom_px: root.status_bar_frame.y;
    property <float> bottom_drop_top_px: root.status_bar_frame.y - root.bottom_drop_height / 1px;
    property <string> drag_target_label:
        root.active_drag_target_group == "left" ? "Dock Left" :
        root.active_drag_target_group == "right" ? "Dock Right" :
        root.active_drag_target_group == "bottom" ? "Dock Bottom" :
        root.active_drag_target_group == "document-left" ? "Split Left" :
        root.active_drag_target_group == "document-right" ? "Split Right" :
        root.active_drag_target_group == "document-top" ? "Split Top" :
        root.active_drag_target_group == "document-bottom" ? "Split Bottom" :
        root.active_drag_target_group == "document" ? "Dock Document" :
        "Drag Tab";

    Rectangle {
        visible: !root.native_floating_window_mode;
        width: parent.width;
        height: parent.height;
        background: palette.shell_bg;

        Rectangle {
            x: root.outer_margin;
            y: root.outer_margin;
            width: parent.width - root.outer_margin * 2;
            height: parent.height - root.outer_margin * 2;
            background: palette.chrome_bg;
            border-width: 0px;
            border-color: palette.border;
            border-radius: 0px;
            clip: true;

            top_bar := Rectangle {
                x: 0px;
                y: 0px;
                width: parent.width;
                height: root.top_bar_height;
                background: palette.chrome_bg;
                out property <FrameRect> file_menu_button_local_frame: {
                    x: menu_button_row.x / 1px + file_menu_button.x / 1px,
                    y: menu_button_row.y / 1px,
                    width: file_menu_button.width / 1px,
                    height: file_menu_button.height / 1px,
                };
                out property <FrameRect> edit_menu_button_local_frame: {
                    x: menu_button_row.x / 1px + edit_menu_button.x / 1px,
                    y: menu_button_row.y / 1px,
                    width: edit_menu_button.width / 1px,
                    height: edit_menu_button.height / 1px,
                };
                out property <FrameRect> selection_menu_button_local_frame: {
                    x: menu_button_row.x / 1px + selection_menu_button.x / 1px,
                    y: menu_button_row.y / 1px,
                    width: selection_menu_button.width / 1px,
                    height: selection_menu_button.height / 1px,
                };
                out property <FrameRect> view_menu_button_local_frame: {
                    x: menu_button_row.x / 1px + view_menu_button.x / 1px,
                    y: menu_button_row.y / 1px,
                    width: view_menu_button.width / 1px,
                    height: view_menu_button.height / 1px,
                };
                out property <FrameRect> window_menu_button_local_frame: {
                    x: menu_button_row.x / 1px + window_menu_button.x / 1px,
                    y: menu_button_row.y / 1px,
                    width: window_menu_button.width / 1px,
                    height: window_menu_button.height / 1px,
                };
                out property <FrameRect> help_menu_button_local_frame: {
                    x: menu_button_row.x / 1px + help_menu_button.x / 1px,
                    y: menu_button_row.y / 1px,
                    width: help_menu_button.width / 1px,
                    height: help_menu_button.height / 1px,
                };

                menu_button_row := HorizontalLayout {
                    x: 8px;
                    y: 1px;
                    spacing: 2px;

                    file_menu_button := MenuBarButton { label: "File"; active: root.open_menu_index == 0; hovered: root.hovered_menu_index == 0; interactive: false; }
                    edit_menu_button := MenuBarButton { label: "Edit"; active: root.open_menu_index == 1; hovered: root.hovered_menu_index == 1; interactive: false; }
                    selection_menu_button := MenuBarButton { label: "Selection"; active: root.open_menu_index == 2; hovered: root.hovered_menu_index == 2; interactive: false; }
                    view_menu_button := MenuBarButton { label: "View"; active: root.open_menu_index == 3; hovered: root.hovered_menu_index == 3; interactive: false; }
                    window_menu_button := MenuBarButton { label: "Window"; active: root.open_menu_index == 4; hovered: root.hovered_menu_index == 4; interactive: false; }
                    help_menu_button := MenuBarButton { label: "Help"; active: root.open_menu_index == 5; hovered: root.hovered_menu_index == 5; interactive: false; }
                }

                if root.open_menu_index == -1: TouchArea {
                    x: 0px;
                    y: 0px;
                    width: parent.width;
                    height: parent.height;
                    clicked => {
                        root.menu_pointer_clicked(
                            root.outer_margin / 1px + self.mouse-x / 1px,
                            root.outer_margin / 1px + self.mouse-y / 1px,
                        );
                    }
                }
            }

            Rectangle {
                x: 0px;
                y: root.top_bar_height;
                width: parent.width;
                height: 1px;
                background: palette.border;
            }

            Rectangle {
                x: 0px;
                y: root.top_bar_height + 1px;
                width: parent.width;
                height: root.host_bar_height;
                background: palette.chrome_bg;

                HorizontalLayout {
                    x: 8px;
                    y: 1px;
                    spacing: 4px;

                    for page[index] in root.host_tabs: DockTabButton {
                        label: page.title;
                        icon_key: page.icon_key;
                        active: page.active;
                        pointer_pressed(x, y) => {
                            root.host_page_pointer_clicked(
                                index,
                                8.0 + self.x / 1px,
                                self.width / 1px,
                                8.0 + self.x / 1px + x,
                                1.0 + self.y / 1px + y,
                            );
                        }
                    }
                }

                Text {
                    x: parent.width - 292px;
                    y: 5px;
                    width: 280px;
                    horizontal-alignment: right;
                    text: root.project_path != "" ? root.project_path : "No project open";
                    color: palette.text_dim;
                    font-size: 9px;
                    overflow: elide;
                }
            }

            Rectangle {
                x: 0px;
                y: root.center_band_frame.y * 1px - 1px;
                width: parent.width;
                height: 1px;
                background: palette.border;
            }

            main_content_zone := Rectangle {
                x: root.center_band_frame.x * 1px;
                y: root.center_band_frame.y * 1px;
                width: root.center_band_frame.width * 1px;
                height: root.center_band_frame.height * 1px;
                background: palette.panel_bg;
            }

            if root.left_stack_width > 0px: left_stack_zone := Rectangle {
                x: root.left_region_frame.x * 1px;
                y: root.left_region_frame.y * 1px;
                width: root.left_region_frame.width * 1px;
                height: root.left_region_frame.height * 1px;
                background: transparent;
                clip: true;
                            HorizontalLayout {
                                spacing: 0px;

                                Rectangle {
                                    width: root.left_rail_width;
                                    background: palette.rail_bg;

                                    VerticalLayout {
                                        x: 3px;
                                        y: 6px;
                                        spacing: 2px;
                                        for tab in root.left_tabs: RailButton {
                                            icon_key: tab.icon_key;
                                            active: tab.active;
                                            pointer_pressed(x, y) => {
                                                root.activity_rail_pointer_clicked(
                                                    "left",
                                                    self.x / 1px + x,
                                                    self.y / 1px + y,
                                                );
                                            }
                                        }
                                    }
                                }

                                if root.left_panel_width > 0px: Rectangle { width: 1px; background: palette.border_soft; }

                                if root.left_panel_width > 0px: Rectangle {
                                    width: root.left_panel_width;
                                    background: palette.panel_bg;

                                    VerticalLayout {
                                        spacing: 0px;

                                        Rectangle {
                                            height: root.panel_header_height;
                                            background: palette.chrome_bg;

                                            HorizontalLayout {
                                                x: 6px;
                                                y: 2px;
                                                spacing: 4px;
                                                for tab[index] in root.left_tabs: left_header_tab := DockTabButton {
                                                    label: tab.title;
                                                    icon_key: tab.icon_key;
                                                    active: tab.active;
                                                    drag_enabled: true;
                                                    drag_origin_x: (root.left_tab_origin_x + self.x) / 1px;
                                                    drag_origin_y: (root.left_tab_origin_y + self.y) / 1px;
                                                    pointer_clicked(x, y) => {
                                                        root.drawer_header_pointer_clicked(
                                                            "left",
                                                            index,
                                                            6.0 + self.x / 1px,
                                                            self.width / 1px,
                                                            6.0 + self.x / 1px + x,
                                                            2.0 + self.y / 1px + y,
                                                        );
                                                    }
                                                    drag_started(x, y) => {
                                                        root.drag_active = true;
                                                        root.drag_tab_id = tab.id;
                                                        root.drag_tab_title = tab.title;
                                                        root.drag_tab_icon_key = tab.icon_key;
                                                        root.drag_source_group = "left";
                                                        root.drag_pointer_x = x;
                                                        root.drag_pointer_y = y;
                                                        root.workbench_drag_pointer_event(1, root.drag_pointer_x, root.drag_pointer_y);
                                                    }
                                                    drag_moved(x, y) => {
                                                        if (root.drag_tab_id == tab.id) {
                                                            root.drag_pointer_x = x;
                                                            root.drag_pointer_y = y;
                                                            root.workbench_drag_pointer_event(1, root.drag_pointer_x, root.drag_pointer_y);
                                                        }
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle { height: 1px; background: palette.border_soft; }

                                        PaneSurface {
                                            width: parent.width;
                                            height: parent.height - root.panel_header_height - 1px;
                                            pane: root.left_pane;
                                            welcome_pane: root.welcome_pane;
                                            recent_projects: root.recent_projects;
                                            hovered_welcome_recent_index: root.hovered_welcome_recent_index;
                                            hovered_welcome_recent_action: root.hovered_welcome_recent_action;
                                            welcome_recent_scroll_px: root.welcome_recent_scroll_px;
                                            hierarchy_nodes: root.hierarchy_nodes;
                                            hovered_hierarchy_index: root.hovered_hierarchy_index;
                                            hierarchy_scroll_px: root.hierarchy_scroll_px;
                                            project_overview: root.project_overview;
                                            activity_asset_tree_folders: root.activity_asset_tree_folders;
                                            activity_asset_content_folders: root.activity_asset_content_folders;
                                            activity_asset_content_items: root.activity_asset_content_items;
                                            activity_asset_selection: root.activity_asset_selection;
                                            activity_asset_references: root.activity_asset_references;
                                            activity_asset_used_by: root.activity_asset_used_by;
                                            activity_asset_search_query: root.activity_asset_search_query;
                                            activity_asset_kind_filter: root.activity_asset_kind_filter;
                                            activity_asset_view_mode: root.activity_asset_view_mode;
                                            activity_asset_utility_tab: root.activity_asset_utility_tab;
                                            activity_asset_tree_hovered_index: root.activity_asset_tree_hovered_index;
                                            activity_asset_tree_scroll_px: root.activity_asset_tree_scroll_px;
                                            activity_asset_content_hovered_index: root.activity_asset_content_hovered_index;
                                            activity_asset_content_scroll_px: root.activity_asset_content_scroll_px;
                                            activity_asset_references_hovered_index: root.activity_asset_references_hovered_index;
                                            activity_asset_references_scroll_px: root.activity_asset_references_scroll_px;
                                            activity_asset_used_by_hovered_index: root.activity_asset_used_by_hovered_index;
                                            activity_asset_used_by_scroll_px: root.activity_asset_used_by_scroll_px;
                                            browser_asset_tree_folders: root.browser_asset_tree_folders;
                                            browser_asset_content_folders: root.browser_asset_content_folders;
                                            browser_asset_content_items: root.browser_asset_content_items;
                                            browser_asset_selection: root.browser_asset_selection;
                                            browser_asset_references: root.browser_asset_references;
                                            browser_asset_used_by: root.browser_asset_used_by;
                                            browser_asset_search_query: root.browser_asset_search_query;
                                            browser_asset_kind_filter: root.browser_asset_kind_filter;
                                            browser_asset_view_mode: root.browser_asset_view_mode;
                                            browser_asset_utility_tab: root.browser_asset_utility_tab;
                                            browser_asset_tree_hovered_index: root.browser_asset_tree_hovered_index;
                                            browser_asset_tree_scroll_px: root.browser_asset_tree_scroll_px;
                                            browser_asset_content_hovered_index: root.browser_asset_content_hovered_index;
                                            browser_asset_content_scroll_px: root.browser_asset_content_scroll_px;
                                            browser_asset_references_hovered_index: root.browser_asset_references_hovered_index;
                                            browser_asset_references_scroll_px: root.browser_asset_references_scroll_px;
                                            browser_asset_used_by_hovered_index: root.browser_asset_used_by_hovered_index;
                                            browser_asset_used_by_scroll_px: root.browser_asset_used_by_scroll_px;
                                            browser_asset_details_scroll_px: root.browser_asset_details_scroll_px;
                                            viewport_image: root.viewport_image;
                                            project_path: root.project_path;
                                            inspector_name: root.inspector_name;
                                            inspector_parent: root.inspector_parent;
                                            inspector_x: root.inspector_x;
                                            inspector_y: root.inspector_y;
                                            inspector_z: root.inspector_z;
                                            inspector_scroll_px: root.inspector_scroll_px;
                                            status_text: root.status_primary;
                                            console_scroll_px: root.console_scroll_px;
                                            delete_enabled: root.delete_enabled;
                                            mesh_import_path: root.mesh_import_path;
                                            show_header: false;
                                            compact_empty: true;
                                            surface_control_clicked(control_id, action_id) => { root.pane_surface_control_clicked(control_id, action_id); }
                                            inspector_control_changed(control_id, value) => { root.inspector_control_changed(control_id, value); }
                                            inspector_control_clicked(control_id) => { root.inspector_control_clicked(control_id); }
                                            mesh_import_path_edited(value) => { root.mesh_import_path_edited(value); }
                                            asset_control_changed(source, control_id, value) => { root.asset_control_changed(source, control_id, value); }
                                            asset_control_clicked(source, control_id) => { root.asset_control_clicked(source, control_id); }
                                            asset_tree_pointer_clicked(surface_mode, x, y, width, height) => { root.asset_tree_pointer_clicked(surface_mode, x, y, width, height); }
                                            asset_tree_pointer_moved(surface_mode, x, y, width, height) => { root.asset_tree_pointer_moved(surface_mode, x, y, width, height); }
                                            asset_tree_pointer_scrolled(surface_mode, x, y, delta, width, height) => { root.asset_tree_pointer_scrolled(surface_mode, x, y, delta, width, height); }
                                            asset_content_pointer_clicked(surface_mode, x, y, width, height) => { root.asset_content_pointer_clicked(surface_mode, x, y, width, height); }
                                            asset_content_pointer_moved(surface_mode, x, y, width, height) => { root.asset_content_pointer_moved(surface_mode, x, y, width, height); }
