        can_convert_to_reference: root.pane.ui_asset_can_convert_to_reference;
        can_extract_component: root.pane.ui_asset_can_extract_component;
        can_promote_to_external_widget: root.pane.ui_asset_can_promote_to_external_widget;
        can_wrap_in_vertical_box: root.pane.ui_asset_can_wrap_in_vertical_box;
        can_unwrap: root.pane.ui_asset_can_unwrap;
        can_create_rule: root.pane.ui_asset_can_create_rule;
        can_extract_rule: root.pane.ui_asset_can_extract_rule;
        preview_available: root.pane.ui_asset_preview_available;
        state_hover: root.pane.ui_asset_style_state_hover;
        state_focus: root.pane.ui_asset_style_state_focus;
        state_pressed: root.pane.ui_asset_style_state_pressed;
        state_disabled: root.pane.ui_asset_style_state_disabled;
        state_selected: root.pane.ui_asset_style_state_selected;
        palette_selected_index: root.pane.ui_asset_palette_selected_index;
                palette_drag_target_preview_index: root.pane.ui_asset_palette_drag_target_preview_index;
                palette_drag_target_action: root.pane.ui_asset_palette_drag_target_action;
                palette_drag_target_label: root.pane.ui_asset_palette_drag_target_label;
                palette_drag_slot_target_items: root.pane.ui_asset_palette_drag_slot_target_items;
