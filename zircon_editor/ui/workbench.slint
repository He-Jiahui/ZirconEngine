    callback asset_reference_pointer_scrolled(surface_mode: string, list_kind: string, x: float, y: float, delta: float, width: float, height: float);
    callback browser_asset_details_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback welcome_control_changed(control_id: string, value: string);
    callback welcome_control_clicked(control_id: string);
    callback welcome_recent_pointer_clicked(x: float, y: float, width: float, height: float);
    callback welcome_recent_pointer_moved(x: float, y: float, width: float, height: float);
    callback welcome_recent_pointer_scrolled(x: float, y: float, delta: float, width: float, height: float);
    callback viewport_pointer_event(kind: int, button: int, x: float, y: float, delta: float);
    callback viewport_toolbar_pointer_clicked(surface_key: string, control_id: string, control_x: float, control_y: float, control_width: float, control_height: float, point_x: float, point_y: float);
    callback ui_asset_action(instance_id: string, action_id: string);
    callback ui_asset_style_class_action(instance_id: string, action_id: string, class_name: string);
    callback ui_asset_inspector_widget_action(instance_id: string, action_id: string, value: string);
    callback ui_asset_style_rule_action(instance_id: string, action_id: string, item_index: int, selector: string);
    callback ui_asset_matched_style_rule_selected(instance_id: string, item_index: int);
    callback ui_asset_style_rule_declaration_action(instance_id: string, action_id: string, item_index: int, declaration_path: string, declaration_value: string);
    callback ui_asset_style_token_action(instance_id: string, action_id: string, item_index: int, token_name: string, token_value: string);
    callback ui_asset_source_edited(instance_id: string, value: string);
    callback ui_asset_source_cursor_changed(instance_id: string, byte_offset: int);
    callback ui_asset_palette_selected(instance_id: string, item_index: int);
    callback ui_asset_palette_drag_hover(instance_id: string, surface_x: float, surface_y: float);
    callback ui_asset_palette_drag_drop(instance_id: string);
