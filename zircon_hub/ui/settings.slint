import { OperationTimelineRowData, SettingStatusData, UiTextData } from "shared.slint";
import {
    HubTokens,
    HubVisualSpec,
    OperationTimelinePanel,
    PageScrollSurface,
    WorkspacePanelSection,
} from "components.slint";
import {
    SettingsBuildDefaultsPanel,
    SettingsConfigurationHealthPanel,
    SettingsDefaultPathsPanel,
    SettingsSaveActionRow,
    SettingsToolchainPanel,
} from "settings_page_components.slint";

export component SettingsPage inherits PageScrollSurface {
    in-out property <string> python-path;
    in-out property <string> cargo-path;
    in-out property <string> rustup-path;
    in-out property <string> project-location;
    in-out property <string> source-path;
    in-out property <string> output-path;
    in-out property <string> device-install-path;
    in-out property <string> build-jobs;
    in-out property <string> build-profile;
    in-out property <string> language;
    in property <[SettingStatusData]> settings-statuses;
    in property <[OperationTimelineRowData]> operation-timeline;
    in property <int> operation-timeline-count;
    in property <UiTextData> ui-text;
    private property <bool> compact: root.content-width < HubTokens.panel-min-lg + HubTokens.control-lg + HubTokens.panel-min-md + HubTokens.panel-gap;
    private property <bool> compact-labels: root.content-width < HubTokens.breakpoint-medium;
    private property <length> save-button-width: min(root.content-width, HubTokens.panel-min-sm);
    private property <int> settings-status-count: root.settings-statuses.length;
    private property <length> health-empty-height: HubTokens.list-row-lg + HubTokens.space-4;
    private property <length> paths-scroll-y: 0px;
    private property <length> health-scroll-y: 0px;
    private property <length> operation-timeline-scroll-y: 0px;
    callback browse-folder(string);
    callback save-settings();

    background: HubVisualSpec.page-background;
    clip: true;

    WorkspacePanelSection {
        compact: root.compact;
        row-height: HubTokens.workspace-row-settings-controls;
        spacing-horizontal: HubTokens.panel-gap;
        spacing-vertical: HubTokens.panel-gap;

        SettingsToolchainPanel {
            basis: HubTokens.panel-min-md + HubTokens.control-sm;
            flex-basis: HubTokens.panel-min-md + HubTokens.control-sm;
            grow: 1;
            flex-grow: 1;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.compact ? root.content-width : HubTokens.panel-min-sm;
            height: HubTokens.workspace-row-settings-controls;
            panel-title: root.ui-text.toolchain;
            ui-text: root.ui-text;
            python-path <=> root.python-path;
            cargo-path <=> root.cargo-path;
            rustup-path <=> root.rustup-path;
        }

        SettingsBuildDefaultsPanel {
            basis: HubTokens.panel-min-md + HubTokens.control-sm;
            flex-basis: HubTokens.panel-min-md + HubTokens.control-sm;
            grow: 1;
            flex-grow: 1;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.compact ? root.content-width : HubTokens.panel-min-sm;
            height: HubTokens.workspace-row-settings-controls;
            panel-title: root.ui-text.build-defaults;
            ui-text: root.ui-text;
            build-jobs <=> root.build-jobs;
            build-profile <=> root.build-profile;
            language <=> root.language;
        }
    }

    WorkspacePanelSection {
        compact: root.compact;
        row-height: HubTokens.workspace-row-settings-detail;
        spacing-horizontal: HubTokens.panel-gap;
        spacing-vertical: HubTokens.panel-gap;

        SettingsDefaultPathsPanel {
            basis: HubTokens.panel-min-lg + HubTokens.control-lg;
            flex-basis: HubTokens.panel-min-lg + HubTokens.control-lg;
            grow: 2;
            flex-grow: 2;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.compact ? root.content-width : HubTokens.panel-min-lg;
            height: HubTokens.workspace-row-settings-detail;
            panel-title: root.ui-text.default-paths;
            ui-text: root.ui-text;
            project-location <=> root.project-location;
            source-path <=> root.source-path;
            output-path <=> root.output-path;
            device-install-path <=> root.device-install-path;
            paths-scroll-y <=> root.paths-scroll-y;
            browse-folder(id) => {
                root.browse-folder(id);
            }
        }

        SettingsConfigurationHealthPanel {
            basis: HubTokens.panel-min-md;
            flex-basis: HubTokens.panel-min-md;
            grow: 1;
            flex-grow: 1;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.compact ? root.content-width : HubTokens.panel-min-md;
            height: HubTokens.workspace-row-settings-detail;
            panel-title: root.ui-text.configuration-health;
            ui-text: root.ui-text;
            settings-statuses: root.settings-statuses;
            settings-status-count: root.settings-status-count;
            compact-labels: root.compact-labels;
            health-empty-height: root.health-empty-height;
            health-scroll-y <=> root.health-scroll-y;
            status-action(action-id) => {
                if (action-id == "save-settings") {
                    root.save-settings();
                } else if (action-id == "browse-project-location") {
                    root.browse-folder("project-location");
                } else if (action-id == "browse-source") {
                    root.browse-folder("source");
                } else if (action-id == "browse-output") {
                    root.browse-folder("output");
                } else if (action-id == "browse-device-install") {
                    root.browse-folder("device-install");
                }
            }
        }
    }

    SettingsSaveActionRow {
        button-width: root.save-button-width;
        action-label: root.ui-text.save-settings;
        action-clicked => {
            root.save-settings();
        }
    }

    WorkspacePanelSection {
        compact: root.compact;
        row-height: HubTokens.workspace-row-settings-detail;
        spacing-horizontal: HubTokens.panel-gap;
        spacing-vertical: HubTokens.panel-gap;

        OperationTimelinePanel {
            basis: HubTokens.panel-min-lg;
            flex-basis: HubTokens.panel-min-lg;
            grow: 1;
            flex-grow: 1;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.compact ? root.content-width : HubTokens.panel-min-lg;
            height: HubTokens.workspace-row-settings-detail;
            timeline-title: root.ui-text.operation-timeline;
            empty-title: root.ui-text.no-operation-timeline;
            empty-detail: root.ui-text.operation-timeline-empty-detail;
            operation-timeline: root.operation-timeline;
            operation-timeline-count: root.operation-timeline-count;
            row-height: HubTokens.list-row-md;
            timeline-scroll-y <=> root.operation-timeline-scroll-y;
            collapse-label: root.compact-labels;
        }
    }
}
