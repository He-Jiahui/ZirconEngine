import { LineEdit, ScrollView } from "std-widgets.slint";
import { FieldLabel, Panel, PillButton } from "shared.slint";

export component SettingsPage inherits Rectangle {
    in-out property <string> python-path;
    in-out property <string> cargo-path;
    in-out property <string> rustup-path;
    in-out property <string> project-location;
    in-out property <string> source-path;
    in-out property <string> output-path;
    in-out property <string> build-jobs;
    in-out property <string> build-profile;
    in-out property <string> language;
    callback save-settings();

    background: #11151a;

    ScrollView {
        content := Rectangle {
            width: root.width;
            height: 860px;
            background: #11151a;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: 28px;
                padding-right: 28px;
                padding-top: 184px;
                padding-bottom: 28px;
                spacing: 16px;

                HorizontalLayout {
                    spacing: 14px;

                    Panel {
                        horizontal-stretch: 1;
                        height: 250px;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            Text {
                                text: "Toolchain";
                                color: #f3f6f9;
                                font-size: 16px;
                                font-weight: 800;
                            }
                            FieldLabel { text: "Python executable"; }
                            LineEdit { placeholder-text: "Python executable"; text <=> root.python-path; }
                            FieldLabel { text: "Cargo executable"; }
                            LineEdit { placeholder-text: "Cargo executable"; text <=> root.cargo-path; }
                            FieldLabel { text: "Rustup executable"; }
                            LineEdit { placeholder-text: "Rustup executable"; text <=> root.rustup-path; }
                        }
                    }

                    Panel {
                        width: 360px;
                        height: 250px;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            Text {
                                text: "Build Defaults";
                                color: #f3f6f9;
                                font-size: 16px;
                                font-weight: 800;
                            }
                            FieldLabel { text: "Build profile"; }
                            LineEdit { placeholder-text: "debug or release"; text <=> root.build-profile; }
                            FieldLabel { text: "Build jobs"; }
                            LineEdit { placeholder-text: "Build jobs"; text <=> root.build-jobs; }
                            FieldLabel { text: "Language"; }
                            LineEdit { placeholder-text: "English or Chinese"; text <=> root.language; }
                        }
                    }
                }

                Panel {
                    height: 250px;
                    VerticalLayout {
                        padding: 18px;
                        spacing: 10px;
                        Text {
                            text: "Default Paths";
                            color: #f3f6f9;
                            font-size: 16px;
                            font-weight: 800;
                        }
                        FieldLabel { text: "Default project directory"; }
                        LineEdit { placeholder-text: "Default project directory"; text <=> root.project-location; }
                        FieldLabel { text: "Default source directory"; }
                        LineEdit { placeholder-text: "Default source directory"; text <=> root.source-path; }
                        FieldLabel { text: "Default staged output directory"; }
                        LineEdit { placeholder-text: "Default staged output directory"; text <=> root.output-path; }
                    }
                }

                HorizontalLayout {
                    spacing: 10px;
                    Rectangle { horizontal-stretch: 1; }
                    PillButton {
                        text: "Save Settings";
                        icon: ">";
                        primary: true;
                        clicked => {
                            root.save-settings();
                        }
                    }
                }
            }
        }
    }
}
