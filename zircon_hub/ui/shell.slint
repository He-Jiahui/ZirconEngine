import {
    BrandMark,
    CenteredIcon,
    HeaderStatusData,
    IconButton,
    MutedText,
    NavItemData,
    PillButton,
    SourceEngineData,
    SourceEngineRowData,
    StatusPill,
    UiTextData,
    WindowButton,
} from "shared.slint";
import { HubTokens } from "tokens.slint";
import { DropDownButton } from "inputs.slint";
import { NavRail } from "navigation.slint";
import { Badge, HeaderGroup, HubPanel } from "surfaces.slint";
import { ListTile, MaterialPalette, MaterialStyleMetrics, MaterialTypography } from "material_bridge.slint";

component HeaderEngineOption inherits Rectangle {
    in property <SourceEngineRowData> engine;
    callback selected(string);

    height: HubTokens.list-row-md;
    border-radius: MaterialStyleMetrics.border_radius_12;
    border-width: root.engine.active ? HubTokens.border-width : 0px;
    border-color: MaterialPalette.primary;
    background: root.engine.active ? MaterialPalette.secondary_container : transparent;
    clip: true;

    ListTile {
        width: parent.width;
        height: parent.height;
        text: root.engine.title;
        supporting_text: root.engine.status + " / " + root.engine.last-build;
        avatar_icon: @image-url("../assets/brand/zircon-mark.svg");
        avatar_background: root.engine.active ? MaterialPalette.primary_container : MaterialPalette.surface_container_high;
        avatar_foreground: root.engine.active ? MaterialPalette.primary : MaterialPalette.on_surface_variant;
        clicked => {
            root.selected(root.engine.id);
        }
    }
}

component HeaderEngineSelector inherits Rectangle {
    in property <SourceEngineData> current-engine;
    in property <[SourceEngineRowData]> engines;
    in property <int> engine-count;
    in property <UiTextData> ui-text;
    in property <length> selector-width: HubTokens.nav-width-expanded-min * 4 / 5;
    in property <length> selector-height: HubTokens.control-md;
    callback selected(string);

    width: root.selector-width;
    height: root.selector-height;

    DropDownButton {
        width: parent.width;
        height: parent.height;
        button-width: parent.width;
        text: root.current-engine.title;
        active: false;
        clicked => {
            popup.show();
        }
    }

    popup := PopupWindow {
        close-policy: close-on-click-outside;
        x: 0px;
        y: root.height + MaterialStyleMetrics.spacing_6;
        width: max(root.selector-width * 2, HubTokens.panel-min-sm);
        height: root.selector-height * 7;

        HubPanel {
            width: parent.width;
            height: parent.height;
            clip: true;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: HubTokens.toolbar-gap;
                spacing: HubTokens.space-2;

                HorizontalLayout {
                    height: HubTokens.icon-lg;
                    spacing: HubTokens.space-2;

                    Text {
                        text: root.ui-text.source-engines;
                        color: MaterialPalette.on_surface;
                        font-size: MaterialTypography.label_large.font_size;
                        font-weight: MaterialTypography.label_large.font_weight;
                    }

                    Rectangle { horizontal-stretch: 1; }

                    Text {
                        text: root.ui-text.registered;
                        color: MaterialPalette.on_surface_variant;
                        font-size: MaterialTypography.label_medium.font_size;
                    }
                }

                for engine in root.engines: HeaderEngineOption {
                    engine: engine;
                    selected(id) => {
                        popup.close();
                        root.selected(id);
                    }
                }

                if root.engine-count == 0: MutedText {
                    text: root.ui-text.no-source-engines;
                }
            }
        }
    }
}

component WindowDragRegion inherits Rectangle {
    in property <length> region-height: HubTokens.space-2;
    callback drag-start(float, float);
    callback drag-move(float, float);
    callback drag-end();

    height: root.region-height;
    horizontal-stretch: 1;
    background: transparent;

    drag-area := TouchArea {
        pointer-event(event) => {
            if (event.button != PointerEventButton.left) {
                return;
            }
            if (event.kind == PointerEventKind.down) {
                root.drag-start(drag-area.mouse-x / 1px, drag-area.mouse-y / 1px);
            }
            if (event.kind == PointerEventKind.up) {
                root.drag-end();
            }
        }
        moved => {
            root.drag-move(drag-area.mouse-x / 1px, drag-area.mouse-y / 1px);
        }
    }
}

export component HubTopHeader inherits HeaderGroup {
    in property <SourceEngineData> source-engine;
    in property <[SourceEngineRowData]> source-engines;
    in property <int> source-engine-count;
    in property <[HeaderStatusData]> header-statuses;
    in property <UiTextData> ui-text;
    in property <bool> compact: false;
    in property <length> header-height: HubTokens.shell-header-height;
    in property <length> drag-height: HubTokens.shell-drag-min;
    in property <length> row-height: HubTokens.shell-row-min;
    in property <length> pad-x: HubTokens.shell-pad-x-min;
    in property <length> gap: HubTokens.toolbar-gap;
    in property <length> nav-width: HubTokens.nav-width-expanded-min;
    in property <length> action-height: HubTokens.control-lg;
    callback select-engine(string);
    callback settings-clicked();
    callback window-minimize();
    callback window-toggle-maximize();
    callback window-close();
    callback window-drag-start(float, float);
    callback window-drag-move(float, float);
    callback window-drag-end();

    group-height: root.header-height;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: HubTokens.space-0;

        WindowDragRegion {
            region-height: root.drag-height;
            drag-start(x, y) => { root.window-drag-start(x, y); }
            drag-move(x, y) => { root.window-drag-move(x, y); }
            drag-end => { root.window-drag-end(); }
        }

        HorizontalLayout {
            height: root.row-height;
            horizontal-stretch: 1;
            padding-left: root.pad-x;
            padding-right: max(HubTokens.space-2, root.pad-x / 3);
            spacing: root.gap;
            alignment: center;

            HorizontalLayout {
                width: max(HubTokens.nav-width-collapsed-max + HubTokens.panel-gap * 5, min(HubTokens.nav-width-expanded-min - HubTokens.space-4, root.nav-width * 4 / 5));
                spacing: root.gap;
                alignment: center;
                BrandMark {}
                VerticalLayout {
                    height: parent.height;
                    spacing: HubTokens.space-0;
                    Rectangle {
                        vertical-stretch: 1;
                        min-height: 0px;
                    }
                    Text {
                        text: "ZIRCON HUB";
                        color: MaterialPalette.on_surface;
                        font-size: MaterialTypography.title_medium.font_size;
                        font-weight: MaterialTypography.title_medium.font_weight;
                    }
                    MutedText {
                        text: root.ui-text.game-engine;
                    }
                    Rectangle {
                        vertical-stretch: 1;
                        min-height: 0px;
                    }
                }
            }

            HeaderEngineSelector {
                selector-width: max(HubTokens.nav-width-collapsed-max * 2, min(HubTokens.nav-width-expanded-min, root.nav-width * 5 / 6));
                selector-height: max(HubTokens.control-sm, min(HubTokens.control-md, root.row-height * 2 / 3));
                current-engine: root.source-engine;
                engines: root.source-engines;
                engine-count: root.source-engine-count;
                ui-text: root.ui-text;
                selected(id) => {
                    root.select-engine(id);
                }
            }

            if !root.compact: Rectangle {
                width: HubTokens.border-width;
                height: HubTokens.control-sm;
                background: HubTokens.stroke-muted;
            }

            if !root.compact: HorizontalLayout {
                height: parent.height;
                spacing: root.gap;
                alignment: center;

                for pill in root.header-statuses: StatusPill {
                    icon: pill.icon;
                    icon-image: pill.icon-image;
                    has-icon-image: pill.has-icon-image;
                    text: pill.text;
                    accent-color: pill.state == "running" ? MaterialPalette.primary : (pill.state == "ok" ? MaterialPalette.primary : (pill.state == "warn" ? MaterialPalette.tertiary : (pill.state == "error" ? MaterialPalette.error : MaterialPalette.outline)));
                }
            }

            WindowDragRegion {
                horizontal-stretch: 1;
                region-height: root.action-height;
                drag-start(x, y) => { root.window-drag-start(x, y); }
                drag-move(x, y) => { root.window-drag-move(x, y); }
                drag-end => { root.window-drag-end(); }
            }

            IconButton {
                icon-image: @image-url("../assets/icons/ui/bell.svg");
                has-icon-image: true;
                enabled: false;
            }
            IconButton {
                icon-image: @image-url("../assets/icons/ui/help.svg");
                has-icon-image: true;
                enabled: false;
            }
            IconButton {
                icon-image: @image-url("../assets/icons/ui/settings.svg");
                has-icon-image: true;
                clicked => {
                    root.settings-clicked();
                }
            }

            Rectangle {
                width: HubTokens.border-width;
                height: root.row-height * 3 / 5;
                background: HubTokens.stroke-muted;
            }

            Rectangle {
                width: max(HubTokens.user-menu-min-width, min(HubTokens.user-menu-max-width, root.nav-width * 2 / 3));
                height: root.action-height;
                HorizontalLayout {
                    width: parent.width;
                    height: parent.height;
                    spacing: HubTokens.space-2;
                    alignment: center;
                    Rectangle {
                        width: HubTokens.icon-xl;
                        height: HubTokens.icon-xl;
                        border-radius: HubTokens.icon-xl / 2;
                        background: MaterialPalette.secondary_container;
                        Text {
                            text: root.ui-text.local-user-initials;
                            color: MaterialPalette.on_secondary_container;
                            font-size: MaterialTypography.label_medium_prominent.font_size;
                            font-weight: MaterialTypography.label_medium_prominent.font_weight;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    Text {
                        text: root.ui-text.local-user;
                        color: MaterialPalette.on_surface;
                        font-size: MaterialTypography.label_medium.font_size;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    CenteredIcon {
                        width: MaterialStyleMetrics.size_14;
                        height: parent.height;
                        icon-size: MaterialStyleMetrics.size_14;
                        source-image: @image-url("../assets/icons/ui/chevron-down.svg");
                        has-source-image: true;
                    }
                }
            }

            WindowButton {
                icon-image: @image-url("../assets/icons/ui/minimize.svg");
                has-icon-image: true;
                clicked => { root.window-minimize(); }
            }
            WindowButton {
                icon-image: @image-url("../assets/icons/ui/maximize.svg");
                has-icon-image: true;
                clicked => { root.window-toggle-maximize(); }
            }
            WindowButton {
                icon-image: @image-url("../assets/icons/ui/close.svg");
                has-icon-image: true;
                danger: true;
                clicked => { root.window-close(); }
            }
        }
    }
}

export component HubNavSidebar inherits Rectangle {
    in property <[NavItemData]> nav-items;
    in property <bool> collapsed: false;
    in property <bool> compact-height: false;
    in property <bool> task-running: false;
    in property <SourceEngineData> source-engine;
    in property <UiTextData> ui-text;
    in property <length> nav-width: HubTokens.nav-width-expanded-min;
    in property <length> nav-pad: HubTokens.space-3;
    in property <length> nav-status-height: HubTokens.shell-row-min * 3;
    in property <length> row-height: HubTokens.shell-row-min;
    in property <length> gap: HubTokens.toolbar-gap;
    callback clicked(string);
    callback toggle-collapse();

    width: root.nav-width;
    vertical-stretch: 1;
    background: HubTokens.surface-page;
    border-width: HubTokens.border-width;
    border-color: HubTokens.stroke-muted;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: root.nav-pad;
        spacing: root.gap;

        NavRail {
            width: parent.width;
            vertical-stretch: 1;
            rail-padding: 0px;
            rail-gap: root.gap;
            rail-background: transparent;
            items: root.nav-items;
            collapsed: root.collapsed;
            clicked(id) => {
                root.clicked(id);
            }
        }

        if !root.collapsed && !root.compact-height: HubPanel {
            height: root.nav-status-height;
            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: HubTokens.panel-gap;
                spacing: HubTokens.space-2;

                HorizontalLayout {
                    spacing: HubTokens.space-2;

                    Rectangle {
                        width: HubTokens.toolbar-gap;
                        height: HubTokens.toolbar-gap;
                        border-radius: HubTokens.toolbar-gap / 2;
                        background: root.task-running ? MaterialPalette.tertiary : MaterialPalette.primary;
                    }

                    Text {
                        text: root.ui-text.engine-status;
                        color: MaterialPalette.on_surface;
                        font-size: MaterialTypography.label_large.font_size;
                        font-weight: MaterialTypography.label_large.font_weight;
                    }
                }

                MutedText { text: root.source-engine.version; }

                Badge {
                    text: root.source-engine.status;
                    tone: "ok";
                    badge-width: HubTokens.control-md * 3;
                }

                Rectangle { vertical-stretch: 1; }

                HubPanel {
                    variant: "interactive";
                    height: HubTokens.control-md;

                    HorizontalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding-left: HubTokens.toolbar-gap;
                        padding-right: HubTokens.toolbar-gap;
                        spacing: HubTokens.space-2;
                        alignment: start;

                        CenteredIcon {
                            width: HubTokens.icon-xs;
                            height: parent.height;
                            icon-size: HubTokens.icon-xs;
                            source-image: @image-url("../assets/icons/ui/refresh.svg");
                            has-source-image: true;
                        }

                        Text {
                            text: root.ui-text.check-for-updates;
                            overflow: elide;
                            color: MaterialPalette.on_surface_variant;
                            font-size: MaterialTypography.label_medium.font_size;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }

        if !root.compact-height: Rectangle { height: HubTokens.border-width; background: HubTokens.stroke-muted; }
        if !root.compact-height: Rectangle {
            height: max(HubTokens.control-md, min(HubTokens.control-lg, root.row-height * 3 / 4));
            border-radius: MaterialStyleMetrics.border_radius_12;
            background: collapse-area.has-hover ? MaterialPalette.surface_container_high : transparent;

            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: root.collapsed ? 0px : HubTokens.space-2;
                padding-right: root.collapsed ? 0px : HubTokens.space-2;
                spacing: HubTokens.space-2;
                alignment: start;

                CenteredIcon {
                    width: root.collapsed ? parent.width : HubTokens.icon-sm;
                    height: parent.height;
                    icon-size: HubTokens.icon-sm;
                    source-image: root.collapsed ? @image-url("../assets/icons/ui/chevron-right.svg") : @image-url("../assets/icons/ui/collapse.svg");
                    has-source-image: true;
                }

                if !root.collapsed: MutedText {
                    text: root.ui-text.collapse;
                    vertical-alignment: center;
                }
            }

            collapse-area := TouchArea {
                clicked => {
                    root.toggle-collapse();
                }
            }
        }
    }
}

export component HubPageHeader inherits Rectangle {
    in property <string> selected-page;
    in property <string> selected-page-title;
    in property <string> selected-page-subtitle;
    in property <string> status-label;
    in property <bool> task-running: false;
    in property <UiTextData> ui-text;
    in property <length> page-title-height: HubTokens.shell-header-height + HubTokens.space-6;
    in property <length> page-pad-x: HubTokens.page-padding;
    in property <length> gap: HubTokens.toolbar-gap;
    in property <length> action-height: HubTokens.control-lg;
    callback import-project();
    callback create-project();

    height: root.page-title-height;
    horizontal-stretch: 1;
    background: HubTokens.surface-page;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: root.page-pad-x;
        padding-right: root.page-pad-x;
        spacing: root.gap;
        alignment: stretch;

        VerticalLayout {
            height: parent.height;
                spacing: MaterialStyleMetrics.spacing_6;
            Rectangle {
                vertical-stretch: 1;
                min-height: 0px;
            }
            Text {
                text: root.selected-page-title;
                color: MaterialPalette.on_surface;
                font-size: max(MaterialTypography.headline_small.font_size, min(MaterialTypography.headline_medium.font_size, root.page-title-height * 7 / 25));
                font-weight: MaterialTypography.headline_medium.font_weight;
            }
            MutedText {
                text: root.selected-page-subtitle;
            }
            Rectangle {
                vertical-stretch: 1;
                min-height: 0px;
            }
        }

        Rectangle { horizontal-stretch: 1; }

        if root.selected-page == "projects": VerticalLayout {
            height: parent.height;

            Rectangle {
                vertical-stretch: 1;
                min-height: 0px;
            }

            HorizontalLayout {
                height: root.action-height;
                spacing: root.gap;
                alignment: center;

                PillButton {
                    text: root.ui-text.import-project;
                    icon-image: @image-url("../assets/icons/ui/import.svg");
                    has-icon-image: true;
                    clicked => {
                        root.import-project();
                    }
                }

                PillButton {
                    text: root.ui-text.create-project;
                    icon-image: @image-url("../assets/icons/ui/plus.svg");
                    has-icon-image: true;
                    primary: true;
                    clicked => {
                        root.create-project();
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                min-height: 0px;
            }
        }

        if root.selected-page != "projects": Text {
            text: root.status-label;
            color: root.task-running ? MaterialPalette.primary : MaterialPalette.on_surface_variant;
            font-size: MaterialTypography.label_large.font_size;
            vertical-alignment: center;
        }
    }
}

export component HubStatusBar inherits Rectangle {
    in property <string> status-detail;
    in property <length> status-height: HubTokens.bottom-status-height;

    height: root.status-height;
    horizontal-stretch: 1;
    background: MaterialPalette.surface_container_low;
    border-color: HubTokens.stroke-muted;
    border-width: HubTokens.border-width;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: HubTokens.panel-gap;
        padding-right: HubTokens.panel-gap;
        alignment: center;

        Text {
            text: root.status-detail;
            color: MaterialPalette.on_surface_variant;
            font-size: MaterialTypography.label_medium.font_size;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
    }
}
