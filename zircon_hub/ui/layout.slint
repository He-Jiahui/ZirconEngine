import { HorizontalDivider, ScrollView, VerticalDivider } from "material_bridge.slint";
import { HubTokens, HubVisualSpec } from "tokens.slint";

export component Fill inherits Rectangle {
    in property <length> fill-spacing: HubTokens.space-0;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    min-width: 1px;
    min-height: 0px;
    background: transparent;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: root.fill-spacing;

        @children
    }
}

export component Divider inherits Rectangle {
    in property <bool> vertical: false;
    in property <brush> tone: HubTokens.stroke-muted;

    width: root.vertical ? HubTokens.border-width : 0px;
    height: root.vertical ? 0px : HubTokens.border-width;
    horizontal-stretch: root.vertical ? 0 : 1;
    vertical-stretch: root.vertical ? 1 : 0;
    background: transparent;

    if root.vertical: VerticalDivider {
        width: parent.width;
        height: parent.height;
    }

    if !root.vertical: HorizontalDivider {
        width: parent.width;
        height: parent.height;
    }
}

export component Stack inherits Rectangle {
    in property <bool> is-row: false;
    in property <bool> wrap: false;
    in property <length> gap: HubTokens.space-0;
    in property <length> gap-x: root.gap;
    in property <length> gap-y: root.gap;
    in property <length> stack-padding: HubTokens.space-0;
    in property <length> stack-padding-left: root.stack-padding;
    in property <length> stack-padding-right: root.stack-padding;
    in property <length> stack-padding-top: root.stack-padding;
    in property <length> stack-padding-bottom: root.stack-padding;

    background: transparent;

    FlexboxLayout {
        width: parent.width;
        height: parent.height;
        flex-direction: root.is-row ? FlexboxLayoutDirection.row : FlexboxLayoutDirection.column;
        flex-wrap: root.wrap ? FlexboxLayoutWrap.wrap : FlexboxLayoutWrap.no-wrap;
        align-content: FlexboxLayoutAlignContent.start;
        align-items: FlexboxLayoutAlignItems.stretch;
        spacing-horizontal: root.gap-x;
        spacing-vertical: root.gap-y;
        padding-left: root.stack-padding-left;
        padding-right: root.stack-padding-right;
        padding-top: root.stack-padding-top;
        padding-bottom: root.stack-padding-bottom;

        @children
    }
}

export component Row inherits Stack {
    is-row: true;
}

export component Column inherits Stack {
    is-row: false;
}

export component Flow inherits Stack {
    is-row: true;
    wrap: true;
}

export component ResponsiveSlot inherits Rectangle {
    in property <length> basis: HubTokens.panel-min-md;
    in property <float> grow: 1;
    in property <float> shrink: 1;
    in property <int> order: 0;

    background: transparent;

    @children
}

export component ResponsiveState inherits Rectangle {
    in property <length> viewport-width: 0px;
    in property <length> viewport-height: 0px;
    out property <bool> compact: root.viewport-width < HubTokens.breakpoint-compact;
    out property <bool> medium: root.viewport-width < HubTokens.breakpoint-medium;
    out property <bool> wide: root.viewport-width >= HubTokens.breakpoint-wide;
    out property <bool> short: root.viewport-height < HubTokens.breakpoint-short;

    width: 0px;
    height: 0px;
    background: transparent;
}

export component ResponsiveCollapse inherits Rectangle {
    in property <length> content-width: 0px;
    in property <length> collapse-at: HubTokens.breakpoint-medium;
    out property <bool> collapsed: root.content-width < root.collapse-at;

    width: 0px;
    height: 0px;
    background: transparent;
}

export component PanelGrid inherits Rectangle {
    in property <length> gap: HubTokens.panel-gap;
    in property <length> row-gap: root.gap;
    in property <length> grid-padding: HubTokens.space-0;
    in property <length> grid-padding-left: root.grid-padding;
    in property <length> grid-padding-right: root.grid-padding;
    in property <length> grid-padding-top: root.grid-padding;
    in property <length> grid-padding-bottom: root.grid-padding;
    in property <bool> compact: false;
    in property <bool> clip-content: true;

    min-width: 0px;
    preferred-width: 0px;
    horizontal-stretch: 1;
    background: transparent;
    clip: root.clip-content;

    FlexboxLayout {
        width: parent.width;
        height: parent.height;
        flex-direction: FlexboxLayoutDirection.row;
        flex-wrap: FlexboxLayoutWrap.wrap;
        align-content: FlexboxLayoutAlignContent.start;
        align-items: root.compact ? FlexboxLayoutAlignItems.stretch : FlexboxLayoutAlignItems.start;
        spacing-horizontal: root.gap;
        spacing-vertical: root.row-gap;
        padding-left: root.grid-padding-left;
        padding-right: root.grid-padding-right;
        padding-top: root.grid-padding-top;
        padding-bottom: root.grid-padding-bottom;

        @children
    }
}

export component Page inherits Rectangle {
    in-out property <length> scroll-y: 0px;
    in property <length> page-padding: root.width < HubTokens.breakpoint-compact ? HubTokens.page-padding-compact : HubTokens.page-padding;
    in property <length> page-padding-x: root.page-padding;
    in property <length> page-padding-y: root.page-padding;
    in property <length> bottom-padding: HubTokens.space-6;
    in property <length> gap: HubTokens.panel-gap;
    out property <length> content-width: max(1px, root.width - root.page-padding-x * 2);
    out property <length> viewport-height: max(HubTokens.control-md, root.height - HubTokens.bottom-status-height);
    out property <length> content-height: max(HubTokens.control-md, root.viewport-height - root.page-padding-y - root.bottom-padding);

    background: HubVisualSpec.page-background;
    clip: true;

    page-scroll := ScrollView {
        width: root.width;
        height: root.viewport-height;
        viewport_y <=> root.scroll-y;
        viewport_width: page-scroll.visible_width;
        viewport_height: max(page-scroll.visible_height, content-layout.preferred-height);
        vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
        horizontal_scrollbar_policy: ScrollBarPolicy.always-off;

        Rectangle {
            width: page-scroll.visible_width;
            height: page-scroll.viewport_height;
            background: HubVisualSpec.page-background;

            content-layout := VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: root.page-padding-x;
                padding-right: root.page-padding-x;
                padding-top: root.page-padding-y;
                padding-bottom: root.bottom-padding;
                spacing: root.gap;
                alignment: stretch;

                @children
            }
        }
    }
}

export component PageScrollSurface inherits Page {}

export component ResponsivePanelFlow inherits PanelGrid {
    in property <length> flow-height: HubTokens.panel-min-sm - HubTokens.space-6 - HubTokens.space-2;
    in property <length> spacing-horizontal: HubTokens.panel-gap;
    in property <length> spacing-vertical: HubTokens.panel-gap;

    min-height: root.flow-height;
    preferred-height: root.flow-height;
    max-height: root.flow-height;
    vertical-stretch: 0;
    gap: root.spacing-horizontal;
    row-gap: root.spacing-vertical;
}

export component WorkspacePanelSection inherits Rectangle {
    in property <bool> compact: false;
    in property <bool> compact-stack: true;
    in property <int> compact-rows: 2;
    in property <length> row-height: HubTokens.workspace-row-build-detail;
    in property <length> compact-height-override: 0px;
    in property <length> spacing-horizontal: HubTokens.panel-gap;
    in property <length> spacing-vertical: HubTokens.panel-gap;
    in property <length> section-padding: HubTokens.space-0;
    in property <length> section-padding-left: root.section-padding;
    in property <length> section-padding-right: root.section-padding;
    in property <length> section-padding-top: root.section-padding;
    in property <length> section-padding-bottom: root.section-padding;
    private property <int> compact-row-count: root.compact-rows < 1 ? 1 : root.compact-rows;
    private property <length> compact-height: root.row-height * root.compact-row-count + root.spacing-vertical * (root.compact-row-count - 1) + root.section-padding-top + root.section-padding-bottom;
    private property <length> regular-height: root.row-height + root.section-padding-top + root.section-padding-bottom;
    private property <length> section-height: root.compact ? (root.compact-height-override > 0px ? root.compact-height-override : root.compact-height) : root.regular-height;

    min-width: 0px;
    preferred-width: 0px;
    horizontal-stretch: 1;
    min-height: root.section-height;
    preferred-height: root.section-height;
    max-height: root.section-height;
    vertical-stretch: 0;
    background: transparent;
    clip: true;

    FlexboxLayout {
        width: parent.width;
        height: root.section-height;
        flex-direction: root.compact && root.compact-stack ? FlexboxLayoutDirection.column : FlexboxLayoutDirection.row;
        flex-wrap: root.compact && root.compact-stack ? FlexboxLayoutWrap.no-wrap : FlexboxLayoutWrap.wrap;
        align-content: FlexboxLayoutAlignContent.start;
        align-items: root.compact && root.compact-stack ? FlexboxLayoutAlignItems.stretch : FlexboxLayoutAlignItems.start;
        spacing-horizontal: root.spacing-horizontal;
        spacing-vertical: root.spacing-vertical;
        padding-left: root.section-padding-left;
        padding-right: root.section-padding-right;
        padding-top: root.section-padding-top;
        padding-bottom: root.section-padding-bottom;

        @children
    }
}
