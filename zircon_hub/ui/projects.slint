import {
    ProjectCardData,
    ProjectDetailData,
    ProjectTemplateData,
    QuickActionData,
    RecentProjectRowData,
    SourceEngineRowData,
    UiTextData,
} from "shared.slint";
import { ProjectDashboardPage } from "project_dashboard.slint";
import {
    ProjectBrowserPage,
    ProjectDetailPage,
    ProjectNewPage,
} from "project_pages.slint";
import { Fill, HubTokens } from "components.slint";

export component ProjectsPage inherits Fill {
    in-out property <string> project-subpage: "dashboard";
    in-out property <string> project-detail-return-subpage: "dashboard";
    in-out property <string> search-query;
    in-out property <string> project-path;
    in-out property <string> project-name;
    in-out property <string> new-project-location;
    in property <string> project-filter-label;
    in property <string> project-sort-label;
    in-out property <string> project-view-mode;
    in-out property <bool> project-cards-expanded: false;
    in property <[ProjectCardData]> project-cards;
    in property <int> project-card-count;
    in property <[RecentProjectRowData]> project-browser-rows;
    in property <int> project-browser-row-count;
    in property <[RecentProjectRowData]> dashboard-project-rows;
    in property <int> dashboard-project-row-count;
    in property <string> dashboard-project-title;
    in property <[ProjectTemplateData]> project-templates;
    in property <int> project-template-count;
    in property <bool> project-create-enabled: true;
    in property <string> project-create-template-label;
    in property <string> project-create-engine-label;
    in property <[SourceEngineRowData]> project-engine-rows;
    in property <int> project-engine-count;
    in property <ProjectDetailData> project-detail;
    in property <[QuickActionData]> quick-actions;
    in property <bool> viewport-compact: false;
    in property <UiTextData> ui-text;
    callback open-project();
    callback create-project();
    callback open-recent-project(string);
    callback select-project(string);
    callback open-project-detail(string);
    callback quick-action(string);
    callback search-projects(string);
    callback view-all-projects();
    callback browse-folder(string);
    callback set-project-filter(string);
    callback set-project-sort(string);
    callback set-project-view-mode(string);
    callback show-project-subpage(string);
    callback select-project-template(string);
    callback select-new-project-engine(string);
    callback select-project-detail-engine(string);
    callback toggle-project-pin();
    callback remove-project-from-hub();
    callback request-delete-project();
    callback cancel-delete-project();
    callback confirm-delete-project();

    background: HubTokens.surface-page;
    clip: true;

    if root.project-subpage == "dashboard": ProjectDashboardPage {
        horizontal-stretch: 1;
        vertical-stretch: 1;
        min-width: 1px;
        min-height: 0px;
        search-query <=> root.search-query;
        project-cards-expanded <=> root.project-cards-expanded;
        project-filter-label: root.project-filter-label;
        project-sort-label: root.project-sort-label;
        project-view-mode: root.project-view-mode;
        project-cards: root.project-cards;
        project-card-count: root.project-card-count;
        dashboard-project-rows: root.dashboard-project-rows;
        dashboard-project-row-count: root.dashboard-project-row-count;
        dashboard-project-title: root.dashboard-project-title;
        quick-actions: root.quick-actions;
        ui-text: root.ui-text;
        select-project(path) => { root.select-project(path); }
        open-project-detail(path) => {
            root.project-detail-return-subpage = "dashboard";
            root.project-subpage = "project-detail";
            root.open-project-detail(path);
        }
        quick-action(id) => { root.quick-action(id); }
        search-projects(query) => { root.search-projects(query); }
        view-all-projects => {
            root.project-view-mode = "list";
            root.project-subpage = "project-browser";
            root.view-all-projects();
        }
        set-project-filter(id) => { root.set-project-filter(id); }
        set-project-sort(id) => { root.set-project-sort(id); }
        set-project-view-mode(id) => {
            root.project-view-mode = id;
            root.set-project-view-mode(id);
        }
        show-project-subpage(id) => {
            root.project-subpage = id;
            root.show-project-subpage(id);
        }
    }

    if root.project-subpage == "new-project": ProjectNewPage {
        horizontal-stretch: 1;
        vertical-stretch: 1;
        min-width: 1px;
        min-height: 0px;
        project-name <=> root.project-name;
        project-location <=> root.new-project-location;
        templates: root.project-templates;
        template-count: root.project-template-count;
        create-enabled: root.project-create-enabled;
        selected-template-label: root.project-create-template-label;
        selected-engine-label: root.project-create-engine-label;
        engines: root.project-engine-rows;
        engine-count: root.project-engine-count;
        viewport-compact: root.viewport-compact;
        ui-text: root.ui-text;
        back => {
            root.project-subpage = "dashboard";
            root.show-project-subpage("dashboard");
        }
        browse-folder(target) => { root.browse-folder(target); }
        create-project => { root.create-project(); }
        select-template(id) => { root.select-project-template(id); }
        select-engine(id) => { root.select-new-project-engine(id); }
    }

    if root.project-subpage == "project-browser": ProjectBrowserPage {
        horizontal-stretch: 1;
        vertical-stretch: 1;
        min-width: 1px;
        min-height: 0px;
        search-query <=> root.search-query;
        project-filter-label: root.project-filter-label;
        project-sort-label: root.project-sort-label;
        list-title: root.dashboard-project-title;
        rows: root.project-browser-rows;
        row-count: root.project-browser-row-count;
        viewport-compact: root.viewport-compact;
        ui-text: root.ui-text;
        back => {
            root.project-view-mode = "grid";
            root.project-subpage = "dashboard";
            root.set-project-view-mode("grid");
            root.show-project-subpage("dashboard");
        }
        search-projects(query) => { root.search-projects(query); }
        set-project-filter(id) => { root.set-project-filter(id); }
        set-project-sort(id) => { root.set-project-sort(id); }
        select-project(path) => { root.select-project(path); }
        open-detail(path) => {
            root.project-detail-return-subpage = "project-browser";
            root.project-subpage = "project-detail";
            root.open-project-detail(path);
        }
    }

    if root.project-subpage == "project-detail": ProjectDetailPage {
        horizontal-stretch: 1;
        vertical-stretch: 1;
        min-width: 1px;
        min-height: 0px;
        project: root.project-detail;
        engines: root.project-engine-rows;
        engine-count: root.project-engine-count;
        viewport-compact: root.viewport-compact;
        ui-text: root.ui-text;
        back => {
            root.project-subpage = root.project-detail-return-subpage;
            if (root.project-detail-return-subpage == "dashboard") {
                root.project-view-mode = "grid";
                root.set-project-view-mode("grid");
            }
            root.show-project-subpage(root.project-detail-return-subpage);
        }
        open-project(path) => { root.open-recent-project(path); }
        select-engine(id) => { root.select-project-detail-engine(id); }
        toggle-pin => { root.toggle-project-pin(); }
        remove-from-hub => { root.remove-project-from-hub(); }
        request-delete => { root.request-delete-project(); }
        cancel-delete => { root.cancel-delete-project(); }
        confirm-delete => { root.confirm-delete-project(); }
    }
}
