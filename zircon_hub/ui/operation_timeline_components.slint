import { OperationTimelineRowData } from "shared.slint";
import { HubTokens } from "tokens.slint";
import { EmptyStateBlock, PanelHeader, PanelSlot } from "surfaces.slint";
import { InfoRow, PanelListViewport } from "data_display.slint";
import { MaterialStyleMetrics } from "material_bridge.slint";

export component OperationTimelineRow inherits InfoRow {
    in property <OperationTimelineRowData> record;
    in property <bool> collapse-label: false;

    row-height: HubTokens.list-row-md;
    title: root.record.action + " / " + root.record.target;
    detail: root.record.recovery != "" ? root.record.recovery : (root.record.log != "" ? root.record.log : (root.record.command != "" ? root.record.command : root.record.detail));
    meta: root.record.process-id != "" ? root.record.process-id + " / " + root.record.finished : root.record.finished;
    leading-image: root.record.success ? @image-url("../assets/icons/status/success.svg") : @image-url("../assets/icons/status/error.svg");
    has-leading-image: true;
    trailing-text: root.record.status;
    trailing-tone: root.record.success ? "ok" : "error";
    show-trailing-badge: true;
    collapse-trailing-label: root.collapse-label;
}

export component OperationTimelinePanel inherits PanelSlot {
    in property <string> timeline-title;
    in property <string> empty-title;
    in property <string> empty-detail;
    in property <[OperationTimelineRowData]> operation-timeline;
    in property <int> operation-timeline-count;
    in property <length> row-height: HubTokens.list-row-sm;
    in-out property <length> timeline-scroll-y: 0px;
    in property <bool> collapse-label: false;

    PanelHeader {
        title: root.timeline-title;
        subtitle: "";
        show-badge: true;
        badge-text: root.operation-timeline-count + "";
        badge-tone: "info";
    }

    PanelListViewport {
        scroll-y <=> root.timeline-scroll-y;
        row-count: root.operation-timeline-count;
        row-height: root.row-height;
        vertical-padding: HubTokens.space-0;
        empty-height: HubTokens.list-row-lg + HubTokens.space-4;

        for record in root.operation-timeline: OperationTimelineRow {
            record: record;
            collapse-label: root.collapse-label;
        }

        if root.operation-timeline-count == 0: EmptyStateBlock {
            height: HubTokens.list-row-lg + HubTokens.space-4;
            title: root.empty-title;
            detail: root.empty-detail;
            body-padding: MaterialStyleMetrics.padding_16;
            center-content: true;
        }
    }
}
