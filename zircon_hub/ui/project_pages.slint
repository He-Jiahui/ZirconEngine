import {
    MutedText,
    ProjectDetailData,
    ProjectTemplateData,
    RecentProjectRowData,
    SourceEngineRowData,
    UiTextData,
} from "shared.slint";
import {
    EmptyStateBlock,
    HubPanel,
    HubTokens,
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialText,
    MaterialTypography,
    PageScrollSurface,
    PanelHeader,
    PanelListViewport,
    PanelSlot,
    ResponsiveSlot,
    SearchBox,
    StatusBanner,
} from "components.slint";

import {
    PageHeader,
    ProjectCreateActionRow,
    ProjectCreateField,
    ProjectFilterSelect,
    ProjectBrowserRow,
    ProjectCreateSummary,
    ProjectDetailActionButton,
    ProjectDetailEngineSection,
    ProjectDetailInfoSection,
    ProjectDetailStatusStrip,
    ProjectEngineChoiceList,
    ProjectSortSelect,
    TemplateChoiceRow,
} from "project_page_components.slint";

export component ProjectNewPage inherits PageScrollSurface {
    in-out property <string> project-name;
    in-out property <string> project-location;
    in property <[ProjectTemplateData]> templates;
    in property <int> template-count;
    in property <bool> create-enabled: true;
    in property <string> selected-template-label;
    in property <string> selected-engine-label;
    in property <[SourceEngineRowData]> engines;
    in property <int> engine-count;
    in property <bool> viewport-compact: false;
    in property <UiTextData> ui-text;
    callback back;
    callback browse-folder(string);
    callback create-project;
    callback select-template(string);
    callback select-engine(string);

    private property <bool> compact-page: root.viewport-compact;
    private property <length> page-pad: root.compact-page ? HubTokens.page-padding-compact : HubTokens.page-padding;
    private property <length> page-gap: root.compact-page ? HubTokens.toolbar-gap : HubTokens.panel-gap;
    private property <length> field-height: HubTokens.input-field;
    private property <length> header-height: max(root.field-height * 11 / 10, min(root.field-height * 3 / 2, root.content-height / 13));
    private property <length> choice-row-height: max(HubTokens.list-row-md, min(HubTokens.list-row-lg, root.content-height / 10));
    private property <length> template-row-height: max(HubTokens.list-row-md, min(HubTokens.list-row-lg, root.content-height / 9));
    private property <length> summary-row-height: max(HubTokens.control-sm, min(root.field-height, root.content-height / 18));
    private property <length> section-label-height: MaterialTypography.body_small.font_size * 3 / 2;
    private property <int> engine-panel-rows: root.engine-count < 1 ? 1 : (root.engine-count > 3 ? 3 : root.engine-count);
    private property <length> engine-row-gap: MaterialStyleMetrics.spacing_8;
    private property <length> engine-list-height: root.engine-count == 0 ? root.choice-row-height : root.engine-panel-rows * root.choice-row-height + (root.engine-panel-rows - 1) * root.engine-row-gap;
    private property <length> engine-section-height: root.section-label-height + MaterialStyleMetrics.spacing_8 + root.engine-list-height;
    private property <length> summary-header-height: root.narrow-flow ? HubTokens.control-md : HubTokens.list-row-sm;
    private property <length> summary-section-height: root.summary-header-height + root.summary-row-height * 2 + root.page-gap;
    private property <bool> narrow-flow: root.content-width < HubTokens.panel-min-md + HubTokens.panel-min-sm + root.page-gap;
    private property <length> main-panel-basis: HubTokens.panel-min-lg + HubTokens.control-lg;
    private property <length> template-panel-basis: HubTokens.panel-min-md;
    private property <length> create-action-row-height: root.field-height;
    private property <length> form-panel-height: HubTokens.space-4 * 2 + HubTokens.list-row-sm + root.field-height * 2 + root.engine-section-height + root.create-action-row-height + root.page-gap * 4;
    private property <length> summary-panel-padding: root.narrow-flow ? HubTokens.space-3 : HubTokens.space-4;
    private property <length> summary-panel-height: root.summary-panel-padding * 2 + root.summary-section-height;
    private property <length> project-settings-panel-height: root.narrow-flow ? root.form-panel-height : root.form-panel-height + root.summary-section-height + root.page-gap;
    private property <int> template-panel-rows: root.template-count < 1 ? 1 : (root.template-count > 4 ? 4 : root.template-count);
    private property <length> template-list-height: root.template-count == 0 ? HubTokens.list-row-lg : root.template-panel-rows * root.template-row-height + (root.template-panel-rows - 1) * root.page-gap;
    private property <length> template-panel-height: HubTokens.space-4 * 2 + HubTokens.control-md + root.template-list-height + root.page-gap;
    private property <bool> compact-choice-labels: root.narrow-flow;
    private property <length> flow-visible-height: max(root.content-height - root.header-height - root.page-gap, root.project-settings-panel-height);
    private property <string> summary-title: root.ui-text.project-summary-title;
    private property <string> summary-subtitle: root.ui-text.project-summary-subtitle;
    private property <string> summary-root-path-label: root.ui-text.project-root-path;
    private property <string> summary-create-label: root.ui-text.create;
    private property <string> summary-ready-label: root.ui-text.ready-to-create;
    private property <string> summary-complete-label: root.ui-text.complete-project-settings;
    private property <bool> project-name-ready: root.project-name != "";
    private property <bool> project-location-ready: root.project-location != "";
    private property <bool> form-ready: root.create-enabled && root.project-name-ready && root.project-location-ready;
    private property <length> flow-height: root.narrow-flow ? root.project-settings-panel-height + root.page-gap + root.summary-panel-height + root.page-gap + root.template-panel-height : max(root.flow-visible-height, root.template-panel-height);
    private property <length> new-engine-scroll-y: 0px;
    private property <length> template-scroll-y: 0px;

    page-padding: root.page-pad;
    bottom-padding: root.page-pad;
    gap: root.page-gap;
    background: HubTokens.surface-page;
    clip: true;

                PageHeader {
                    header-height: root.header-height;
                    title: root.ui-text.new-project-title;
                    subtitle: root.ui-text.new-project-subtitle;
                    back => { root.back(); }
                }

                FlexboxLayout {
                    horizontal-stretch: 1;
                    height: root.flow-height;
                    flex-direction: FlexboxLayoutDirection.row;
                    flex-wrap: root.narrow-flow ? FlexboxLayoutWrap.wrap : FlexboxLayoutWrap.no-wrap;
                    align-content: FlexboxLayoutAlignContent.start;
                    align-items: FlexboxLayoutAlignItems.start;
                    spacing-horizontal: root.page-gap;
                    spacing-vertical: root.page-gap;

                    PanelSlot {
                        basis: root.narrow-flow ? root.content-width : root.main-panel-basis;
                        flex-basis: root.narrow-flow ? root.content-width : root.main-panel-basis;
                        grow: root.narrow-flow ? 1 : 2;
                        flex-grow: root.narrow-flow ? 1 : 2;
                        shrink: 1;
                        flex-shrink: 1;
                        min-width: root.narrow-flow ? root.content-width : HubTokens.panel-min-md;
                        height: root.narrow-flow ? root.project-settings-panel-height : root.flow-height;
                        body-padding: HubTokens.space-4;
                        body-spacing: root.page-gap;

                            PanelHeader {
                                title: root.ui-text.project-settings-title;
                                subtitle: root.ui-text.project-settings-subtitle;
                            }

                            ProjectCreateField {
                                field-height: root.field-height;
                                field-label: root.ui-text.project-name;
                                field-placeholder: root.ui-text.project-name;
                                field-text <=> root.project-name;
                            }

                            ProjectCreateField {
                                field-height: root.field-height;
                                field-label: root.ui-text.location;
                                field-placeholder: root.ui-text.location;
                                field-text <=> root.project-location;
                                show-browse: true;
                                browse-label: root.ui-text.browse;
                                browse-clicked => { root.browse-folder("new-project-location"); }
                            }

                            VerticalLayout {
                                height: root.engine-section-height;
                                vertical-stretch: 0;
                                spacing: MaterialStyleMetrics.spacing_8;
                                MaterialText {
                                    height: root.section-label-height;
                                    text: root.ui-text.source-engine;
                                    color: MaterialPalette.on_surface_variant;
                                    style: MaterialTypography.body_small;
                                    vertical_alignment: center;
                                }
                                ProjectEngineChoiceList {
                                    engines: root.engines;
                                    engine-count: root.engine-count;
                                    list-height: root.engine-list-height;
                                    list-scroll-y <=> root.new-engine-scroll-y;
                                    row-height: root.choice-row-height;
                                    row-spacing: root.engine-row-gap;
                                    empty-height: root.choice-row-height;
                                    selected-label: root.ui-text.selected-label;
                                    registered-label: root.ui-text.registered;
                                    empty-title: root.ui-text.register-source-engine-before-create;
                                    collapse-label: root.compact-choice-labels;
                                    selected(id) => { root.select-engine(id); }
                                }
                            }

                            ProjectCreateActionRow {
                                row-height: root.create-action-row-height;
                                row-spacing: root.page-gap;
                                action-label: root.ui-text.create;
                                action-enabled: root.form-ready;
                                action-clicked => { root.create-project(); }
                            }

                            ProjectCreateSummary {
                                visible: !root.narrow-flow;
                                title: root.summary-title;
                                subtitle: root.narrow-flow ? "" : root.summary-subtitle;
                                root-path-label: root.summary-root-path-label;
                                create-label: root.summary-create-label;
                                ready-label: root.summary-ready-label;
                                complete-label: root.summary-complete-label;
                                project-location: root.project-location;
                                project-name: root.project-name;
                                form-ready: root.form-ready;
                                row-height: root.summary-row-height;
                                summary-height: root.narrow-flow ? 0px : root.summary-section-height;
                                row-spacing: max(MaterialStyleMetrics.spacing_4, root.page-gap / 2);
                            }
                    }

                    PanelSlot {
                        visible: root.narrow-flow;
                        basis: root.narrow-flow ? root.content-width : 0px;
                        flex-basis: root.narrow-flow ? root.content-width : 0px;
                        grow: root.narrow-flow ? 1 : 0;
                        flex-grow: root.narrow-flow ? 1 : 0;
                        shrink: 1;
                        flex-shrink: 1;
                        min-width: root.narrow-flow ? root.content-width : 0px;
                        height: root.narrow-flow ? root.summary-panel-height : 0px;
                        body-padding: root.summary-panel-padding;
                        body-spacing: 0px;

                            ProjectCreateSummary {
                                title: root.summary-title;
                                subtitle: root.narrow-flow ? "" : root.summary-subtitle;
                                root-path-label: root.summary-root-path-label;
                                create-label: root.summary-create-label;
                                ready-label: root.summary-ready-label;
                                complete-label: root.summary-complete-label;
                                project-location: root.project-location;
                                project-name: root.project-name;
                                form-ready: root.form-ready;
                                row-height: root.summary-row-height;
                                summary-height: root.narrow-flow ? root.summary-section-height : 0px;
                                row-spacing: max(MaterialStyleMetrics.spacing_4, root.page-gap / 2);
                            }
                    }

                    PanelSlot {
                        basis: root.narrow-flow ? root.content-width : root.template-panel-basis;
                        flex-basis: root.narrow-flow ? root.content-width : root.template-panel-basis;
                        grow: 1;
                        flex-grow: 1;
                        shrink: 1;
                        flex-shrink: 1;
                        min-width: root.narrow-flow ? root.content-width : HubTokens.panel-min-sm;
                        height: root.narrow-flow ? root.template-panel-height : root.flow-height;
                        body-padding: HubTokens.space-4;
                        body-spacing: root.page-gap;

                            PanelHeader {
                                title: root.ui-text.templates-title;
                                show-badge: true;
                                badge-text: root.template-count + "";
                                badge-tone: "neutral";
                            }

                            template-list := PanelListViewport {
                                height: root.template-list-height;
                                scroll-y <=> root.template-scroll-y;
                                row-count: root.template-count;
                                row-height: root.template-row-height;
                                row-spacing: root.page-gap;
                                vertical-padding: 0px;
                                empty-height: HubTokens.list-row-lg;

                                for template in root.templates: TemplateChoiceRow {
                                    row-height: root.template-row-height;
                                    template: template;
                                    soon-label: root.ui-text.soon-label;
                                    collapse-label: root.compact-choice-labels;
                                    selected(id) => { root.select-template(id); }
                                }
                            }
                }
    }
}


export component ProjectBrowserPage inherits PageScrollSurface {
    in-out property <string> search-query;
    in property <string> project-filter-label;
    in property <string> project-sort-label;
    in property <string> list-title: "Project List";
    in property <[RecentProjectRowData]> rows;
    in property <int> row-count;
    in property <bool> viewport-compact: false;
    in property <UiTextData> ui-text;
    callback back;
    callback search-projects(string);
    callback set-project-filter(string);
    callback set-project-sort(string);
    callback select-project(string);
    callback open-detail(string);

    private property <length> browser-scroll-y: 0px;
    private property <bool> compact-page: root.viewport-compact;
    private property <length> page-pad: root.compact-page ? HubTokens.page-padding-compact : HubTokens.page-padding;
    private property <length> page-gap: root.compact-page ? HubTokens.toolbar-gap : HubTokens.panel-gap;
    private property <length> toolbar-height: max(HubTokens.input-field, min(HubTokens.input-field + HubTokens.space-2, root.content-height / 18));
    private property <length> toolbar-control-min-width: root.toolbar-height * 18 / 5;
    private property <bool> toolbar-wrap: root.content-width < root.toolbar-control-min-width * 4 + root.page-gap * 3;
    private property <length> browser-row-height: max(HubTokens.list-row-md, min(HubTokens.list-row-lg + MaterialStyleMetrics.spacing_16, root.content-height / 11));
    private property <length> browser-row-gap: max(MaterialStyleMetrics.spacing_6, min(MaterialStyleMetrics.spacing_12, root.content-height / 90));
    private property <length> toolbar-row-height: root.toolbar-wrap ? root.toolbar-height * 2 + root.page-gap : root.toolbar-height;
    private property <length> toolbar-search-basis: root.toolbar-wrap ? root.content-width : root.content-width * HubTokens.project-browser-toolbar-search-ratio;
    private property <length> toolbar-select-basis: root.toolbar-wrap ? root.toolbar-control-min-width : max(root.content-width * HubTokens.project-browser-toolbar-select-ratio, root.toolbar-control-min-width);
    private property <length> browser-row-slot-height: root.browser-row-height + root.browser-row-gap;
    private property <length> browser-panel-chrome-height: HubTokens.control-md + root.page-gap * 3;
    private property <int> browser-visible-rows: root.row-count < 5 ? root.row-count : 5;
    private property <length> browser-available-height: max(root.browser-panel-chrome-height + root.browser-row-slot-height, root.content-height - root.toolbar-height * 6 / 5 - root.toolbar-row-height - root.page-gap * 2);
    private property <length> browser-available-list-height: max(root.browser-row-slot-height, root.browser-available-height - root.browser-panel-chrome-height);
    private property <int> browser-fit-row-count: Math.floor(root.browser-available-list-height / root.browser-row-slot-height);
    private property <int> browser-fit-rows: root.browser-fit-row-count < 1 ? 1 : root.browser-fit-row-count;
    private property <int> browser-panel-rows: root.browser-visible-rows < 1 ? 1 : (root.browser-visible-rows < root.browser-fit-rows ? root.browser-visible-rows : root.browser-fit-rows);
    private property <length> browser-list-height: root.row-count == 0 ? HubTokens.list-row-lg : root.browser-panel-rows * root.browser-row-height + (root.browser-panel-rows - 1) * root.browser-row-gap;
    private property <length> browser-panel-height: root.browser-panel-chrome-height + root.browser-list-height;
    page-padding: root.page-pad;
    bottom-padding: root.page-pad;
    gap: root.page-gap;
    background: HubTokens.surface-page;
    clip: true;

        PageHeader {
            header-height: root.toolbar-height * 6 / 5;
            title: root.ui-text.project-browser-title;
            subtitle: root.ui-text.project-browser-subtitle;
            back => { root.back(); }
        }

        FlexboxLayout {
            height: root.toolbar-row-height;
            flex-direction: FlexboxLayoutDirection.row;
            flex-wrap: FlexboxLayoutWrap.wrap;
            align-content: FlexboxLayoutAlignContent.start;
            align-items: FlexboxLayoutAlignItems.start;
            spacing-horizontal: root.page-gap;
            spacing-vertical: root.page-gap;

            ResponsiveSlot {
                basis: root.toolbar-search-basis;
                flex-basis: root.toolbar-search-basis;
                grow: 1;
                flex-grow: 1;
                shrink: 1;
                flex-shrink: 1;
                min-width: root.toolbar-search-basis;
                height: root.toolbar-height;

                SearchBox {
                    width: parent.width;
                    height: parent.height;
                    box-width: parent.width;
                    box-height: root.toolbar-height;
                    text <=> root.search-query;
                    placeholder: root.ui-text.search-projects;
                    edited(query) => { root.search-projects(query); }
                }
            }

            ResponsiveSlot {
                basis: root.toolbar-select-basis;
                flex-basis: root.toolbar-select-basis;
                grow: 1;
                flex-grow: 1;
                shrink: 1;
                flex-shrink: 1;
                min-width: root.toolbar-select-basis;
                height: root.toolbar-height;

                ProjectFilterSelect {
                    width: parent.width;
                    height: parent.height;
                    select-height: root.toolbar-height;
                    label: root.project-filter-label;
                    ui-text: root.ui-text;
                    selected(id) => { root.set-project-filter(id); }
                }
            }

            ResponsiveSlot {
                basis: root.toolbar-select-basis;
                flex-basis: root.toolbar-select-basis;
                grow: 1;
                flex-grow: 1;
                shrink: 1;
                flex-shrink: 1;
                min-width: root.toolbar-select-basis;
                height: root.toolbar-height;

                ProjectSortSelect {
                    width: parent.width;
                    height: parent.height;
                    select-height: root.toolbar-height;
                    label: root.project-sort-label;
                    ui-text: root.ui-text;
                    selected(id) => { root.set-project-sort(id); }
                }
            }
        }

        HubPanel {
            horizontal-stretch: 1;
            height: root.browser-panel-height;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: root.page-gap;
                spacing: root.page-gap;

                PanelHeader {
                    title: root.list-title;
                    show-badge: true;
                    badge-text: root.row-count + "";
                    badge-tone: "neutral";
                }

                browser-list := PanelListViewport {
                    horizontal-stretch: 1;
                    vertical-stretch: 0;
                    height: root.browser-list-height;
                    scroll-y <=> root.browser-scroll-y;
                    row-count: root.row-count;
                    row-height: root.browser-row-height;
                    row-spacing: root.browser-row-gap;
                    vertical-padding: 0px;
                    empty-height: HubTokens.list-row-lg;

                    for row in root.rows: ProjectBrowserRow {
                        row-width: browser-list.visible_width;
                        row-height: root.browser-row-height;
                        project: row;
                        pinned-label: root.ui-text.pinned-label;
                        missing-label: root.ui-text.missing-label;
                        select(path) => { root.select-project(path); }
                        open-detail(path) => { root.open-detail(path); }
                    }

                    if root.row-count == 0: EmptyStateBlock {
                        height: HubTokens.list-row-lg;
                        title: root.ui-text.no-projects-match;
                        body-padding: HubTokens.space-4;
                        center-content: true;
                    }
                }
            }
        }
    }

export component ProjectDetailPage inherits PageScrollSurface {
    in property <ProjectDetailData> project;
    in property <[SourceEngineRowData]> engines;
    in property <int> engine-count;
    in property <bool> viewport-compact: false;
    in property <UiTextData> ui-text;
    callback back;
    callback open-project(string);
    callback select-engine(string);
    callback toggle-pin;
    callback remove-from-hub;
    callback request-delete;
    callback cancel-delete;
    callback confirm-delete;

    private property <bool> compact-page: root.viewport-compact;
    private property <length> page-pad: root.compact-page ? HubTokens.page-padding-compact : HubTokens.page-padding;
    private property <length> page-gap: root.compact-page ? HubTokens.toolbar-gap : HubTokens.panel-gap;
    private property <bool> narrow-flow: root.content-width < HubTokens.panel-min-lg + HubTokens.panel-min-md + root.page-gap;
    private property <length> detail-panel-padding: root.narrow-flow ? HubTokens.space-3 : HubTokens.space-4;
    private property <length> cover-height: root.narrow-flow ? HubTokens.list-row-lg : max(root.action-row-height * 5 / 2, min(root.action-row-height * 7 / 2, root.content-height * HubTokens.project-detail-cover-ratio));
    private property <length> detail-choice-row-height: max(HubTokens.list-row-md, min(HubTokens.list-row-md + MaterialStyleMetrics.spacing_8, root.content-height / 13));
    private property <length> action-row-height: max(HubTokens.control-sm, min(HubTokens.control-lg, root.content-height / 20));
    private property <length> status-row-height: max(MaterialStyleMetrics.size_24, root.action-row-height * 3 / 5);
    private property <length> status-gap: max(MaterialStyleMetrics.spacing_8, root.action-row-height / 4);
    private property <length> info-row-height: root.narrow-flow ? HubTokens.control-sm : max(root.action-row-height * 7 / 10, min(root.action-row-height * 9 / 10, root.content-height * HubTokens.project-detail-info-row-ratio));
    private property <length> detail-info-row-gap: max(MaterialStyleMetrics.spacing_4, root.page-gap / 2);
    private property <length> detail-title-header-height: root.narrow-flow ? HubTokens.control-md : HubTokens.list-row-sm;
    private property <length> detail-info-header-height: root.narrow-flow ? HubTokens.control-md : HubTokens.list-row-sm;
    private property <length> detail-info-section-height: root.detail-info-header-height + root.info-row-height * 5 + root.detail-info-row-gap * 5;
    private property <length> version-badge-width: max(root.action-row-height * 3, root.content-width * HubTokens.project-detail-version-badge-ratio);
    private property <length> pin-badge-width: max(root.action-row-height * 2, root.content-width * HubTokens.project-detail-pin-badge-ratio);
    private property <int> detail-engine-panel-rows: root.engine-count < 1 ? 1 : (root.engine-count > 3 ? 3 : root.engine-count);
    private property <length> detail-engine-row-gap: max(MaterialStyleMetrics.spacing_4, root.page-gap / 2);
    private property <length> detail-engine-list-height: root.engine-count == 0 ? HubTokens.list-row-lg : root.detail-engine-panel-rows * root.detail-choice-row-height + (root.detail-engine-panel-rows - 1) * root.detail-engine-row-gap;
    private property <length> detail-engine-section-height: HubTokens.list-row-sm + root.detail-engine-list-height + root.page-gap;
    private property <length> detail-main-panel-height: root.detail-panel-padding * 2 + root.cover-height + root.detail-title-header-height + root.status-row-height + root.detail-info-section-height + root.page-gap * 3;
    private property <length> detail-action-standard-height: HubTokens.control-md + root.action-row-height * 4 + HubTokens.control-sm + root.detail-engine-section-height + root.page-gap * 6;
    private property <length> detail-action-delete-height: HubTokens.control-md + HubTokens.list-row-sm + root.action-row-height * 2 + root.page-gap * 3;
    private property <length> detail-action-panel-height: root.detail-panel-padding * 2 + (root.project.pending-delete ? root.detail-action-delete-height : root.detail-action-standard-height);
    private property <length> detail-header-height: max(HubTokens.control-lg, root.action-row-height * 6 / 5);
    private property <length> detail-visible-height: max(root.content-height - root.detail-header-height - root.page-gap, root.detail-main-panel-height);
    private property <length> detail-main-height: root.narrow-flow ? root.detail-main-panel-height : max(root.detail-visible-height, root.detail-main-panel-height);
    private property <length> detail-action-height: root.narrow-flow ? root.detail-action-panel-height : max(root.detail-visible-height, root.detail-action-panel-height);
    private property <length> detail-flow-height: root.narrow-flow ? root.detail-main-height + root.page-gap + root.detail-action-height : max(root.detail-main-height, root.detail-action-height);
    private property <length> detail-engine-scroll-y: 0px;
    page-padding: root.page-pad;
    bottom-padding: root.page-pad;
    gap: root.page-gap;
    background: HubTokens.surface-page;
    clip: true;

                PageHeader {
                    header-height: root.detail-header-height;
                    title: root.ui-text.project-detail-title;
                    subtitle: root.project.title;
                    back => { root.back(); }
                }

                FlexboxLayout {
                    horizontal-stretch: 1;
                    height: root.detail-flow-height;
                    flex-direction: FlexboxLayoutDirection.row;
                    flex-wrap: root.narrow-flow ? FlexboxLayoutWrap.wrap : FlexboxLayoutWrap.no-wrap;
                    align-content: FlexboxLayoutAlignContent.start;
                    align-items: FlexboxLayoutAlignItems.start;
                    spacing-horizontal: root.page-gap;
                    spacing-vertical: root.page-gap;

                    PanelSlot {
                        basis: root.narrow-flow ? root.content-width : HubTokens.panel-min-lg;
                        flex-basis: root.narrow-flow ? root.content-width : HubTokens.panel-min-lg;
                        grow: 2;
                        flex-grow: 2;
                        shrink: 1;
                        flex-shrink: 1;
                        min-width: root.narrow-flow ? root.content-width : HubTokens.panel-min-md;
                        height: root.detail-main-height;
                        body-padding: root.detail-panel-padding;
                        body-spacing: root.page-gap;

                    Rectangle {
                        horizontal-stretch: 1;
                        height: root.cover-height;
                        border-radius: MaterialStyleMetrics.border_radius_12;
                        background: root.project.accent == 0 ? MaterialPalette.primary_container : (root.project.accent == 1 ? MaterialPalette.secondary_container : MaterialPalette.tertiary_container);
                        clip: true;
                        if root.project.has-cover: Image {
                            width: parent.width;
                            height: parent.height;
                            source: root.project.cover-image;
                            image-fit: cover;
                        }
                    }

                    PanelHeader {
                        title: root.project.title;
                        subtitle: root.narrow-flow ? "" : root.project.project-path;
                        show-badge: true;
                        badge-text: root.project.status;
                        badge-tone: root.project.missing ? "warning" : "accent";
                    }

                    ProjectDetailStatusStrip {
                        row-height: root.status-row-height;
                        row-spacing: root.status-gap;
                        version-badge-width: root.version-badge-width;
                        pin-badge-width: root.pin-badge-width;
                        detail: root.project;
                        copy: root.ui-text;
                    }

                    ProjectDetailInfoSection {
                        section-height: root.detail-info-section-height;
                        row-height: root.info-row-height;
                        row-spacing: root.detail-info-row-gap;
                        header-subtitle: root.narrow-flow ? "" : root.ui-text.project-info-subtitle;
                        project: root.project;
                        ui-text: root.ui-text;
                    }

                    }

                    PanelSlot {
                        basis: root.narrow-flow ? root.content-width : HubTokens.panel-min-md;
                        flex-basis: root.narrow-flow ? root.content-width : HubTokens.panel-min-md;
                        grow: 1;
                        flex-grow: 1;
                        shrink: 1;
                        flex-shrink: 1;
                        min-width: root.narrow-flow ? root.content-width : HubTokens.panel-min-sm;
                        height: root.detail-action-height;
                        body-padding: root.detail-panel-padding;
                        body-spacing: root.page-gap;

                    PanelHeader { title: root.ui-text.project-actions-title; }

                    if root.project.pending-delete: StatusBanner {
                        horizontal-stretch: 1;
                        title: root.ui-text.confirm-delete;
                        detail: root.ui-text.recycle-bin-delete-detail;
                        tone: "error";
                    }

                    if root.project.pending-delete: ProjectDetailActionButton {
                        action-height: root.action-row-height;
                        text: root.ui-text.confirm-delete;
                        action-icon: @image-url("../assets/icons/ui/alert.svg");
                        enabled: root.project.can-delete;
                        clicked => { root.confirm-delete(); }
                    }

                    if root.project.pending-delete: ProjectDetailActionButton {
                        action-height: root.action-row-height;
                        text: root.ui-text.cancel-delete;
                        action-icon: @image-url("../assets/icons/ui/close.svg");
                        clicked => { root.cancel-delete(); }
                    }

                    if !root.project.pending-delete: ProjectDetailActionButton {
                        action-height: root.action-row-height;
                        text: root.ui-text.open;
                        action-icon: @image-url("../assets/icons/nav/editor.svg");
                        primary: true;
                        enabled: root.project.can-open;
                        clicked => { root.open-project(root.project.open-path); }
                    }

                    if !root.project.pending-delete: ProjectDetailActionButton {
                        action-height: root.action-row-height;
                        text: root.project.pinned ? root.ui-text.unpin-project : root.ui-text.pin-project;
                        action-icon: @image-url("../assets/icons/ui/grid.svg");
                        clicked => { root.toggle-pin(); }
                    }

                    if !root.project.pending-delete: ProjectDetailActionButton {
                        action-height: root.action-row-height;
                        text: root.ui-text.remove-from-hub;
                        action-icon: @image-url("../assets/icons/ui/close.svg");
                        clicked => { root.remove-from-hub(); }
                    }

                    if !root.project.pending-delete: MutedText {
                        height: HubTokens.control-sm;
                        text: root.ui-text.remove-from-hub-detail;
                        overflow: elide;
                    }

                    if !root.project.pending-delete: ProjectDetailActionButton {
                        action-height: root.action-row-height;
                        text: root.ui-text.delete-project;
                        action-icon: @image-url("../assets/icons/ui/alert.svg");
                        enabled: root.project.can-delete;
                        clicked => { root.request-delete(); }
                    }

                    if !root.project.pending-delete: ProjectDetailEngineSection {
                        section-height: root.detail-engine-section-height;
                        section-spacing: root.page-gap;
                        detail: root.project;
                        copy: root.ui-text;
                        engines: root.engines;
                        engine-count: root.engine-count;
                        list-height: root.detail-engine-list-height;
                        list-scroll-y <=> root.detail-engine-scroll-y;
                        row-height: root.detail-choice-row-height;
                        row-spacing: root.detail-engine-row-gap;
                        empty-height: HubTokens.list-row-lg;
                        collapse-label: root.narrow-flow;
                        selected(id) => { root.select-engine(id); }
                    }
                }
            }
        }
