import { MutedText, PillButton } from "shared.slint";
import { HubPanel, PanelHeader } from "components.slint";

export component PlaceholderPage inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> action-label: "Open Editor";
    in property <string> reserved-text;
    callback primary-action();

    background: #11151a;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 28px;
        padding-right: 28px;
        padding-top: 28px;
        padding-bottom: 28px;
        spacing: 18px;

        HubPanel {
            height: 240px;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: 24px;
                spacing: 12px;

                PanelHeader {
                    title: root.title;
                    subtitle: root.subtitle;
                }

                MutedText {
                    text: root.reserved-text;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: 10px;

                    PillButton {
                        text: root.action-label;
                        icon-image: @image-url("../assets/icons/ui/chevron-right.svg");
                        has-icon-image: true;
                        clicked => {
                            root.primary-action();
                        }
                    }
                }
            }
        }
    }
}
