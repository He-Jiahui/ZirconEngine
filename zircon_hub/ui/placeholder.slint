import { MutedText, PillButton } from "shared.slint";
import { HubPanel, HubTokens, MaterialStyleMetrics, PanelHeader } from "components.slint";

export component PlaceholderPage inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> action-label: "Open Editor";
    in property <string> reserved-text;
    callback primary-action();

    background: HubTokens.surface-page;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: HubTokens.page-padding;
        padding-right: HubTokens.page-padding;
        padding-top: HubTokens.page-padding;
        padding-bottom: HubTokens.page-padding;
        spacing: HubTokens.panel-gap;

        HubPanel {
            height: HubTokens.list-row-lg * 3;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: MaterialStyleMetrics.padding_24;
                spacing: HubTokens.toolbar-gap;

                PanelHeader {
                    title: root.title;
                    subtitle: root.subtitle;
                }

                MutedText {
                    text: root.reserved-text;
                }

                Rectangle { vertical-stretch: 1; }

                HorizontalLayout {
                    spacing: HubTokens.toolbar-gap;

                    PillButton {
                        text: root.action-label;
                        icon-image: @image-url("../assets/icons/ui/chevron-right.svg");
                        has-icon-image: true;
                        clicked => {
                            root.primary-action();
                        }
                    }
                }
            }
        }
    }
}
