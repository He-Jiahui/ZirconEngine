import {
    QuickActionData,
    RecentProjectRowData,
    SourceBuildHistoryRowData,
    IconButton,
    MutedText,
} from "shared.slint";
import { HubTokens } from "tokens.slint";
import { PageScrollSurface } from "layout.slint";
import { HubPanel, PanelHeader, StatusBadge } from "surfaces.slint";
import {
    ListTile,
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialText,
    MaterialTypography,
    ScrollView,
    StateLayerArea,
} from "material_bridge.slint";

export component InfoRow inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <string> meta;
    in property <image> leading-image;
    in property <bool> has-leading-image: false;
    in property <int> accent: 0;
    in property <string> trailing-text;
    in property <string> trailing-tone: "neutral";
    in property <bool> show-trailing-badge: false;
    in property <bool> show-arrow: false;
    in property <bool> enabled: true;
    in property <bool> selected: false;
    in property <length> row-height: HubTokens.list-row-md;
    callback clicked;

    private property <length> trailing-slot-width: root.show-trailing-badge ? (root.show-arrow ? HubTokens.control-md * 4 : HubTokens.control-md * 3) : (root.show-arrow ? HubTokens.control-md : 0px);
    private property <length> trailing-icon-size: max(MaterialStyleMetrics.size_32, min(HubTokens.control-md, root.row-height * 7 / 12));
    private property <color> avatar-background: root.accent == 0 ? MaterialPalette.primary_container : (root.accent == 1 ? MaterialPalette.secondary_container : (root.accent == 2 ? MaterialPalette.tertiary_container : MaterialPalette.surface_container_highest));
    private property <color> avatar-foreground: root.accent == 0 ? MaterialPalette.primary : (root.accent == 1 ? MaterialPalette.secondary : (root.accent == 2 ? MaterialPalette.tertiary : MaterialPalette.on_surface_variant));
    private property <string> supporting-text: root.detail == "" ? root.meta : (root.meta == "" ? root.detail : root.detail + " / " + root.meta);

    horizontal-stretch: 1;
    height: root.row-height;
    min-width: 1px;
    preferred-width: 0px;
    border-radius: MaterialStyleMetrics.border_radius_12;
    border-width: HubTokens.border-width;
    border-color: root.selected ? MaterialPalette.primary : MaterialPalette.outline_variant;
    background: !root.enabled ? MaterialPalette.surface_container_low.with_alpha(MaterialPalette.disable_opacity) : (root.selected ? MaterialPalette.secondary_container : MaterialPalette.surface_container_low);
    clip: true;

    ListTile {
        width: parent.width;
        height: parent.height;
        text: root.title;
        supporting_text: root.supporting-text;
        avatar_icon: root.has-leading-image ? root.leading-image : @image-url("../assets/brand/zircon-mark.svg");
        avatar_background: root.enabled ? root.avatar-background : MaterialPalette.surface_container_high;
        avatar_foreground: root.enabled ? root.avatar-foreground : MaterialPalette.on_surface_variant;
        enabled: root.enabled;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }

        Rectangle {
            width: root.trailing-slot-width;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;

                Rectangle { vertical-stretch: 1; min-height: 0px; }

                HorizontalLayout {
                    width: parent.width;
                    height: max(HubTokens.control-sm, root.trailing-icon-size);
                    spacing: HubTokens.space-2;
                    alignment: end;

                    if root.show-trailing-badge: StatusBadge {
                        text: root.trailing-text;
                        tone: root.trailing-tone;
                    }

                    if root.show-arrow: IconButton {
                        width: root.trailing-icon-size;
                        height: root.trailing-icon-size;
                        icon-image: @image-url("../assets/icons/ui/chevron-right.svg");
                        has-icon-image: true;
                        enabled: root.enabled;
                        clicked => {
                            if (root.enabled) {
                                root.clicked();
                            }
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; min-height: 0px; }
            }
        }
    }
}

export component ActionRow inherits Rectangle {
    in property <QuickActionData> action;
    in property <length> row-height: HubTokens.list-row-md;
    callback activate(string);

    private property <length> trailing-size: max(MaterialStyleMetrics.size_32, min(HubTokens.control-md, root.row-height * 7 / 12));

    horizontal-stretch: 1;
    height: root.row-height;
    min-width: 1px;
    preferred-width: 0px;
    border-radius: MaterialStyleMetrics.border_radius_12;
    border-width: HubTokens.border-width;
    border-color: MaterialPalette.outline_variant;
    background: MaterialPalette.surface_container_low;
    clip: true;

    ListTile {
        width: parent.width;
        height: parent.height;
        text: root.action.title;
        supporting_text: root.action.detail;
        avatar_icon: root.action.has-icon-image ? root.action.icon-image : @image-url("../assets/icons/ui/alert.svg");
        avatar_background: root.action.enabled ? MaterialPalette.primary_container : MaterialPalette.surface_container_high;
        avatar_foreground: root.action.enabled ? MaterialPalette.primary : MaterialPalette.on_surface_variant;
        enabled: root.action.enabled;
        clicked => {
            if (root.action.enabled) {
                root.activate(root.action.id);
            }
        }

        Rectangle {
            width: root.trailing-size;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;

                Rectangle { vertical-stretch: 1; min-height: 0px; }

                HorizontalLayout {
                    height: root.trailing-size;
                    alignment: end;

                    IconButton {
                        width: root.trailing-size;
                        height: root.trailing-size;
                        icon-image: @image-url("../assets/icons/ui/chevron-right.svg");
                        has-icon-image: true;
                        enabled: root.action.enabled;
                        clicked => {
                            root.activate(root.action.id);
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; min-height: 0px; }
            }
        }
    }
}

export component BuildHistoryRow inherits InfoRow {
    in property <SourceBuildHistoryRowData> record;

    row-height: HubTokens.list-row-md;
    title: root.record.detail;
    detail: root.record.output-path;
    meta: root.record.profile + " / " + root.record.finished;
    leading-image: root.record.success ? @image-url("../assets/icons/status/success.svg") : @image-url("../assets/icons/status/error.svg");
    has-leading-image: true;
    trailing-text: root.record.status;
    trailing-tone: root.record.success ? "ok" : "error";
    show-trailing-badge: true;
}

export component TableColumnHeader inherits Rectangle {
    in property <string> text;
    in property <length> row-height: MaterialStyleMetrics.size_24 + MaterialStyleMetrics.size_2;

    height: root.row-height;
    background: transparent;

    MaterialText {
        width: parent.width;
        height: parent.height;
        text: root.text;
        overflow: elide;
        color: MaterialPalette.on_surface_variant;
        style: MaterialTypography.label_medium;
        vertical_alignment: center;
    }
}

export component ProjectTableRow inherits Rectangle {
    in property <RecentProjectRowData> project;
    in property <string> action-tooltip: "";
    in property <length> row-height: HubTokens.table-row;
    in property <length> row-gap: HubTokens.toolbar-gap;
    in property <length> content-gap: HubTokens.space-2;
    in property <length> name-min-width: HubTokens.panel-min-sm * 2 / 5;
    in property <length> version-width: HubTokens.control-md * 3;
    in property <length> version-min-width: HubTokens.control-md * 5 / 2;
    in property <length> modified-width: HubTokens.control-md * 5 / 2;
    in property <length> modified-min-width: HubTokens.control-md * 2;
    in property <length> location-min-width: HubTokens.control-md * 3;
    in property <length> action-size: HubTokens.table-row;
    callback select(string);
    callback open(string);

    private property <length> thumb-size: max(root.row-height * 6 / 7, min(root.action-size, root.row-height));

    height: root.row-height;
    border-radius: MaterialStyleMetrics.border_radius_8;
    border-width: root.project.selected ? HubTokens.border-width : 0px;
    border-color: root.project.selected ? HubTokens.accent : transparent;
    background: root.project.selected ? MaterialPalette.primary_container : transparent;
    clip: true;

    row-state := StateLayerArea {
        width: parent.width;
        height: parent.height;
        color: root.project.selected ? MaterialPalette.on_primary_container : MaterialPalette.on_surface;
        border_radius: MaterialStyleMetrics.border_radius_8;
        clicked => {
            root.select(root.project.project-path);
        }
    }

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: root.row-gap;
        alignment: center;

        Rectangle {
            horizontal-stretch: 2;
            min-width: root.name-min-width;
            height: parent.height;
            clip: true;

            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                spacing: root.content-gap;
                alignment: start;

                Rectangle {
                    width: root.thumb-size;
                    height: root.thumb-size;
                    border-radius: MaterialStyleMetrics.border_radius_8;
                    border-width: HubTokens.border-width;
                    border-color: HubTokens.accent;
                    background: root.project.accent == 0 ? MaterialPalette.primary_container : (root.project.accent == 1 ? MaterialPalette.secondary_container : (root.project.accent == 2 ? MaterialPalette.tertiary_container : MaterialPalette.surface_container_high));
                    clip: true;
                    if root.project.has-cover: Image {
                        width: parent.width;
                        height: parent.height;
                        source: root.project.cover-image;
                        image-fit: cover;
                    }
                    if !root.project.has-cover: Image {
                        width: parent.width;
                        height: parent.height;
                        source: @image-url("../assets/brand/zircon-mark.svg");
                        image-fit: contain;
                    }
                }

                MaterialText {
                    text: root.project.title;
                    overflow: elide;
                    color: root.project.selected ? MaterialPalette.on_primary_container : MaterialPalette.on_surface;
                    style: MaterialTypography.label_large;
                    vertical_alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }

        MaterialText {
            text: root.project.version;
            overflow: elide;
            color: MaterialPalette.on_surface_variant;
            style: MaterialTypography.body_small;
            vertical_alignment: center;
            preferred-width: root.version-width;
            min-width: root.version-min-width;
        }

        MaterialText {
            text: root.project.modified;
            overflow: elide;
            color: MaterialPalette.on_surface_variant;
            style: MaterialTypography.body_small;
            vertical_alignment: center;
            preferred-width: root.modified-width;
            min-width: root.modified-min-width;
        }

        MaterialText {
            text: root.project.project-path;
            overflow: elide;
            color: MaterialPalette.on_surface_variant;
            style: MaterialTypography.body_small;
            vertical_alignment: center;
            horizontal-stretch: 2;
            min-width: root.location-min-width;
        }

        IconButton {
            width: root.action-size;
            height: root.action-size;
            icon-image: @image-url("../assets/icons/ui/more-vertical.svg");
            has-icon-image: true;
            clicked => {
                root.open(root.project.project-path);
            }
        }
    }
}

export component DataTable inherits Rectangle {
    in property <[RecentProjectRowData]> rows;
    in property <int> row-count;
    in property <string> name-label;
    in property <string> version-label;
    in property <string> modified-label;
    in property <string> location-label;
    in property <string> empty-text;
    callback select(string);
    callback open(string);

    in property <length> row-height: HubTokens.table-row;
    in property <length> header-height: max(root.row-height * 9 / 10, MaterialStyleMetrics.size_24 + MaterialStyleMetrics.size_2);
    in property <length> row-gap: max(MaterialStyleMetrics.spacing_2, min(MaterialStyleMetrics.spacing_4, root.row-height / 8));
    in property <length> column-gap: HubTokens.toolbar-gap;
    in property <length> action-size: root.row-height;
    in property <length> name-min-width: HubTokens.panel-min-sm * 2 / 5;
    in property <length> version-width: HubTokens.control-md * 3;
    in property <length> version-min-width: HubTokens.control-md * 5 / 2;
    in property <length> modified-width: HubTokens.control-md * 5 / 2;
    in property <length> modified-min-width: HubTokens.control-md * 2;
    in property <length> location-min-width: HubTokens.control-md * 3;

    private property <length> scroll-y: 0px;

    clip: true;
    background: transparent;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: MaterialStyleMetrics.spacing_4;

        HorizontalLayout {
            height: root.header-height;
            spacing: root.column-gap;
            alignment: start;

            TableColumnHeader {
                text: root.name-label;
                row-height: root.header-height;
                horizontal-stretch: 2;
                min-width: root.name-min-width;
            }
            TableColumnHeader {
                text: root.version-label;
                row-height: root.header-height;
                preferred-width: root.version-width;
                min-width: root.version-min-width;
            }
            TableColumnHeader {
                text: root.modified-label;
                row-height: root.header-height;
                preferred-width: root.modified-width;
                min-width: root.modified-min-width;
            }
            TableColumnHeader {
                text: root.location-label;
                row-height: root.header-height;
                horizontal-stretch: 2;
                min-width: root.location-min-width;
            }
            Rectangle {
                width: root.action-size;
                height: root.action-size;
            }
        }

        Rectangle {
            height: HubTokens.border-width;
            horizontal-stretch: 1;
            background: HubTokens.stroke-muted;
        }

        table-scroll := ScrollView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            viewport_y <=> root.scroll-y;
            viewport_width: table-scroll.visible_width;
            viewport_height: max(table-scroll.visible_height, root.row-count * (root.row-height + root.row-gap) + root.row-gap * 4);
            vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
            horizontal_scrollbar_policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: table-scroll.visible_width;
                height: table-scroll.viewport_height;
                background: transparent;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding-top: root.row-gap * 2;
                    padding-bottom: root.row-gap * 2;
                    spacing: root.row-gap;

                    for row in root.rows: ProjectTableRow {
                        project: row;
                        row-height: root.row-height;
                        row-gap: root.column-gap;
                        content-gap: max(MaterialStyleMetrics.spacing_6, root.column-gap * 2 / 3);
                        name-min-width: root.name-min-width;
                        version-width: root.version-width;
                        version-min-width: root.version-min-width;
                        modified-width: root.modified-width;
                        modified-min-width: root.modified-min-width;
                        location-min-width: root.location-min-width;
                        action-size: root.action-size;
                        select(path) => {
                            root.select(path);
                        }
                        open(path) => {
                            root.open(path);
                        }
                    }

                    if root.row-count == 0: MutedText {
                        text: root.empty-text;
                    }
                }
            }
        }
    }
}

export component CatalogListPanel inherits HubPanel {
    in-out property <length> scroll-y: 0px;
    in property <string> title;
    in property <string> badge-text;
    in property <string> badge-tone: "accent";
    in property <string> empty-title;
    in property <string> empty-detail;
    in property <int> row-count;
    in property <length> row-height: HubTokens.list-row-lg;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    min-height: HubTokens.list-row-lg * 4;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: HubTokens.space-4;
        spacing: HubTokens.toolbar-gap;

        PanelHeader {
            title: root.title;
            show-badge: true;
            badge-text: root.badge-text;
            badge-tone: root.badge-tone;
        }

        catalog-scroll := ScrollView {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            viewport_y <=> root.scroll-y;
            viewport_width: catalog-scroll.visible_width;
            viewport_height: max(catalog-scroll.visible_height, (root.row-count == 0 ? HubTokens.list-row-lg + HubTokens.space-4 : root.row-count * (root.row-height + HubTokens.space-2) + HubTokens.space-2));
            vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
            horizontal_scrollbar_policy: ScrollBarPolicy.always-off;

            Rectangle {
                width: catalog-scroll.visible_width;
                height: catalog-scroll.viewport_height;
                background: transparent;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding-top: HubTokens.space-1;
                    padding-bottom: HubTokens.space-1;
                    spacing: HubTokens.space-2;

                    if root.row-count == 0: Rectangle {
                        horizontal-stretch: 1;
                        height: HubTokens.list-row-lg + HubTokens.space-2;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: MaterialStyleMetrics.padding_14;
                            spacing: MaterialStyleMetrics.spacing_6;

                            MaterialText {
                                text: root.empty-title;
                                overflow: elide;
                                color: MaterialPalette.on_surface;
                                style: MaterialTypography.label_large;
                            }

                            if root.empty-detail != "": MutedText {
                                text: root.empty-detail;
                                overflow: elide;
                            }
                        }
                    }

                    @children
                }
            }
        }
    }
}

export component CatalogPage inherits Rectangle {
    in-out property <length> scroll-y: 0px;
    in-out property <length> list-scroll-y: 0px;
    in property <string> title;
    in property <string> badge-text;
    in property <string> badge-tone: "accent";
    in property <string> empty-title;
    in property <string> empty-detail;
    in property <int> row-count;
    in property <length> row-height: HubTokens.list-row-lg;
    private property <length> content-height: page-surface.content-height;
    private property <length> panel-height: max(HubTokens.list-row-lg * 4, root.content-height);

    background: HubTokens.surface-page;

    page-surface := PageScrollSurface {
        width: root.width;
        height: root.height;
        scroll-y <=> root.scroll-y;

        CatalogListPanel {
            scroll-y <=> root.list-scroll-y;
            height: root.panel-height;
            title: root.title;
            badge-text: root.badge-text;
            badge-tone: root.badge-tone;
            empty-title: root.empty-title;
            empty-detail: root.empty-detail;
            row-count: root.row-count;
            row-height: root.row-height;

            @children
        }
    }
}

export component PanelListViewport inherits ScrollView {
    in-out property <length> scroll-y: 0px;
    in property <int> row-count;
    in property <length> row-height: HubTokens.list-row-lg;
    in property <length> row-spacing: HubTokens.space-2;
    in property <length> vertical-padding: HubTokens.space-1;
    in property <length> empty-height: HubTokens.list-row-lg + HubTokens.space-4;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    viewport_y <=> root.scroll-y;
    viewport_width: root.visible_width;
    viewport_height: max(
        root.visible_height,
        root.row-count == 0 ? root.empty-height : root.row-count * (root.row-height + root.row-spacing) + root.vertical-padding * 2,
    );
    vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
    horizontal_scrollbar_policy: ScrollBarPolicy.always-off;

    Rectangle {
        width: root.visible_width;
        height: root.viewport_height;
        background: transparent;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-top: root.vertical-padding;
            padding-bottom: root.vertical-padding;
            spacing: root.row-spacing;

            @children
        }
    }
}
