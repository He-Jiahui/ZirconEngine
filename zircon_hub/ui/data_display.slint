import {
    QuickActionData,
    SourceBuildHistoryRowData,
    IconButton,
    MutedText,
} from "shared.slint";
import { HubTokens, HubVisualSpec } from "tokens.slint";
import { PageScrollSurface } from "layout.slint";
import { EmptyStateBlock, HubPanel, PanelHeader, PanelSlot, StatusBadge } from "surfaces.slint";
import {
    Icon,
    ListTile,
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialText,
    MaterialTypography,
    ScrollView,
    StateLayerArea,
} from "material_bridge.slint";

export struct TreeItemData {
    id: string,
    title: string,
    detail: string,
    depth: int,
    expanded: bool,
    selected: bool,
    disabled: bool,
    has-children: bool,
    icon-image: image,
    has-icon-image: bool,
    trailing-text: string,
    trailing-tone: string,
}

export component InfoRow inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <string> meta;
    in property <image> leading-image;
    in property <bool> has-leading-image: false;
    in property <int> accent: 0;
    in property <string> trailing-text;
    in property <string> trailing-tone: "neutral";
    in property <bool> show-trailing-badge: false;
    in property <bool> collapse-trailing-label: false;
    in property <bool> show-arrow: false;
    in property <bool> enabled: true;
    in property <bool> selected: false;
    in property <bool> focused: false;
    in property <bool> pressed: false;
    in property <bool> hovered: false;
    in property <length> row-height: HubTokens.list-row-md;
    in property <length> idle-border-width: HubTokens.border-width;
    in property <length> selected-border-width: HubTokens.border-width;
    in property <color> idle-background: HubVisualSpec.panel-background;
    in property <color> selected-background: MaterialPalette.secondary_container;
    in property <color> enabled-avatar-background: root.avatar-background;
    in property <color> enabled-avatar-foreground: root.avatar-foreground;
    callback clicked;

    private property <length> trailing-slot-width: root.show-trailing-badge ? (root.collapse-trailing-label ? (root.show-arrow ? HubTokens.control-md : 0px) : (root.show-arrow ? HubTokens.control-md * 4 : HubTokens.control-md * 3)) : (root.show-arrow ? HubTokens.control-md : 0px);
    private property <length> trailing-icon-size: max(MaterialStyleMetrics.size_32, min(HubTokens.control-md, root.row-height * 7 / 12));
    private property <color> avatar-background: root.accent == 0 ? MaterialPalette.primary_container : (root.accent == 1 ? MaterialPalette.secondary_container : (root.accent == 2 ? MaterialPalette.tertiary_container : MaterialPalette.surface_container_highest));
    private property <color> avatar-foreground: root.accent == 0 ? MaterialPalette.primary : (root.accent == 1 ? MaterialPalette.secondary : (root.accent == 2 ? MaterialPalette.tertiary : MaterialPalette.on_surface_variant));
    private property <string> supporting-text: root.detail == "" ? root.meta : (root.meta == "" ? root.detail : root.detail + " / " + root.meta);

    horizontal-stretch: 1;
    height: root.row-height;
    min-width: 1px;
    preferred-width: 0px;
    border-radius: HubVisualSpec.panel-radius;
    border-width: root.focused ? HubVisualSpec.focus-ring-width : (root.selected ? root.selected-border-width : root.idle-border-width);
    border-color: root.focused ? HubVisualSpec.focus-ring-color : (root.selected ? HubVisualSpec.accent-stroke : HubVisualSpec.outline-muted);
    background: !root.enabled ? HubVisualSpec.panel-background.with_alpha(HubVisualSpec.disabled-opacity) : (root.selected ? root.selected-background : root.idle-background);
    clip: true;

    ListTile {
        width: parent.width;
        height: parent.height;
        text: root.title;
        supporting_text: root.supporting-text;
        avatar_icon: root.has-leading-image ? root.leading-image : @image-url("../assets/brand/zircon-mark.svg");
        avatar_background: root.enabled ? root.enabled-avatar-background : MaterialPalette.surface_container_high;
        avatar_foreground: root.enabled ? root.enabled-avatar-foreground : MaterialPalette.on_surface_variant;
        enabled: root.enabled;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }

        Rectangle {
            width: root.trailing-slot-width;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;

                Rectangle { vertical-stretch: 1; min-height: 0px; }

                HorizontalLayout {
                    width: parent.width;
                    height: max(HubTokens.control-sm, root.trailing-icon-size);
                    spacing: HubTokens.space-2;
                    alignment: end;

                    if root.show-trailing-badge && !root.collapse-trailing-label: StatusBadge {
                        text: root.trailing-text;
                        tone: root.trailing-tone;
                    }

                    if root.show-arrow: IconButton {
                        width: root.trailing-icon-size;
                        height: root.trailing-icon-size;
                        icon-image: @image-url("../assets/icons/ui/chevron-right.svg");
                        has-icon-image: true;
                        enabled: root.enabled;
                        clicked => {
                            if (root.enabled) {
                                root.clicked();
                            }
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; min-height: 0px; }
            }
        }
    }
}

export component ActionRow inherits Rectangle {
    in property <QuickActionData> action;
    in property <length> row-height: HubTokens.list-row-md;
    in property <bool> plain-avatar: false;
    in property <bool> plain-trailing: false;
    in property <bool> show-trailing: true;
    in property <bool> compact-shell: false;
    in property <bool> focused: false;
    in property <float> disabled-shell-opacity: 1.0;
    in property <color> enabled-avatar-background: MaterialPalette.primary_container;
    in property <color> enabled-avatar-foreground: MaterialPalette.primary;
    in property <color> disabled-avatar-background: MaterialPalette.surface_container_high;
    in property <color> disabled-avatar-foreground: MaterialPalette.on_surface_variant;
    callback activate(string);

    private property <length> trailing-size: max(MaterialStyleMetrics.size_32, min(HubTokens.control-md, root.row-height * 7 / 12));
    private property <length> row-corner-radius: root.compact-shell ? HubVisualSpec.compact-radius : HubVisualSpec.panel-radius;
    private property <color> action-avatar-background: root.plain-avatar ? transparent : (root.action.enabled ? root.enabled-avatar-background : root.disabled-avatar-background);
    private property <color> action-avatar-foreground: root.plain-avatar ? MaterialPalette.on_surface : (root.action.enabled ? root.enabled-avatar-foreground : root.disabled-avatar-foreground);

    horizontal-stretch: 1;
    height: root.row-height;
    min-width: 1px;
    preferred-width: 0px;
    border-radius: root.row-corner-radius;
    border-width: root.focused ? HubVisualSpec.focus-ring-width : HubTokens.border-width;
    border-color: root.focused ? HubVisualSpec.focus-ring-color : HubVisualSpec.outline-muted;
    background: root.action.enabled ? HubVisualSpec.panel-background : HubVisualSpec.panel-background.with_alpha(root.disabled-shell-opacity);
    clip: true;

    ListTile {
        width: parent.width;
        height: parent.height;
        text: root.action.title;
        supporting_text: root.action.detail;
        avatar_icon: root.action.has-icon-image ? root.action.icon-image : @image-url("../assets/icons/ui/alert.svg");
        avatar_background: root.action-avatar-background;
        avatar_foreground: root.action-avatar-foreground;
        enabled: root.action.enabled;
        clicked => {
            if (root.action.enabled) {
                root.activate(root.action.id);
            }
        }

        Rectangle {
            width: root.show-trailing ? root.trailing-size : 0px;
            height: parent.height;
            background: transparent;

            VerticalLayout {
                width: parent.width;
                height: parent.height;

                Rectangle { vertical-stretch: 1; min-height: 0px; }

                HorizontalLayout {
                    height: root.trailing-size;
                    alignment: end;

                    if root.show-trailing && !root.plain-trailing: IconButton {
                            width: root.trailing-size;
                            height: root.trailing-size;
                            icon-image: @image-url("../assets/icons/ui/chevron-right.svg");
                            has-icon-image: true;
                            enabled: root.action.enabled;
                            clicked => {
                                root.activate(root.action.id);
                            }
                        }

                    if root.show-trailing && root.plain-trailing: Rectangle {
                        width: root.trailing-size;
                        height: root.trailing-size;

                        StateLayerArea {
                            width: parent.width;
                            height: parent.height;
                            color: MaterialPalette.on_surface;
                            border_radius: HubVisualSpec.compact-radius;
                            clicked => {
                                root.activate(root.action.id);
                            }
                        }

                        Image {
                            width: HubTokens.icon-sm;
                            height: HubTokens.icon-sm;
                            source: @image-url("../assets/icons/ui/chevron-right.svg");
                            colorize: MaterialPalette.on_surface;
                        }
                    }
                }

                Rectangle { vertical-stretch: 1; min-height: 0px; }
            }
        }
    }
}

export component MetricCard inherits HubPanel {
    in property <string> label;
    in property <string> primary;
    in property <string> secondary;
    in property <bool> compact: false;

    min-height: root.compact ? HubTokens.list-row-md + HubTokens.space-2 : HubTokens.list-row-md;
    horizontal-stretch: 1;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: MaterialStyleMetrics.padding_16;
        padding-right: MaterialStyleMetrics.padding_16;
        padding-top: root.compact ? HubTokens.space-2 : MaterialStyleMetrics.padding_16;
        padding-bottom: root.compact ? HubTokens.space-2 : MaterialStyleMetrics.padding_16;
        spacing: root.compact ? HubTokens.space-1 : MaterialStyleMetrics.spacing_6;

        MutedText {
            text: root.label;
            overflow: elide;
        }

        MaterialText {
            text: root.primary;
            overflow: elide;
            color: MaterialPalette.on_surface;
            style: MaterialTypography.title_small;
        }

        MutedText {
            text: root.secondary;
            overflow: elide;
        }
    }
}

export component BuildHistoryRow inherits InfoRow {
    in property <SourceBuildHistoryRowData> record;
    in property <bool> collapse-label: false;

    row-height: HubTokens.list-row-md;
    title: root.record.detail;
    detail: root.record.log != "" ? root.record.log : root.record.output-path;
    meta: root.record.process-id != "" ? root.record.process-id + " / " + root.record.profile + " / " + root.record.finished : root.record.profile + " / " + root.record.finished;
    leading-image: root.record.success ? @image-url("../assets/icons/status/success.svg") : @image-url("../assets/icons/status/error.svg");
    has-leading-image: true;
    trailing-text: root.record.status;
    trailing-tone: root.record.success ? "ok" : "error";
    show-trailing-badge: true;
    collapse-trailing-label: root.collapse-label;
}

export component PanelListViewport inherits ScrollView {
    in-out property <length> scroll-y: 0px;
    in property <int> row-count;
    in property <length> row-height: HubTokens.list-row-lg;
    in property <length> row-spacing: HubTokens.space-2;
    in property <length> vertical-padding: HubTokens.space-1;
    in property <length> empty-height: HubTokens.list-row-lg + HubTokens.space-4;

    private property <length> list-content-height: root.row-count == 0 ? root.empty-height : root.row-count * root.row-height + (root.row-count - 1) * root.row-spacing + root.vertical-padding * 2;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    viewport_y <=> root.scroll-y;
    viewport_width: root.visible_width;
    viewport_height: max(root.visible_height, root.list-content-height);
    vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
    horizontal_scrollbar_policy: ScrollBarPolicy.always-off;

    Rectangle {
        width: root.visible_width;
        height: root.viewport_height;
        background: transparent;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-top: root.vertical-padding;
            padding-bottom: root.vertical-padding;
            spacing: root.row-spacing;

            @children
        }
    }
}

export component HubListView inherits HubPanel {
    in-out property <length> scroll-y: 0px;
    in property <string> title;
    in property <string> badge-text;
    in property <string> badge-tone: "neutral";
    in property <bool> show-header: false;
    in property <int> row-count;
    in property <length> row-height: HubTokens.list-row-md;
    in property <length> row-spacing: HubTokens.space-2;
    in property <length> vertical-padding: HubTokens.space-0;
    in property <length> empty-height: root.row-height + root.body-padding;
    in property <length> body-padding: HubTokens.space-4;
    in property <length> body-spacing: root.row-spacing;

    horizontal-stretch: 1;
    vertical-stretch: 1;
    min-height: root.row-height + root.body-padding * 2;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: root.body-padding;
        spacing: root.body-spacing;

        if root.show-header: PanelHeader {
            title: root.title;
            show-badge: root.badge-text != "";
            badge-text: root.badge-text;
            badge-tone: root.badge-tone;
        }

        PanelListViewport {
            scroll-y <=> root.scroll-y;
            row-count: root.row-count;
            row-height: root.row-height;
            row-spacing: root.row-spacing;
            vertical-padding: root.vertical-padding;
            empty-height: root.empty-height;

            @children
        }
    }
}

export component HubListPanelSlot inherits PanelSlot {
    in-out property <length> scroll-y: 0px;
    in property <string> title;
    in property <string> subtitle;
    in property <string> badge-text;
    in property <string> badge-tone: "neutral";
    in property <bool> show-header: true;
    in property <bool> show-badge: root.badge-text != "";
    in property <length> header-height: HubTokens.control-md;
    in property <int> row-count;
    in property <length> row-height: HubTokens.list-row-md;
    in property <length> row-spacing: HubTokens.space-2;
    in property <length> vertical-padding: HubTokens.space-0;
    in property <length> empty-height: root.row-height + root.body-padding;

    if root.show-header: PanelHeader {
        height: root.header-height;
        title: root.title;
        subtitle: root.subtitle;
        show-badge: root.show-badge;
        badge-text: root.badge-text;
        badge-tone: root.badge-tone;
    }

    PanelListViewport {
        scroll-y <=> root.scroll-y;
        row-count: root.row-count;
        row-height: root.row-height;
        row-spacing: root.row-spacing;
        vertical-padding: root.vertical-padding;
        empty-height: root.empty-height;

        @children
    }
}

export component CatalogListPanel inherits HubListView {
    in property <string> empty-title;
    in property <string> empty-detail;

    badge-tone: "accent";
    show-header: true;
    row-height: HubTokens.list-row-lg;
    row-spacing: HubTokens.space-2;
    vertical-padding: HubTokens.space-1;
    body-padding: HubTokens.space-4;
    empty-height: root.row-height + HubTokens.space-4;
    horizontal-stretch: 1;
    vertical-stretch: 1;
    min-height: root.row-height * 4;

    if root.row-count == 0: EmptyStateBlock {
        horizontal-stretch: 1;
        height: max(root.row-height + HubTokens.space-2, parent.height);
        title: root.empty-title;
        detail: root.empty-detail;
        body-padding: MaterialStyleMetrics.padding_14;
        body-spacing: MaterialStyleMetrics.spacing_6;
        center-content: true;
    }

    @children
}

export component CatalogPage inherits PageScrollSurface {
    in-out property <length> list-scroll-y: 0px;
    in property <string> title;
    in property <string> badge-text;
    in property <string> badge-tone: "accent";
    in property <string> empty-title;
    in property <string> empty-detail;
    in property <int> row-count;
    in property <length> row-height: HubTokens.list-row-lg;
    private property <length> row-slot-height: root.row-height + HubTokens.space-2;
    private property <length> panel-chrome-height: HubTokens.space-4 * 2 + HubTokens.control-md + HubTokens.toolbar-gap;
    private property <length> fit-list-height: max(root.row-slot-height, root.content-height - root.panel-chrome-height);
    private property <int> fit-row-count: Math.floor(root.fit-list-height / root.row-slot-height);
    private property <int> visible-row-count: root.fit-row-count < 1 ? 1 : root.fit-row-count;
    private property <length> fitted-panel-height: root.panel-chrome-height + root.visible-row-count * root.row-slot-height;
    private property <length> panel-height: root.row-count > root.visible-row-count ? root.fitted-panel-height : root.content-height;

    background: HubVisualSpec.page-background;

    CatalogListPanel {
        scroll-y <=> root.list-scroll-y;
        height: root.panel-height;
        title: root.title;
        badge-text: root.badge-text;
        badge-tone: root.badge-tone;
        empty-title: root.empty-title;
        empty-detail: root.empty-detail;
        row-count: root.row-count;
        row-height: root.row-height;

        @children
    }
}

export component HubTreeRow inherits Rectangle {
    in property <TreeItemData> item;
    in property <length> row-height: HubTokens.list-row-md;
    in property <length> row-spacing: HubTokens.space-2;
    callback activated(string);
    callback toggle-expanded(string);

    private property <bool> enabled: !root.item.disabled;
    private property <length> depth-indent: root.item.depth * HubTokens.space-4;
    private property <color> row-background: root.item.selected ? MaterialPalette.secondary_container : HubVisualSpec.panel-background;
    private property <color> row-foreground: root.item.selected ? MaterialPalette.on_secondary_container : MaterialPalette.on_surface;
    private property <string> supporting-text: root.item.detail;

    horizontal-stretch: 1;
    height: root.row-height;
    min-width: 1px;
    border-radius: HubVisualSpec.compact-radius;
    border-width: root.item.selected ? HubTokens.border-width : 0px;
    border-color: root.item.selected ? HubVisualSpec.accent-stroke : transparent;
    background: root.enabled ? root.row-background : HubVisualSpec.panel-background.with_alpha(HubVisualSpec.disabled-opacity);
    opacity: root.enabled ? 1.0 : HubVisualSpec.disabled-opacity;
    clip: true;

    StateLayerArea {
        width: parent.width;
        height: parent.height;
        color: root.row-foreground;
        border_radius: HubVisualSpec.compact-radius;
        clicked => {
            if root.enabled {
                root.activated(root.item.id);
            }
        }
    }

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: HubTokens.space-3;
        padding-right: HubTokens.space-3;
        spacing: root.row-spacing;
        alignment: center;

        Rectangle {
            width: root.depth-indent;
            height: parent.height;
            background: transparent;
        }

        Rectangle {
            width: HubTokens.control-sm;
            height: HubTokens.control-sm;
            border-radius: HubVisualSpec.compact-radius;
            background: transparent;
            clip: true;

            if root.item.has-children: StateLayerArea {
                width: parent.width;
                height: parent.height;
                color: MaterialPalette.on_surface_variant;
                border_radius: HubVisualSpec.compact-radius;
                clicked => {
                    if root.enabled {
                        root.toggle-expanded(root.item.id);
                    }
                }
            }

            if root.item.has-children: Icon {
                width: HubTokens.icon-sm;
                height: HubTokens.icon-sm;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                source: root.item.expanded ? @image-url("../assets/icons/ui/chevron-down.svg") : @image-url("../assets/icons/ui/chevron-right.svg");
                colorize: MaterialPalette.on_surface_variant;
            }
        }

        ListTile {
            horizontal-stretch: 1;
            min-width: 1px;
            height: parent.height;
            text: root.item.title;
            supporting_text: root.supporting-text;
            avatar_icon: root.item.has-icon-image ? root.item.icon-image : @image-url("../assets/brand/zircon-mark.svg");
            avatar_background: root.item.selected ? MaterialPalette.primary_container : MaterialPalette.surface_container_high;
            avatar_foreground: root.item.selected ? MaterialPalette.primary : MaterialPalette.on_surface_variant;
            enabled: root.enabled;
            clicked => {
                if root.enabled {
                    root.activated(root.item.id);
                }
            }

            if root.item.trailing-text != "": StatusBadge {
                text: root.item.trailing-text;
                tone: root.item.trailing-tone;
            }
        }
    }
}

export component HubTreeView inherits HubPanel {
    in-out property <length> scroll-y: 0px;
    in property <string> title;
    in property <[TreeItemData]> items;
    in property <int> item-count;
    in property <length> row-height: HubTokens.list-row-md;
    in property <bool> show-header: false;
    callback activated(string);
    callback toggle-expanded(string);

    horizontal-stretch: 1;
    vertical-stretch: 1;
    min-height: root.row-height * 3;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: HubTokens.space-4;
        spacing: HubTokens.space-2;

        if root.show-header: PanelHeader {
            title: root.title;
            show-badge: true;
            badge-text: root.item-count + "";
            badge-tone: "info";
        }

        PanelListViewport {
            scroll-y <=> root.scroll-y;
            row-count: root.item-count;
            row-height: root.row-height;
            row-spacing: HubTokens.space-1;
            vertical-padding: HubTokens.space-0;

            for item in root.items: HubTreeRow {
                item: item;
                row-height: root.row-height;
                activated(id) => {
                    root.activated(id);
                }
                toggle-expanded(id) => {
                    root.toggle-expanded(id);
                }
            }
        }
    }
}
