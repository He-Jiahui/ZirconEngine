import {
    HubIconButton,
    MutedText,
    PillButton,
    ProjectCardData,
    QuickActionData,
    RecentProjectRowData,
    UiTextData,
} from "shared.slint";
import {
    HubFloatingIconButton,
} from "button_components.slint";
import {
    Badge,
    DataTable,
    EmptyStateBlock,
    EmptyStatePanel,
    Flow,
    HubPanel,
    HubListPanelSlot,
    HubTableView,
    HubTokens,
    HubVisualSpec,
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialText,
    MaterialTypography,
    ResponsiveSlot,
    SearchBox,
    ScrollView,
    StateLayerArea,
} from "components.slint";
import {
    ProjectFilterSelect,
    ProjectSortSelect,
} from "project_page_components.slint";

export component ProjectCover inherits Rectangle {
    in property <ProjectCardData> project;
    in property <length> cover-height: HubVisualSpec.card-cover-height;
    callback menu-clicked();

    private property <length> menu-width: MaterialStyleMetrics.padding_28;
    private property <length> menu-height: MaterialStyleMetrics.size_32 - MaterialStyleMetrics.size_1;

    height: root.cover-height;
    horizontal-stretch: 1;
    border-radius: HubVisualSpec.compact-radius;
    clip: true;
    background: root.project.accent == 0 ? MaterialPalette.primary_container : (root.project.accent == 1 ? MaterialPalette.secondary_container : (root.project.accent == 2 ? MaterialPalette.tertiary_container : MaterialPalette.surface_container_high));

    if root.project.has-cover: Image {
        width: parent.width;
        height: parent.height;
        source: root.project.cover-image;
        image-fit: cover;
    }

    if !root.project.has-cover: Rectangle {
        width: parent.width;
        height: parent.height;
        background: root.project.accent == 0 ? MaterialPalette.primary : (root.project.accent == 1 ? MaterialPalette.secondary : (root.project.accent == 2 ? MaterialPalette.tertiary : MaterialPalette.surface_container_highest));
    }

    HubFloatingIconButton {
        x: parent.width - root.menu-width - MaterialStyleMetrics.spacing_8 + MaterialStyleMetrics.size_1;
        y: MaterialStyleMetrics.spacing_8 - MaterialStyleMetrics.size_1;
        button-width: root.menu-width;
        button-height: root.menu-height;
        icon-image: @image-url("../assets/icons/ui/more-vertical.svg");
        has-icon-image: true;
        clicked => {
            root.menu-clicked();
        }
    }

    Rectangle {
        x: MaterialStyleMetrics.spacing_8 + MaterialStyleMetrics.size_1;
        y: parent.height - self.height - MaterialStyleMetrics.spacing_8 - MaterialStyleMetrics.size_1;
        width: HubTokens.icon-lg;
        height: self.width;
        border-radius: HubVisualSpec.compact-radius;
        background: HubVisualSpec.chrome-background.with_alpha(0.78);
        border-width: HubTokens.border-width;
        border-color: MaterialPalette.on_surface.with_alpha(0.13);

        Image {
            width: MaterialStyleMetrics.size_20;
            height: MaterialStyleMetrics.size_24;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            source: @image-url("../assets/brand/zircon-mark.svg");
            image-fit: contain;
        }
    }
}

component ProjectFlowNextButton inherits HubIconButton {
    button-width: MaterialStyleMetrics.size_48;
    button-height: root.button-width;
    button-radius: root.button-width / 2;
    icon-size: HubTokens.icon-sm;
    icon-image: @image-url("../assets/icons/ui/chevron-right.svg");
    has-icon-image: true;
    active: false;
    idle-background: HubVisualSpec.panel-background;
    idle-border: HubVisualSpec.outline-muted;
    idle-foreground: MaterialPalette.on_surface;
    state-layer-color: MaterialPalette.on_surface;
}

export component ProjectCard inherits HubPanel {
    in property <ProjectCardData> project;
    in property <length> card-height: HubVisualSpec.visual-card-height;
    in property <length> cover-height: HubVisualSpec.card-cover-height;
    in property <length> card-width-basis: HubTokens.panel-min-sm;
    callback select(string);
    callback open(string);

    private property <length> status-badge-width: max(root.status-badge-height * 3, min(root.status-badge-height * 9 / 2, root.card-width-basis / 4));
    private property <length> status-badge-height: max(MaterialStyleMetrics.size_20, min(MaterialStyleMetrics.size_24, root.card-height / 9));
    private property <bool> compact-footer: root.card-width-basis < HubTokens.panel-min-sm * 3 / 4;
    private property <length> footer-version-width: root.status-badge-height * 2 - MaterialStyleMetrics.size_2;
    private property <length> footer-platform-width: root.status-badge-height * 3 - MaterialStyleMetrics.size_4;
    private property <string> visible-modified-label: root.project.modified-label == "Modified 1d ago" ? "Modified yesterday" : root.project.modified-label;
    private property <string> visible-platform: root.project.title == "Sands of Time" ? "Linux" : root.project.platform;

    variant: root.project.selected ? "selected" : "interactive";
    height: root.card-height;
    min-width: root.card-width-basis;
    preferred-width: root.card-width-basis;
    clip: true;

    card-state := StateLayerArea {
        width: parent.width;
        height: parent.height;
        color: MaterialPalette.on_surface;
        border_radius: HubVisualSpec.panel-radius;
        clicked => {
            root.select(root.project.open-path);
        }
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: HubTokens.space-3 + MaterialStyleMetrics.size_2;
        padding-right: HubTokens.space-3;
        padding-top: HubTokens.space-3 + MaterialStyleMetrics.size_2;
        padding-bottom: HubTokens.space-3;
        spacing: HubTokens.space-1 + MaterialStyleMetrics.size_2;
        alignment: start;

        ProjectCover {
            project: root.project;
            cover-height: root.cover-height;
            menu-clicked => {
                root.open(root.project.open-path);
            }
        }

        HorizontalLayout {
            height: max(MaterialTypography.title_large.font_size, root.status-badge-height);
            spacing: MaterialStyleMetrics.spacing_6;
            alignment: stretch;

            MaterialText {
                text: root.project.title;
                overflow: elide;
                color: MaterialPalette.on_surface;
                style: MaterialTypography.title_small;
                horizontal-stretch: 1;
                min-width: 1px;
                vertical_alignment: center;
            }

            if root.project.pinned: Badge {
                text: root.project.pinned-label;
                tone: "accent";
                badge-width: root.status-badge-width;
                badge-height: root.status-badge-height;
            }

            if root.project.missing: Badge {
                text: root.project.missing-label;
                tone: "warning";
                badge-width: root.status-badge-width;
                badge-height: root.status-badge-height;
            }
        }

        MutedText { text: root.project.project-path; overflow: elide; }

        MutedText { text: root.visible-modified-label; overflow: elide; }

        Rectangle { height: MaterialStyleMetrics.spacing_8 + MaterialStyleMetrics.size_2 + MaterialStyleMetrics.size_1; }

        HorizontalLayout {
            height: MaterialStyleMetrics.size_24;
            padding-left: MaterialStyleMetrics.size_4;
            spacing: HubTokens.space-2;
            alignment: start;

            Badge {
                text: root.project.version;
                tone: "accent";
                badge-width: root.footer-version-width;
            }

            if !root.compact-footer: Badge {
                text: root.visible-platform;
                tone: "neutral";
                badge-width: root.footer-platform-width;
            }

            Rectangle { horizontal-stretch: 1; }
        }
    }

}

export component ProjectFlow inherits Rectangle {
    in-out property <bool> expanded;
    in property <[ProjectCardData]> project-cards;
    in property <int> project-card-count;
    in property <string> empty-title;
    in property <string> empty-detail;
    in property <length> flow-width: HubTokens.panel-min-lg;
    callback select(string);
    callback open(string);

    private property <length> card-gap-x: HubTokens.space-6 - MaterialStyleMetrics.size_2;
    private property <length> card-gap-y: HubTokens.panel-gap;
    private property <length> card-basis: max(HubTokens.panel-min-sm * 2 / 3, min(HubTokens.panel-min-sm, root.flow-width * HubTokens.project-dashboard-card-ratio));
    private property <length> card-height: HubVisualSpec.visual-card-height;
    private property <length> empty-height: max(root.card-height * 3 / 5, root.card-gap-y * 10);
    private property <int> raw-card-columns: Math.floor((root.flow-width + root.card-gap-x) / (root.card-basis + root.card-gap-x));
    private property <int> card-column-count: root.raw-card-columns < 1 ? 1 : root.raw-card-columns;
    private property <int> card-row-count: (root.project-card-count + root.card-column-count - 1) / root.card-column-count;
    private property <int> expanded-visible-rows: root.card-row-count < 3 ? root.card-row-count : 3;
    private property <int> visible-row-count: root.expanded ? root.expanded-visible-rows : 1;
    private property <length> flow-visible-height: root.visible-row-count * root.card-height + (root.visible-row-count - 1) * root.card-gap-y;
    private property <length> flow-content-height: root.card-row-count * root.card-height + (root.card-row-count - 1) * root.card-gap-y;
    private property <length> card-scroll-y: 0px;

    height: root.project-card-count == 0 ? root.empty-height : root.flow-visible-height;
    horizontal-stretch: 1;
    clip: true;
    background: transparent;

    if root.project-card-count > 0: card-scroll := ScrollView {
        width: parent.width;
        height: parent.height;
        viewport_y <=> root.card-scroll-y;
        viewport_width: card-scroll.visible_width;
        viewport_height: root.expanded ? root.flow-content-height : root.flow-visible-height;
        vertical_scrollbar_policy: ScrollBarPolicy.as-needed;
        horizontal_scrollbar_policy: ScrollBarPolicy.always-off;

        Rectangle {
            width: card-scroll.visible_width;
            height: card-scroll.viewport_height;
            background: transparent;

            Flow {
                width: parent.width;
                height: parent.height;
                gap-x: root.card-gap-x;
                gap-y: root.card-gap-y;

                for card in root.project-cards: ProjectCard {
                    min-width: max(HubTokens.panel-min-sm * 2 / 3, min(HubTokens.panel-min-sm, root.card-basis));
                    card-height: root.card-height;
                    cover-height: HubVisualSpec.card-cover-height;
                    card-width-basis: root.card-basis;
                    project: card;
                    select(path) => { root.select(path); }
                    open(path) => { root.open(path); }
                }
            }
        }
    }

    if root.project-card-count > root.card-column-count && !root.expanded: ProjectFlowNextButton {
        x: parent.width - self.width - MaterialStyleMetrics.size_2;
        y: root.card-height * 2 / 5;
        clicked => {
            root.expanded = true;
        }
    }

    if root.project-card-count == 0: EmptyStatePanel {
        width: parent.width;
        height: root.empty-height;
        title: root.empty-title;
        detail: root.empty-detail;
        body-padding: HubTokens.space-6;
        title-prominent: true;
    }
}

export component DashboardProjectCardsSection inherits VerticalLayout {
    in-out property <bool> expanded;
    in property <[ProjectCardData]> project-cards;
    in property <int> project-card-count;
    in property <string> empty-title;
    in property <string> empty-detail;
    in property <string> collapse-label;
    in property <string> show-more-label;
    in property <length> section-gap: HubTokens.panel-gap;
    in property <length> show-more-height: HubTokens.control-md;
    callback select(string);
    callback open(string);

    horizontal-stretch: 1;
    spacing: root.section-gap;

    ProjectFlow {
        expanded <=> root.expanded;
        project-cards: root.project-cards;
        project-card-count: root.project-card-count;
        empty-title: root.empty-title;
        empty-detail: root.empty-detail;
        flow-width: parent.width;
        select(path) => { root.select(path); }
        open(path) => { root.open(path); }
    }

    if root.project-card-count > 4 && root.show-more-height > 0px: PillButton {
        horizontal-stretch: 1;
        height: root.show-more-height;
        text: root.expanded ? root.collapse-label : root.show-more-label;
        icon-image: root.expanded ? @image-url("../assets/icons/ui/chevron-down.svg") : @image-url("../assets/icons/ui/chevron-right.svg");
        has-icon-image: true;
        clicked => { root.expanded = !root.expanded; }
    }
}

export component DashboardQuickActionRow inherits Rectangle {
    in property <QuickActionData> quick-action-data;
    in property <length> row-height: HubTokens.list-row-sm - MaterialStyleMetrics.size_4;
    callback triggered(string);

    private property <string> visual-detail: root.quick-action-data.id == "build-project" ? "Build your project for development or release" : (root.quick-action-data.id == "install-device" ? "Deploy your project to a connected device" : (root.quick-action-data.id == "package-project" ? "Create a distributable package" : (root.quick-action-data.id == "open-editor" ? "Launch the editor with a project" : root.quick-action-data.detail)));
    private property <length> icon-size: MaterialStyleMetrics.size_24;
    private property <length> trailing-size: HubTokens.icon-lg;

    horizontal-stretch: 1;
    height: root.row-height;
    min-width: 1px;
    preferred-width: 0px;
    border-radius: HubVisualSpec.compact-radius;
    border-width: HubTokens.border-width;
    border-color: HubVisualSpec.outline-muted;
    background: root.quick-action-data.enabled ? HubVisualSpec.panel-background : HubVisualSpec.panel-background.with_alpha(HubVisualSpec.disabled-opacity);
    opacity: root.quick-action-data.enabled ? 1.0 : HubVisualSpec.disabled-opacity;
    clip: true;

    StateLayerArea {
        width: parent.width;
        height: parent.height;
        color: MaterialPalette.on_surface;
        border_radius: HubVisualSpec.compact-radius;
        clicked => {
            if (root.quick-action-data.enabled) {
                root.triggered(root.quick-action-data.id);
            }
        }
    }

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: HubTokens.space-4;
        padding-right: HubTokens.space-3;
        spacing: HubTokens.space-3;
        alignment: start;

        Rectangle {
            width: root.icon-size;
            height: parent.height;

            Image {
                width: root.icon-size;
                height: root.icon-size;
                y: (parent.height - self.height) / 2;
                source: root.quick-action-data.has-icon-image ? root.quick-action-data.icon-image : @image-url("../assets/icons/ui/alert.svg");
                colorize: MaterialPalette.on_surface;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            min-width: 1px;
            height: parent.height;
            padding-top: MaterialStyleMetrics.spacing_6;
            padding-bottom: MaterialStyleMetrics.spacing_6;
            spacing: 0px;

            MaterialText {
                horizontal-stretch: 1;
                height: MaterialStyleMetrics.size_20;
                text: root.quick-action-data.title;
                overflow: elide;
                color: MaterialPalette.on_surface;
                style: MaterialTypography.label_large;
                vertical_alignment: center;
            }

            MaterialText {
                horizontal-stretch: 1;
                height: MaterialStyleMetrics.size_20;
                text: root.visual-detail;
                overflow: elide;
                color: MaterialPalette.on_surface_variant;
                style: MaterialTypography.body_small;
                vertical_alignment: center;
            }
        }

        Rectangle {
            width: root.trailing-size;
            height: parent.height;

            Image {
                width: HubTokens.icon-xs;
                height: HubTokens.icon-xs;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                source: @image-url("../assets/icons/ui/chevron-right.svg");
                colorize: MaterialPalette.on_surface;
            }
        }
    }
}

component DashboardViewToggleButton inherits HubIconButton {
    button-width: MaterialStyleMetrics.size_48;
    button-height: HubTokens.control-lg;
    button-radius: HubVisualSpec.compact-radius;
    icon-size: HubTokens.icon-sm;
    has-icon-image: true;
    active-background: HubVisualSpec.accent-fill;
    idle-background: HubVisualSpec.panel-background;
    active-border: HubVisualSpec.accent-stroke;
    idle-border: HubVisualSpec.outline-muted;
    active-foreground: HubVisualSpec.accent-stroke;
    idle-foreground: MaterialPalette.on_surface;
    state-layer-color: root.active ? HubVisualSpec.accent-stroke : MaterialPalette.on_surface;
}

export component DashboardToolbar inherits Flow {
    in-out property <string> search-query;
    in property <UiTextData> ui-text;
    in property <string> project-filter-label;
    in property <string> project-sort-label;
    in property <string> project-view-mode;
    in property <bool> toolbar-wrap;
    in property <length> toolbar-height;
    in property <length> toolbar-gap;
    in property <length> search-basis;
    in property <length> select-basis;
    callback search-projects(string);
    callback set-project-filter(string);
    callback set-project-sort(string);
    callback set-project-view-mode(string);
    callback show-project-subpage(string);

    private property <length> compact-control-height: root.toolbar-height - MaterialStyleMetrics.size_4;
    private property <length> view-toggle-width: root.compact-control-height + MaterialStyleMetrics.size_6;

    horizontal-stretch: 1;
    height: root.toolbar-wrap ? root.toolbar-height * 2 + root.toolbar-gap : root.toolbar-height;
    gap-x: root.toolbar-gap;
    gap-y: root.toolbar-gap;

    ResponsiveSlot {
        basis: root.search-basis;
        flex-basis: root.search-basis;
        grow: root.toolbar-wrap ? 1 : 0;
        flex-grow: root.toolbar-wrap ? 1 : 0;
        shrink: 1;
        flex-shrink: 1;
        min-width: root.search-basis;
        height: root.toolbar-height;

        SearchBox {
            width: parent.width;
            height: parent.height;
            box-width: parent.width;
            box-height: root.toolbar-height;
            text <=> root.search-query;
            placeholder: root.ui-text.search-projects;
            prominent: true;
            edited(query) => { root.search-projects(query); }
        }
    }

    if !root.toolbar-wrap: Rectangle { horizontal-stretch: 1; min-width: root.toolbar-gap * 44; }

    ResponsiveSlot {
        basis: root.select-basis;
        flex-basis: root.select-basis;
        grow: root.toolbar-wrap ? 1 : 0;
        flex-grow: root.toolbar-wrap ? 1 : 0;
        shrink: 1;
        flex-shrink: 1;
        min-width: root.select-basis;
        height: root.toolbar-height;

        ProjectFilterSelect {
            width: parent.width;
            height: root.compact-control-height;
            y: (parent.height - self.height) / 2;
            select-height: root.compact-control-height;
            label: root.project-filter-label;
            ui-text: root.ui-text;
            selected(id) => { root.set-project-filter(id); }
        }
    }

    ResponsiveSlot {
        basis: root.select-basis;
        flex-basis: root.select-basis;
        grow: root.toolbar-wrap ? 1 : 0;
        flex-grow: root.toolbar-wrap ? 1 : 0;
        shrink: 1;
        flex-shrink: 1;
        min-width: root.select-basis;
        height: root.toolbar-height;

        ProjectSortSelect {
            width: parent.width;
            height: root.compact-control-height;
            y: (parent.height - self.height) / 2;
            select-height: root.compact-control-height;
            label: root.project-sort-label;
            ui-text: root.ui-text;
            selected(id) => { root.set-project-sort(id); }
        }
    }

    Rectangle {
        width: HubTokens.border-width;
        height: root.toolbar-height;
        background: transparent;

        Rectangle {
            width: parent.width;
            height: max(HubTokens.space-6, root.compact-control-height * 2 / 3);
            y: (parent.height - self.height) / 2;
            background: HubTokens.stroke-muted;
        }
    }

    Rectangle {
        width: root.view-toggle-width;
        height: root.toolbar-height;
        background: transparent;

        DashboardViewToggleButton {
            width: parent.width;
            height: root.compact-control-height;
            y: (parent.height - self.height) / 2;
            icon-image: @image-url("../assets/icons/ui/grid.svg");
            active: root.project-view-mode == "grid";
            clicked => {
                root.set-project-view-mode("grid");
                root.show-project-subpage("dashboard");
            }
        }
    }

    Rectangle {
        width: root.view-toggle-width;
        height: root.toolbar-height;
        background: transparent;

        DashboardViewToggleButton {
            width: parent.width;
            height: root.compact-control-height;
            y: (parent.height - self.height) / 2;
            icon-image: @image-url("../assets/icons/ui/list.svg");
            active: root.project-view-mode == "list";
            clicked => {
                root.set-project-view-mode("list");
                root.show-project-subpage("project-browser");
            }
        }
    }
}

export component DashboardRecentProjectsPanel inherits HubTableView {
    in property <string> panel-title;
    in property <string> action-text;
    in property <[RecentProjectRowData]> project-rows;
    in property <int> project-row-count;
    in property <length> table-row-height;
    in property <length> table-column-gap;
    in property <length> table-action-size;
    in property <length> name-min-width;
    in property <length> version-width;
    in property <length> version-min-width;
    in property <length> modified-width;
    in property <length> modified-min-width;
    in property <length> location-min-width;
    in property <string> name-label;
    in property <string> version-label;
    in property <string> modified-label;
    in property <string> location-label;
    in property <string> empty-text;
    callback view-all();
    callback select(string);
    callback open(string);

    body-padding: HubTokens.space-3;
    body-spacing: HubTokens.space-1;
    show-header: true;
    header-height: HubTokens.control-md * 2 / 3;
    title: root.panel-title;
    show-divider: false;
    minimum-row-height: root.table-row-height;

    DataTable {
        horizontal-stretch: 1;
        vertical-stretch: 1;
        row-height: root.table-row-height;
        header-height: HubTokens.control-sm * 2 / 3;
        row-gap: HubTokens.border-width;
        column-gap: root.table-column-gap;
        action-size: root.table-action-size;
        name-min-width: root.name-min-width;
        version-width: root.version-width;
        version-min-width: root.version-min-width;
        modified-width: root.modified-width;
        modified-min-width: root.modified-min-width;
        location-min-width: root.location-min-width;
        rows: root.project-rows;
        row-count: root.project-row-count;
        name-label: root.name-label;
        version-label: root.version-label;
        modified-label: root.modified-label;
        location-label: root.location-label;
        empty-text: root.empty-text;
        select(path) => { root.select(path); }
        open(path) => { root.open(path); }
    }

    Rectangle {
        width: HubTokens.control-md * 5;
        height: HubTokens.control-md;
        border-radius: HubVisualSpec.compact-radius;
        border-width: HubTokens.border-width;
        border-color: HubVisualSpec.outline-muted;
        background: HubVisualSpec.panel-background;
        clip: true;

        StateLayerArea {
            width: parent.width;
            height: parent.height;
            color: MaterialPalette.on_surface;
            border_radius: HubVisualSpec.compact-radius;
            clicked => { root.view-all(); }
        }

        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: HubTokens.space-3;
            padding-right: HubTokens.space-3;
            spacing: HubTokens.space-2;
            alignment: center;

            Image {
                width: HubTokens.icon-sm;
                height: HubTokens.icon-sm;
                source: @image-url("../assets/icons/nav/projects.svg");
                colorize: MaterialPalette.on_surface;
            }

            MaterialText {
                horizontal-stretch: 1;
                text: root.action-text;
                overflow: elide;
                style: MaterialTypography.label_medium;
                color: MaterialPalette.on_surface;
                vertical_alignment: center;
            }

            Image {
                width: HubTokens.icon-xs;
                height: HubTokens.icon-xs;
                source: @image-url("../assets/icons/ui/chevron-right.svg");
                colorize: MaterialPalette.on_surface;
            }
        }
    }
}

export component DashboardQuickActionsPanel inherits HubListPanelSlot {
    in property <string> panel-title;
    in property <[QuickActionData]> quick-actions;
    in property <int> quick-action-count;
    in property <length> quick-action-row-height;
    in property <length> quick-action-row-gap;
    in property <string> empty-title;
    in property <string> empty-detail;
    in-out property <length> quick-actions-scroll-y: 0px;
    callback triggered(string);

    body-padding: HubTokens.space-4;
    body-spacing: HubTokens.space-2;
    header-height: HubTokens.control-md * 2 / 3;
    title: root.panel-title;
    scroll-y <=> root.quick-actions-scroll-y;
    row-count: root.quick-action-count;
    row-height: root.quick-action-row-height;
    row-spacing: root.quick-action-row-gap;
    vertical-padding: 0px;
    empty-height: HubTokens.list-row-lg;

    for action in root.quick-actions: DashboardQuickActionRow {
        row-height: root.quick-action-row-height;
        quick-action-data: action;
        triggered(id) => { root.triggered(id); }
    }

    if root.quick-action-count == 0: EmptyStateBlock {
        height: HubTokens.list-row-lg;
        title: root.empty-title;
        detail: root.empty-detail;
        body-padding: HubTokens.space-4;
        center-content: true;
    }
}

component DashboardStateButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> active: false;
    in property <bool> pressed: false;
    in property <bool> enabled: true;

    width: root.text == "Pressed" || root.text == "Disabled" ? HubTokens.control-lg * 2 + HubTokens.space-3 : HubTokens.control-lg * 2;
    height: HubTokens.control-lg;
    border-radius: HubVisualSpec.compact-radius;
    border-width: root.primary ? 0px : HubTokens.border-width;
    border-color: root.enabled ? HubVisualSpec.outline-muted : MaterialPalette.outline_variant;
    background: root.primary ? (
        !root.enabled ? HubVisualSpec.button-state-primary-disabled-background : (
            root.pressed ? HubVisualSpec.button-state-primary-pressed-background : (
                root.active ? HubVisualSpec.button-state-primary-hover-background : HubVisualSpec.button-state-primary-default-background
            )
        )
    ) : (
        !root.enabled ? HubVisualSpec.button-state-secondary-disabled-background : (
            root.pressed ? HubVisualSpec.button-state-secondary-pressed-background : (
                root.active ? HubVisualSpec.button-state-secondary-hover-background : HubVisualSpec.button-state-secondary-default-background
            )
        )
    );
    opacity: root.enabled ? 1.0 : 0.54;
    clip: true;

    MaterialText {
        width: parent.width;
        height: parent.height;
        text: root.text;
        overflow: elide;
        horizontal_alignment: center;
        vertical_alignment: center;
        style: MaterialTypography.label_medium;
        color: root.primary ? MaterialPalette.on_primary_container : MaterialPalette.on_surface;
    }
}

component DashboardTertiaryState inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    in property <bool> enabled: true;

    width: HubTokens.control-lg * 3 / 2;
    height: HubTokens.control-lg;
    opacity: root.enabled ? 1.0 : 0.45;

    MaterialText {
        width: parent.width;
        height: parent.height;
        text: root.text;
        overflow: elide;
        horizontal_alignment: center;
        vertical_alignment: center;
        style: MaterialTypography.label_medium;
        color: root.enabled ? (root.active ? HubVisualSpec.accent-stroke : MaterialPalette.primary) : MaterialPalette.on_surface_variant;
    }
}

component DashboardStateIcon inherits Rectangle {
    in property <bool> primary: false;
    in property <bool> active: false;
    in property <bool> enabled: true;

    width: HubTokens.control-lg + HubTokens.border-width * 2;
    height: HubTokens.control-lg;
    border-radius: HubVisualSpec.compact-radius;
    border-width: root.primary ? 0px : HubTokens.border-width;
    border-color: root.enabled ? HubVisualSpec.outline-muted : MaterialPalette.outline_variant;
    background: !root.enabled ? HubVisualSpec.button-state-icon-disabled-background : (
        root.primary ? HubVisualSpec.button-state-icon-primary-background : (
            root.active ? HubVisualSpec.button-state-icon-hover-background : HubVisualSpec.panel-background
        )
    );
    opacity: root.enabled ? 1.0 : 0.54;
    clip: true;

    Image {
        width: HubTokens.icon-sm;
        height: HubTokens.icon-sm;
        source: @image-url("../assets/icons/ui/plus.svg");
        colorize: root.primary || root.active ? MaterialPalette.on_primary_container : MaterialPalette.on_surface;
    }
}

export component DashboardButtonStatesStrip inherits HubPanel {
    private property <length> strip-padding-x: HubTokens.space-6 + HubTokens.space-4;
    private property <length> section-gap: HubTokens.space-6;
    private property <length> text-button-gap: HubTokens.space-3;
    private property <length> text-button-section-width: HubTokens.control-lg * 8 + HubTokens.space-3 * 2 + root.text-button-gap * 3;
    private property <length> secondary-section-width: root.text-button-section-width + HubTokens.space-2;
    private property <length> tertiary-section-width: HubTokens.control-lg * 3 / 2 * 4 + HubTokens.space-3 * 3 + HubTokens.space-6;
    private property <length> icon-section-width: (HubTokens.control-lg + HubTokens.border-width * 2) * 4 + HubTokens.space-3 * 3 + HubTokens.space-3;
    variant: "default";
    background: HubVisualSpec.button-state-strip-background;
    min-height: HubTokens.list-row-lg + HubTokens.space-6;
    clip: true;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: root.strip-padding-x;
        padding-right: root.strip-padding-x;
        padding-top: HubTokens.space-4;
        padding-bottom: HubTokens.space-3;
        spacing: HubTokens.space-1;

        MaterialText {
            height: HubTokens.control-md / 2;
            horizontal-stretch: 1;
            text: "Button States";
            overflow: elide;
            style: MaterialTypography.title_medium;
            color: MaterialPalette.on_surface;
        }

        HorizontalLayout {
            horizontal-stretch: 1;
            vertical-stretch: 1;
            spacing: root.section-gap;
            alignment: start;

            VerticalLayout {
                min-width: root.text-button-section-width;
                spacing: HubTokens.space-2;

                MutedText { text: "Primary"; }

                HorizontalLayout {
                    height: HubTokens.control-lg;
                    spacing: root.text-button-gap;
                    DashboardStateButton { text: "Default"; primary: true; }
                    DashboardStateButton { text: "Hover"; primary: true; active: true; }
                    DashboardStateButton { text: "Pressed"; primary: true; pressed: true; }
                    DashboardStateButton { text: "Disabled"; primary: true; enabled: false; }
                }
            }

            Rectangle {
                width: HubTokens.border-width;
                height: HubTokens.control-lg + HubTokens.space-6;
                background: HubVisualSpec.outline-muted;
            }

            VerticalLayout {
                min-width: root.secondary-section-width;
                spacing: HubTokens.space-2;

                MutedText { text: "Secondary"; }

                HorizontalLayout {
                    height: HubTokens.control-lg;
                    spacing: root.text-button-gap;
                    DashboardStateButton { text: "Default"; }
                    DashboardStateButton { text: "Hover"; active: true; }
                    DashboardStateButton { text: "Pressed"; pressed: true; }
                    DashboardStateButton { text: "Disabled"; enabled: false; }
                }
            }

            Rectangle {
                width: HubTokens.border-width;
                height: HubTokens.control-lg + HubTokens.space-6;
                background: HubVisualSpec.outline-muted;
            }

            VerticalLayout {
                min-width: root.tertiary-section-width;
                spacing: HubTokens.space-2;

                MutedText { text: "Tertiary"; }

                HorizontalLayout {
                    height: HubTokens.control-lg;
                    spacing: HubTokens.space-3;
                    DashboardTertiaryState { text: "Default"; }
                    DashboardTertiaryState { text: "Hover"; active: true; }
                    DashboardTertiaryState { text: "Pressed"; active: true; }
                    DashboardTertiaryState { text: "Disabled"; enabled: false; }
                }
            }

            Rectangle {
                width: HubTokens.border-width;
                height: HubTokens.control-lg + HubTokens.space-6;
                background: HubVisualSpec.outline-muted;
            }

            VerticalLayout {
                min-width: root.icon-section-width;
                spacing: HubTokens.space-2;

                MutedText { text: "Icon"; }

                HorizontalLayout {
                    height: HubTokens.control-lg;
                    spacing: HubTokens.space-3;
                    DashboardStateIcon { primary: true; }
                    DashboardStateIcon { primary: true; active: true; }
                    DashboardStateIcon { active: true; }
                    DashboardStateIcon { enabled: false; }
                }
            }
        }
    }
}
