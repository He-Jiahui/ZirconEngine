import { MutedText } from "shared.slint";
import { ResponsiveSlot } from "layout.slint";
import { HubTokens } from "tokens.slint";
import { ElevatedCard, OutlinedCard, OutlineButton, MaterialPalette, MaterialStyleMetrics, MaterialText, MaterialTypography } from "material_bridge.slint";

export component HubPanel inherits Rectangle {
    in property <string> variant: "default";

    background: transparent;
    clip: true;

    if root.variant == "elevated": ElevatedCard {
        width: parent.width;
        height: parent.height;
    }

    if root.variant != "elevated": OutlinedCard {
        width: parent.width;
        height: parent.height;
    }

    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: MaterialStyleMetrics.border_radius_12;
        border-width: root.variant == "selected" || root.variant == "danger" ? HubTokens.border-width : 0px;
        border-color: root.variant == "danger" ? MaterialPalette.error : (root.variant == "selected" ? MaterialPalette.primary : transparent);
        background: transparent;
        clip: true;

        @children
    }
}

export component HubCard inherits HubPanel {
    variant: "interactive";
}

export component PanelSlot inherits ResponsiveSlot {
    in property <string> variant: "default";
    in property <length> body-padding: HubTokens.space-4;
    in property <length> body-spacing: HubTokens.toolbar-gap;

    HubPanel {
        width: parent.width;
        height: parent.height;
        variant: root.variant;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding: root.body-padding;
            spacing: root.body-spacing;
            alignment: stretch;

            @children
        }
    }
}

export component HeaderGroup inherits Rectangle {
    in property <length> group-height: HubTokens.shell-header-height;

    height: root.group-height;
    horizontal-stretch: 1;
    min-width: 1px;
    preferred-width: 0px;
    background: HubTokens.surface-page;
    border-width: HubTokens.border-width;
    border-color: HubTokens.stroke-muted;
    clip: true;
}

export component Badge inherits Rectangle {
    in property <string> text;
    in property <string> tone: "neutral";
    in property <length> badge-width: MaterialStyleMetrics.size_64;
    in property <length> badge-height: MaterialStyleMetrics.size_24;

    width: root.badge-width;
    height: root.badge-height;
    border-radius: MaterialStyleMetrics.border_radius_4;
    border-width: HubTokens.border-width;
    border-color: root.tone == "warning" ? MaterialPalette.tertiary : (root.tone == "error" ? MaterialPalette.error : (root.tone == "accent" || root.tone == "ok" ? MaterialPalette.primary : MaterialPalette.outline_variant));
    background: root.tone == "warning" ? MaterialPalette.tertiary_container : (root.tone == "error" ? MaterialPalette.error_container : (root.tone == "accent" || root.tone == "ok" ? MaterialPalette.primary_container : MaterialPalette.surface_container_highest));

    MaterialText {
        width: parent.width;
        height: parent.height;
        text: root.text;
        overflow: elide;
        color: root.tone == "warning" ? MaterialPalette.on_tertiary_container : (root.tone == "error" ? MaterialPalette.on_error_container : (root.tone == "accent" || root.tone == "ok" ? MaterialPalette.on_primary_container : MaterialPalette.on_surface_variant));
        style: MaterialTypography.label_medium;
        horizontal_alignment: center;
        vertical_alignment: center;
    }
}

export component StatusBadge inherits Badge {
    badge-width: HubTokens.control-md * 3;
    badge-height: HubTokens.control-sm;
}

export component PanelHeader inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> badge-text;
    in property <string> badge-tone: "neutral";
    in property <bool> show-badge: false;
    in property <length> badge-width: HubTokens.control-md * 3;
    in property <string> action-text;
    in property <bool> show-action: false;
    in property <length> action-width: HubTokens.panel-min-sm / 2;
    callback action-clicked;

    height: subtitle == "" ? HubTokens.control-md : HubTokens.list-row-sm;
    horizontal-stretch: 1;
    min-width: 1px;
    preferred-width: 0px;
    background: transparent;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: HubTokens.toolbar-gap;
        alignment: stretch;

        VerticalLayout {
            spacing: MaterialStyleMetrics.spacing_2;
            min-width: 1px;

            MaterialText {
                text: root.title;
                overflow: elide;
                color: HubTokens.text-primary;
                style: MaterialTypography.title_medium;
                horizontal_alignment: left;
                vertical_alignment: center;
            }

            if root.subtitle != "": MutedText {
                text: root.subtitle;
                overflow: elide;
            }
        }

        Rectangle {
            horizontal-stretch: 1;
            min-width: HubTokens.space-2;
        }

        if root.show-badge: StatusBadge {
            text: root.badge-text;
            tone: root.badge-tone;
            badge-width: root.badge-width;
        }

        if root.show-action: OutlineButton {
            width: root.action-width;
            height: HubTokens.control-md;
            text: root.action-text;
            icon: @image-url("../assets/icons/ui/chevron-right.svg");
            clicked => {
                root.action-clicked();
            }
        }
    }
}

export component OverviewPanel inherits HubPanel {
    in property <string> title;
    in property <string> subtitle;
    in property <string> badge-text;
    in property <string> badge-tone: "accent";
    in property <bool> show-badge: true;
    in property <length> badge-width: HubTokens.control-md * 3;
    in property <length> body-padding-horizontal: MaterialStyleMetrics.padding_16;
    in property <length> body-padding-vertical: MaterialStyleMetrics.padding_14;

    height: HubTokens.list-row-lg;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: root.body-padding-horizontal;
        padding-right: root.body-padding-horizontal;
        padding-top: root.body-padding-vertical;
        padding-bottom: root.body-padding-vertical;

        PanelHeader {
            title: root.title;
            subtitle: root.subtitle;
            show-badge: root.show-badge;
            badge-text: root.badge-text;
            badge-tone: root.badge-tone;
            badge-width: root.badge-width;
        }
    }
}

export component EmptyStateBlock inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <string> extra-detail;
    in property <length> body-padding: HubTokens.space-4;
    in property <length> body-spacing: HubTokens.space-2;
    in property <bool> title-prominent: false;
    in property <bool> center-content: false;

    horizontal-stretch: 1;
    min-height: HubTokens.control-md;
    background: transparent;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: root.body-padding;
        spacing: root.body-spacing;
        alignment: stretch;

        Rectangle {
            vertical-stretch: root.center-content ? 1 : 0;
            min-height: 0px;
        }

        MaterialText {
            text: root.title;
            overflow: elide;
            color: MaterialPalette.on_surface;
            style: root.title-prominent ? MaterialTypography.title_medium : MaterialTypography.label_large;
            horizontal-stretch: 1;
            min-width: 1px;
        }

        if root.detail != "": MutedText {
            text: root.detail;
            overflow: elide;
            horizontal-stretch: 1;
            min-width: 1px;
        }

        if root.extra-detail != "": MutedText {
            text: root.extra-detail;
            overflow: elide;
            horizontal-stretch: 1;
            min-width: 1px;
        }

        Rectangle {
            vertical-stretch: root.center-content ? 1 : 0;
            min-height: 0px;
        }
    }
}

export component EmptyStatePanel inherits HubPanel {
    in property <string> title;
    in property <string> detail;
    in property <string> extra-detail;
    in property <length> body-padding: HubTokens.space-4;
    in property <length> body-spacing: HubTokens.space-2;
    in property <bool> title-prominent: false;

    horizontal-stretch: 1;
    min-height: HubTokens.list-row-sm;

    EmptyStateBlock {
        width: parent.width;
        height: parent.height;
        title: root.title;
        detail: root.detail;
        extra-detail: root.extra-detail;
        body-padding: root.body-padding;
        body-spacing: root.body-spacing;
        title-prominent: root.title-prominent;
    }
}

export component StatusBanner inherits HubPanel {
    in property <string> title;
    in property <string> detail;
    in property <string> tone: "info";

    variant: root.tone == "error" ? "danger" : "elevated";
    height: HubTokens.list-row-sm;
    vertical-stretch: 0;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: HubTokens.space-4;
        spacing: HubTokens.space-1;

        MaterialText {
            text: root.title;
            overflow: elide;
            color: HubTokens.text-primary;
            style: MaterialTypography.title_small;
        }

        if root.detail != "": MutedText {
            text: root.detail;
            overflow: elide;
        }
    }
}
