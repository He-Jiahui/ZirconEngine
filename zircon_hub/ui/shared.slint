export component BrandMark inherits Rectangle {
    width: 34px;
    height: 34px;
    border-radius: 6px;
    background: transparent;

    Image {
        width: parent.width;
        height: parent.height;
        source: @image-url("../assets/brand/zircon-mark.svg");
        image-fit: contain;
    }
}

export component CenteredIcon inherits Rectangle {
    in property <image> source-image;
    in property <image> fallback-image: @image-url("../assets/icons/ui/alert.svg");
    in property <bool> has-source-image: false;
    in property <length> icon-size: 18px;

    clip: true;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 0px;

        Rectangle {
            vertical-stretch: 1;
            min-height: 0px;
        }

        HorizontalLayout {
            height: root.icon-size;
            alignment: center;

            Image {
                width: root.icon-size;
                height: root.icon-size;
                source: root.has-source-image ? root.source-image : root.fallback-image;
                image-fit: contain;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            min-height: 0px;
        }
    }
}

export component PillButton inherits Rectangle {
    in property <string> text;
    in property <string> icon;
    in property <image> icon-image;
    in property <bool> has-icon-image: false;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked;

    min-width: 110px;
    height: 36px;
    border-radius: 7px;
    border-width: 1px;
    border-color: primary ? #1caaa3 : #333841;
    background: !enabled ? #1d2228 : (primary ? (area.pressed ? #08756f : (area.has-hover ? #0a8f88 : #086b66)) : (area.pressed ? #242a31 : (area.has-hover ? #22272e : #181c22)));

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 14px;
        padding-right: 14px;
        spacing: 8px;
        alignment: center;

        if root.has-icon-image || root.icon != "": CenteredIcon {
            width: 18px;
            height: parent.height;
            icon-size: 18px;
            source-image: root.icon-image;
            has-source-image: root.has-icon-image;
            fallback-image: @image-url("../assets/icons/ui/alert.svg");
        }

        Text {
            text: root.text;
            color: root.enabled ? #f2f5f7 : #767d86;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    area := TouchArea {
        enabled: root.enabled;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

export component IconButton inherits Rectangle {
    in property <string> icon;
    in property <image> icon-image;
    in property <bool> has-icon-image: false;
    in property <bool> active: false;
    in property <bool> enabled: true;
    callback clicked;

    width: 36px;
    height: 36px;
    border-radius: 7px;
    border-width: 1px;
    border-color: active ? #13aaa2 : (area.has-hover ? #424852 : #30353d);
    background: !enabled ? #1a1e24 : (active ? #073e3d : (area.pressed ? #252b33 : (area.has-hover ? #20262d : #171b21)));

    CenteredIcon {
        width: parent.width;
        height: parent.height;
        icon-size: 18px;
        source-image: root.icon-image;
        has-source-image: root.has-icon-image;
        fallback-image: @image-url("../assets/icons/ui/alert.svg");
    }

    area := TouchArea {
        enabled: root.enabled;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

export component NavButton inherits Rectangle {
    in property <NavItemData> item;
    in property <bool> collapsed: false;
    callback clicked(string);

    height: 46px;
    border-radius: 8px;
    border-width: root.item.active ? 1px : 0px;
    border-color: #1ec8be;
    background: root.item.active ? #0a4644 : (area.has-hover ? #1b2027 : transparent);

    if root.collapsed: HorizontalLayout {
        width: parent.width;
        height: parent.height;
        alignment: center;

        CenteredIcon {
            width: parent.width;
            height: parent.height;
            icon-size: 24px;
            source-image: root.item.icon-image;
            has-source-image: root.item.has-icon-image;
            fallback-image: @image-url("../assets/icons/nav/projects.svg");
        }
    }

    if !root.collapsed: HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 14px;
        padding-right: 12px;
        spacing: 12px;
        alignment: start;

        CenteredIcon {
            width: 24px;
            height: parent.height;
            icon-size: 24px;
            source-image: root.item.icon-image;
            has-source-image: root.item.has-icon-image;
            fallback-image: @image-url("../assets/icons/nav/projects.svg");
        }

        Text {
            text: root.item.title;
            color: root.item.active ? #f5fbff : #c3c9d1;
            font-size: 14px;
            font-weight: root.item.active ? 700 : 500;
            vertical-alignment: center;
            overflow: elide;
            horizontal-stretch: 1;
        }
    }

    area := TouchArea {
        clicked => {
            root.clicked(root.item.id);
        }
    }
}

export component StatusPill inherits Rectangle {
    in property <string> icon;
    in property <image> icon-image;
    in property <bool> has-icon-image: false;
    in property <string> text;
    in property <color> accent-color;

    min-width: 88px;
    height: 36px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.accent-color;
    background: #171b20;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 14px;
        padding-right: 14px;
        spacing: 8px;
        alignment: center;

        CenteredIcon {
            width: 18px;
            height: parent.height;
            icon-size: 18px;
            source-image: root.icon-image;
            has-source-image: root.has-icon-image;
            fallback-image: @image-url("../assets/icons/status/running.svg");
        }

        Text {
            text: root.text;
            color: root.accent-color;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

export component WindowButton inherits Rectangle {
    in property <string> icon;
    in property <image> icon-image;
    in property <bool> has-icon-image: false;
    in property <bool> danger: false;
    callback clicked;

    width: 36px;
    height: 36px;
    background: root.danger && area.has-hover ? #6d2025 : (area.has-hover ? #242a31 : transparent);

    CenteredIcon {
        width: parent.width;
        height: parent.height;
        icon-size: 16px;
        source-image: root.icon-image;
        has-source-image: root.has-icon-image;
        fallback-image: @image-url("../assets/icons/ui/close.svg");
    }

    area := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component Panel inherits Rectangle {
    border-radius: 8px;
    border-width: 1px;
    border-color: #343942;
    background: #181c22;
}

export component FieldLabel inherits Text {
    color: #f2f5f7;
    font-size: 13px;
    font-weight: 700;
}

export component MutedText inherits Text {
    color: #9fa7b2;
    font-size: 12px;
}
