export struct NavItemData {
    id: string,
    title: string,
    icon: string,
    active: bool,
}

export struct ProjectCardData {
    title: string,
    project-path: string,
    modified: string,
    version: string,
    platform: string,
    accent: int,
}

export struct RecentProjectRowData {
    title: string,
    project-path: string,
    modified: string,
    version: string,
    accent: int,
}

export struct QuickActionData {
    id: string,
    icon: string,
    title: string,
    detail: string,
    enabled: bool,
}

export struct SourceEngineData {
    title: string,
    version: string,
    source-path: string,
    output-path: string,
    last-build: string,
    status: string,
    build-profile: string,
    jobs: string,
}

export component BrandMark inherits Rectangle {
    width: 34px;
    height: 34px;
    border-radius: 6px;
    background: #073d3f;
    border-width: 1px;
    border-color: #24d5ca;

    Rectangle {
        x: 8px;
        y: 7px;
        width: 9px;
        height: 20px;
        border-radius: 2px;
        background: #23c8c2;
    }

    Rectangle {
        x: 18px;
        y: 7px;
        width: 8px;
        height: 20px;
        border-radius: 2px;
        background: #8bf5e8;
    }
}

export component PillButton inherits Rectangle {
    in property <string> text;
    in property <string> icon;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked;

    min-width: 110px;
    height: 36px;
    border-radius: 7px;
    border-width: 1px;
    border-color: primary ? #1caaa3 : #333841;
    background: !enabled ? #1d2228 : (primary ? (area.pressed ? #08756f : (area.has-hover ? #0a8f88 : #086b66)) : (area.pressed ? #242a31 : (area.has-hover ? #22272e : #181c22)));

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.icon;
            color: root.enabled ? (root.primary ? #d8fffb : #f2f5f7) : #767d86;
            font-size: 17px;
            vertical-alignment: center;
        }

        Text {
            text: root.text;
            color: root.enabled ? #f2f5f7 : #767d86;
            font-size: 14px;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    area := TouchArea {
        enabled: root.enabled;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

export component IconButton inherits Rectangle {
    in property <string> icon;
    in property <bool> active: false;
    in property <bool> enabled: true;
    callback clicked;

    width: 36px;
    height: 36px;
    border-radius: 7px;
    border-width: 1px;
    border-color: active ? #13aaa2 : (area.has-hover ? #424852 : #30353d);
    background: !enabled ? #1a1e24 : (active ? #073e3d : (area.pressed ? #252b33 : (area.has-hover ? #20262d : #171b21)));

    Text {
        text: root.icon;
        color: root.enabled ? (root.active ? #61f3e9 : #c8ced7) : #737b85;
        font-size: 18px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    area := TouchArea {
        enabled: root.enabled;
        clicked => {
            if (root.enabled) {
                root.clicked();
            }
        }
    }
}

export component NavButton inherits Rectangle {
    in property <NavItemData> item;
    callback clicked(string);

    height: 46px;
    border-radius: 8px;
    border-width: root.item.active ? 1px : 0px;
    border-color: #1ec8be;
    background: root.item.active ? #0a4644 : (area.has-hover ? #1b2027 : transparent);

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 12px;
        spacing: 12px;
        alignment: start;

        Text {
            width: 24px;
            text: root.item.icon;
            color: root.item.active ? #a6fff7 : #b7bec8;
            font-size: 16px;
            font-weight: 700;
            vertical-alignment: center;
        }

        Text {
            text: root.item.title;
            color: root.item.active ? #f5fbff : #c3c9d1;
            font-size: 14px;
            font-weight: root.item.active ? 700 : 500;
            vertical-alignment: center;
        }
    }

    area := TouchArea {
        clicked => {
            root.clicked(root.item.id);
        }
    }
}

export component StatusPill inherits Rectangle {
    in property <string> icon;
    in property <string> text;
    in property <color> accent-color;

    min-width: 88px;
    height: 36px;
    border-radius: 8px;
    border-width: 1px;
    border-color: root.accent-color;
    background: #171b20;

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 8px;
        alignment: center;

        Text {
            text: root.icon;
            color: root.accent-color;
            font-size: 14px;
            vertical-alignment: center;
        }

        Text {
            text: root.text;
            color: root.accent-color;
            font-size: 13px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

export component WindowButton inherits Rectangle {
    in property <string> icon;
    in property <bool> danger: false;
    callback clicked;

    width: 36px;
    height: 36px;
    background: root.danger && area.has-hover ? #6d2025 : (area.has-hover ? #242a31 : transparent);

    Text {
        text: root.icon;
        color: root.danger && area.has-hover ? #fff3f3 : #c6ccd5;
        font-size: 15px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    area := TouchArea {
        clicked => {
            root.clicked();
        }
    }
}

export component Panel inherits Rectangle {
    border-radius: 8px;
    border-width: 1px;
    border-color: #343942;
    background: #181c22;
}

export component FieldLabel inherits Text {
    color: #f2f5f7;
    font-size: 13px;
    font-weight: 700;
}

export component MutedText inherits Text {
    color: #9fa7b2;
    font-size: 12px;
}
