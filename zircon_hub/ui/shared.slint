export component BrandMark inherits Rectangle {
    width: MaterialStyleMetrics.size_36;
    height: root.width;
    border-radius: MaterialStyleMetrics.border_radius_8;
    background: transparent;

    Image {
        width: parent.width;
        height: parent.height;
        source: @image-url("../assets/brand/zircon-mark.svg");
        image-fit: contain;
    }
}

export component CenteredIcon inherits Rectangle {
    in property <image> source-image;
    in property <image> fallback-image: @image-url("../assets/icons/ui/alert.svg");
    in property <bool> has-source-image: false;
    in property <length> icon-size: MaterialStyleMetrics.icon_size_18;

    clip: true;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: 0px;

        Rectangle {
            vertical-stretch: 1;
            min-height: 0px;
        }

        HorizontalLayout {
            height: root.icon-size;
            alignment: center;

            Image {
                width: root.icon-size;
                height: root.icon-size;
                source: root.has-source-image ? root.source-image : root.fallback-image;
                image-fit: contain;
            }
        }

        Rectangle {
            vertical-stretch: 1;
            min-height: 0px;
        }
    }
}

export component PillButton inherits Rectangle {
    in property <string> text;
    in property <string> icon;
    in property <image> icon-image;
    in property <bool> has-icon-image: false;
    in property <bool> primary: false;
    in property <bool> enabled: true;
    callback clicked;

    height: MaterialStyleMetrics.size_40;
    min-width: root.height * 3;
    preferred-width: root.height * 4;
    clip: true;

    if root.primary && (root.has-icon-image || root.icon != ""): FilledButton {
        width: parent.width;
        height: parent.height;
        text: root.text;
        icon: root.has-icon-image ? root.icon-image : @image-url("../assets/icons/ui/alert.svg");
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }

    if root.primary && !(root.has-icon-image || root.icon != ""): FilledButton {
        width: parent.width;
        height: parent.height;
        text: root.text;
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }

    if !root.primary && (root.has-icon-image || root.icon != ""): TonalButton {
        width: parent.width;
        height: parent.height;
        text: root.text;
        icon: root.has-icon-image ? root.icon-image : @image-url("../assets/icons/ui/alert.svg");
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }

    if !root.primary && !(root.has-icon-image || root.icon != ""): TonalButton {
        width: parent.width;
        height: parent.height;
        text: root.text;
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

export component IconButton inherits Rectangle {
    in property <string> icon;
    in property <image> icon-image;
    in property <bool> has-icon-image: false;
    in property <bool> active: false;
    in property <bool> enabled: true;
    callback clicked;

    width: MaterialStyleMetrics.size_40;
    height: root.width;
    clip: true;

    if root.active: FilledIconButton {
        width: parent.width;
        height: parent.height;
        icon: root.has-icon-image ? root.icon-image : @image-url("../assets/icons/ui/alert.svg");
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }

    if !root.active: TonalIconButton {
        width: parent.width;
        height: parent.height;
        icon: root.has-icon-image ? root.icon-image : @image-url("../assets/icons/ui/alert.svg");
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }
}

export component NavButton inherits Rectangle {
    in property <NavItemData> item;
    in property <bool> collapsed: false;
    callback clicked(string);

    height: MaterialStyleMetrics.size_56;
    border-radius: root.height / 2;
    border-width: root.item.active ? MaterialStyleMetrics.size_1 : 0px;
    border-color: MaterialPalette.primary;
    background: root.item.active ? MaterialPalette.secondary_container : transparent;
    clip: true;

    ListTile {
        width: parent.width;
        height: parent.height;
        text: root.collapsed ? "" : root.item.title;
        supporting_text: "";
        avatar_icon: root.item.has-icon-image ? root.item.icon-image : @image-url("../assets/icons/nav/projects.svg");
        avatar_background: transparent;
        avatar_foreground: root.item.active ? MaterialPalette.on_secondary_container : MaterialPalette.primary;
        clicked => {
            root.clicked(root.item.id);
        }
    }
}

export component StatusPill inherits Rectangle {
    in property <string> icon;
    in property <image> icon-image;
    in property <bool> has-icon-image: false;
    in property <string> text;
    in property <color> accent-color;

    height: MaterialStyleMetrics.size_40;
    min-width: root.height * 5 / 2;
    border-radius: root.height / 2;
    border-width: MaterialStyleMetrics.size_1;
    border-color: root.accent-color;
    background: MaterialPalette.surface_container_low;
    clip: true;

    ActionChip {
        width: parent.width;
        height: parent.height;
        icon: root.has-icon-image ? root.icon-image : @image-url("../assets/icons/status/running.svg");
        text: root.text;
        tooltip: root.text;
    }
}

export component WindowButton inherits Rectangle {
    in property <string> icon;
    in property <image> icon-image;
    in property <bool> has-icon-image: false;
    in property <bool> danger: false;
    callback clicked;

    width: MaterialStyleMetrics.size_40;
    height: root.width;
    clip: true;

    MaterialIconButton {
        width: parent.width;
        height: parent.height;
        icon: root.has-icon-image ? root.icon-image : @image-url("../assets/icons/ui/close.svg");
        inline: true;
        has_error: root.danger;
        tooltip: root.icon;
        clicked => {
            root.clicked();
        }
    }
}

export component Panel inherits Rectangle {
    border-radius: MaterialStyleMetrics.border_radius_12;
    border-width: MaterialStyleMetrics.size_1;
    border-color: MaterialPalette.outline_variant;
    background: MaterialPalette.surface_container_low;
}

export component FieldLabel inherits MaterialText {
    color: MaterialPalette.on_surface;
    style: MaterialTypography.label_large;
}

export component MutedText inherits MaterialText {
    color: MaterialPalette.on_surface_variant;
    style: MaterialTypography.body_small;
}
