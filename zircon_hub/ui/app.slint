import {
    AssetData,
    CloudServiceData,
    CloudSummaryData,
    HeaderStatusData,
    LearnData,
    NavItemData,
    PluginData,
    ProjectCardData,
    ProjectDetailData,
    ProjectTemplateData,
    QuickActionData,
    RecentProjectRowData,
    SettingStatusData,
    SourceBuildHistoryRowData,
    SourceEngineData,
    SourceEngineRowData,
    TeamData,
    TeamMemberData,
    UiTextData,
} from "shared.slint";
import { ProjectsPage } from "projects.slint";
import { EditorPage } from "editor.slint";
import { BuildsPage } from "builds.slint";
import { AssetsPage } from "assets.slint";
import { PluginsPage } from "plugins.slint";
import { CloudPage } from "cloud.slint";
import { LearnPage } from "learn.slint";
import { TeamPage } from "team.slint";
import { SettingsPage } from "settings.slint";
import { ZirconMaterialTheme } from "theme.slint";
import { HubTokens, HubTopHeader, HubNavSidebar, HubPageHeader, HubStatusBar } from "components.slint";

export component HubWindow inherits Window {
    title: "Zircon Hub";
    no-frame: true;
    resize-border-width: HubTokens.window-resize-border;
    min-width: HubTokens.window-min-width;
    min-height: HubTokens.window-min-height;
    preferred-width: HubTokens.window-preferred-width;
    preferred-height: HubTokens.window-preferred-height;

    in-out property <bool> nav-collapsed: false;
    in-out property <bool> engine-picker-open: false;
    in-out property <string> selected-page: "projects";
    in-out property <length> editor-scroll-y: 0px;
    in-out property <length> assets-scroll-y: 0px;
    in-out property <length> builds-scroll-y: 0px;
    in-out property <length> plugins-scroll-y: 0px;
    in-out property <length> cloud-scroll-y: 0px;
    in-out property <length> team-scroll-y: 0px;
    in-out property <length> learn-scroll-y: 0px;
    in-out property <length> settings-scroll-y: 0px;
    in property <string> selected-page-title: "Projects";
    in property <string> selected-page-subtitle: "Manage your projects and start building worlds.";
    in property <string> project-filter-label: "All Projects";
    in property <string> project-sort-label: "Last Modified";
    in-out property <string> project-entry-mode: "none";
    in-out property <string> project-view-mode: "grid";
    in-out property <string> project-subpage: "dashboard";
    in-out property <string> search-query;
    in-out property <string> project-path;
    in-out property <string> project-name: "ZirconProject";
    in-out property <string> project-location;
    in-out property <string> source-path;
    in-out property <string> output-path;
    in-out property <string> device-install-path;
    in-out property <string> active-engine-name;
    in-out property <string> python-path;
    in-out property <string> cargo-path;
    in-out property <string> rustup-path;
    in-out property <string> build-jobs;
    in-out property <string> build-profile: "debug";
    in-out property <string> language: "English";
    in property <[NavItemData]> nav-items;
    in property <[ProjectCardData]> project-cards;
    in property <int> project-card-count;
    in-out property <bool> project-cards-expanded: false;
    in property <[RecentProjectRowData]> project-list-rows;
    in property <int> project-list-row-count;
    in property <[RecentProjectRowData]> project-browser-rows;
    in property <int> project-browser-row-count;
    in property <[RecentProjectRowData]> dashboard-project-rows;
    in property <int> dashboard-project-row-count;
    in property <string> dashboard-project-title: "Recent Projects";
    in property <[ProjectTemplateData]> project-templates;
    in property <int> project-template-count;
    in property <bool> project-create-enabled: true;
    in property <string> project-create-template-label;
    in property <string> project-create-engine-label;
    in property <[SourceEngineRowData]> project-engine-rows;
    in property <int> project-engine-count;
    in property <ProjectDetailData> project-detail;
    in property <[RecentProjectRowData]> recent-project-rows;
    in property <int> recent-project-row-count;
    in property <[QuickActionData]> quick-actions;
    in property <[AssetData]> assets;
    in property <int> asset-count;
    in property <[LearnData]> learn-resources;
    in property <int> learn-count;
    in property <[PluginData]> plugins;
    in property <int> plugin-count;
    in property <TeamData> team-summary;
    in property <[TeamMemberData]> team-members;
    in property <int> team-member-count;
    in property <CloudSummaryData> cloud-summary;
    in property <[CloudServiceData]> cloud-services;
    in property <int> cloud-service-count;
    in property <[HeaderStatusData]> header-statuses;
    in property <[SettingStatusData]> settings-statuses;
    in property <[SourceEngineRowData]> source-engines;
    in property <int> source-engine-count;
    in property <[SourceBuildHistoryRowData]> source-build-history;
    in property <int> source-build-history-count;
    in property <SourceEngineData> source-engine;
    in property <string> status-label: "Ready";
    in property <string> status-detail: "Hub is ready";
    in property <bool> task-running: false;
    in property <UiTextData> ui-text;
    private property <length> shell-header-height: HubTokens.shell-header-height;
    private property <length> shell-drag-height: HubTokens.shell-drag-max;
    private property <length> shell-row-height: root.shell-header-height - root.shell-drag-height;
    private property <length> shell-gap: HubTokens.toolbar-gap;
    private property <length> shell-pad-x: HubTokens.space-6;
    private property <length> nav-width: root.nav-collapsed ? ((HubTokens.nav-width-collapsed-min + HubTokens.nav-width-collapsed-max) / 2) : ((HubTokens.nav-width-expanded-min + HubTokens.nav-width-expanded-max) / 2);
    private property <length> nav-pad: root.nav-collapsed ? max(HubTokens.space-2, min(HubTokens.space-3, root.nav-width / 7)) : max(HubTokens.space-3, min(HubTokens.space-4, root.nav-width / 16));
    private property <length> nav-status-height: root.shell-row-height * 3;
    private property <length> page-title-height: root.shell-header-height + HubTokens.space-6;
    private property <length> page-pad-x: HubTokens.page-padding;
    private property <length> page-action-height: HubTokens.control-lg;
    private property <length> bottom-status-height: HubTokens.bottom-status-height;
    private property <bool> header-compact: root.width < HubTokens.breakpoint-wide;
    private property <bool> sidebar-compact-height: root.height < HubTokens.breakpoint-short;

    callback show-page(string);
    callback open-project();
    callback open-recent-project(string);
    callback select-project(string);
    callback show-project-subpage(string);
    callback open-project-detail(string);
    callback select-project-template(string);
    callback select-new-project-engine(string);
    callback select-project-detail-engine(string);
    callback toggle-project-pin();
    callback remove-project-from-hub();
    callback request-delete-project();
    callback cancel-delete-project();
    callback confirm-delete-project();
    callback create-project();
    callback save-settings();
    callback build-engine();
    callback open-output();
    callback launch-editor();
    callback quick-action(string);
    callback search-projects(string);
    callback view-all-projects();
    callback browse-folder(string);
    callback select-engine(string);
    callback rename-active-engine(string);
    callback remove-engine(string);
    callback open-learn-resource(string);
    callback cycle-engine();
    callback set-project-filter(string);
    callback set-project-sort(string);
    callback set-project-view-mode(string);
    callback window-minimize();
    callback window-toggle-maximize();
    callback window-close();
    callback window-drag-start(float, float);
    callback window-drag-move(float, float);
    callback window-drag-end();

    function reset-page-scrolls() {
        focus-sink.focus();
        root.editor-scroll-y = 0px;
        root.assets-scroll-y = 0px;
        root.builds-scroll-y = 0px;
        root.plugins-scroll-y = 0px;
        root.cloud-scroll-y = 0px;
        root.team-scroll-y = 0px;
        root.learn-scroll-y = 0px;
        root.settings-scroll-y = 0px;
    }

    Rectangle {
        width: root.width;
        height: root.height;
        background: HubTokens.surface-page;

        ZirconMaterialTheme { }

        focus-sink := FocusScope {
            width: HubTokens.border-width;
            height: HubTokens.border-width;
        }

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            spacing: HubTokens.space-0;

            HubTopHeader {
                header-height: root.shell-header-height;
                drag-height: root.shell-drag-height;
                row-height: root.shell-row-height;
                pad-x: root.shell-pad-x;
                gap: root.shell-gap;
                nav-width: root.nav-width;
                action-height: root.page-action-height;
                compact: root.header-compact;
                source-engine: root.source-engine;
                source-engines: root.source-engines;
                source-engine-count: root.source-engine-count;
                header-statuses: root.header-statuses;
                ui-text: root.ui-text;
                select-engine(id) => { root.select-engine(id); }
                settings-clicked => {
                    root.reset-page-scrolls();
                    root.show-page("settings");
                }
                window-minimize => { root.window-minimize(); }
                window-toggle-maximize => { root.window-toggle-maximize(); }
                window-close => { root.window-close(); }
                window-drag-start(x, y) => { root.window-drag-start(x, y); }
                window-drag-move(x, y) => { root.window-drag-move(x, y); }
                window-drag-end => { root.window-drag-end(); }
            }

            Rectangle {
                width: parent.width;
                height: root.height - root.shell-header-height;
                background: HubTokens.surface-page;

                HorizontalLayout {
                    width: parent.width;
                    height: parent.height;
                    spacing: HubTokens.space-0;

                    HubNavSidebar {
                        nav-width: root.nav-width;
                        nav-pad: root.nav-pad;
                        nav-status-height: root.nav-status-height;
                        row-height: root.shell-row-height;
                        gap: max(HubTokens.space-2, min(HubTokens.toolbar-gap, root.nav-pad));
                        nav-items: root.nav-items;
                        collapsed: root.nav-collapsed;
                        compact-height: root.sidebar-compact-height;
                        task-running: root.task-running;
                        source-engine: root.source-engine;
                        ui-text: root.ui-text;
                        clicked(id) => {
                            root.show-page(id);
                            root.reset-page-scrolls();
                        }
                        toggle-collapse => {
                            root.nav-collapsed = !root.nav-collapsed;
                        }
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        vertical-stretch: 1;
                        min-width: 1px;
                        preferred-width: 0px;
                        min-height: 0px;
                        preferred-height: 0px;
                        background: HubTokens.surface-page;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            spacing: HubTokens.space-0;

                            HubPageHeader {
                                page-title-height: root.page-title-height;
                                page-pad-x: root.page-pad-x;
                                gap: root.shell-gap;
                                action-height: root.page-action-height;
                                selected-page: root.selected-page;
                                selected-page-title: root.selected-page-title;
                                selected-page-subtitle: root.selected-page-subtitle;
                                status-label: root.status-label;
                                task-running: root.task-running;
                                ui-text: root.ui-text;
                                import-project => {
                                    root.project-entry-mode = "open";
                                    root.project-subpage = "project-browser";
                                    root.show-project-subpage("project-browser");
                                }
                                create-project => {
                                    root.project-entry-mode = "create";
                                    root.project-subpage = "new-project";
                                    root.show-project-subpage("new-project");
                                }
                            }

                            Rectangle {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;
                                min-width: 1px;
                                preferred-width: 0px;
                                min-height: 0px;
                                preferred-height: 0px;
                                clip: true;
                            if root.selected-page == "projects": ProjectsPage {
                                width: parent.width;
                                height: parent.height;
                                project-subpage <=> root.project-subpage;
                                project-entry-mode <=> root.project-entry-mode;
                                search-query <=> root.search-query;
                                project-path <=> root.project-path;
                                project-name <=> root.project-name;
                                project-location <=> root.project-location;
                                project-filter-label: root.project-filter-label;
                                project-sort-label: root.project-sort-label;
                                project-view-mode <=> root.project-view-mode;
                                project-cards-expanded <=> root.project-cards-expanded;
                                project-cards: root.project-cards;
                                project-card-count: root.project-card-count;
                                project-list-rows: root.project-list-rows;
                                project-list-row-count: root.project-list-row-count;
                                project-browser-rows: root.project-browser-rows;
                                project-browser-row-count: root.project-browser-row-count;
                                dashboard-project-rows: root.dashboard-project-rows;
                                dashboard-project-row-count: root.dashboard-project-row-count;
                                dashboard-project-title: root.dashboard-project-title;
                                project-templates: root.project-templates;
                                project-template-count: root.project-template-count;
                                project-create-enabled: root.project-create-enabled;
                                project-create-template-label: root.project-create-template-label;
                                project-create-engine-label: root.project-create-engine-label;
                                project-engine-rows: root.project-engine-rows;
                                project-engine-count: root.project-engine-count;
                                project-detail: root.project-detail;
                                recent-project-rows: root.recent-project-rows;
                                recent-project-row-count: root.recent-project-row-count;
                                quick-actions: root.quick-actions;
                                ui-text: root.ui-text;
                                open-project => { root.open-project(); }
                                open-recent-project(path) => { root.open-recent-project(path); }
                                select-project(path) => { root.select-project(path); }
                                open-project-detail(path) => { root.open-project-detail(path); }
                                create-project => { root.create-project(); }
                                quick-action(id) => { root.quick-action(id); }
                                search-projects(query) => { root.search-projects(query); }
                                view-all-projects => { root.view-all-projects(); }
                                browse-folder(target) => { root.browse-folder(target); }
                                set-project-filter(id) => { root.set-project-filter(id); }
                                set-project-sort(id) => { root.set-project-sort(id); }
                                set-project-view-mode(mode) => { root.set-project-view-mode(mode); }
                                show-project-subpage(id) => { root.show-project-subpage(id); }
                                select-project-template(id) => { root.select-project-template(id); }
                                select-new-project-engine(id) => { root.select-new-project-engine(id); }
                                select-project-detail-engine(id) => { root.select-project-detail-engine(id); }
                                toggle-project-pin => { root.toggle-project-pin(); }
                                remove-project-from-hub => { root.remove-project-from-hub(); }
                                request-delete-project => { root.request-delete-project(); }
                                cancel-delete-project => { root.cancel-delete-project(); }
                                confirm-delete-project => { root.confirm-delete-project(); }
                            }
                            if root.selected-page == "editor": EditorPage {
                                width: parent.width;
                                height: parent.height;
                                scroll-y <=> root.editor-scroll-y;
                                source-path <=> root.source-path;
                                output-path <=> root.output-path;
                                active-engine-name <=> root.active-engine-name;
                                source-engine: root.source-engine;
                                source-engines: root.source-engines;
                                source-engine-count: root.source-engine-count;
                                source-build-history: root.source-build-history;
                                source-build-history-count: root.source-build-history-count;
                                ui-text: root.ui-text;
                                save-settings => { root.save-settings(); }
                                browse-folder(target) => { root.browse-folder(target); }
                                select-engine(id) => { root.select-engine(id); }
                                rename-active-engine(name) => { root.rename-active-engine(name); }
                                remove-engine(id) => { root.remove-engine(id); }
                                build-engine => { root.build-engine(); }
                                open-output => { root.open-output(); }
                                launch-editor => { root.launch-editor(); }
                            }
                            if root.selected-page == "settings": SettingsPage {
                                width: parent.width;
                                height: parent.height;
                                scroll-y <=> root.settings-scroll-y;
                                python-path <=> root.python-path;
                                cargo-path <=> root.cargo-path;
                                rustup-path <=> root.rustup-path;
                                project-location <=> root.project-location;
                                source-path <=> root.source-path;
                                output-path <=> root.output-path;
                                device-install-path <=> root.device-install-path;
                                build-jobs <=> root.build-jobs;
                                build-profile <=> root.build-profile;
                                language <=> root.language;
                                settings-statuses: root.settings-statuses;
                                ui-text: root.ui-text;
                                browse-folder(target) => { root.browse-folder(target); }
                                save-settings => { root.save-settings(); }
                            }
                            if root.selected-page == "builds": BuildsPage {
                                width: parent.width;
                                height: parent.height;
                                scroll-y <=> root.builds-scroll-y;
                                source-engine: root.source-engine;
                                status-label: root.status-label;
                                status-detail: root.status-detail;
                                ui-text: root.ui-text;
                                build-engine => { root.build-engine(); }
                                open-output => { root.open-output(); }
                                launch-editor => { root.launch-editor(); }
                            }
                            if root.selected-page == "assets": AssetsPage {
                                width: parent.width;
                                height: parent.height;
                                scroll-y <=> root.assets-scroll-y;
                                assets: root.assets;
                                asset-count: root.asset-count;
                                ui-text: root.ui-text;
                            }
                            if root.selected-page == "plugins": PluginsPage {
                                width: parent.width;
                                height: parent.height;
                                scroll-y <=> root.plugins-scroll-y;
                                plugins: root.plugins;
                                plugin-count: root.plugin-count;
                                ui-text: root.ui-text;
                            }
                            if root.selected-page == "cloud": CloudPage {
                                width: parent.width;
                                height: parent.height;
                                scroll-y <=> root.cloud-scroll-y;
                                summary: root.cloud-summary;
                                services: root.cloud-services;
                                service-count: root.cloud-service-count;
                                ui-text: root.ui-text;
                            }
                            if root.selected-page == "team": TeamPage {
                                width: parent.width;
                                height: parent.height;
                                scroll-y <=> root.team-scroll-y;
                                summary: root.team-summary;
                                members: root.team-members;
                                member-count: root.team-member-count;
                                ui-text: root.ui-text;
                            }
                            if root.selected-page == "learn": LearnPage {
                                width: parent.width;
                                height: parent.height;
                                scroll-y <=> root.learn-scroll-y;
                                resources: root.learn-resources;
                                resource-count: root.learn-count;
                                ui-text: root.ui-text;
                                open-resource(path) => { root.open-learn-resource(path); }
                            }
                        }

                        HubStatusBar {
                            status-height: root.bottom-status-height;
                            status-detail: root.status-detail;
                        }
                    }
                    }
                }
            }
        }

    }
}
