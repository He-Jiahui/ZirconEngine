import { TeamData, TeamMemberData, UiTextData } from "shared.slint";
import { EmptyStateBlock, HubTokens, InfoRow, MaterialStyleMetrics, MetricCard, OverviewPanel, PageScrollSurface, PanelHeader, PanelListViewport, PanelSlot, ResponsiveSlot, WorkspacePanelSection } from "components.slint";

component TeamMemberRow inherits InfoRow {
    in property <TeamMemberData> member;
    in property <UiTextData> ui-text;
    in property <bool> collapse-label: false;

    title: root.member.name;
    detail: root.member.email;
    meta: "";
    leading-image: @image-url("../assets/icons/nav/team.svg");
    has-leading-image: true;
    accent: root.member.accent;
    trailing-text: root.member.commits + " " + root.ui-text.team-commits;
    trailing-tone: "accent";
    show-trailing-badge: true;
    collapse-trailing-label: root.collapse-label;
    row-height: HubTokens.list-row-lg;
}

component TeamSummarySlot inherits ResponsiveSlot {
    in property <string> label;
    in property <string> primary;
    in property <string> secondary;

    MetricCard {
        width: parent.width;
        height: parent.height;
        label: root.label;
        primary: root.primary;
        secondary: root.secondary;
    }
}

export component TeamPage inherits PageScrollSurface {
    in property <TeamData> summary;
    in property <[TeamMemberData]> members;
    in property <int> member-count;
    in property <bool> has-selected-project: false;
    in property <UiTextData> ui-text;
    private property <length> header-height: HubTokens.list-row-lg;
    private property <bool> summary-compact: root.content-width < HubTokens.panel-min-sm * 3 / 4 + HubTokens.panel-min-md + HubTokens.panel-gap;
    private property <length> member-row-height: root.summary-compact ? HubTokens.list-row-md : HubTokens.list-row-lg;
    private property <length> summary-section-height: root.summary-compact ? HubTokens.workspace-row-team-summary * 2 + HubTokens.panel-gap : HubTokens.workspace-row-team-summary;
    private property <length> member-row-slot-height: root.member-row-height + HubTokens.space-2;
    private property <length> member-panel-chrome-height: HubTokens.control-md + HubTokens.toolbar-gap + HubTokens.space-4 * 2;
    private property <int> member-visible-rows: root.member-count < 6 ? root.member-count : 6;
    private property <length> member-available-height: max(root.member-panel-chrome-height + root.member-row-slot-height, root.content-height - root.header-height - root.summary-section-height - HubTokens.panel-gap * 2);
    private property <length> member-available-list-height: max(root.member-row-slot-height, root.member-available-height - root.member-panel-chrome-height);
    private property <int> member-fit-row-count: Math.floor(root.member-available-list-height / root.member-row-slot-height);
    private property <int> member-fit-rows: root.member-fit-row-count < 1 ? 1 : root.member-fit-row-count;
    private property <int> member-panel-rows: root.member-visible-rows < 1 ? 1 : (root.member-visible-rows < root.member-fit-rows ? root.member-visible-rows : root.member-fit-rows);
    private property <length> member-list-height: root.member-count == 0 ? HubTokens.list-row-lg + HubTokens.space-4 : root.member-panel-rows * root.member-row-height + (root.member-panel-rows - 1) * HubTokens.space-2 + HubTokens.space-1 * 2;
    private property <length> members-panel-height: root.member-panel-chrome-height + root.member-list-height;
    private property <length> member-scroll-y: 0px;
    private property <string> workspace-title: root.has-selected-project ? root.ui-text.team-workspace-selected : root.ui-text.team-workspace;
    private property <string> members-empty-detail: root.has-selected-project ? root.ui-text.team-empty-selected-detail : root.ui-text.team-empty-global-detail;

    background: HubTokens.surface-page;
    clip: true;

    OverviewPanel {
        height: root.header-height;
        title: root.workspace-title;
        subtitle: root.summary.status;
        badge-text: root.member-count + " " + root.ui-text.team-members-found;
        badge-width: HubTokens.control-lg * 3;
    }

    WorkspacePanelSection {
        compact: root.summary-compact;
        row-height: HubTokens.workspace-row-team-summary;
        spacing-horizontal: HubTokens.panel-gap;
        spacing-vertical: HubTokens.panel-gap;

        TeamSummarySlot {
            basis: HubTokens.panel-min-sm * 4 / 5;
            flex-basis: HubTokens.panel-min-sm * 4 / 5;
            grow: 0;
            flex-grow: 0;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.summary-compact ? root.content-width : HubTokens.panel-min-sm * 3 / 4;
            height: HubTokens.workspace-row-team-summary;
            label: root.ui-text.team-git-identity;
            primary: root.summary.identity-name;
            secondary: root.summary.identity-email;
        }

        TeamSummarySlot {
            basis: HubTokens.panel-min-md;
            flex-basis: HubTokens.panel-min-md;
            grow: 1;
            flex-grow: 1;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.summary-compact ? root.content-width : HubTokens.panel-min-sm;
            height: HubTokens.workspace-row-team-summary;
            label: root.ui-text.team-repository;
            primary: root.summary.repository-path;
            secondary: root.ui-text.team-local-only;
        }
    }

    PanelSlot {
        horizontal-stretch: 1;
        height: root.members-panel-height;
        body-padding: MaterialStyleMetrics.padding_16;
        body-spacing: HubTokens.toolbar-gap;

        PanelHeader {
            title: root.ui-text.team-members-found;
            show-badge: true;
            badge-text: root.member-count + "";
            badge-tone: "neutral";
        }

        PanelListViewport {
            scroll-y <=> root.member-scroll-y;
            row-count: root.member-count;
            row-height: root.member-row-height;
            empty-height: HubTokens.list-row-lg + HubTokens.space-4;

            if root.member-count == 0: EmptyStateBlock {
                height: HubTokens.list-row-lg + HubTokens.space-4;
                title: root.ui-text.no-team-members-found;
                detail: root.members-empty-detail;
                extra-detail: root.summary.repository-path;
                body-padding: MaterialStyleMetrics.padding_16;
                center-content: true;
            }

            for member in root.members: TeamMemberRow {
                row-height: root.member-row-height;
                member: member;
                ui-text: root.ui-text;
                collapse-label: root.content-width < HubTokens.breakpoint-medium;
            }
        }
    }
}
