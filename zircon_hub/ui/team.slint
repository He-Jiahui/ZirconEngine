import { MutedText, TeamData, TeamMemberData, UiTextData } from "shared.slint";
import { HubPanel, HubTokens, InfoRow, MaterialPalette, MaterialStyleMetrics, MaterialTypography, PageScrollSurface, PanelHeader, PanelListViewport, ResponsivePanelFlow } from "components.slint";

component TeamSummaryItem inherits Rectangle {
    in property <string> label;
    in property <string> primary;
    in property <string> secondary;

    min-height: HubTokens.list-row-md;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: MaterialStyleMetrics.spacing_6;

        MutedText {
            text: root.label;
            overflow: elide;
        }

        Text {
            text: root.primary;
            overflow: elide;
            color: MaterialPalette.on_surface;
            font-size: MaterialTypography.title_small.font_size;
            font-weight: MaterialTypography.title_small.font_weight;
        }

        MutedText {
            text: root.secondary;
            overflow: elide;
        }
    }
}

component TeamSummaryCard inherits HubPanel {
    in property <string> label;
    in property <string> primary;
    in property <string> secondary;

    height: HubTokens.list-row-lg + HubTokens.space-7;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: MaterialStyleMetrics.padding_16;
        padding-right: MaterialStyleMetrics.padding_16;
        padding-top: MaterialStyleMetrics.padding_16;
        padding-bottom: MaterialStyleMetrics.padding_16;

        TeamSummaryItem {
            horizontal-stretch: 1;
            label: root.label;
            primary: root.primary;
            secondary: root.secondary;
        }
    }
}

component TeamMemberRow inherits InfoRow {
    in property <TeamMemberData> member;
    in property <UiTextData> ui-text;

    title: root.member.name;
    detail: root.member.email;
    meta: "";
    leading-image: @image-url("../assets/icons/nav/team.svg");
    has-leading-image: true;
    accent: root.member.accent;
    trailing-text: root.member.commits + " " + root.ui-text.team-commits;
    trailing-tone: "accent";
    show-trailing-badge: true;
    row-height: HubTokens.list-row-lg;
}

export component TeamPage inherits Rectangle {
    in-out property <length> scroll-y: 0px;
    in property <TeamData> summary;
    in property <[TeamMemberData]> members;
    in property <int> member-count;
    in property <UiTextData> ui-text;
    private property <bool> compact: root.width < HubTokens.breakpoint-compact;
    private property <length> member-scroll-y: 0px;

    background: HubTokens.surface-page;
    clip: true;

    PageScrollSurface {
        width: root.width;
        height: root.height;
        scroll-y <=> root.scroll-y;

        HubPanel {
            height: HubTokens.list-row-lg;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: MaterialStyleMetrics.padding_16;
                padding-right: MaterialStyleMetrics.padding_16;
                padding-top: MaterialStyleMetrics.padding_14;
                padding-bottom: MaterialStyleMetrics.padding_14;

                PanelHeader {
                    title: root.ui-text.team-workspace;
                    subtitle: root.summary.status;
                    show-badge: true;
                    badge-text: root.member-count + " " + root.ui-text.team-members-found;
                    badge-tone: "accent";
                }
            }
        }

        ResponsivePanelFlow {
            flow-height: root.compact ? (HubTokens.list-row-lg + HubTokens.space-7) * 2 + HubTokens.panel-gap : HubTokens.list-row-lg + HubTokens.space-7;
            spacing-horizontal: HubTokens.panel-gap;
            spacing-vertical: HubTokens.panel-gap;

            TeamSummaryCard {
                flex-basis: HubTokens.panel-min-sm * 4 / 5;
                flex-grow: 0;
                flex-shrink: 1;
                min-width: HubTokens.panel-min-sm * 3 / 4;
                label: root.ui-text.team-git-identity;
                primary: root.summary.identity-name;
                secondary: root.summary.identity-email;
            }

            TeamSummaryCard {
                flex-basis: HubTokens.panel-min-lg;
                flex-grow: 1;
                flex-shrink: 1;
                min-width: HubTokens.panel-min-sm;
                label: root.ui-text.team-repository;
                primary: root.summary.repository-path;
                secondary: root.ui-text.team-local-only;
            }
        }

        HubPanel {
            horizontal-stretch: 1;
            vertical-stretch: 1;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: MaterialStyleMetrics.padding_16;
                spacing: HubTokens.toolbar-gap;

                PanelHeader {
                    title: root.ui-text.team-members-found;
                    show-badge: true;
                    badge-text: root.member-count + "";
                    badge-tone: "neutral";
                }

                PanelListViewport {
                    scroll-y <=> root.member-scroll-y;
                    row-count: root.member-count;
                    row-height: HubTokens.list-row-lg;
                    empty-height: HubTokens.list-row-lg + HubTokens.space-4;

                    if root.member-count == 0: HubPanel {
                        height: HubTokens.list-row-lg + HubTokens.space-4;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: MaterialStyleMetrics.padding_16;
                            spacing: HubTokens.space-2;

                            Text {
                                text: root.ui-text.no-team-members-found;
                                color: MaterialPalette.on_surface;
                                font-size: MaterialTypography.label_large.font_size;
                                font-weight: MaterialTypography.label_large.font_weight;
                            }

                            MutedText {
                                text: root.summary.repository-path;
                                overflow: elide;
                            }
                        }
                    }

                    for member in root.members: Rectangle {
                        width: parent.width;
                        height: HubTokens.list-row-lg;

                        TeamMemberRow {
                            width: parent.width;
                            height: parent.height;
                            member: member;
                            ui-text: root.ui-text;
                        }
                    }
                }
            }
        }
    }
}
