import { MutedText, TeamData, TeamMemberData, UiTextData } from "shared.slint";
import { HubPanel, HubTokens, InfoRow, MaterialPalette, MaterialStyleMetrics, MaterialText, MaterialTypography, PageScrollSurface, PanelHeader, PanelListViewport, ResponsiveSlot, WorkspacePanelSection } from "components.slint";

component TeamSummaryItem inherits Rectangle {
    in property <string> label;
    in property <string> primary;
    in property <string> secondary;

    min-height: HubTokens.list-row-md;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: MaterialStyleMetrics.spacing_6;

        MutedText {
            text: root.label;
            overflow: elide;
        }

        MaterialText {
            text: root.primary;
            overflow: elide;
            color: MaterialPalette.on_surface;
            style: MaterialTypography.title_small;
        }

        MutedText {
            text: root.secondary;
            overflow: elide;
        }
    }
}

component TeamSummaryCard inherits HubPanel {
    in property <string> label;
    in property <string> primary;
    in property <string> secondary;

    height: HubTokens.list-row-lg + HubTokens.space-7;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: MaterialStyleMetrics.padding_16;
        padding-right: MaterialStyleMetrics.padding_16;
        padding-top: MaterialStyleMetrics.padding_16;
        padding-bottom: MaterialStyleMetrics.padding_16;

        TeamSummaryItem {
            horizontal-stretch: 1;
            label: root.label;
            primary: root.primary;
            secondary: root.secondary;
        }
    }
}

component TeamMemberRow inherits InfoRow {
    in property <TeamMemberData> member;
    in property <UiTextData> ui-text;

    title: root.member.name;
    detail: root.member.email;
    meta: "";
    leading-image: @image-url("../assets/icons/nav/team.svg");
    has-leading-image: true;
    accent: root.member.accent;
    trailing-text: root.member.commits + " " + root.ui-text.team-commits;
    trailing-tone: "accent";
    show-trailing-badge: true;
    row-height: HubTokens.list-row-lg;
}

export component TeamPage inherits Rectangle {
    in-out property <length> scroll-y: 0px;
    in property <TeamData> summary;
    in property <[TeamMemberData]> members;
    in property <int> member-count;
    in property <bool> has-selected-project: false;
    in property <UiTextData> ui-text;
    private property <length> content-width: page-surface.content-width;
    private property <length> content-height: page-surface.content-height;
    private property <length> header-height: HubTokens.list-row-lg;
    private property <bool> summary-compact: root.content-width < HubTokens.panel-min-sm + HubTokens.panel-min-lg + HubTokens.panel-gap;
    private property <length> member-row-height: root.summary-compact ? HubTokens.list-row-md : HubTokens.list-row-lg;
    private property <length> summary-section-height: root.summary-compact ? HubTokens.workspace-row-team-summary * 2 + HubTokens.panel-gap : HubTokens.workspace-row-team-summary;
    private property <length> members-panel-height: max(root.member-row-height * 3, root.content-height - root.header-height - root.summary-section-height - HubTokens.panel-gap * 2);
    private property <length> member-scroll-y: 0px;
    private property <string> workspace-title: root.has-selected-project ? root.ui-text.team-workspace-selected : root.ui-text.team-workspace;
    private property <string> members-empty-detail: root.has-selected-project ? root.ui-text.team-empty-selected-detail : root.ui-text.team-empty-global-detail;

    background: HubTokens.surface-page;
    clip: true;

    page-surface := PageScrollSurface {
        width: root.width;
        height: root.height;
        scroll-y <=> root.scroll-y;

        HubPanel {
            height: root.header-height;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: MaterialStyleMetrics.padding_16;
                padding-right: MaterialStyleMetrics.padding_16;
                padding-top: MaterialStyleMetrics.padding_14;
                padding-bottom: MaterialStyleMetrics.padding_14;

                PanelHeader {
                    title: root.workspace-title;
                    subtitle: root.summary.status;
                    show-badge: true;
                    badge-text: root.member-count + " " + root.ui-text.team-members-found;
                    badge-tone: "accent";
                    badge-width: HubTokens.control-lg * 3;
                }
            }
        }

        WorkspacePanelSection {
            compact: root.summary-compact;
            row-height: HubTokens.workspace-row-team-summary;
            spacing-horizontal: HubTokens.panel-gap;
            spacing-vertical: HubTokens.panel-gap;

            ResponsiveSlot {
                basis: HubTokens.panel-min-sm * 4 / 5;
                grow: 0;
                shrink: 1;
                min-width: root.summary-compact ? root.content-width : HubTokens.panel-min-sm * 3 / 4;
                height: HubTokens.workspace-row-team-summary;

                TeamSummaryCard {
                    width: parent.width;
                    height: parent.height;
                    label: root.ui-text.team-git-identity;
                    primary: root.summary.identity-name;
                    secondary: root.summary.identity-email;
                }
            }

            ResponsiveSlot {
                basis: HubTokens.panel-min-lg;
                grow: 1;
                shrink: 1;
                min-width: root.summary-compact ? root.content-width : HubTokens.panel-min-sm;
                height: HubTokens.workspace-row-team-summary;

                TeamSummaryCard {
                    width: parent.width;
                    height: parent.height;
                    label: root.ui-text.team-repository;
                    primary: root.summary.repository-path;
                    secondary: root.ui-text.team-local-only;
                }
            }
        }

        HubPanel {
            horizontal-stretch: 1;
            height: root.members-panel-height;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: MaterialStyleMetrics.padding_16;
                spacing: HubTokens.toolbar-gap;

                PanelHeader {
                    title: root.ui-text.team-members-found;
                    show-badge: true;
                    badge-text: root.member-count + "";
                    badge-tone: "neutral";
                }

                PanelListViewport {
                    scroll-y <=> root.member-scroll-y;
                    row-count: root.member-count;
                    row-height: root.member-row-height;
                    empty-height: HubTokens.list-row-lg + HubTokens.space-4;

                    if root.member-count == 0: HubPanel {
                        height: HubTokens.list-row-lg + HubTokens.space-4;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: MaterialStyleMetrics.padding_16;
                            spacing: HubTokens.space-2;

                            MaterialText {
                                text: root.ui-text.no-team-members-found;
                                color: MaterialPalette.on_surface;
                                style: MaterialTypography.label_large;
                            }

                            MutedText {
                                text: root.members-empty-detail;
                                overflow: elide;
                            }

                            MutedText {
                                text: root.summary.repository-path;
                                overflow: elide;
                            }
                        }
                    }

                    for member in root.members: Rectangle {
                        width: parent.width;
                        height: root.member-row-height;

                        TeamMemberRow {
                            width: parent.width;
                            height: parent.height;
                            row-height: root.member-row-height;
                            member: member;
                            ui-text: root.ui-text;
                        }
                    }
                }
            }
        }
    }
}
