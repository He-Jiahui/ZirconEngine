import { TeamMemberData, UiTextData } from "shared.slint";
import {
    EmptyStateBlock,
    HubListPanelSlot,
    HubTokens,
    InfoRow,
    MaterialStyleMetrics,
    MetricCard,
    ResponsiveSlot,
} from "components.slint";

export component TeamMemberRow inherits InfoRow {
    in property <TeamMemberData> member;
    in property <UiTextData> ui-text;
    in property <bool> collapse-label: false;

    title: root.member.name;
    detail: root.member.email;
    meta: "";
    leading-image: @image-url("../assets/icons/nav/team.svg");
    has-leading-image: true;
    accent: root.member.accent;
    trailing-text: root.member.commits + " " + root.ui-text.team-commits;
    trailing-tone: "accent";
    show-trailing-badge: true;
    collapse-trailing-label: root.collapse-label;
    row-height: HubTokens.list-row-lg;
}

export component TeamSummarySlot inherits ResponsiveSlot {
    in property <string> label;
    in property <string> primary;
    in property <string> secondary;

    MetricCard {
        width: parent.width;
        height: parent.height;
        label: root.label;
        primary: root.primary;
        secondary: root.secondary;
    }
}

export component TeamMembersPanel inherits HubListPanelSlot {
    in property <[TeamMemberData]> members;
    in property <int> member-count;
    in property <length> member-row-height;
    in property <string> members-empty-detail;
    in property <string> repository-path;
    in property <UiTextData> ui-text;
    in property <bool> collapse-label: false;
    in-out property <length> member-scroll-y;

    body-padding: MaterialStyleMetrics.padding_16;
    body-spacing: HubTokens.toolbar-gap;
    title: root.ui-text.team-members-found;
    show-badge: true;
    badge-text: root.member-count + "";
    badge-tone: "neutral";
    scroll-y <=> root.member-scroll-y;
    row-count: root.member-count;
    row-height: root.member-row-height;
    empty-height: HubTokens.list-row-lg + HubTokens.space-4;

    if root.member-count == 0: EmptyStateBlock {
        height: HubTokens.list-row-lg + HubTokens.space-4;
        title: root.ui-text.no-team-members-found;
        detail: root.members-empty-detail;
        extra-detail: root.repository-path;
        body-padding: MaterialStyleMetrics.padding_16;
        center-content: true;
    }

    for member in root.members: TeamMemberRow {
        row-height: root.member-row-height;
        member: member;
        ui-text: root.ui-text;
        collapse-label: root.collapse-label;
    }
}
