import {
    AssetData,
    LearnData,
    PluginData,
    UiTextData,
} from "shared.slint";
import { HubTokens, InfoRow } from "components.slint";

export component AssetRow inherits InfoRow {
    in property <AssetData> asset;
    in property <UiTextData> ui-text;
    in property <bool> collapse-label: false;

    title: root.asset.name;
    detail: root.asset.path;
    meta: root.ui-text.asset-source + ": " + root.asset.source + "    " + root.ui-text.asset-size + ": " + root.asset.size;
    leading-image: @image-url("../assets/icons/nav/assets.svg");
    has-leading-image: true;
    trailing-text: root.asset.kind;
    trailing-tone: "accent";
    show-trailing-badge: true;
    collapse-trailing-label: root.collapse-label;
    row-height: HubTokens.list-row-lg + HubTokens.space-6;
}

export component PluginRow inherits InfoRow {
    in property <PluginData> plugin;
    in property <UiTextData> ui-text;
    in property <bool> collapse-label: false;

    title: root.plugin.title;
    detail: root.plugin.description;
    meta: root.plugin.scope + "    " + root.ui-text.plugin-packaging + ": " + root.plugin.packaging + "    " + root.ui-text.plugin-modules + ": " + root.plugin.modules + "    " + root.ui-text.plugin-maturity + ": " + root.plugin.maturity + "    " + root.plugin.path;
    leading-image: @image-url("../assets/icons/nav/plugins.svg");
    has-leading-image: true;
    trailing-text: root.plugin.category;
    trailing-tone: "accent";
    show-trailing-badge: true;
    collapse-trailing-label: root.collapse-label;
    row-height: HubTokens.list-row-lg + HubTokens.space-6;
}

export component LearnRow inherits InfoRow {
    in property <LearnData> resource;
    in property <UiTextData> ui-text;
    in property <bool> collapse-label: false;
    callback open-resource(string);

    title: root.resource.title;
    detail: root.resource.summary;
    meta: root.resource.source + "    " + root.ui-text.learn-category + ": " + root.resource.category + "    " + root.resource.path;
    leading-image: @image-url("../assets/icons/ui/help.svg");
    has-leading-image: true;
    trailing-text: root.resource.category;
    trailing-tone: "accent";
    show-trailing-badge: true;
    collapse-trailing-label: root.collapse-label;
    show-arrow: true;
    row-height: HubTokens.list-row-lg + HubTokens.space-6;
    clicked => {
        root.open-resource(root.resource.path);
    }
}
