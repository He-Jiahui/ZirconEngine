import {
    IconButton,
    MutedText,
    PillButton,
    SourceBuildHistoryRowData,
    SourceEngineData,
    SourceEngineRowData,
    UiTextData,
} from "shared.slint";
import { ActionRow, Badge, BuildHistoryRow, Divider, HubPanel, HubTextField, HubTokens, InfoRow, ListTile, MaterialPalette, MaterialStyleMetrics, PageScrollSurface, PanelHeader, PanelListViewport, ResponsiveSlot, WorkspacePanelSection } from "components.slint";

component SourceEngineRow inherits Rectangle {
    in property <SourceEngineRowData> engine;
    callback selected(string);
    callback remove(string);

    private property <length> remove-size: min(HubTokens.icon-lg, root.height - MaterialStyleMetrics.spacing_16);

    height: HubTokens.list-row-md;
    border-radius: MaterialStyleMetrics.border_radius_12;
    border-width: HubTokens.border-width;
    border-color: root.engine.active ? MaterialPalette.primary : MaterialPalette.outline_variant;
    background: root.engine.active ? MaterialPalette.secondary_container : MaterialPalette.surface_container_low;
    clip: true;

    ListTile {
        width: parent.width;
        height: parent.height;
        text: root.engine.title;
        supporting_text: root.engine.version + " / " + root.engine.source-path + " / " + root.engine.last-build;
        avatar_icon: @image-url("../assets/brand/zircon-mark.svg");
        avatar_background: root.engine.active ? MaterialPalette.primary_container : MaterialPalette.surface_container_high;
        avatar_foreground: root.engine.active ? MaterialPalette.primary : MaterialPalette.on_surface_variant;
        clicked => {
            root.selected(root.engine.id);
        }

        HorizontalLayout {
            spacing: HubTokens.space-2;
            alignment: center;

            Badge {
                text: root.engine.status;
                tone: root.engine.active ? "accent" : "neutral";
                badge-width: HubTokens.control-md * 3;
            }

            IconButton {
                width: root.remove-size;
                height: root.remove-size;
                icon-image: @image-url("../assets/icons/ui/close.svg");
                has-icon-image: true;
                clicked => {
                    root.remove(root.engine.id);
                }
            }
        }
    }
}
export component EditorPage inherits Rectangle {
    in-out property <length> scroll-y: 0px;
    in-out property <string> source-path;
    in-out property <string> output-path;
    in-out property <string> active-engine-name;
    in property <SourceEngineData> source-engine;
    in property <[SourceEngineRowData]> source-engines;
    in property <int> source-engine-count;
    in property <[SourceBuildHistoryRowData]> source-build-history;
    in property <int> source-build-history-count;
    in property <UiTextData> ui-text;
    private property <length> content-width: page-surface.content-width;
    private property <length> side-panel-min-width: HubTokens.panel-min-md + HubTokens.control-lg * 2;
    private property <length> overview-min-width: HubTokens.panel-min-lg + HubTokens.control-lg * 2;
    private property <bool> compact: root.content-width < root.overview-min-width + root.side-panel-min-width + HubTokens.panel-gap;
    private property <length> engine-list-scroll-y: 0px;
    private property <length> build-history-scroll-y: 0px;
    callback save-settings();
    callback browse-folder(string);
    callback select-engine(string);
    callback rename-active-engine(string);
    callback remove-engine(string);
    callback build-engine();
    callback open-output();
    callback launch-editor();

    background: HubTokens.surface-page;
    forward-focus: page-focus;
    clip: true;

    page-focus := FocusScope {
        width: HubTokens.border-width;
        height: HubTokens.border-width;
    }

    page-surface := PageScrollSurface {
        width: root.width;
        height: root.height;
        scroll-y <=> root.scroll-y;

        WorkspacePanelSection {
            compact: root.compact;
            row-height: HubTokens.workspace-row-editor-summary;
            spacing-horizontal: HubTokens.panel-gap;
            spacing-vertical: HubTokens.panel-gap;

            ResponsiveSlot {
                basis: root.overview-min-width;
                grow: 2;
                shrink: 1;
                min-width: root.compact ? root.content-width : root.overview-min-width;
                height: HubTokens.workspace-row-editor-summary;

                    HubPanel {
                        width: parent.width;
                        height: parent.height;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: HubTokens.space-4;
                            spacing: HubTokens.space-3;
                            alignment: stretch;

                            PanelHeader {
                                title: root.source-engine.title;
                                subtitle: root.source-engine.version + " / " + root.source-engine.status;
                                show-badge: true;
                                badge-text: root.source-engine.build-profile;
                                badge-tone: "accent";
                                show-action: true;
                                action-text: root.ui-text.open-editor;
                                action-clicked => {
                                    root.launch-editor();
                                }
                            }

                            Divider {}

                            InfoRow {
                                row-height: HubTokens.list-row-md;
                                title: root.ui-text.source-prefix;
                                detail: root.source-engine.source-path;
                                meta: root.ui-text.last-build-prefix + root.source-engine.last-build;
                                leading-image: @image-url("../assets/brand/zircon-mark.svg");
                                has-leading-image: true;
                                trailing-text: root.source-engine.status;
                                trailing-tone: "ok";
                                show-trailing-badge: true;
                            }

                            InfoRow {
                                row-height: HubTokens.list-row-md;
                                title: root.ui-text.output-prefix;
                                detail: root.source-engine.output-path;
                                meta: root.ui-text.profile-prefix + root.source-engine.build-profile;
                                leading-image: @image-url("../assets/icons/ui/folder.svg");
                                has-leading-image: true;
                                trailing-text: root.source-engine.jobs + root.ui-text.jobs-suffix;
                                trailing-tone: "neutral";
                                show-trailing-badge: true;
                            }
                        }
                    }
                }

            ResponsiveSlot {
                basis: root.side-panel-min-width;
                grow: 1;
                shrink: 1;
                min-width: root.compact ? root.content-width : root.side-panel-min-width;
                height: HubTokens.workspace-row-editor-summary;

                    HubPanel {
                        width: parent.width;
                        height: parent.height;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: HubTokens.space-4;
                            spacing: HubTokens.toolbar-gap;

                            PanelHeader {
                                title: root.ui-text.editor-actions;
                                subtitle: "";
                            }

                            ActionRow {
                                action: {
                                    id: "save-source",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/ui/settings.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.save-source,
                                    detail: root.ui-text.source-checkout-path,
                                    enabled: true,
                                };
                                activate(id) => {
                                    root.save-settings();
                                }
                            }

                            ActionRow {
                                action: {
                                    id: "build",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/actions/build-project.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.build,
                                    detail: root.ui-text.compile-editor,
                                    enabled: true,
                                };
                                activate(id) => {
                                    root.build-engine();
                                }
                            }

                            ActionRow {
                                action: {
                                    id: "open-output",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/ui/folder.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.open-output,
                                    detail: root.source-engine.output-path,
                                    enabled: true,
                                };
                                activate(id) => {
                                    root.open-output();
                                }
                            }
                        }
                    }
                }
        }

        WorkspacePanelSection {
            compact: root.compact;
            row-height: HubTokens.workspace-row-editor-config;
            spacing-horizontal: HubTokens.panel-gap;
            spacing-vertical: HubTokens.panel-gap;

            ResponsiveSlot {
                basis: root.overview-min-width;
                grow: 2;
                shrink: 1;
                min-width: root.compact ? root.content-width : root.overview-min-width;
                height: HubTokens.workspace-row-editor-config;

                HubPanel {
                    width: parent.width;
                    height: parent.height;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding: HubTokens.space-4;
                        spacing: HubTokens.space-3;

                        PanelHeader {
                            title: root.ui-text.source-engine;
                            subtitle: root.ui-text.source-checkout-path;
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: HubTokens.input-field;

                            HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                spacing: HubTokens.toolbar-gap;
                                alignment: center;

                                HubTextField {
                                    horizontal-stretch: 1;
                                    label: root.ui-text.active-engine-name;
                                    placeholder: root.ui-text.active-engine-name;
                                    text <=> root.active-engine-name;
                                }

                                PillButton {
                                    height: HubTokens.control-md;
                                    text: root.ui-text.rename;
                                    icon-image: @image-url("../assets/icons/ui/edit.svg");
                                    has-icon-image: true;
                                    clicked => {
                                        root.rename-active-engine(root.active-engine-name);
                                    }
                                }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: HubTokens.input-field;

                            HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                spacing: HubTokens.toolbar-gap;
                                alignment: center;

                                HubTextField {
                                    horizontal-stretch: 1;
                                    label: root.ui-text.source-checkout-path;
                                    placeholder: root.ui-text.source-checkout-path;
                                    text <=> root.source-path;
                                }

                                PillButton {
                                    height: HubTokens.control-md;
                                    text: root.ui-text.browse;
                                    icon-image: @image-url("../assets/icons/ui/folder.svg");
                                    has-icon-image: true;
                                    clicked => {
                                        root.browse-folder("source");
                                    }
                                }
                            }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: HubTokens.input-field;

                            HorizontalLayout {
                                width: parent.width;
                                height: parent.height;
                                spacing: HubTokens.toolbar-gap;
                                alignment: center;

                                HubTextField {
                                    horizontal-stretch: 1;
                                    label: root.ui-text.staged-output-directory;
                                    placeholder: root.ui-text.staged-output-directory;
                                    text <=> root.output-path;
                                }

                                PillButton {
                                    height: HubTokens.control-md;
                                    text: root.ui-text.browse;
                                    icon-image: @image-url("../assets/icons/ui/folder.svg");
                                    has-icon-image: true;
                                    clicked => {
                                        root.browse-folder("output");
                                    }
                                }
                            }
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }
                    }
                }
            }

            ResponsiveSlot {
                basis: root.side-panel-min-width;
                grow: 1;
                shrink: 1;
                min-width: root.compact ? root.content-width : root.side-panel-min-width;
                height: HubTokens.workspace-row-editor-config;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    spacing: HubTokens.panel-gap;

                    HubPanel {
                        vertical-stretch: 1;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: HubTokens.space-4;
                            spacing: HubTokens.toolbar-gap;

                            PanelHeader {
                                title: root.ui-text.source-engines;
                                subtitle: "";
                                show-badge: true;
                                badge-text: root.source-engine-count + "";
                                badge-tone: "info";
                            }

                            PanelListViewport {
                                scroll-y <=> root.engine-list-scroll-y;
                                row-count: root.source-engine-count;
                                row-height: HubTokens.list-row-md;

                                for engine in root.source-engines: SourceEngineRow {
                                    engine: engine;
                                    selected(id) => {
                                        root.select-engine(id);
                                    }
                                    remove(id) => {
                                        root.remove-engine(id);
                                    }
                                }

                                if root.source-engine-count == 0: MutedText {
                                    text: root.ui-text.no-source-engines;
                                }
                            }
                        }
                    }

                    HubPanel {
                        vertical-stretch: 1;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: HubTokens.space-4;
                            spacing: HubTokens.toolbar-gap;

                            PanelHeader {
                                title: root.ui-text.build-history;
                                subtitle: "";
                                show-badge: true;
                                badge-text: root.source-build-history-count + "";
                                badge-tone: "info";
                            }

                            PanelListViewport {
                                scroll-y <=> root.build-history-scroll-y;
                                row-count: root.source-build-history-count;
                                row-height: HubTokens.list-row-md;

                                for record in root.source-build-history: BuildHistoryRow {
                                    record: record;
                                }

                                if root.source-build-history-count == 0: MutedText {
                                    text: root.ui-text.no-build-history;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
