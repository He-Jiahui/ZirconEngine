import { ScrollView } from "std-widgets.slint";
import {
    IconButton,
    MutedText,
    PillButton,
    ProjectCardData,
    QuickActionData,
    RecentProjectRowData,
    UiTextData,
} from "shared.slint";
import {
    ActionRow,
    Badge,
    DataTable,
    Flow,
    HubPanel,
    HubTokens,
    MaterialPalette,
    MaterialStyleMetrics,
    MaterialTypography,
    PanelGrid,
    PanelHeader,
    ResponsiveSlot,
    SearchBox,
    ToolbarSelect,
} from "components.slint";

component ProjectCover inherits Rectangle {
    in property <ProjectCardData> project;
    in property <length> cover-height: HubTokens.list-row-lg + MaterialStyleMetrics.size_32;

    height: root.cover-height;
    horizontal-stretch: 1;
    border-radius: MaterialStyleMetrics.border_radius_12;
    clip: true;
    background: root.project.accent == 0 ? MaterialPalette.primary_container : (root.project.accent == 1 ? MaterialPalette.secondary_container : (root.project.accent == 2 ? MaterialPalette.tertiary_container : MaterialPalette.surface_container_high));

    if root.project.has-cover: Image {
        width: parent.width;
        height: parent.height;
        source: root.project.cover-image;
        image-fit: cover;
    }

    if !root.project.has-cover: Rectangle {
        width: parent.width;
        height: parent.height;
        background: root.project.accent == 0 ? MaterialPalette.primary : (root.project.accent == 1 ? MaterialPalette.secondary : (root.project.accent == 2 ? MaterialPalette.tertiary : MaterialPalette.surface_container_highest));
    }

    if root.project.has-cover: Rectangle {
        width: parent.width;
        height: parent.height;
        background: MaterialPalette.shadow_30;
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: HubTokens.space-2;
        spacing: HubTokens.space-1;

        Rectangle {
            horizontal-stretch: 1;
            height: HubTokens.icon-lg;

            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                alignment: start;

                Rectangle { horizontal-stretch: 1; }

                IconButton {
                    width: HubTokens.icon-lg;
                    height: HubTokens.icon-lg;
                    icon-image: @image-url("../assets/icons/ui/more-vertical.svg");
                    has-icon-image: true;
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        Rectangle {
            horizontal-stretch: 1;
            height: MaterialStyleMetrics.size_32;

            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                alignment: start;

                Rectangle {
                    width: MaterialStyleMetrics.size_32;
                    height: self.width;
                    border-radius: MaterialStyleMetrics.border_radius_8;
                    background: MaterialPalette.primary_container;
                    border-width: HubTokens.border-width;
                    border-color: MaterialPalette.primary;

                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: @image-url("../assets/brand/zircon-mark.svg");
                        image-fit: contain;
                    }
                }

                Rectangle { horizontal-stretch: 1; }
            }
        }
    }
}

component ProjectCard inherits HubPanel {
    in property <ProjectCardData> project;
    in property <UiTextData> ui-text;
    in property <length> card-height: HubTokens.list-row-lg * 3;
    in property <length> cover-height: root.card-height * 9 / 20;
    in property <length> card-width-basis: HubTokens.panel-min-sm;
    callback select(string);
    callback open(string);

    private property <length> status-badge-width: max(root.status-badge-height * 3, min(root.status-badge-height * 4, root.card-width-basis / 4));
    private property <length> status-badge-height: max(MaterialStyleMetrics.size_20, min(MaterialStyleMetrics.size_24, root.card-height / 10));
    private property <bool> compact-footer: root.card-width-basis < HubTokens.panel-min-sm * 3 / 4;
    private property <length> footer-version-width: max(root.status-badge-height * 4, min(root.status-badge-height * 5, root.card-width-basis * 2 / 5));
    private property <length> footer-platform-width: max(root.status-badge-height * 3, min(root.status-badge-height * 4, root.card-width-basis / 5));

    variant: root.project.selected ? "selected" : "interactive";
    height: root.card-height;
    min-width: min(max(HubTokens.panel-min-sm * 2 / 3, root.card-width-basis * 4 / 5), root.card-width-basis);
    preferred-width: root.card-width-basis;
    clip: true;

    area := TouchArea {
        clicked => {
            root.select(root.project.project-path);
        }
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding: HubTokens.space-3;
        spacing: HubTokens.space-2;
        alignment: start;

        ProjectCover {
            project: root.project;
            cover-height: root.cover-height;
        }

        HorizontalLayout {
            height: max(MaterialTypography.title_large.font_size, root.status-badge-height);
            spacing: MaterialStyleMetrics.spacing_6;
            alignment: stretch;

            Text {
                text: root.project.title;
                overflow: elide;
                color: MaterialPalette.on_surface;
                font-size: MaterialTypography.title_small.font_size;
                font-weight: MaterialTypography.title_small.font_weight;
                horizontal-stretch: 1;
                min-width: 1px;
                vertical-alignment: center;
            }

            if root.project.pinned: Badge {
                text: root.ui-text.pinned-label;
                tone: "accent";
                badge-width: root.status-badge-width;
                badge-height: root.status-badge-height;
            }

            if root.project.missing: Badge {
                text: root.ui-text.missing-label;
                tone: "warning";
                badge-width: root.status-badge-width;
                badge-height: root.status-badge-height;
            }
        }

        MutedText {
            text: root.project.project-path;
            overflow: elide;
        }

        MutedText {
            text: root.ui-text.modified-prefix + root.project.modified;
            overflow: elide;
        }

        Rectangle { vertical-stretch: 1; }

        HorizontalLayout {
            height: MaterialStyleMetrics.size_24;
            spacing: HubTokens.space-2;
            alignment: start;

            Badge {
                text: root.project.version;
                tone: "accent";
                badge-width: root.footer-version-width;
            }

            if !root.compact-footer: Badge {
                text: root.project.platform;
                tone: "neutral";
                badge-width: root.footer-platform-width;
            }

            Rectangle { horizontal-stretch: 1; }

            IconButton {
                width: MaterialStyleMetrics.size_32;
                height: MaterialStyleMetrics.size_24;
                icon-image: @image-url("../assets/icons/ui/chevron-right.svg");
                has-icon-image: true;
                clicked => {
                    root.open(root.project.project-path);
                }
            }
        }
    }
}

component ProjectFlow inherits Rectangle {
    in-out property <bool> expanded;
    in property <[ProjectCardData]> project-cards;
    in property <int> project-card-count;
    in property <UiTextData> ui-text;
    in property <length> card-height-token: HubTokens.list-row-lg * 3;
    callback select(string);
    callback open(string);

    private property <length> card-gap-x: max(HubTokens.panel-gap, min(MaterialStyleMetrics.spacing_16 + MaterialStyleMetrics.spacing_4, root.width / 80));
    private property <length> card-gap-y: max(HubTokens.space-3, min(MaterialStyleMetrics.spacing_16 + MaterialStyleMetrics.spacing_2, root.width / 92));
    private property <length> card-basis: max(HubTokens.panel-min-sm * 2 / 3, (root.width - root.card-gap-x * 3) / 4);
    private property <length> card-height: root.card-height-token;
    private property <length> empty-height: max(root.card-height * 3 / 5, root.card-gap-y * 10);

    height: root.project-card-count == 0 ? root.empty-height : (root.expanded ? root.card-height * 2 + root.card-gap-y : root.card-height);
    clip: true;
    background: transparent;

    if root.project-card-count > 0: Flow {
        width: parent.width;
        height: parent.height;
        gap-x: root.card-gap-x;
        gap-y: root.card-gap-y;

        for card in root.project-cards: ProjectCard {
            flex-basis: root.card-basis;
            flex-grow: 1;
            flex-shrink: 1;
            min-width: min(max(HubTokens.panel-min-sm * 2 / 3, root.card-basis * 4 / 5), root.width);
            card-height: root.card-height;
            cover-height: max(root.card-height * 2 / 5, min(root.card-height * 9 / 20, root.card-basis * 2 / 5));
            card-width-basis: root.card-basis;
            project: card;
            ui-text: root.ui-text;
            select(path) => {
                root.select(path);
            }
            open(path) => {
                root.open(path);
            }
        }
    }

    if root.project-card-count == 0: HubPanel {
        width: parent.width;
        height: root.empty-height;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding: HubTokens.space-6;
            spacing: HubTokens.space-2;

            Text {
                text: root.ui-text.projects-empty-title;
                color: MaterialPalette.on_surface;
                font-size: MaterialTypography.title_medium.font_size;
                font-weight: 800;
            }

            MutedText {
                text: root.ui-text.projects-empty-detail;
                overflow: elide;
            }
        }
    }
}

export component ProjectDashboardPage inherits Rectangle {
    in-out property <string> search-query;
    in-out property <bool> project-cards-expanded: false;
    in-out property <length> scroll-y: 0px;
    in property <string> project-filter-label;
    in property <string> project-sort-label;
    in property <string> project-view-mode;
    in property <[ProjectCardData]> project-cards;
    in property <int> project-card-count;
    in property <[RecentProjectRowData]> dashboard-project-rows;
    in property <int> dashboard-project-row-count;
    in property <string> dashboard-project-title;
    in property <[QuickActionData]> quick-actions;
    in property <UiTextData> ui-text;
    callback select-project(string);
    callback open-project-detail(string);
    callback quick-action(string);
    callback search-projects(string);
    callback view-all-projects();
    callback set-project-filter(string);
    callback set-project-sort(string);
    callback set-project-view-mode(string);
    callback show-project-subpage(string);

    private property <length> quick-actions-scroll-y: 0px;
    private property <bool> compact: root.width < HubTokens.breakpoint-compact;
    private property <length> page-pad: max(HubTokens.page-padding-compact, min(HubTokens.page-padding, root.width / 56));
    private property <length> page-gap: max(HubTokens.toolbar-gap, min(HubTokens.panel-gap, root.width / 110));
    private property <length> content-width: max(1px, root.width - root.page-pad - root.page-pad);
    private property <length> dashboard-column-width: root.content-width - root.page-gap;
    private property <length> toolbar-height: max(HubTokens.input-field, min(HubTokens.input-field + HubTokens.space-2, root.height / 18));
    private property <length> toolbar-control-min-width: root.toolbar-height * 4;
    private property <bool> dashboard-toolbar-wrap: root.content-width < root.toolbar-control-min-width * 4 + root.toolbar-height * 2 + root.page-gap * 5;
    private property <length> dashboard-toolbar-height: root.dashboard-toolbar-wrap ? root.toolbar-height * 2 + root.page-gap : root.toolbar-height;
    private property <length> dashboard-toolbar-select-width: root.dashboard-toolbar-wrap ? max(root.toolbar-control-min-width, (root.content-width - root.toolbar-height * 2 - root.page-gap * 5 - HubTokens.border-width) / 2) : max(root.content-width / 9, root.toolbar-control-min-width);
    private property <length> dashboard-card-basis: max(HubTokens.panel-min-sm * 2 / 3, (root.content-width - root.page-gap * 3) / 4);
    private property <length> dashboard-card-height: max(HubTokens.list-row-lg * 3, min(HubTokens.list-row-lg * 7 / 2, root.dashboard-card-basis * 3 / 4));
    private property <length> dashboard-empty-height: max(root.dashboard-card-height * 3 / 5, root.toolbar-height * 3);
    private property <length> dashboard-flow-height: root.project-card-count == 0 ? root.dashboard-empty-height : (root.project-cards-expanded ? root.dashboard-card-height * 2 + root.page-gap : root.dashboard-card-height);
    private property <length> dashboard-show-more-height: root.project-card-count > 4 ? root.toolbar-height : 0px;
    private property <length> dashboard-lower-height: root.compact ? max(root.height * 3 / 5, root.toolbar-height * 12) : max(root.height * 7 / 20, root.toolbar-height * 7);
    private property <length> dashboard-panel-height: root.compact ? max(root.toolbar-height * 5, (root.dashboard-lower-height - root.page-gap) / 2) : root.dashboard-lower-height;
    private property <length> dashboard-table-row-height: max(root.toolbar-height * 3 / 5, min(root.toolbar-height * 7 / 10, root.dashboard-lower-height / 10));
    private property <length> dashboard-table-gap: max(HubTokens.toolbar-gap, min(HubTokens.panel-gap, root.page-gap));
    private property <length> dashboard-table-width: max(root.toolbar-height * 8, root.dashboard-column-width * 58 / 100);
    private property <length> quick-action-row-gap: max(MaterialStyleMetrics.spacing_6, min(HubTokens.space-2, root.dashboard-lower-height / 36));
    private property <length> quick-action-row-height: max(HubTokens.list-row-md, min(HubTokens.list-row-lg, (root.dashboard-lower-height - root.toolbar-height * 5 / 2) / 4));
    private property <length> dashboard-content-height: root.page-pad + root.dashboard-toolbar-height + root.page-gap + root.dashboard-flow-height + (root.project-card-count > 4 ? root.page-gap + root.dashboard-show-more-height : 0px) + root.page-gap + root.dashboard-lower-height + root.page-pad;

    background: HubTokens.surface-page;
    clip: true;

    dashboard-scroll := ScrollView {
        width: root.width;
        height: root.height;
        viewport-y <=> root.scroll-y;
        viewport-width: dashboard-scroll.visible-width;
        viewport-height: max(dashboard-scroll.visible-height, root.dashboard-content-height);
        vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
        horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
        mouse-drag-pan-enabled: true;

        Rectangle {
            width: dashboard-scroll.visible-width;
            height: dashboard-scroll.viewport-height;
            background: HubTokens.surface-page;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: root.page-pad;
                padding-right: root.page-pad;
                padding-bottom: root.page-pad;
                spacing: root.page-gap;

                Flow {
                    width: root.content-width;
                    height: root.dashboard-toolbar-height;
                    gap-x: root.page-gap;
                    gap-y: root.page-gap;

                    SearchBox {
                        flex-basis: root.dashboard-toolbar-wrap ? root.content-width : max(root.content-width / 4, root.toolbar-height * 6);
                        flex-grow: root.dashboard-toolbar-wrap ? 1 : 0;
                        flex-shrink: 1;
                        box-width: root.dashboard-toolbar-wrap ? root.content-width : max(root.content-width / 4, root.toolbar-height * 6);
                        box-height: root.toolbar-height;
                        text <=> root.search-query;
                        placeholder: root.ui-text.search-projects;
                        edited(query) => { root.search-projects(query); }
                    }

                    if !root.dashboard-toolbar-wrap: Rectangle { horizontal-stretch: 1; min-width: root.page-gap; }

                    ToolbarSelect {
                        flex-basis: root.dashboard-toolbar-select-width;
                        flex-grow: root.dashboard-toolbar-wrap ? 1 : 0;
                        flex-shrink: 1;
                        icon-image: @image-url("../assets/icons/ui/folder.svg");
                        has-icon-image: true;
                        text: root.project-filter-label;
                        select-width: root.dashboard-toolbar-select-width;
                        select-height: root.toolbar-height;
                        option-count: 3;
                        menu-items: [
                            { icon: @image-url("../assets/icons/ui/folder.svg"), text: root.ui-text.all-projects-label, trailing_text: "", enabled: true },
                            { icon: @image-url("../assets/icons/ui/folder.svg"), text: root.ui-text.existing-projects-label, trailing_text: "", enabled: true },
                            { icon: @image-url("../assets/icons/ui/folder.svg"), text: root.ui-text.missing-label, trailing_text: "", enabled: true },
                        ];
                        options: [
                            { id: "all", label: root.ui-text.all-projects-label, active: root.project-filter-label == root.ui-text.all-projects-label },
                            { id: "existing", label: root.ui-text.existing-projects-label, active: root.project-filter-label == root.ui-text.existing-projects-label },
                            { id: "missing", label: root.ui-text.missing-label, active: root.project-filter-label == root.ui-text.missing-label },
                        ];
                        selected(id) => { root.set-project-filter(id); }
                    }

                    ToolbarSelect {
                        flex-basis: root.dashboard-toolbar-select-width;
                        flex-grow: root.dashboard-toolbar-wrap ? 1 : 0;
                        flex-shrink: 1;
                        icon-image: @image-url("../assets/icons/ui/sort.svg");
                        has-icon-image: true;
                        text: root.project-sort-label;
                        select-width: root.dashboard-toolbar-select-width;
                        select-height: root.toolbar-height;
                        option-count: 2;
                        menu-items: [
                            { icon: @image-url("../assets/icons/ui/sort.svg"), text: root.ui-text.last-modified-column, trailing_text: "", enabled: true },
                            { icon: @image-url("../assets/icons/ui/sort.svg"), text: root.ui-text.name-column, trailing_text: "", enabled: true },
                        ];
                        options: [
                            { id: "last-modified", label: root.ui-text.last-modified-column, active: root.project-sort-label == root.ui-text.last-modified-column },
                            { id: "name", label: root.ui-text.name-column, active: root.project-sort-label == root.ui-text.name-column },
                        ];
                        selected(id) => { root.set-project-sort(id); }
                    }

                    Rectangle { width: HubTokens.border-width; height: max(HubTokens.space-6, root.toolbar-height * 2 / 3); background: HubTokens.stroke-muted; }

                    IconButton {
                        width: root.toolbar-height;
                        icon-image: @image-url("../assets/icons/ui/grid.svg");
                        has-icon-image: true;
                        active: root.project-view-mode == "grid";
                        clicked => {
                            root.set-project-view-mode("grid");
                            root.show-project-subpage("dashboard");
                        }
                    }

                    IconButton {
                        width: root.toolbar-height;
                        icon-image: @image-url("../assets/icons/ui/list.svg");
                        has-icon-image: true;
                        active: false;
                        clicked => {
                            root.set-project-view-mode("list");
                            root.show-project-subpage("project-browser");
                        }
                    }
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: root.page-gap;

                    ProjectFlow {
                        expanded <=> root.project-cards-expanded;
                        project-cards: root.project-cards;
                        project-card-count: root.project-card-count;
                        card-height-token: root.dashboard-card-height;
                        ui-text: root.ui-text;
                        select(path) => { root.select-project(path); }
                        open(path) => { root.open-project-detail(path); }
                    }

                    if root.project-card-count > 4: PillButton {
                        horizontal-stretch: 1;
                        height: root.dashboard-show-more-height;
                        text: root.project-cards-expanded ? root.ui-text.collapse-projects : root.ui-text.show-more-projects;
                        icon-image: root.project-cards-expanded ? @image-url("../assets/icons/ui/chevron-down.svg") : @image-url("../assets/icons/ui/chevron-right.svg");
                        has-icon-image: true;
                        clicked => { root.project-cards-expanded = !root.project-cards-expanded; }
                    }
                }

                PanelGrid {
                    horizontal-stretch: 1;
                    height: root.dashboard-lower-height;
                    gap: root.page-gap;
                    row-gap: root.page-gap;

                    ResponsiveSlot {
                        basis: root.compact ? root.content-width : root.dashboard-column-width * 58 / 100;
                        grow: 1;
                        shrink: 1;
                        min-width: min(max(root.content-width * 3 / 10, root.toolbar-height * 8), root.content-width);
                        height: root.dashboard-panel-height;

                        HubPanel {
                            width: parent.width;
                            height: parent.height;

                            VerticalLayout {
                                width: parent.width;
                                height: parent.height;
                                padding: HubTokens.space-4;
                                spacing: HubTokens.toolbar-gap;
                                alignment: stretch;

                                PanelHeader {
                                    title: root.dashboard-project-title;
                                    show-action: true;
                                    action-text: root.ui-text.view-all-projects;
                                    action-clicked => { root.view-all-projects(); }
                                }

                                DataTable {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    row-height: root.dashboard-table-row-height;
                                    column-gap: root.dashboard-table-gap;
                                    action-size: root.dashboard-table-row-height;
                                    name-min-width: max(root.toolbar-height * 4, root.dashboard-table-width * 18 / 100);
                                    version-width: max(root.toolbar-height * 3, root.dashboard-table-width * 16 / 100);
                                    version-min-width: max(root.toolbar-height * 2, root.dashboard-table-width * 12 / 100);
                                    modified-width: max(root.toolbar-height * 5 / 2, root.dashboard-table-width * 13 / 100);
                                    modified-min-width: max(root.toolbar-height * 2, root.dashboard-table-width * 10 / 100);
                                    location-min-width: max(root.toolbar-height * 3, root.dashboard-table-width * 16 / 100);
                                    rows: root.dashboard-project-rows;
                                    row-count: root.dashboard-project-row-count;
                                    name-label: root.ui-text.name-column;
                                    version-label: root.ui-text.engine-version-column;
                                    modified-label: root.ui-text.last-modified-column;
                                    location-label: root.ui-text.location-column;
                                    empty-text: root.ui-text.no-projects-match;
                                    select(path) => { root.select-project(path); }
                                    open(path) => { root.open-project-detail(path); }
                                }
                            }
                        }
                    }

                    ResponsiveSlot {
                        basis: root.compact ? root.content-width : root.dashboard-column-width * 40 / 100;
                        grow: 1;
                        shrink: 1;
                        min-width: min(max(root.content-width / 4, root.toolbar-height * 7), root.content-width);
                        height: root.dashboard-panel-height;

                        HubPanel {
                            width: parent.width;
                            height: parent.height;

                            VerticalLayout {
                                width: parent.width;
                                height: parent.height;
                                padding: HubTokens.space-4;
                                spacing: HubTokens.toolbar-gap;
                                alignment: stretch;

                                PanelHeader { title: root.ui-text.quick-actions; }

                                action-scroll := ScrollView {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    viewport-y <=> root.quick-actions-scroll-y;
                                    viewport-width: action-scroll.visible-width;
                                    viewport-height: max(action-scroll.visible-height, root.quick-action-row-height * 4 + root.quick-action-row-gap * 3);
                                    vertical-scrollbar-policy: ScrollBarPolicy.as-needed;
                                    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;

                                    VerticalLayout {
                                        width: action-scroll.visible-width;
                                        spacing: root.quick-action-row-gap;

                                        for action in root.quick-actions: ActionRow {
                                            row-height: root.quick-action-row-height;
                                            action: action;
                                            activate(id) => { root.quick-action(id); }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
