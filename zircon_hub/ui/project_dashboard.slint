import {
    ProjectCardData,
    QuickActionData,
    RecentProjectRowData,
    UiTextData,
} from "shared.slint";
import {
    HubTokens,
    HubVisualSpec,
    MaterialStyleMetrics,
    PageScrollSurface,
    PanelGrid,
} from "components.slint";
import {
    DashboardQuickActionsPanel,
    DashboardProjectCardsSection,
    DashboardRecentProjectsPanel,
    DashboardToolbar,
} from "project_dashboard_components.slint";

export component ProjectDashboardPage inherits PageScrollSurface {
    in-out property <string> search-query;
    in-out property <bool> project-cards-expanded: false;
    in property <string> project-filter-label;
    in property <string> project-sort-label;
    in property <string> project-view-mode;
    in property <[ProjectCardData]> project-cards;
    in property <int> project-card-count;
    in property <[RecentProjectRowData]> dashboard-project-rows;
    in property <int> dashboard-project-row-count;
    in property <string> dashboard-project-title;
    in property <[QuickActionData]> quick-actions;
    in property <UiTextData> ui-text;
    callback select-project(string);
    callback open-project-detail(string);
    callback quick-action(string);
    callback search-projects(string);
    callback view-all-projects();
    callback set-project-filter(string);
    callback set-project-sort(string);
    callback set-project-view-mode(string);
    callback show-project-subpage(string);

    private property <length> quick-actions-scroll-y: 0px;
    private property <bool> compact: root.content-width < HubTokens.breakpoint-compact - root.page-pad-x * 2;
    private property <length> page-pad-x: HubTokens.page-padding;
    private property <length> page-pad-y: MaterialStyleMetrics.spacing_8 + MaterialStyleMetrics.size_1;
    private property <length> page-gap: HubTokens.space-6;
    private property <length> dashboard-main-basis: HubTokens.panel-min-lg + HubTokens.control-lg;
    private property <length> dashboard-side-basis: HubTokens.panel-min-md + HubTokens.control-lg;
    private property <length> dashboard-lower-gap: HubTokens.toolbar-gap;
    private property <length> dashboard-recent-width: max(HubTokens.panel-min-md, root.content-width - root.dashboard-side-basis - root.dashboard-lower-gap);
    private property <length> toolbar-height: HubTokens.control-lg + HubTokens.space-1;
    private property <length> toolbar-control-min-width: root.toolbar-height * 4;
    private property <bool> dashboard-toolbar-wrap: root.content-width < root.toolbar-control-min-width * 4 + root.toolbar-height * 2 + root.page-gap * 5;
    private property <length> dashboard-toolbar-search-basis: root.dashboard-toolbar-wrap ? root.content-width : max(root.content-width * HubTokens.project-dashboard-toolbar-search-ratio, root.toolbar-height * 13 / 2);
    private property <length> dashboard-toolbar-select-basis: root.dashboard-toolbar-wrap ? root.toolbar-control-min-width : max(root.content-width * HubTokens.project-dashboard-toolbar-select-ratio, root.toolbar-height * 4);
    private property <length> dashboard-show-more-height: 0px;
    // The legacy viewport-height ratio tokens are intentionally no longer used here:
    // root.viewport-height * HubTokens.project-dashboard-lower-compact-ratio
    // root.viewport-height * HubTokens.project-dashboard-lower-regular-ratio
    private property <length> dashboard-lower-height: root.compact ? max(root.content-height * HubTokens.project-dashboard-lower-compact-ratio, root.content-height / 18) : max(root.toolbar-height * 6, root.content-height * HubTokens.project-dashboard-lower-regular-ratio + HubTokens.space-3);
    private property <length> dashboard-panel-height: root.compact ? max(root.toolbar-height * 5, (root.dashboard-lower-height - root.page-gap) / 2) : root.dashboard-lower-height;
    private property <length> dashboard-table-row-height: HubTokens.control-sm + MaterialStyleMetrics.size_2;
    private property <length> dashboard-table-gap: max(HubTokens.toolbar-gap, min(HubTokens.panel-gap, root.page-gap));
    private property <length> dashboard-table-width: max(root.toolbar-height * 8, root.content-width * HubTokens.project-dashboard-table-ratio);
    private property <int> quick-action-count: root.quick-actions.length;
    private property <length> quick-action-row-gap: MaterialStyleMetrics.spacing_6;
    private property <length> quick-action-row-height: HubTokens.list-row-sm - MaterialStyleMetrics.size_4;
    page-padding: root.page-pad-x;
    page-padding-x: root.page-pad-x;
    page-padding-y: root.page-pad-y;
    bottom-padding: root.page-pad-y;
    gap: root.page-gap;
    background: HubVisualSpec.page-background;
    clip: true;

                DashboardToolbar {
                    search-query <=> root.search-query;
                    ui-text: root.ui-text;
                    project-filter-label: root.project-filter-label;
                    project-sort-label: root.project-sort-label;
                    project-view-mode: root.project-view-mode;
                    toolbar-wrap: root.dashboard-toolbar-wrap;
                    toolbar-height: root.toolbar-height;
                    toolbar-gap: HubTokens.toolbar-gap;
                    search-basis: root.dashboard-toolbar-search-basis;
                    select-basis: root.dashboard-toolbar-select-basis;
                    search-projects(query) => { root.search-projects(query); }
                    set-project-filter(id) => { root.set-project-filter(id); }
                    set-project-sort(id) => { root.set-project-sort(id); }
                    set-project-view-mode(mode) => { root.set-project-view-mode(mode); }
                    show-project-subpage(page) => { root.show-project-subpage(page); }
                }

                DashboardProjectCardsSection {
                    expanded <=> root.project-cards-expanded;
                    project-cards: root.project-cards;
                    project-card-count: root.project-card-count;
                    empty-title: root.ui-text.projects-empty-title;
                    empty-detail: root.ui-text.projects-empty-detail;
                    collapse-label: root.ui-text.collapse-projects;
                    show-more-label: root.ui-text.show-more-projects;
                    section-gap: root.page-gap;
                    show-more-height: root.dashboard-show-more-height;
                    select(path) => { root.select-project(path); }
                    open(path) => { root.open-project-detail(path); }
                }

                if !root.compact: HorizontalLayout {
                    width: parent.width;
                    horizontal-stretch: 1;
                    height: root.dashboard-lower-height;
                    spacing: root.dashboard-lower-gap;

                    DashboardRecentProjectsPanel {
                        width: root.dashboard-recent-width;
                        height: root.dashboard-panel-height;
                        panel-title: root.dashboard-project-title;
                        action-text: root.ui-text.view-all-projects;
                        project-rows: root.dashboard-project-rows;
                        project-row-count: root.dashboard-project-row-count;
                        table-row-height: root.dashboard-table-row-height;
                        table-column-gap: root.dashboard-table-gap;
                        table-action-size: root.dashboard-table-row-height;
                        name-min-width: max(root.toolbar-height * 4, root.dashboard-table-width * 18 / 100);
                        version-width: max(root.toolbar-height * 3, root.dashboard-table-width * 16 / 100);
                        version-min-width: max(root.toolbar-height * 2, root.dashboard-table-width * 12 / 100);
                        modified-width: max(root.toolbar-height * 5 / 2, root.dashboard-table-width * 13 / 100);
                        modified-min-width: max(root.toolbar-height * 2, root.dashboard-table-width * 10 / 100);
                        location-min-width: max(root.toolbar-height * 3, root.dashboard-table-width * 16 / 100);
                        name-label: root.ui-text.name-column;
                        version-label: root.ui-text.engine-version-column;
                        modified-label: root.ui-text.last-modified-column;
                        location-label: root.ui-text.location-column;
                        empty-text: root.ui-text.no-projects-match;
                        view-all => { root.view-all-projects(); }
                        select(path) => { root.select-project(path); }
                        open(path) => { root.open-project-detail(path); }
                    }

                    DashboardQuickActionsPanel {
                        width: root.dashboard-side-basis;
                        height: root.dashboard-panel-height;
                        panel-title: root.ui-text.quick-actions;
                        quick-actions: root.quick-actions;
                        quick-action-count: root.quick-action-count;
                        quick-action-row-height: root.quick-action-row-height;
                        quick-action-row-gap: root.quick-action-row-gap;
                        empty-title: root.ui-text.no-quick-actions;
                        empty-detail: root.ui-text.quick-actions-empty-detail;
                        quick-actions-scroll-y <=> root.quick-actions-scroll-y;
                        triggered(id) => { root.quick-action(id); }
                    }
                }

                if root.compact: PanelGrid {
                    horizontal-stretch: 1;
                    height: root.dashboard-lower-height;
                    gap: root.page-gap;
                    row-gap: root.page-gap;

                    DashboardRecentProjectsPanel {
                        basis: root.compact ? root.content-width : root.dashboard-main-basis;
                        flex-basis: root.compact ? root.content-width : root.dashboard-main-basis;
                        grow: 2;
                        flex-grow: 2;
                        shrink: 1;
                        flex-shrink: 1;
                        min-width: root.compact ? root.content-width : HubTokens.panel-min-md;
                        height: root.dashboard-panel-height;
                        panel-title: root.dashboard-project-title;
                        action-text: root.ui-text.view-all-projects;
                        project-rows: root.dashboard-project-rows;
                        project-row-count: root.dashboard-project-row-count;
                        table-row-height: root.dashboard-table-row-height;
                        table-column-gap: root.dashboard-table-gap;
                        table-action-size: root.dashboard-table-row-height;
                        name-min-width: max(root.toolbar-height * 4, root.dashboard-table-width * 18 / 100);
                        version-width: max(root.toolbar-height * 3, root.dashboard-table-width * 16 / 100);
                        version-min-width: max(root.toolbar-height * 2, root.dashboard-table-width * 12 / 100);
                        modified-width: max(root.toolbar-height * 5 / 2, root.dashboard-table-width * 13 / 100);
                        modified-min-width: max(root.toolbar-height * 2, root.dashboard-table-width * 10 / 100);
                        location-min-width: max(root.toolbar-height * 3, root.dashboard-table-width * 16 / 100);
                        name-label: root.ui-text.name-column;
                        version-label: root.ui-text.engine-version-column;
                        modified-label: root.ui-text.last-modified-column;
                        location-label: root.ui-text.location-column;
                        empty-text: root.ui-text.no-projects-match;
                        view-all => { root.view-all-projects(); }
                        select(path) => { root.select-project(path); }
                        open(path) => { root.open-project-detail(path); }
                    }

                    DashboardQuickActionsPanel {
                        basis: root.compact ? root.content-width : root.dashboard-side-basis;
                        flex-basis: root.compact ? root.content-width : root.dashboard-side-basis;
                        grow: 1;
                        flex-grow: 1;
                        shrink: 1;
                        flex-shrink: 1;
                        min-width: root.compact ? root.content-width : HubTokens.panel-min-sm;
                        height: root.dashboard-panel-height;
                        panel-title: root.ui-text.quick-actions;
                        quick-actions: root.quick-actions;
                        quick-action-count: root.quick-action-count;
                        quick-action-row-height: root.quick-action-row-height;
                        quick-action-row-gap: root.quick-action-row-gap;
                        empty-title: root.ui-text.no-quick-actions;
                        empty-detail: root.ui-text.quick-actions-empty-detail;
                        quick-actions-scroll-y <=> root.quick-actions-scroll-y;
                        triggered(id) => { root.quick-action(id); }
                    }
                }
}
