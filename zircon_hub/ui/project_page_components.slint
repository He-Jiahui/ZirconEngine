import {
    IconButton,
    MutedText,
    PillButton,
    ProjectTemplateData,
    SourceEngineRowData,
    UiTextData,
} from "shared.slint";
import { Badge, CheckState, EmptyStateBlock, HubCheckBox, HubListPanelSlot, HubTextField, HubTokens, HubVisualSpec, InfoRow, MaterialPalette, MaterialStyleMetrics, MaterialText, MaterialTypography, PanelHeader, PanelListViewport, PanelSlot, StateLayerArea, StatusBadge } from "components.slint";
export {
    ProjectFilterSelect,
    ProjectSortSelect,
    ProjectBrowserTableHeader,
    ProjectBrowserRow,
    ProjectBrowserResultsPanel,
} from "project_browser_components.slint";

export component PageHeader inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <length> header-height: MaterialStyleMetrics.size_48;
    callback back;

    private property <length> back-size: max(MaterialStyleMetrics.size_36, min(MaterialStyleMetrics.size_40, root.header-height * 4 / 5));
    private property <length> content-height: max(root.back-size, MaterialStyleMetrics.size_48);

    height: root.header-height;
    horizontal-stretch: 1;

    VerticalLayout {
        width: parent.width;
        height: parent.height;

        Rectangle { vertical-stretch: 1; min-height: 0px; }

        HorizontalLayout {
            height: root.content-height;
            spacing: MaterialStyleMetrics.spacing_12;
            alignment: start;

            IconButton {
                width: root.back-size;
                height: root.back-size;
                icon-image: @image-url("../assets/icons/ui/chevron-left.svg");
                has-icon-image: true;
                clicked => { root.back(); }
            }

            VerticalLayout {
                height: parent.height;
                horizontal-stretch: 1;
                min-width: 1px;
                spacing: MaterialStyleMetrics.spacing_2;

                Rectangle { vertical-stretch: 1; min-height: 0px; }

                MaterialText {
                    text: root.title;
                    overflow: elide;
                    color: MaterialPalette.on_surface;
                    style: MaterialTypography.title_large;
                    vertical_alignment: center;
                }

                MutedText {
                    text: root.subtitle;
                    overflow: elide;
                }

                Rectangle { vertical-stretch: 1; min-height: 0px; }
            }
        }

        Rectangle { vertical-stretch: 1; min-height: 0px; }
    }
}

export component EngineChoiceRow inherits Rectangle {
    in property <SourceEngineRowData> engine;
    in property <length> row-height: HubTokens.list-row-md;
    in property <string> selected-label: "Selected";
    in property <string> registered-label: "Registered";
    in property <bool> collapse-label: false;
    callback selected(string);

    private property <length> effective-row-height: max(root.row-height, HubTokens.list-row-md);

    height: root.effective-row-height;
    horizontal-stretch: 1;
    min-width: 1px;

    InfoRow {
        width: parent.width;
        height: parent.height;
        row-height: root.effective-row-height;
        title: root.engine.title;
        detail: root.engine.version;
        meta: root.engine.source-path;
        leading-image: @image-url("../assets/icons/nav/editor.svg");
        has-leading-image: true;
        accent: 0;
        selected: root.engine.active;
        trailing-text: root.engine.active ? root.selected-label : root.registered-label;
        trailing-tone: root.engine.active ? "accent" : "neutral";
        show-trailing-badge: true;
        collapse-trailing-label: root.collapse-label;
        clicked => { root.selected(root.engine.id); }
    }
}

export component TemplateChoiceRow inherits Rectangle {
    in property <ProjectTemplateData> template;
    in property <length> row-height: HubTokens.list-row-md;
    in property <string> soon-label: "Soon";
    in property <bool> collapse-label: false;
    callback selected(string);

    private property <length> effective-row-height: max(root.row-height, HubTokens.list-row-md);
    private property <CheckState> selection-state: root.template.selected ? CheckState.checked : CheckState.unchecked;
    private property <string> trailing-label: root.template.enabled ? root.template.category : root.soon-label;
    private property <bool> show-template-badge: root.trailing-label != "" && !root.collapse-label;

    height: root.effective-row-height;
    horizontal-stretch: 1;
    min-width: 1px;
    border-radius: HubVisualSpec.panel-radius;
    border-width: HubTokens.border-width;
    border-color: root.template.selected ? HubVisualSpec.accent-stroke : HubVisualSpec.outline-muted;
    background: !root.template.enabled ? HubVisualSpec.panel-background.with_alpha(HubVisualSpec.disabled-opacity) : (root.template.selected ? MaterialPalette.secondary_container : HubVisualSpec.panel-background);
    clip: true;

    StateLayerArea {
        width: parent.width;
        height: parent.height;
        color: root.template.selected ? HubVisualSpec.accent-stroke : MaterialPalette.on_surface;
        border_radius: HubVisualSpec.panel-radius;
        enabled: root.template.enabled;
        clicked => {
            if (root.template.enabled) {
                root.selected(root.template.id);
            }
        }
    }

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: HubTokens.space-4;
        padding-right: HubTokens.space-4;
        spacing: HubTokens.toolbar-gap;
        alignment: center;

        HubCheckBox {
            check-state: root.selection-state;
            enabled: root.template.enabled;
            changed(state) => {
                if (root.template.enabled) {
                    root.selected(root.template.id);
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            min-width: 1px;
            spacing: MaterialStyleMetrics.spacing_2;

            MaterialText {
                text: root.template.title;
                overflow: elide;
                color: root.template.enabled ? MaterialPalette.on_surface : MaterialPalette.on_surface_variant;
                style: MaterialTypography.label_large;
                vertical_alignment: center;
                horizontal_alignment: left;
            }

            MaterialText {
                text: root.template.description;
                overflow: elide;
                color: MaterialPalette.on_surface_variant;
                style: MaterialTypography.body_small;
                vertical_alignment: center;
                horizontal_alignment: left;
            }
        }

        if root.show-template-badge: StatusBadge {
            text: root.trailing-label;
            tone: !root.template.enabled ? "warning" : (root.template.selected ? "accent" : "neutral");
        }
    }
}

export component ProjectSettingSummaryRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <bool> badge-value: false;
    in property <string> badge-tone: "neutral";
    in property <length> row-height: HubTokens.control-md;

    private property <length> label-width: root.row-height * 9 / 2;
    private property <length> badge-width: root.row-height * 5;

    height: root.row-height;
    horizontal-stretch: 1;
    min-width: 1px;
    border-width: 0px;
    background: transparent;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: max(MaterialStyleMetrics.spacing_8, root.row-height / 5);
        alignment: stretch;

        MaterialText {
            width: root.label-width;
            text: root.label;
            overflow: elide;
            color: MaterialPalette.on_surface_variant;
            style: MaterialTypography.label_medium;
            vertical_alignment: center;
            horizontal_alignment: left;
        }

        if !root.badge-value: MaterialText {
            horizontal-stretch: 1;
            min-width: 1px;
            text: root.value;
            overflow: elide;
            color: MaterialPalette.on_surface;
            style: MaterialTypography.label_large;
            vertical_alignment: center;
            horizontal_alignment: left;
        }

        if root.badge-value: Rectangle {
            horizontal-stretch: 1;
            min-width: 1px;
            HorizontalLayout {
                width: parent.width;
                height: parent.height;
                alignment: center;
                Badge {
                    text: root.value;
                    tone: root.badge-tone;
                    badge-width: root.badge-width;
                }
            }
        }
    }
}

export component ProjectCreateSummary inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <string> root-path-label;
    in property <string> create-label;
    in property <string> ready-label;
    in property <string> complete-label;
    in property <string> project-location;
    in property <string> project-name;
    in property <bool> form-ready: false;
    in property <length> row-height: HubTokens.control-md;
    in property <length> summary-height: HubTokens.list-row-sm + HubTokens.control-md * 2 + HubTokens.panel-gap;
    in property <length> row-spacing: HubTokens.panel-gap / 2;

    height: root.summary-height;
    horizontal-stretch: 1;
    min-width: 1px;
    vertical-stretch: 0;
    background: transparent;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        spacing: root.row-spacing;

        PanelHeader {
            title: root.title;
            subtitle: root.subtitle;
        }

        ProjectSettingSummaryRow {
            row-height: root.row-height;
            label: root.root-path-label;
            value: root.project-location + "\\" + root.project-name;
        }

        ProjectSettingSummaryRow {
            row-height: root.row-height;
            label: root.create-label;
            value: root.form-ready ? root.ready-label : root.complete-label;
            badge-value: true;
            badge-tone: root.form-ready ? "accent" : "warning";
        }
    }
}

export component ProjectCreateField inherits Rectangle {
    in property <string> field-label;
    in property <string> field-placeholder;
    in property <length> field-height: HubTokens.input-field;
    in-out property <string> field-text;
    in property <bool> show-browse: false;
    in property <string> browse-label;
    callback browse-clicked();

    horizontal-stretch: 1;
    min-width: 1px;
    preferred-width: 0px;
    height: root.field-height;
    background: transparent;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        spacing: HubTokens.toolbar-gap;
        alignment: center;

        HubTextField {
            text <=> root.field-text;
            label: root.field-label;
            placeholder: root.field-placeholder;
            horizontal-stretch: 1;
        }

        if root.show-browse: PillButton {
            height: HubTokens.control-md;
            text: root.browse-label;
            icon-image: @image-url("../assets/icons/ui/folder.svg");
            has-icon-image: true;
            clicked => {
                root.browse-clicked();
            }
        }
    }
}

export component ProjectCreateActionRow inherits Rectangle {
    in property <length> row-height;
    in property <length> row-spacing;
    in property <string> action-label;
    in property <bool> action-enabled;
    callback action-clicked();

    horizontal-stretch: 1;
    min-width: 1px;
    preferred-width: 0px;
    height: root.row-height;
    vertical-stretch: 0;
    background: transparent;

    HorizontalLayout {
        width: parent.width;
        height: parent.height;
        alignment: center;
        spacing: root.row-spacing;

        Rectangle { horizontal-stretch: 1; }

        PillButton {
            text: root.action-label;
            icon-image: @image-url("../assets/icons/ui/plus.svg");
            has-icon-image: true;
            primary: true;
            enabled: root.action-enabled;
            clicked => { root.action-clicked(); }
        }
    }
}

export component ProjectEngineChoiceList inherits PanelListViewport {
    in property <[SourceEngineRowData]> engines;
    in property <int> engine-count;
    in property <length> list-height;
    in-out property <length> list-scroll-y: 0px;
    in property <string> selected-label;
    in property <string> registered-label;
    in property <string> empty-title;
    in property <bool> collapse-label: false;
    callback selected(string);

    horizontal-stretch: 1;
    min-width: 1px;
    preferred-width: 0px;
    height: root.list-height;
    scroll-y <=> root.list-scroll-y;
    row-count: root.engine-count;
    vertical-padding: 0px;

    if root.engine-count == 0: EmptyStateBlock {
        height: root.list-height;
        title: root.empty-title;
        body-padding: HubTokens.space-4;
        center-content: true;
    }

    for engine in root.engines: EngineChoiceRow {
        row-height: root.row-height;
        engine: engine;
        selected-label: root.selected-label;
        registered-label: root.registered-label;
        collapse-label: root.collapse-label;
        selected(id) => { root.selected(id); }
    }
}

export component ProjectCreateSettingsPanel inherits PanelSlot {
    in-out property <string> project-name;
    in-out property <string> project-location;
    in property <[SourceEngineRowData]> engines;
    in property <int> engine-count;
    in property <UiTextData> ui-text;
    in property <length> field-height;
    in property <length> page-gap;
    in property <length> section-label-height;
    in property <length> engine-section-height;
    in property <length> engine-list-height;
    in property <length> engine-row-gap;
    in property <length> choice-row-height;
    in-out property <length> engine-scroll-y: 0px;
    in property <bool> collapse-label: false;
    in property <length> create-action-row-height;
    in property <bool> form-ready: false;
    in property <bool> show-summary: true;
    in property <string> summary-title;
    in property <string> summary-subtitle;
    in property <string> summary-root-path-label;
    in property <string> summary-create-label;
    in property <string> summary-ready-label;
    in property <string> summary-complete-label;
    in property <length> summary-row-height;
    in property <length> summary-section-height;

    callback browse-folder(string);
    callback create-project();
    callback select-engine(string);

    body-padding: HubTokens.space-4;
    body-spacing: root.page-gap;

    PanelHeader {
        title: root.ui-text.project-settings-title;
        subtitle: root.ui-text.project-settings-subtitle;
    }

    ProjectCreateField {
        field-height: root.field-height;
        field-label: root.ui-text.project-name;
        field-placeholder: root.ui-text.project-name;
        field-text <=> root.project-name;
    }

    ProjectCreateField {
        field-height: root.field-height;
        field-label: root.ui-text.location;
        field-placeholder: root.ui-text.location;
        field-text <=> root.project-location;
        show-browse: true;
        browse-label: root.ui-text.browse;

        browse-clicked => {
            root.browse-folder("new-project-location");
        }
    }

    VerticalLayout {
        height: root.engine-section-height;
        vertical-stretch: 0;
        spacing: MaterialStyleMetrics.spacing_8;

        MaterialText {
            height: root.section-label-height;
            text: root.ui-text.source-engine;
            color: MaterialPalette.on_surface_variant;
            style: MaterialTypography.body_small;
            vertical_alignment: center;
        }

        ProjectEngineChoiceList {
            engines: root.engines;
            engine-count: root.engine-count;
            list-height: root.engine-list-height;
            list-scroll-y <=> root.engine-scroll-y;
            row-height: root.choice-row-height;
            row-spacing: root.engine-row-gap;
            empty-height: root.choice-row-height;
            selected-label: root.ui-text.selected-label;
            registered-label: root.ui-text.registered;
            empty-title: root.ui-text.register-source-engine-before-create;
            collapse-label: root.collapse-label;

            selected(id) => {
                root.select-engine(id);
            }
        }
    }

    ProjectCreateActionRow {
        row-height: root.create-action-row-height;
        row-spacing: root.page-gap;
        action-label: root.ui-text.create;
        action-enabled: root.form-ready;

        action-clicked => {
            root.create-project();
        }
    }

    ProjectCreateSummary {
        visible: root.show-summary;
        title: root.summary-title;
        subtitle: root.show-summary ? root.summary-subtitle : "";
        root-path-label: root.summary-root-path-label;
        create-label: root.summary-create-label;
        ready-label: root.summary-ready-label;
        complete-label: root.summary-complete-label;
        project-location: root.project-location;
        project-name: root.project-name;
        form-ready: root.form-ready;
        row-height: root.summary-row-height;
        summary-height: root.show-summary ? root.summary-section-height : 0px;
        row-spacing: max(MaterialStyleMetrics.spacing_4, root.page-gap / 2);
    }
}

export component ProjectCreateCompactSummaryPanel inherits PanelSlot {
    in property <length> panel-padding: HubTokens.space-3;
    in property <length> page-gap;
    in property <string> title;
    in property <string> subtitle;
    in property <string> root-path-label;
    in property <string> create-label;
    in property <string> ready-label;
    in property <string> complete-label;
    in property <string> project-location;
    in property <string> project-name;
    in property <bool> form-ready: false;
    in property <length> row-height;
    in property <length> summary-height;

    body-padding: root.panel-padding;
    body-spacing: 0px;

    ProjectCreateSummary {
        title: root.title;
        subtitle: root.subtitle;
        root-path-label: root.root-path-label;
        create-label: root.create-label;
        ready-label: root.ready-label;
        complete-label: root.complete-label;
        project-location: root.project-location;
        project-name: root.project-name;
        form-ready: root.form-ready;
        row-height: root.row-height;
        summary-height: root.summary-height;
        row-spacing: max(MaterialStyleMetrics.spacing_4, root.page-gap / 2);
    }
}

export component ProjectTemplateRailPanel inherits HubListPanelSlot {
    in property <string> panel-title;
    in property <[ProjectTemplateData]> templates;
    in property <int> template-count;
    in property <length> list-height;
    in-out property <length> list-scroll-y: 0px;
    in property <string> soon-label;
    in property <bool> collapse-label: false;
    callback selected(string);

    body-padding: HubTokens.space-4;
    body-spacing: root.row-spacing;
    title: root.panel-title;
    show-badge: true;
    badge-text: root.template-count + "";
    badge-tone: "neutral";
    scroll-y <=> root.list-scroll-y;
    row-count: root.template-count;
    vertical-padding: 0px;
    empty-height: HubTokens.list-row-lg;

    for template in root.templates: TemplateChoiceRow {
        row-height: root.row-height;
        template: template;
        soon-label: root.soon-label;
        collapse-label: root.collapse-label;
        selected(id) => { root.selected(id); }
    }
}
