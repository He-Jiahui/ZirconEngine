import { CloudServiceData, CloudSummaryData, OperationTimelineRowData, UiTextData } from "shared.slint";
import { HubTokens, HubVisualSpec, OperationTimelinePanel, OverviewPanel, PageScrollSurface, ResponsiveCollapse, WorkspacePanelSection } from "components.slint";
import { CloudMetricSlot, CloudPackageActionsPanel, CloudServicesPanel } from "cloud_page_components.slint";

export component CloudPage inherits PageScrollSurface {
    in property <CloudSummaryData> summary;
    in property <[CloudServiceData]> services;
    in property <int> service-count;
    in property <[OperationTimelineRowData]> operation-timeline;
    in property <int> operation-timeline-count;
    in property <bool> has-selected-project: false;
    in property <UiTextData> ui-text;
    callback package-project();
    callback install-device();
    private property <length> header-height: HubTokens.list-row-lg;
    private property <string> overview-title: root.has-selected-project ? root.ui-text.cloud-overview-selected : root.ui-text.cloud-overview;
    private property <string> overview-detail: root.has-selected-project ? root.ui-text.cloud-local-selected-detail : root.ui-text.cloud-local-only;
    private property <bool> metrics-compact: root.content-width < HubTokens.panel-min-md * 2 + root.metric-gap;
    private property <length> metric-row-height: root.metrics-compact ? HubTokens.list-row-md + HubTokens.space-2 : HubTokens.workspace-row-cloud-metrics;
    private property <length> metric-gap: HubTokens.space-3;
    private property <length> metric-min-width: HubTokens.panel-min-sm * 3 / 4;
    private property <bool> metrics-four-columns: root.content-width >= root.metric-min-width * 4 + root.metric-gap * 4;
    private property <bool> metrics-two-columns: !root.metrics-four-columns && root.content-width >= root.metric-min-width * 2 + root.metric-gap;
    private property <int> metric-row-count: root.metrics-four-columns ? 1 : (root.metrics-two-columns ? 2 : 4);
    private property <length> metric-slot-basis: root.metrics-four-columns || root.metrics-two-columns ? root.metric-min-width : root.content-width;
    private property <length> metric-slot-min-width: root.metrics-four-columns || root.metrics-two-columns ? root.metric-min-width : root.content-width;
    private property <float> metric-slot-grow: 1;
    private property <length> metric-section-height: root.metric-row-height * root.metric-row-count + root.metric-gap * (root.metric-row-count - 1);
    private property <length> service-row-slot-height: HubTokens.list-row-lg + HubTokens.space-2;
    private property <length> service-panel-chrome-height: HubTokens.control-md + HubTokens.toolbar-gap + HubTokens.space-4 * 2;
    private property <int> service-visible-rows: root.service-count < 4 ? root.service-count : 4;
    private property <length> service-available-height: max(root.service-panel-chrome-height + root.service-row-slot-height, root.content-height - root.header-height - root.metric-section-height - HubTokens.panel-gap * 2);
    private property <length> service-available-list-height: max(root.service-row-slot-height, root.service-available-height - root.service-panel-chrome-height);
    private property <int> service-fit-row-count: Math.floor(root.service-available-list-height / root.service-row-slot-height);
    private property <int> service-fit-rows: root.service-fit-row-count < 1 ? 1 : root.service-fit-row-count;
    private property <int> service-panel-rows: root.service-visible-rows < 1 ? 1 : (root.service-visible-rows < root.service-fit-rows ? root.service-visible-rows : root.service-fit-rows);
    private property <length> service-list-height: root.service-count == 0 ? HubTokens.list-row-lg + HubTokens.space-4 : root.service-panel-rows * HubTokens.list-row-lg + (root.service-panel-rows - 1) * HubTokens.space-2 + HubTokens.space-1 * 2;
    private property <length> actions-panel-height: root.service-panel-chrome-height + HubTokens.list-row-sm * 2 + HubTokens.toolbar-gap;
    private property <length> services-panel-height: root.service-panel-chrome-height + root.service-list-height;
    private property <length> service-scroll-y: 0px;
    private property <length> operation-timeline-scroll-y: 0px;

    background: HubVisualSpec.page-background;
    clip: true;

    label-collapse := ResponsiveCollapse {
        content-width: root.content-width;
        collapse-at: HubTokens.breakpoint-medium;
    }

    OverviewPanel {
        height: root.header-height;
        title: root.overview-title;
        subtitle: root.overview-detail;
        badge-text: root.summary.status;
    }

    WorkspacePanelSection {
        compact: root.metric-row-count > 1;
        compact-stack: false;
        compact-rows: root.metric-row-count;
        row-height: root.metric-row-height;
        spacing-horizontal: root.metric-gap;
        spacing-vertical: root.metric-gap;

        CloudMetricSlot {
            basis: root.metric-slot-basis;
            flex-basis: root.metric-slot-basis;
            grow: root.metric-slot-grow;
            flex-grow: root.metric-slot-grow;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.metric-slot-min-width;
            height: root.metric-row-height;
            label: root.ui-text.cloud-local-mode;
            primary: root.summary.local-mode-status;
            secondary: root.ui-text.cloud-local-only;
            compact-card: root.metrics-compact;
        }

        CloudMetricSlot {
            basis: root.metric-slot-basis;
            flex-basis: root.metric-slot-basis;
            grow: root.metric-slot-grow;
            flex-grow: root.metric-slot-grow;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.metric-slot-min-width;
            height: root.metric-row-height;
            label: root.ui-text.cloud-output;
            primary: root.summary.output-status;
            secondary: root.summary.output-path;
            compact-card: root.metrics-compact;
        }

        CloudMetricSlot {
            basis: root.metric-slot-basis;
            flex-basis: root.metric-slot-basis;
            grow: root.metric-slot-grow;
            flex-grow: root.metric-slot-grow;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.metric-slot-min-width;
            height: root.metric-row-height;
            label: root.ui-text.cloud-device-install;
            primary: root.summary.device-status;
            secondary: root.summary.device-path;
            compact-card: root.metrics-compact;
        }

        CloudMetricSlot {
            basis: root.metric-slot-basis;
            flex-basis: root.metric-slot-basis;
            grow: root.metric-slot-grow;
            flex-grow: root.metric-slot-grow;
            shrink: 1;
            flex-shrink: 1;
            min-width: root.metric-slot-min-width;
            height: root.metric-row-height;
            label: root.ui-text.cloud-packages;
            primary: root.summary.package-status;
            secondary: root.summary.package-path;
            compact-card: root.metrics-compact;
        }
    }

    CloudPackageActionsPanel {
        horizontal-stretch: 1;
        height: root.actions-panel-height;
        summary: root.summary;
        ui-text: root.ui-text;
        overview-detail: root.overview-detail;
        package-project => {
            root.package-project();
        }
        install-device => {
            root.install-device();
        }
    }

    CloudServicesPanel {
        horizontal-stretch: 1;
        height: root.services-panel-height;
        ui-text: root.ui-text;
        services: root.services;
        service-count: root.service-count;
        overview-detail: root.overview-detail;
        collapse-label: label-collapse.collapsed;
        service-scroll-y <=> root.service-scroll-y;
    }

    OperationTimelinePanel {
        horizontal-stretch: 1;
        height: root.actions-panel-height;
        timeline-title: root.summary.operation-timeline-title;
        empty-title: root.summary.operation-timeline-empty-title;
        empty-detail: root.summary.operation-timeline-empty-detail;
        operation-timeline: root.operation-timeline;
        operation-timeline-count: root.operation-timeline-count;
        collapse-label: label-collapse.collapsed;
        timeline-scroll-y <=> root.operation-timeline-scroll-y;
    }
}
