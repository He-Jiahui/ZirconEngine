import { MutedText, ProjectDetailData, SourceBuildHistoryRowData, SourceEngineData, UiTextData } from "shared.slint";
import { ActionRow, Badge, BuildHistoryRow, Divider, HubPanel, HubTokens, InfoRow, MaterialPalette, MaterialText, MaterialTypography, PageScrollSurface, PanelHeader, PanelListViewport, ResponsiveSlot, WorkspacePanelSection } from "components.slint";

export component BuildsPage inherits Rectangle {
    in-out property <length> scroll-y: 0px;
    in property <ProjectDetailData> project;
    in property <SourceEngineData> source-engine;
    in property <[SourceBuildHistoryRowData]> source-build-history;
    in property <int> source-build-history-count;
    in property <string> status-label;
    in property <string> status-detail;
    in property <UiTextData> ui-text;
    callback build-engine();
    callback open-output();
    callback launch-editor();
    callback package-project();
    callback install-device();
    private property <length> content-width: page-surface.content-width;
    private property <length> side-panel-min-width: HubTokens.panel-min-md + HubTokens.control-lg * 2;
    private property <length> overview-min-width: HubTokens.panel-min-lg + HubTokens.control-lg * 2;
    private property <bool> compact: root.content-width < root.overview-min-width + root.side-panel-min-width + HubTokens.panel-gap;
    private property <length> build-history-scroll-y: 0px;
    private property <length> build-row-height: HubTokens.list-row-sm;
    private property <length> build-summary-height: HubTokens.control-md + root.build-row-height * 5 + HubTokens.toolbar-gap * 5 + HubTokens.space-4 * 2;
    private property <length> build-detail-height: HubTokens.control-md + root.build-row-height * 4 + HubTokens.toolbar-gap * 4 + HubTokens.space-4 * 2;

    background: HubTokens.surface-page;
    clip: true;

    page-surface := PageScrollSurface {
        width: root.width;
        height: root.height;
        scroll-y <=> root.scroll-y;

        WorkspacePanelSection {
            compact: root.compact;
            row-height: root.build-summary-height;
            spacing-horizontal: HubTokens.panel-gap;
            spacing-vertical: HubTokens.panel-gap;

                ResponsiveSlot {
                    basis: root.overview-min-width;
                    grow: 2;
                    shrink: 1;
                    min-width: root.compact ? root.content-width : root.overview-min-width;
                    height: root.build-summary-height;

                    HubPanel {
                        width: parent.width;
                        height: parent.height;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: HubTokens.space-4;
                            spacing: HubTokens.space-3;

                            PanelHeader {
                                title: root.ui-text.source-build;
                                subtitle: root.project.title + " / " + root.source-engine.version + " / " + root.source-engine.status;
                                show-badge: true;
                                badge-text: root.status-label;
                                badge-tone: root.status-label == "Ready" ? "ok" : (root.status-label == "Building" ? "accent" : "neutral");
                                show-action: false;
                                action-text: root.ui-text.build-now;
                                action-clicked => {
                                    root.build-engine();
                                }
                            }

                            Divider {}

                            InfoRow {
                                row-height: root.build-row-height;
                                title: root.ui-text.source-prefix;
                                detail: root.source-engine.source-path;
                                meta: root.ui-text.last-build-prefix + root.source-engine.last-build;
                                leading-image: @image-url("../assets/icons/nav/builds.svg");
                                has-leading-image: true;
                                trailing-text: root.source-engine.status;
                                trailing-tone: "ok";
                                show-trailing-badge: true;
                            }

                            InfoRow {
                                row-height: root.build-row-height;
                                title: root.ui-text.output-prefix;
                                detail: root.source-engine.output-path;
                                meta: root.ui-text.profile-prefix + root.source-engine.build-profile;
                                leading-image: @image-url("../assets/icons/ui/folder.svg");
                                has-leading-image: true;
                                trailing-text: root.source-engine.jobs + root.ui-text.jobs-suffix;
                                trailing-tone: "neutral";
                                show-trailing-badge: true;
                            }

                            HorizontalLayout {
                                spacing: HubTokens.toolbar-gap;

                                Badge {
                                    text: root.source-engine.build-profile;
                                    tone: "accent";
                                    badge-width: HubTokens.control-md * 2 + HubTokens.space-2;
                                }

                                Badge {
                                    text: root.source-engine.jobs + root.ui-text.jobs-suffix;
                                    tone: "neutral";
                                    badge-width: HubTokens.control-md * 2 + HubTokens.space-2;
                                }
                            }
                        }
                    }
                }

                ResponsiveSlot {
                    basis: root.side-panel-min-width;
                    grow: 1;
                    shrink: 1;
                    min-width: root.compact ? root.content-width : root.side-panel-min-width;
                    height: root.build-summary-height;

                    HubPanel {
                        width: parent.width;
                        height: parent.height;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: HubTokens.space-4;
                            spacing: HubTokens.toolbar-gap;

                            PanelHeader {
                                title: root.ui-text.build-controls;
                                subtitle: "";
                            }

                            ActionRow {
                                row-height: root.build-row-height;
                                action: {
                                    id: "build-editor",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/actions/build-project.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.build-editor,
                                    detail: root.ui-text.compile-editor,
                                    enabled: true,
                                };
                                activate(id) => {
                                    root.build-engine();
                                }
                            }

                            ActionRow {
                                row-height: root.build-row-height;
                                action: {
                                    id: "open-output",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/ui/folder.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.open-output,
                                    detail: root.source-engine.output-path,
                                    enabled: true,
                                };
                                activate(id) => {
                                    root.open-output();
                                }
                            }

                            ActionRow {
                                row-height: root.build-row-height;
                                action: {
                                    id: "open-editor",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/actions/open-editor.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.open-editor,
                                    detail: root.project.can-open ? root.project.title : root.ui-text.select-project-before-opening,
                                    enabled: root.project.can-open,
                                };
                                activate(id) => {
                                    root.launch-editor();
                                }
                            }

                            ActionRow {
                                row-height: root.build-row-height;
                                action: {
                                    id: "package-project",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/actions/package-project.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.package-project,
                                    detail: root.project.can-open ? root.project.title : root.ui-text.select-project-before-packaging,
                                    enabled: root.project.can-open,
                                };
                                activate(id) => {
                                    root.package-project();
                                }
                            }

                            ActionRow {
                                row-height: root.build-row-height;
                                action: {
                                    id: "install-device",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/actions/install-device.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.install-to-device,
                                    detail: root.project.can-open ? root.project.title : root.ui-text.select-project-before-installing,
                                    enabled: root.project.can-open,
                                };
                                activate(id) => {
                                    root.install-device();
                                }
                            }
                        }
                    }
                }
        }

        WorkspacePanelSection {
                compact: root.compact;
                row-height: root.build-detail-height;
                spacing-horizontal: HubTokens.panel-gap;
                spacing-vertical: HubTokens.panel-gap;

                ResponsiveSlot {
                    basis: root.overview-min-width;
                    grow: 2;
                    shrink: 1;
                    min-width: root.compact ? root.content-width : root.overview-min-width;
                    height: root.build-detail-height;

                    HubPanel {
                        width: parent.width;
                        height: parent.height;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: HubTokens.space-4;
                            spacing: HubTokens.toolbar-gap;

                        PanelHeader {
                            title: root.ui-text.build-pipeline;
                            subtitle: "";
                            show-badge: true;
                            badge-text: "4";
                            badge-tone: "info";
                        }

                        InfoRow {
                            row-height: root.build-row-height;
                            title: root.ui-text.validate-source;
                            detail: root.source-engine.source-path;
                            meta: "";
                            leading-image: @image-url("../assets/icons/status/success.svg");
                            has-leading-image: true;
                            trailing-text: root.source-engine.status;
                            trailing-tone: "ok";
                            show-trailing-badge: true;
                        }

                        InfoRow {
                            row-height: root.build-row-height;
                            title: root.ui-text.compile-editor;
                            detail: "tools/zircon_build.py --targets editor,runtime";
                            meta: "";
                            leading-image: @image-url("../assets/icons/actions/build-project.svg");
                            has-leading-image: true;
                            trailing-text: root.status-label;
                            trailing-tone: root.status-label == "Building" ? "accent" : "neutral";
                            show-trailing-badge: true;
                        }

                        InfoRow {
                            row-height: root.build-row-height;
                            title: root.ui-text.stage-runtime;
                            detail: root.source-engine.output-path;
                            meta: "";
                            leading-image: @image-url("../assets/icons/ui/folder.svg");
                            has-leading-image: true;
                            trailing-text: root.source-engine.last-build;
                            trailing-tone: "info";
                            show-trailing-badge: true;
                        }

                        InfoRow {
                            row-height: root.build-row-height;
                            title: root.ui-text.package-project;
                            detail: root.project.project-path != "" ? root.project.project-path : root.ui-text.reserved-project-export;
                            meta: "";
                            leading-image: @image-url("../assets/icons/actions/package-project.svg");
                            has-leading-image: true;
                            trailing-text: root.project.can-open ? root.project.status : root.ui-text.unavailable;
                            trailing-tone: root.project.can-open ? "ok" : "warning";
                            show-trailing-badge: true;
                        }
                    }
                }
                }

                ResponsiveSlot {
                    basis: root.side-panel-min-width;
                    grow: 1;
                    shrink: 1;
                    min-width: root.compact ? root.content-width : root.side-panel-min-width;
                    height: root.build-detail-height;

                    HubPanel {
                        width: parent.width;
                        height: parent.height;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding: HubTokens.space-4;
                        spacing: HubTokens.panel-gap;

                        PanelHeader {
                            title: root.ui-text.current-task;
                            subtitle: "";
                            show-badge: true;
                            badge-text: root.status-label;
                            badge-tone: root.status-label == "Ready" ? "ok" : (root.status-label == "Building" ? "accent" : "neutral");
                        }

                        MaterialText {
                            text: root.status-label;
                            overflow: elide;
                            color: MaterialPalette.primary;
                            style: MaterialTypography.headline_small;
                        }

                        MutedText {
                            text: root.status-detail;
                            overflow: elide;
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }

                        Divider {}

                        PanelHeader {
                            title: root.ui-text.build-history;
                            subtitle: "";
                            show-badge: true;
                            badge-text: root.source-build-history-count + "";
                            badge-tone: "info";
                        }

                        PanelListViewport {
                            scroll-y <=> root.build-history-scroll-y;
                            row-count: root.source-build-history-count;
                            row-height: root.build-row-height;
                            vertical-padding: HubTokens.space-0;
                            empty-height: root.build-row-height;

                            for record in root.source-build-history: BuildHistoryRow {
                                record: record;
                            }

                            if root.source-build-history-count == 0: MutedText {
                                text: root.ui-text.no-build-history;
                            }
                        }
                    }
                }
                }
            }
        }
    }
