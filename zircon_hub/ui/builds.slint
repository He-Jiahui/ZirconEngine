import { ScrollView } from "std-widgets.slint";
import { MutedText, Panel, PillButton, SourceEngineData } from "shared.slint";

component BuildStep inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <string> state;
    in property <bool> active: false;

    height: 54px;
    border-radius: 7px;
    border-width: 1px;
    border-color: active ? #1aaea6 : #303641;
    background: active ? #073e3d : #171b21;

    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 12px;
        alignment: start;

        Rectangle {
            width: 28px;
            height: 28px;
            border-radius: 14px;
            background: root.active ? #0d8b85 : #2a3038;
            Text {
                text: root.active ? ">" : "-";
                color: root.active ? #dcfffb : #aeb6c2;
                font-size: 14px;
                font-weight: 800;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            spacing: 2px;
            Text {
                text: root.title;
                color: #f3f6f9;
                font-size: 13px;
                font-weight: 800;
            }
            MutedText { text: root.detail; }
        }

        Rectangle { horizontal-stretch: 1; }

        Text {
            text: root.state;
            color: root.active ? #73f7ed : #9fa7b2;
            font-size: 12px;
            vertical-alignment: center;
        }
    }
}

export component BuildsPage inherits Rectangle {
    in property <SourceEngineData> source-engine;
    in property <string> status-label;
    in property <string> status-detail;
    callback build-engine();
    callback open-output();
    callback launch-editor();

    background: #11151a;

    ScrollView {
        content := Rectangle {
            width: root.width;
            height: 820px;
            background: #11151a;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding-left: 28px;
                padding-right: 28px;
                padding-top: 184px;
                padding-bottom: 28px;
                spacing: 18px;

                HorizontalLayout {
                    spacing: 14px;

                    Panel {
                        horizontal-stretch: 1;
                        height: 238px;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 12px;

                            HorizontalLayout {
                                spacing: 14px;
                                Rectangle {
                                    width: 52px;
                                    height: 52px;
                                    border-radius: 10px;
                                    background: #073e3d;
                                    border-width: 1px;
                                    border-color: #24d5ca;
                                    Text {
                                        text: "/>";
                                        color: #a6fff7;
                                        font-size: 18px;
                                        font-weight: 900;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                VerticalLayout {
                                    spacing: 4px;
                                    Text {
                                        text: "Source Build";
                                        color: #f3f6f9;
                                        font-size: 20px;
                                        font-weight: 900;
                                    }
                                    MutedText {
                                        text: root.source-engine.version + " / " + root.source-engine.status;
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                                PillButton {
                                    text: "Build Now";
                                    icon: "/>";
                                    primary: true;
                                    clicked => {
                                        root.build-engine();
                                    }
                                }
                            }

                            Rectangle { height: 1px; background: #303641; }

                            MutedText { text: "Source: " + root.source-engine.source-path; }
                            MutedText { text: "Output: " + root.source-engine.output-path; }
                            MutedText { text: "Last build: " + root.source-engine.last-build; }

                            HorizontalLayout {
                                spacing: 10px;
                                Rectangle {
                                    width: 86px;
                                    height: 26px;
                                    border-radius: 5px;
                                    background: #063f3e;
                                    border-width: 1px;
                                    border-color: #0f7d78;
                                    Text {
                                        text: root.source-engine.build-profile;
                                        color: #72f7ee;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                                Rectangle {
                                    width: 86px;
                                    height: 26px;
                                    border-radius: 5px;
                                    background: #2a2f36;
                                    border-width: 1px;
                                    border-color: #3a4049;
                                    Text {
                                        text: root.source-engine.jobs + " jobs";
                                        color: #c9cfd8;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }

                    Panel {
                        width: 360px;
                        height: 238px;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            Text {
                                text: "Build Controls";
                                color: #f3f6f9;
                                font-size: 16px;
                                font-weight: 800;
                            }
                            PillButton {
                                text: "Build Editor";
                                icon: "/>";
                                primary: true;
                                clicked => {
                                    root.build-engine();
                                }
                            }
                            PillButton {
                                text: "Open Output";
                                icon: "[]";
                                clicked => {
                                    root.open-output();
                                }
                            }
                            PillButton {
                                text: "Launch Editor";
                                icon: ">";
                                clicked => {
                                    root.launch-editor();
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 14px;

                    Panel {
                        horizontal-stretch: 1;
                        height: 300px;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            Text {
                                text: "Build Pipeline";
                                color: #f3f6f9;
                                font-size: 16px;
                                font-weight: 800;
                            }
                            BuildStep {
                                title: "Validate Source";
                                detail: root.source-engine.source-path;
                                state: root.source-engine.status;
                                active: true;
                            }
                            BuildStep {
                                title: "Compile Editor";
                                detail: "tools/zircon_build.py --targets editor,runtime";
                                state: root.status-label;
                                active: root.status-label == "Building";
                            }
                            BuildStep {
                                title: "Stage Runtime";
                                detail: root.source-engine.output-path;
                                state: root.source-engine.last-build;
                                active: false;
                            }
                            BuildStep {
                                title: "Package Project";
                                detail: "Reserved for project export";
                                state: "Unavailable";
                                active: false;
                            }
                        }
                    }

                    Panel {
                        width: 420px;
                        height: 300px;
                        VerticalLayout {
                            padding: 18px;
                            spacing: 10px;
                            Text {
                                text: "Current Task";
                                color: #f3f6f9;
                                font-size: 16px;
                                font-weight: 800;
                            }
                            Text {
                                text: root.status-label;
                                color: #73f7ed;
                                font-size: 24px;
                                font-weight: 900;
                            }
                            MutedText {
                                text: root.status-detail;
                            }
                            Rectangle { vertical-stretch: 1; }
                            Rectangle {
                                height: 1px;
                                background: #303641;
                            }
                            MutedText {
                                text: "Profile " + root.source-engine.build-profile + " / " + root.source-engine.jobs + " jobs";
                            }
                        }
                    }
                }
            }
        }
    }
}
