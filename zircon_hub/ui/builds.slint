import { MutedText, SourceEngineData, UiTextData } from "shared.slint";
import { ActionRow, Badge, HubPanel, InfoRow, PageScrollSurface, PanelHeader, ResponsivePanelFlow } from "components.slint";

export component BuildsPage inherits Rectangle {
    in-out property <length> scroll-y: 0px;
    in property <SourceEngineData> source-engine;
    in property <string> status-label;
    in property <string> status-detail;
    in property <UiTextData> ui-text;
    callback build-engine();
    callback open-output();
    callback launch-editor();
    private property <bool> compact: root.width < 1120px;

    background: #11151a;
    clip: true;

    PageScrollSurface {
        width: root.width;
        height: root.height;
        scroll-y <=> root.scroll-y;
        content-height: root.compact ? 1360px : 780px;
        page-padding: 0px;
        bottom-padding: 0px;
        gap: 0px;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            padding-left: 28px;
            padding-right: 28px;
            padding-top: 28px;
            padding-bottom: 28px;
            spacing: 18px;

            ResponsivePanelFlow {
                width: parent.width;
                horizontal-stretch: 1;
                flow-height: root.compact ? 626px : 306px;
                spacing-horizontal: 14px;
                spacing-vertical: 14px;

                HubPanel {
                    flex-basis: 600px;
                    flex-grow: 1;
                    flex-shrink: 1;
                    min-width: 420px;
                    height: 306px;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: 18px;
                            spacing: 12px;

                            PanelHeader {
                                title: root.ui-text.source-build;
                                subtitle: root.source-engine.version + " / " + root.source-engine.status;
                                show-badge: true;
                                badge-text: root.status-label;
                                badge-tone: root.status-label == "Ready" ? "ok" : (root.status-label == "Building" ? "accent" : "neutral");
                                show-action: true;
                                action-text: root.ui-text.build-now;
                                action-clicked => {
                                    root.build-engine();
                                }
                            }

                            Rectangle {
                                height: 1px;
                                background: #303641;
                            }

                            InfoRow {
                                row-height: 64px;
                                title: root.ui-text.source-prefix;
                                detail: root.source-engine.source-path;
                                meta: root.ui-text.last-build-prefix + root.source-engine.last-build;
                                leading-image: @image-url("../assets/icons/nav/builds.svg");
                                has-leading-image: true;
                                trailing-text: root.source-engine.status;
                                trailing-tone: "ok";
                                show-trailing-badge: true;
                            }

                            InfoRow {
                                row-height: 64px;
                                title: root.ui-text.output-prefix;
                                detail: root.source-engine.output-path;
                                meta: root.ui-text.profile-prefix + root.source-engine.build-profile;
                                leading-image: @image-url("../assets/icons/ui/folder.svg");
                                has-leading-image: true;
                                trailing-text: root.source-engine.jobs + root.ui-text.jobs-suffix;
                                trailing-tone: "neutral";
                                show-trailing-badge: true;
                            }

                            HorizontalLayout {
                                spacing: 10px;

                                Badge {
                                    text: root.source-engine.build-profile;
                                    tone: "accent";
                                    badge-width: 86px;
                                }

                                Badge {
                                    text: root.source-engine.jobs + root.ui-text.jobs-suffix;
                                    tone: "neutral";
                                    badge-width: 86px;
                                }
                            }
                        }
                }

                HubPanel {
                    flex-basis: 380px;
                    flex-grow: 0;
                    flex-shrink: 1;
                    min-width: 340px;
                    height: 306px;

                        VerticalLayout {
                            width: parent.width;
                            height: parent.height;
                            padding: 18px;
                            spacing: 10px;

                            PanelHeader {
                                title: root.ui-text.build-controls;
                                subtitle: "";
                            }

                            ActionRow {
                                action: {
                                    id: "build-editor",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/actions/build-project.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.build-editor,
                                    detail: root.ui-text.compile-editor,
                                    enabled: true,
                                };
                                activate(id) => {
                                    root.build-engine();
                                }
                            }

                            ActionRow {
                                action: {
                                    id: "open-output",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/ui/folder.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.open-output,
                                    detail: root.source-engine.output-path,
                                    enabled: true,
                                };
                                activate(id) => {
                                    root.open-output();
                                }
                            }

                            ActionRow {
                                action: {
                                    id: "open-editor",
                                    icon: "",
                                    icon-image: @image-url("../assets/icons/actions/open-editor.svg"),
                                    has-icon-image: true,
                                    title: root.ui-text.open-editor,
                                    detail: root.source-engine.title,
                                    enabled: true,
                                };
                                activate(id) => {
                                    root.launch-editor();
                                }
                            }
                        }
                }
            }

            ResponsivePanelFlow {
                width: parent.width;
                horizontal-stretch: 1;
                flow-height: root.compact ? 650px : 360px;
                spacing-horizontal: 14px;
                spacing-vertical: 14px;

                HubPanel {
                    flex-basis: 600px;
                    flex-grow: 1;
                    flex-shrink: 1;
                    min-width: 420px;
                    height: 360px;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding: 18px;
                        spacing: 10px;

                        PanelHeader {
                            title: root.ui-text.build-pipeline;
                            subtitle: "";
                            show-badge: true;
                            badge-text: "4";
                            badge-tone: "info";
                        }

                        InfoRow {
                            row-height: 62px;
                            title: root.ui-text.validate-source;
                            detail: root.source-engine.source-path;
                            meta: "";
                            leading-image: @image-url("../assets/icons/status/success.svg");
                            has-leading-image: true;
                            trailing-text: root.source-engine.status;
                            trailing-tone: "ok";
                            show-trailing-badge: true;
                        }

                        InfoRow {
                            row-height: 62px;
                            title: root.ui-text.compile-editor;
                            detail: "tools/zircon_build.py --targets editor,runtime";
                            meta: "";
                            leading-image: @image-url("../assets/icons/actions/build-project.svg");
                            has-leading-image: true;
                            trailing-text: root.status-label;
                            trailing-tone: root.status-label == "Building" ? "accent" : "neutral";
                            show-trailing-badge: true;
                        }

                        InfoRow {
                            row-height: 62px;
                            title: root.ui-text.stage-runtime;
                            detail: root.source-engine.output-path;
                            meta: "";
                            leading-image: @image-url("../assets/icons/ui/folder.svg");
                            has-leading-image: true;
                            trailing-text: root.source-engine.last-build;
                            trailing-tone: "info";
                            show-trailing-badge: true;
                        }

                        InfoRow {
                            row-height: 62px;
                            title: root.ui-text.package-project;
                            detail: root.ui-text.reserved-project-export;
                            meta: "";
                            leading-image: @image-url("../assets/icons/actions/package-project.svg");
                            has-leading-image: true;
                            trailing-text: root.ui-text.unavailable;
                            trailing-tone: "warning";
                            show-trailing-badge: true;
                        }
                    }
                }

                HubPanel {
                    flex-basis: 360px;
                    flex-grow: 0;
                    flex-shrink: 1;
                    min-width: 340px;
                    height: 360px;

                    VerticalLayout {
                        width: parent.width;
                        height: parent.height;
                        padding: 18px;
                        spacing: 14px;

                        PanelHeader {
                            title: root.ui-text.current-task;
                            subtitle: "";
                            show-badge: true;
                            badge-text: root.status-label;
                            badge-tone: root.status-label == "Ready" ? "ok" : (root.status-label == "Building" ? "accent" : "neutral");
                        }

                        Text {
                            text: root.status-label;
                            overflow: elide;
                            color: #73f7ed;
                            font-size: 24px;
                            font-weight: 900;
                        }

                        MutedText {
                            text: root.status-detail;
                            overflow: elide;
                        }

                        Rectangle {
                            vertical-stretch: 1;
                        }

                        Rectangle {
                            height: 1px;
                            background: #303641;
                        }

                        HorizontalLayout {
                            spacing: 10px;

                            Badge {
                                text: root.source-engine.build-profile;
                                tone: "accent";
                                badge-width: 96px;
                            }

                            Badge {
                                text: root.source-engine.jobs + root.ui-text.jobs-suffix;
                                tone: "neutral";
                                badge-width: 96px;
                            }
                        }
                    }
                }
            }
        }
    }
}
