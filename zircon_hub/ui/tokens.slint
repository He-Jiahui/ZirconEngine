import { MaterialPalette, MaterialStyleMetrics } from "material_bridge.slint";

export global HubTokens {
    in property <length> space-0: 0px;
    in property <length> space-1: MaterialStyleMetrics.spacing_4;
    in property <length> space-2: MaterialStyleMetrics.spacing_8;
    in property <length> space-3: MaterialStyleMetrics.spacing_12;
    in property <length> space-4: MaterialStyleMetrics.spacing_16;
    in property <length> space-6: MaterialStyleMetrics.spacing_16 + MaterialStyleMetrics.spacing_8;
    in property <length> space-7: MaterialStyleMetrics.spacing_16 + MaterialStyleMetrics.spacing_12;

    in property <length> breakpoint-compact: MaterialStyleMetrics.size_640 + MaterialStyleMetrics.size_200 * 2;
    in property <length> breakpoint-medium: MaterialStyleMetrics.size_640 * 2;
    in property <length> breakpoint-wide: MaterialStyleMetrics.size_640 * 2 + MaterialStyleMetrics.size_256;

    in property <length> page-padding: MaterialStyleMetrics.padding_28 + MaterialStyleMetrics.size_2;
    in property <length> page-padding-compact: MaterialStyleMetrics.padding_16;
    in property <length> panel-gap: MaterialStyleMetrics.spacing_16 - MaterialStyleMetrics.size_1 * 2;
    in property <length> toolbar-gap: MaterialStyleMetrics.spacing_8 + MaterialStyleMetrics.size_1 * 2;

    in property <length> icon-xs: MaterialStyleMetrics.spacing_16;
    in property <length> icon-sm: MaterialStyleMetrics.icon_size_18;
    in property <length> icon-md: MaterialStyleMetrics.size_20;
    in property <length> icon-lg: MaterialStyleMetrics.padding_28;
    in property <length> icon-xl: MaterialStyleMetrics.size_32 + MaterialStyleMetrics.size_1 * 2;

    in property <length> control-sm: MaterialStyleMetrics.size_32 + MaterialStyleMetrics.size_1 * 2;
    in property <length> control-md: MaterialStyleMetrics.size_40 - MaterialStyleMetrics.size_1 * 2;
    in property <length> control-lg: MaterialStyleMetrics.size_40 + MaterialStyleMetrics.size_1 * 2;
    in property <length> input-field: MaterialStyleMetrics.size_56;
    in property <length> input-width: MaterialStyleMetrics.size_344 + MaterialStyleMetrics.size_80;
    in property <length> table-row: MaterialStyleMetrics.padding_28;
    in property <length> list-row-sm: MaterialStyleMetrics.size_56;
    in property <length> list-row-md: MaterialStyleMetrics.size_72;
    in property <length> list-row-lg: MaterialStyleMetrics.size_80 + MaterialStyleMetrics.size_6;
    in property <length> border-width: MaterialStyleMetrics.size_1;

    in property <length> panel-min-sm: MaterialStyleMetrics.size_344;
    in property <length> panel-min-md: MaterialStyleMetrics.size_344 + MaterialStyleMetrics.size_80;
    in property <length> panel-min-lg: MaterialStyleMetrics.size_344 + MaterialStyleMetrics.size_200;

    in property <float> project-dashboard-toolbar-search-ratio: 0.24;
    in property <float> project-dashboard-toolbar-select-ratio: 0.142;
    in property <float> project-dashboard-card-ratio: 0.23125;
    in property <float> project-dashboard-lower-compact-ratio: 0.60;
    in property <float> project-dashboard-lower-regular-ratio: 0.393;
    in property <float> project-dashboard-table-ratio: 0.58;
    in property <float> project-new-main-stack-ratio: 0.60;
    in property <float> project-new-side-stack-ratio: 0.40;
    in property <float> project-browser-toolbar-search-ratio: 0.40;
    in property <float> project-browser-toolbar-select-ratio: 0.125;
    in property <float> project-detail-cover-ratio: 0.25;
    in property <float> project-detail-info-row-ratio: 0.05;
    in property <float> project-detail-version-badge-ratio: 0.10;
    in property <float> project-detail-pin-badge-ratio: 0.0714286;
    in property <float> project-detail-main-panel-ratio: 0.50;
    in property <float> project-detail-action-panel-ratio: 0.25;
    in property <float> project-detail-main-stack-ratio: 0.60;
    in property <float> project-detail-action-stack-ratio: 0.40;

    in property <length> workspace-row-editor-summary: root.control-md + root.list-row-sm * 3 + root.toolbar-gap * 3 + root.space-4 * 2;
    in property <length> workspace-row-editor-config: MaterialStyleMetrics.size_200 * 2 + MaterialStyleMetrics.size_72 + MaterialStyleMetrics.size_4;
    in property <length> workspace-row-build-summary: root.control-md + root.list-row-md * 5 + root.toolbar-gap * 5 + root.space-4 * 2;
    in property <length> workspace-row-build-detail: root.control-md + root.list-row-md * 4 + root.toolbar-gap * 4 + root.space-4 * 2;
    in property <length> workspace-row-settings-controls: MaterialStyleMetrics.size_200 + MaterialStyleMetrics.size_80 + MaterialStyleMetrics.size_6;
    in property <length> workspace-row-settings-detail: MaterialStyleMetrics.size_200 * 2 - MaterialStyleMetrics.size_8;
    in property <length> workspace-row-cloud-metrics: root.list-row-lg + root.space-6;
    in property <length> workspace-row-team-summary: root.list-row-lg + root.space-7;

    in property <length> breakpoint-short: MaterialStyleMetrics.size_640 + MaterialStyleMetrics.size_256 + MaterialStyleMetrics.size_64;
    in property <length> shell-row-min: MaterialStyleMetrics.size_52;
    in property <length> shell-row-max: MaterialStyleMetrics.size_56;
    in property <length> shell-drag-min: MaterialStyleMetrics.size_8;
    in property <length> shell-drag-max: MaterialStyleMetrics.size_8;
    in property <length> shell-header-height: MaterialStyleMetrics.size_64 + root.toolbar-gap;
    in property <length> shell-gap-min: MaterialStyleMetrics.spacing_8;
    in property <length> shell-gap-max: MaterialStyleMetrics.spacing_12;
    in property <length> shell-pad-x-min: MaterialStyleMetrics.padding_16;
    in property <length> shell-pad-x-max: MaterialStyleMetrics.padding_24;
    in property <length> nav-width-collapsed-min: MaterialStyleMetrics.size_80;
    in property <length> nav-width-collapsed-max: MaterialStyleMetrics.size_80;
    in property <length> nav-width-expanded-min: MaterialStyleMetrics.size_200;
    in property <length> nav-width-expanded-max: MaterialStyleMetrics.size_200 + MaterialStyleMetrics.padding_24;
    in property <length> bottom-status-height: MaterialStyleMetrics.size_32;
    in property <length> status-badge-width: root.control-lg * 5;
    in property <length> window-resize-border: MaterialStyleMetrics.size_6;
    in property <length> window-min-width: MaterialStyleMetrics.size_640 + MaterialStyleMetrics.size_344;
    in property <length> window-min-height: MaterialStyleMetrics.size_640;
    in property <length> window-preferred-width: root.breakpoint-wide + root.nav-width-collapsed-min;
    in property <length> window-preferred-height: MaterialStyleMetrics.size_640 + MaterialStyleMetrics.size_360 + MaterialStyleMetrics.size_24;
    in property <length> user-menu-min-width: root.nav-width-collapsed-max + root.control-lg + root.space-1;
    in property <length> user-menu-max-width: root.nav-width-collapsed-max * 2 + root.space-1;

    in property <brush> surface-page: MaterialPalette.background;
    in property <brush> surface-panel: MaterialPalette.surface_container_low;
    in property <brush> surface-panel-hover: MaterialPalette.surface_container_high;
    in property <brush> surface-elevated: MaterialPalette.surface_container;
    in property <brush> stroke-muted: MaterialPalette.outline_variant;
    in property <brush> stroke-strong: MaterialPalette.outline;
    in property <brush> accent: MaterialPalette.primary;
    in property <brush> accent-fill: MaterialPalette.primary_container;
    in property <brush> text-primary: MaterialPalette.on_surface;
    in property <brush> text-muted: MaterialPalette.on_surface_variant;
}

export global HubVisualSpec {
    in property <length> reference-width: MaterialStyleMetrics.size_640 * 2 + MaterialStyleMetrics.size_256 + MaterialStyleMetrics.size_32;
    in property <length> reference-height: MaterialStyleMetrics.size_640 + MaterialStyleMetrics.size_344 + MaterialStyleMetrics.spacing_16 + MaterialStyleMetrics.size_2 + MaterialStyleMetrics.size_1;
    in property <length> panel-radius: MaterialStyleMetrics.border_radius_12;
    in property <length> compact-radius: MaterialStyleMetrics.border_radius_8;
    in property <length> badge-radius: MaterialStyleMetrics.border_radius_4;
    in property <length> focus-ring-width: MaterialStyleMetrics.size_2;
    in property <length> focus-ring-offset: MaterialStyleMetrics.size_2;
    in property <length> panel-padding: HubTokens.space-4;
    in property <length> section-gap: HubTokens.panel-gap;
    in property <length> toolbar-density-height: HubTokens.control-md;
    in property <length> card-cover-height: HubTokens.list-row-lg + MaterialStyleMetrics.size_24 + MaterialStyleMetrics.size_2;
    in property <length> visual-card-height: HubTokens.list-row-lg * 3 - MaterialStyleMetrics.spacing_8;
    in property <length> visual-table-row-height: HubTokens.table-row;
    in property <color> page-background: rgb(21, 21, 21);
    in property <color> chrome-background: rgb(19, 19, 19);
    in property <color> chrome-outline-muted: rgb(33, 33, 33);
    in property <color> panel-background: rgb(32, 32, 32);
    in property <color> panel-raised-background: rgb(34, 34, 34);
    in property <color> panel-hover-background: rgb(40, 40, 40);
    in property <color> outline-muted: rgb(56, 56, 56);
    in property <color> outline-strong: rgb(135, 135, 135);
    in property <color> accent-fill: MaterialPalette.primary_container;
    in property <color> accent-stroke: MaterialPalette.primary;
    in property <color> nav-active-fill: rgb(20, 55, 54);
    in property <color> badge-accent-fill: rgb(28, 56, 56);
    in property <color> badge-accent-stroke: rgb(42, 118, 121);
    in property <color> badge-accent-foreground: MaterialPalette.on_primary_container;
    in property <color> focus-ring-color: MaterialPalette.primary;
    in property <float> disabled-opacity: MaterialPalette.disable_opacity;
    in property <color> status-neutral-fill: MaterialPalette.surface_container_high;
    in property <color> status-neutral-stroke: MaterialPalette.outline_variant;
    in property <color> status-neutral-foreground: MaterialPalette.on_surface_variant;
    in property <color> status-info-fill: MaterialPalette.secondary_container;
    in property <color> status-info-stroke: MaterialPalette.secondary;
    in property <color> status-info-foreground: MaterialPalette.on_secondary_container;
    in property <color> status-success-fill: MaterialPalette.primary_container;
    in property <color> success-stroke: rgb(112, 226, 128);
    in property <color> status-success-stroke: root.success-stroke;
    in property <color> status-success-foreground: MaterialPalette.on_primary_container;
    in property <color> warning-fill: MaterialPalette.tertiary_container;
    in property <color> warning-stroke: MaterialPalette.tertiary;
    in property <color> status-warning-fill: root.warning-fill;
    in property <color> status-warning-stroke: root.warning-stroke;
    in property <color> status-warning-foreground: MaterialPalette.on_tertiary_container;
    in property <color> error-fill: MaterialPalette.error_container;
    in property <color> error-stroke: MaterialPalette.error;
    in property <color> status-error-fill: root.error-fill;
    in property <color> status-error-stroke: root.error-stroke;
    in property <color> status-error-foreground: MaterialPalette.on_error_container;
    in property <color> button-state-primary-default-background: rgb(8, 119, 121);
    in property <color> button-state-primary-hover-background: rgb(8, 139, 137);
    in property <color> button-state-primary-pressed-background: rgb(10, 118, 119);
    in property <color> button-state-primary-disabled-background: rgb(30, 56, 56);
    in property <color> button-state-secondary-default-background: rgb(45, 47, 48);
    in property <color> button-state-secondary-hover-background: rgb(53, 55, 56);
    in property <color> button-state-secondary-pressed-background: rgb(58, 60, 61);
    in property <color> button-state-secondary-disabled-background: rgb(31, 32, 33);
    in property <color> button-state-icon-primary-background: rgb(7, 122, 124);
    in property <color> button-state-icon-hover-background: rgb(7, 107, 109);
    in property <color> button-state-icon-disabled-background: rgb(33, 35, 36);
    in property <color> button-state-strip-background: rgb(22, 22, 22);
}
