import { PluginData, UiTextData } from "shared.slint";
import { CatalogPage, HubTokens, InfoRow } from "components.slint";

component PluginRow inherits InfoRow {
    in property <PluginData> plugin;
    in property <UiTextData> ui-text;

    title: root.plugin.title;
    detail: root.plugin.description;
    meta: root.plugin.scope + "    " + root.ui-text.plugin-packaging + ": " + root.plugin.packaging + "    " + root.ui-text.plugin-modules + ": " + root.plugin.modules + "    " + root.ui-text.plugin-maturity + ": " + root.plugin.maturity + "    " + root.plugin.path;
    leading-image: @image-url("../assets/icons/nav/plugins.svg");
    has-leading-image: true;
    trailing-text: root.plugin.category;
    trailing-tone: "accent";
    show-trailing-badge: true;
    row-height: HubTokens.list-row-lg + HubTokens.space-6;
}

export component PluginsPage inherits Rectangle {
    in-out property <length> scroll-y: 0px;
    in property <[PluginData]> plugins;
    in property <int> plugin-count;
    in property <bool> has-selected-project: false;
    in property <UiTextData> ui-text;
    private property <length> list-scroll-y: 0px;
    private property <string> catalog-title: root.has-selected-project ? root.ui-text.plugin-catalog-selected : root.ui-text.plugin-catalog;
    private property <string> plugins-empty-detail: root.has-selected-project ? root.ui-text.plugin-empty-selected-detail : root.ui-text.plugin-empty-global-detail;

    background: HubTokens.surface-page;

    CatalogPage {
        width: root.width;
        height: root.height;
        scroll-y <=> root.scroll-y;
        list-scroll-y <=> root.list-scroll-y;
        title: root.catalog-title;
        badge-text: root.plugin-count + " " + root.ui-text.plugins-found;
        badge-tone: "accent";
        empty-title: root.ui-text.no-plugins-found;
        empty-detail: root.plugins-empty-detail;
        row-count: root.plugin-count;
        row-height: HubTokens.list-row-lg + HubTokens.space-6;

        for plugin in root.plugins: PluginRow {
            plugin: plugin;
            ui-text: root.ui-text;
        }
    }
}
